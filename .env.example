# ---------------------------------------------------------------------------
# ACM-VIT website — environment variables
# Copy to `.env` and fill in. `.env` is gitignored; this file is committed.
# Vars prefixed PUBLIC_ are inlined into the client bundle at BUILD time
# (Vite), so they must be present wherever the build runs (CI / CF Pages),
# not just at runtime.
# ---------------------------------------------------------------------------

# === Media CDN (Cloudflare R2) — audio + video offload ======================
# Base URL the site prepends to /audio/* and /videos/* via getMediaUrl().
# Leave empty to serve media from the origin (local). Set to activate the CDN.
#   test:       https://pub-<hash>.r2.dev        (rate-limited, dev only)
#   production: https://media.acmvit.in          (custom domain, once Active)
PUBLIC_MEDIA_CDN_URL=

# R2 credentials — only needed where the upload script runs (laptop / CI),
# NOT in the site runtime. From: R2 > Manage R2 API Tokens (Object Read & Write).
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_MEDIA_BUCKET_NAME=acmvit-media
# Run: npm run deploy:media  (uploads public/audio + public/videos to R2)

# === Optional: whole-site asset CDN =========================================
# Routes bundled _astro/* assets + getAssetUrl() paths to a CDN. Currently
# unused; leave empty. If set, the CDN bucket MUST contain dist/client assets
# (use scripts/upload-r2.mjs -> deploy:cdn), else site JS/CSS 404s.
PUBLIC_CDN_URL=
# Bucket for scripts/upload-r2.mjs (deploy:cdn). Defaults to a leftover name,
# so set this explicitly if you use that script.
R2_BUCKET_NAME=

# === Contact form / email (Resend) ==========================================
PUBLIC_CONTACT_ENDPOINT=
RESEND_API_KEY=
RESEND_FROM=

# === Keystatic CMS ==========================================================
# Default to ACM-VIT/ACM-VIT if unset.
KEYSTATIC_GITHUB_REPO_OWNER=ACM-VIT
KEYSTATIC_GITHUB_REPO_NAME=ACM-VIT

# === Legacy AWS S3 + CloudFront (updateCDN.js) — DO NOT USE =================
# Broken for the current Cloudflare adapter (uploads server bundle + wrong
# key prefix). Kept only for reference. Runs on postbuild ONLY when
# NODE_ENV=production AND these are set; leaving them empty keeps it dormant.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET_NAME=
# AWS_DISTRIBUTION_ID=
# ASTRO_OUTPUT_DIR=./dist
# UPLOAD_CONCURRENCY_LIMIT=5
