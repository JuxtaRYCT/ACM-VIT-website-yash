{"nodes": [{"id": "docs_grep_v0_grep_newsletter", "label": "GREP v0 Newsletter", "file_type": "document", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 1", "source_url": null, "captured_at": "2025", "author": null, "contributor": null, "rationale": "ACM-VIT's official quarterly newsletter, Origins Edition. Curated snapshot of the chapter's journey spotlighting initiatives, impactful work, and people. The 0th edition revisits ACM-VIT's 15-year journey to provide context and continuity."}, {"id": "docs_grep_v0_acm", "label": "Association for Computing Machinery (ACM)", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "World's largest educational and scientific organization in computing, established 1947. Amplifies collective voice of computing profession through visionary leadership, advocacy for high standards, and recognition of technical achievements."}, {"id": "docs_grep_v0_acm_vit_chapter", "label": "ACM-VIT Student Chapter", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Official student chapter of ACM at VIT Vellore, founded 2009 (officially launched Jan 25, 2010). Student-led, technology-driven community making technology accessible and fostering innovation. Over 150 members. Tagline: 'Because Technology Matters'. Motto: 'Give people wonderful tools, and they'll do wonderful things.'"}, {"id": "docs_grep_v0_acm_w", "label": "ACM-W (ACM Women)", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Association for Computing Machinery - Women chapter. Mission to encourage and empower women in STEM through community, mentorship, and knowledge sharing. Won best emerging chapter award at ACM-India Summit 2023."}, {"id": "docs_grep_v0_dr_aswani_kumar_cherukuri", "label": "Dr. Aswani Kumar Cherukuri", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 6", "source_url": null, "captured_at": null, "author": "Dr. Aswani Kumar Cherukuri", "contributor": null}, {"id": "docs_grep_v0_manan_shah", "label": "Manan Shah", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 7", "source_url": "https://github.com/mananssh", "captured_at": null, "author": "Manan Shah", "contributor": null}, {"id": "docs_grep_v0_code2create", "label": "Code2Create Hackathon", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Flagship 36-hour hackathon debuted September 2015. Interdisciplinary teams work on theme-based tracks (Fintech, AR/VR, Clean Energy, Health Care, Education, Smart Cities, Space). Grew from local to pan-India with close to 1000 registrations. Code2Create 2025 was the latest edition."}, {"id": "docs_grep_v0_reverse_coding", "label": "Reverse Coding", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 14", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Competitive coding event where participants reverse-engineer the logic from expected output and write source from scratch. Started April 2013 with 96 participants, grew to 900. Biggest competitive coding event at VIT."}, {"id": "docs_grep_v0_cryptic_hunt", "label": "Cryptic Hunt", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 14", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tech-based scavenger hunt solving cryptic riddles via QR codes. Introduced as lead Gravitas event September 2022. Grew to graVITas' biggest scavenger hunt with 800+ participants annually."}, {"id": "docs_grep_v0_codart", "label": "Codart", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 12", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Competitive programming event combined with dart throwing. Started 2016 with 120 participants, grew to 200+ teams by 2018. Online rounds followed by offline finale where dart throws decided coding challenge difficulty."}, {"id": "docs_grep_v0_code_plus_plus", "label": "Code++", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 12", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pure competitive programming event. 4-hour mathematical marathon on HackerRank, 800 participants. Focuses on complex algorithms and mathematical puzzles."}, {"id": "docs_grep_v0_tiny_hack", "label": "The Tiny Hack", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 12", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "10-hour hackathon held 2023 for building small impactful solutions to real-world problems."}, {"id": "docs_grep_v0_apptitude", "label": "Apptitude", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "36-hour hackathon dedicated to app development, first organized July 2020. Gives app dev its own spotlight. Apptitude'21 was SDG-themed."}, {"id": "docs_grep_v0_forktober", "label": "Forktober", "file_type": "concept", "source_file": "public/docs/grep-v0.pdf", "source_location": "Page 13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Open-source initiative inspired by Hacktoberfest (DigitalOcean), first hosted October 2021. 