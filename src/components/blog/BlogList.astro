---
import type { BlogPost } from '../../lib/blog/types';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<section class="blog-list" id="all-blogs">
  {/* Header */}
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl sm:text-3xl font-['PolySans_Trial'] font-medium text-[#FEFCD9]">
      All Articles
    </h2>
    <span class="text-sm font-mono text-gray-500">{posts.length} posts</span>
  </div>

  {/* Filter bar */}
  <div class="blog-list__filters flex flex-wrap gap-2 mb-8" id="blog-filters">
    <button class="blog-filter-btn active" data-filter="all">All</button>
    <button class="blog-filter-btn" data-filter="hashnode">Hashnode</button>
    <button class="blog-filter-btn" data-filter="medium">Medium</button>
  </div>

  {/* Search */}
  <div class="relative mb-10">
    <input
      type="text"
      id="blog-search"
      placeholder="Search articles..."
      class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-sm text-[#FEFCD9] placeholder-gray-500 font-mono outline-none focus:border-[#F95F4A]/50 focus:ring-1 focus:ring-[#F95F4A]/20 transition-all duration-200"
    />
    <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
    </svg>
  </div>

  {/* Posts grid */}
  <div class="blog-list__grid" id="blog-grid">
    {posts.map((post) => {
      const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      const internalUrl = `/blogs/${post.source}/${post.slug}`;

      return (
        <a
          href={internalUrl}
          class="blog-list-item group"
          data-source={post.source}
          data-title={post.title.toLowerCase()}
          data-tags={post.tags.join(',').toLowerCase()}
        >
          <div class="blog-list-item__image">
            {post.coverImage ? (
              <img
                src={post.coverImage}
                alt={post.title}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="blog-list-item__placeholder">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            )}
          </div>

          <div class="blog-list-item__content">
            <h3 class="text-base font-['PolySans_Trial'] font-medium text-[#FEFCD9] group-hover:text-[#F95F4A] transition-colors duration-200 leading-snug line-clamp-2">
              {post.title}
            </h3>
            <p class="mt-1.5 text-sm text-gray-400 line-clamp-2 leading-relaxed">
              {post.brief}
            </p>
            <div class="mt-2 flex items-center gap-2 text-xs text-gray-500 font-mono">
              <time datetime={post.publishedAt}>{formattedDate}</time>
              <span class="w-1 h-1 rounded-full bg-gray-600" />
              <span>{post.readingTime} min</span>
              {post.author && post.author !== 'ACM-VIT' && (
                <>
                  <span class="w-1 h-1 rounded-full bg-gray-600" />
                  <span>{post.author}</span>
                </>
              )}
            </div>
          </div>

          {/* Arrow */}
          <div class="blog-list-item__arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </a>
      );
    })}
  </div>
</section>

<script>
  // Filter buttons
  const filterBtns = document.querySelectorAll('.blog-filter-btn');
  const items = document.querySelectorAll('.blog-list-item') as NodeListOf<HTMLElement>;
  const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;

  let activeFilter = 'all';
  let searchQuery = '';

  function applyFilters() {
    items.forEach((item) => {
      const source = item.dataset.source || '';
      const title = item.dataset.title || '';
      const tags = item.dataset.tags || '';

      const matchesFilter = activeFilter === 'all' || source === activeFilter;
      const matchesSearch = !searchQuery
        || title.includes(searchQuery)
        || tags.includes(searchQuery);

      item.style.display = matchesFilter && matchesSearch ? '' : 'none';
    });
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = (btn as HTMLElement).dataset.filter || 'all';
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilters();
  });
</script>
