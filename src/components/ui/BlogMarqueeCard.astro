---
interface Props {
  title: string;
  link: string;
  bgUrl: string;
  author?: string;
  readingTime?: number;
  tag?: string;
}

import { getAssetUrl } from "../../utils/cdn";
const { title, link, bgUrl, author, readingTime, tag } = Astro.props;

const imageUrl = bgUrl.startsWith("http") ? bgUrl : getAssetUrl(bgUrl);
---

<a
  href={link}
  rel="noopener noreferrer"
  class="blog-mcard group relative block w-[74vw] sm:w-[340px] aspect-[1.55] shrink-0 mr-5
         overflow-hidden rounded-2xl border border-[#fefcd9]/12 bg-[#141312]
         transition-[transform,border-color,box-shadow] duration-500 ease-out
         hover:-translate-y-2 hover:border-[#F95F4A]/70
         hover:shadow-[0_20px_60px_-15px_rgba(249,95,74,0.45)]"
>
  <!-- Cover -->
  <img
    src={imageUrl}
    alt=""
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-110"
    loading="lazy"
    decoding="async"
  />

  <!-- Readability gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent"
  >
  </div>
  <!-- Accent wash on hover -->
  <div
    class="absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    style="background: linear-gradient(160deg, rgba(249,95,74,0.28), transparent 55%);"
  >
  </div>

  <!-- Tag pill -->
  {
    tag && (
      <span class="absolute left-4 top-4 z-10 rounded-full border border-[#fefcd9]/25 bg-black/40 px-3 py-1 font-['PolySans_Trial',sans-serif] text-[10px] font-medium uppercase tracking-[0.18em] text-[#FEFCD9] backdrop-blur-sm">
        {tag}
      </span>
    )
  }

  <!-- Bottom content -->
  <div class="absolute inset-x-0 bottom-0 z-10 flex flex-col gap-2 p-5">
    <h3
      class="blog-mcard-title font-['PolySans_Trial',sans-serif] text-lg font-bold leading-[1.15] text-[#FEFCD9]"
    >
      {title}
    </h3>
    <div
      class="flex items-center gap-2 font-['PolySans_Trial',sans-serif] text-xs font-light text-[#FEFCD9]/70"
    >
      {author && <span class="truncate">{author}</span>}
      {author && readingTime ? <span class="text-[#F95F4A]">·</span> : null}
      {readingTime ? <span>{readingTime} min read</span> : null}
      <span
        class="ml-auto inline-flex h-7 w-7 items-center justify-center rounded-full border border-[#F95F4A]/60 text-[#F95F4A] transition-all duration-300 group-hover:bg-[#F95F4A] group-hover:text-black"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H8M17 7v9" />
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .blog-mcard-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
