---
/**
 * SectionHeading - reusable animated section title.
 * Theme: cream (#FEFCD9) text, red (#F95F4A) accent, PolySans Trial.
 * Scroll-triggered reveal: eyebrow fades in, title words rise + clip-reveal,
 * accent bar wipes in. Light-mode compatible via globals.css token overrides.
 *
 * Usage:
 *   <SectionHeading eyebrow="Built by us" title="Our" accent="Projects"
 *     subtitle="Some of our popular projects" />
 */
export interface Props {
  /** Small uppercase kicker above the title. */
  eyebrow?: string;
  /** Leading (non-accent) part of the title. */
  title: string;
  /** Highlighted part of the title, rendered in the accent color. */
  accent?: string;
  /** Optional supporting line below the title. */
  subtitle?: string;
  /** Text alignment. */
  align?: "left" | "center";
  /** Accent color override. */
  accentColor?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  accent = "",
  subtitle,
  align = "center",
  accentColor = "#F95F4A",
  class: className = "",
} = Astro.props;

const alignClasses =
  align === "center"
    ? "items-center text-center mx-auto"
    : "items-start text-left";
---

<div
  class:list={[
    "section-heading flex w-full max-w-5xl flex-col gap-4 px-6",
    alignClasses,
    className,
  ]}
  style={`--accent: ${accentColor};`}
  data-section-heading
>
  {
    eyebrow && (
      <span class="sh-eyebrow inline-flex items-center gap-2 font-['PolySans_Trial',sans-serif] text-xs font-light uppercase tracking-[0.3em] text-[#FEFCD9]/70">
        <span class="sh-dot inline-block h-1.5 w-1.5 rounded-full bg-[var(--accent)]" />
        {eyebrow}
      </span>
    )
  }

  <h2
    class="sh-title m-0 font-['PolySans_Trial',sans-serif] text-4xl font-bold uppercase leading-[0.95] tracking-[-0.03em] text-[#FEFCD9] sm:text-6xl lg:text-7xl"
  >
    <span class="sh-word inline-block">{title}</span>
    {accent && <span class="sh-word inline-block text-[var(--accent)]"> {accent}</span>}
  </h2>

  <span
    class="sh-bar block h-[3px] w-24 origin-left rounded-full bg-[var(--accent)]"
  ></span>

  {
    subtitle && (
      <p class="sh-subtitle m-0 max-w-2xl font-['PolySans_Trial',sans-serif] text-base font-light leading-relaxed text-[#FEFCD9]/75 sm:text-lg">
        {subtitle}
      </p>
    )
  }
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initSectionHeadings() {
    document
      .querySelectorAll<HTMLElement>("[data-section-heading]")
      .forEach((heading) => {
        if (heading.dataset.shInit) return;
        heading.dataset.shInit = "1";

        const eyebrow = heading.querySelector(".sh-eyebrow");
        const words = heading.querySelectorAll(".sh-word");
        const bar = heading.querySelector(".sh-bar");
        const subtitle = heading.querySelector(".sh-subtitle");

        gsap.set(words, { yPercent: 110, opacity: 0 });
        gsap.set(bar, { scaleX: 0 });
        if (eyebrow) gsap.set(eyebrow, { opacity: 0, y: 12 });
        if (subtitle) gsap.set(subtitle, { opacity: 0, y: 16 });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: heading,
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
        });

        if (eyebrow)
          tl.to(eyebrow, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });

        tl.to(
          words,
          {
            yPercent: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            stagger: 0.12,
          },
          eyebrow ? "-=0.2" : 0,
        )
          .to(bar, { scaleX: 1, duration: 0.6, ease: "power3.out" }, "-=0.4");

        if (subtitle)
          tl.to(
            subtitle,
            { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" },
            "-=0.3",
          );
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSectionHeadings);
  } else {
    initSectionHeadings();
  }
  // Re-run after the responsive variant host clones its template into the DOM.
  window.addEventListener("variants-mounted", () => initSectionHeadings());
</script>

<style>
  /* Clip the rising words so they reveal from behind the baseline. */
  .sh-title {
    overflow: hidden;
    padding-bottom: 0.08em;
  }
</style>
