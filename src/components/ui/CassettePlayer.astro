---
// Pure Astro - no React, no hydration
---

<audio id="cp-audio" preload="metadata"></audio>

<!-- Minimized button -->
<button id="cp-toggle" class="cp-mini" aria-label="Open music player">
  <div class="cp-eq" id="cp-eq">
    <span class="cp-eq-bar"></span>
    <span class="cp-eq-bar"></span>
    <span class="cp-eq-bar"></span>
    <span class="cp-eq-bar"></span>
  </div>
  <svg class="cp-mini-note" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
  </svg>
</button>

<!-- Expanded player -->
<div id="cp-player" class="cp-player">
  <!-- Iridescent top rim - light refraction at the glass edge -->
  <div class="cp-refract-rim" aria-hidden="true"></div>

  <!-- Minimize chevron -->
  <button id="cp-minimize" class="cp-min-btn" aria-label="Minimize">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
  </button>

  <!-- Cassette SVG - track info + controls live INSIDE -->
  <div class="cp-cassette" id="cp-cassette">
    <svg viewBox="0 0 280 175" xmlns="http://www.w3.org/2000/svg">
      <!-- Body -->
      <rect class="cp-c-body" x="1" y="1" width="278" height="173" rx="11"/>

      <!-- Cover -->
      <path class="cp-c-cover" d="M 18 10 L 22 10 L 28 16 L 252 16 L 258 10 L 262 10 Q 266 10 266 14 L 266 120 L 14 120 L 14 14 Q 14 10 18 10 Z"/>
      <line class="cp-c-line" x1="20" y1="22" x2="260" y2="22"/>
      <line class="cp-c-line" x1="20" y1="114" x2="260" y2="114"/>

      <!-- Left reel -->
      <circle class="cp-c-outer" cx="92" cy="58" r="24"/>
      <circle class="cp-c-mid" cx="92" cy="58" r="16"/>
      <circle class="cp-c-hub" cx="92" cy="58" r="5.5"/>
      <g class="cp-spokes cp-spokes-l">
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(0,92,58)"/>
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(60,92,58)"/>
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(120,92,58)"/>
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(180,92,58)"/>
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(240,92,58)"/>
        <line x1="92" y1="40" x2="92" y2="34" transform="rotate(300,92,58)"/>
      </g>
      <circle class="cp-c-tape-l" cx="92" cy="58" r="19"/>

      <!-- Right reel -->
      <circle class="cp-c-outer" cx="188" cy="58" r="24"/>
      <circle class="cp-c-mid" cx="188" cy="58" r="16"/>
      <circle class="cp-c-hub-accent" cx="188" cy="58" r="5.5"/>
      <g class="cp-spokes cp-spokes-r">
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(0,188,58)"/>
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(60,188,58)"/>
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(120,188,58)"/>
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(180,188,58)"/>
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(240,188,58)"/>
        <line x1="188" y1="40" x2="188" y2="34" transform="rotate(300,188,58)"/>
      </g>
      <circle class="cp-c-tape-r" cx="188" cy="58" r="10"/>

      <!-- Tape path -->
      <path class="cp-c-path" d="M 68 58 A 24 24 0 0 0 92 82 L 188 82 A 24 24 0 0 0 212 58"/>

      <!-- Tape window -->
      <rect class="cp-c-window" x="118" y="69" width="44" height="16" rx="3"/>

      <!-- Center post -->
      <circle class="cp-c-post" cx="140" cy="58" r="2.5"/>

      <!-- ─── TRACK INFO on the label area ─── -->
      <rect class="cp-c-label-bg" x="40" y="92" width="200" height="22" rx="4"/>
      <text class="cp-c-title" id="cp-svg-title" x="140" y="100" text-anchor="middle" dominant-baseline="middle">&mdash;</text>
      <text class="cp-c-artist-txt" id="cp-svg-artist" x="140" y="110" text-anchor="middle" dominant-baseline="middle">&mdash;</text>

      <!-- ─── CONTROLS inside the cassette body ─── -->
      <!-- Prev -->
      <g class="cp-svg-btn" id="cp-prev" transform="translate(75,135)">
        <rect x="-14" y="-10" width="28" height="20" rx="4" class="cp-svg-btn-bg"/>
        <path d="M-2 0l6 4V-4zM-5-4v8" fill="currentColor" stroke="none" class="cp-svg-btn-icon"/>
      </g>
      <!-- Play/Pause -->
      <g class="cp-svg-btn cp-svg-play" id="cp-play-g" transform="translate(140,135)">
        <circle r="14" class="cp-svg-play-bg"/>
        <path class="cp-ico-play" d="M-3-5v10l8-5z" fill="#fff" stroke="none"/>
        <g class="cp-ico-pause" style="display:none">
          <rect x="-4" y="-4.5" width="3" height="9" rx="0.5" fill="#fff"/>
          <rect x="1" y="-4.5" width="3" height="9" rx="0.5" fill="#fff"/>
        </g>
      </g>
      <!-- Next -->
      <g class="cp-svg-btn" id="cp-next" transform="translate(205,135)">
        <rect x="-14" y="-10" width="28" height="20" rx="4" class="cp-svg-btn-bg"/>
        <path d="M-4-4v8l6-4zM5-4v8" fill="currentColor" stroke="none" class="cp-svg-btn-icon"/>
      </g>

      <!-- ─── PROGRESS BAR inside cassette ─── -->
      <rect class="cp-c-prog-bg" x="40" y="155" width="200" height="3" rx="1.5"/>
      <rect class="cp-c-prog-fill" id="cp-prog" x="40" y="155" width="0" height="3" rx="1.5"/>

      <!-- Time labels -->
      <text class="cp-c-time" id="cp-time-l" x="40" y="165" dominant-baseline="hanging">0:00</text>
      <text class="cp-c-time" id="cp-time-r" x="240" y="165" text-anchor="end" dominant-baseline="hanging">0:00</text>

      <!-- Pin holes -->
      <circle class="cp-c-pin" cx="50" cy="135" r="1.5"/>
      <circle class="cp-c-pin" cx="230" cy="135" r="1.5"/>

      <!-- Corner screws -->
      <circle class="cp-c-screw" cx="8" cy="8" r="2.5"/>
      <circle class="cp-c-screw" cx="272" cy="8" r="2.5"/>
      <circle class="cp-c-screw" cx="8" cy="167" r="2.5"/>
      <circle class="cp-c-screw" cx="272" cy="167" r="2.5"/>
    </svg>
  </div>

  <!-- Volume row (below cassette) -->
  <div class="cp-vol-row">
    <span class="cp-vol-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/></svg>
    </span>
    <div class="cp-slider-area" id="cp-vol-area">
      <div class="cp-slider-wrap">
        <div class="cp-slider-track"><div class="cp-slider-fill" id="cp-vol-fill" style="width:70%"></div></div>
      </div>
    </div>
    <span class="cp-vol-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
    </span>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { getMediaUrl } from '../../utils/cdn';

  const PLAYLIST = [
    { title: "Experience", artist: "Ludovico Einaudi", src: "/audio/audio-experience-ludovico-einaudi.mp3" },
    { title: "Code Monkey", artist: "Jonathan Coulton", src: "/audio/audio-code-monkey.mp3" },
    { title: "Daydreamer", artist: "AURORA", src: "/audio/audio-daydreamer-aurora.mp3" },
    { title: "All The Things", artist: "Dual Core", src: "/audio/audio-all-the-things-dual-core.mp3" },
    { title: "Find the Longest Path", artist: "Daniel Barrett", src: "/audio/audio-find-the-longest-path.mp3" },
    { title: "GTA San Andreas Theme", artist: "Michael Hunter", src: "/audio/audio-gta-san-andreas-theme.mp3" },
    { title: "Hello World", artist: "Louie Zong", src: "/audio/audio-hello-world-louie-zong.mp3" },
    { title: "Here Comes Another Bubble", artist: "The Richter Scales", src: "/audio/audio-here-comes-another-bubble-richter-scales.mp3" },
    { title: "Another Brick in the Wall", artist: "Pink Floyd", src: "/audio/audio-another-brick-in-the-wall-pink-floyd.mp3" },
    { title: "Digital Witness", artist: "St. Vincent", src: "/audio/audio-digital-witness-st-vincent.mp3" },
    { title: "Stretch Your Face", artist: "Tobacco", src: "/audio/audio-stretch-your-face-tobacco.mp3" },
    { title: "That's The Way It Is", artist: "Daniel Lanois", src: "/audio/audio-thats-the-way-it-is-daniel-lanois.mp3" },
    { title: "Big Bang Theory Theme", artist: "Barenaked Ladies", src: "/audio/audio-big-bang-theory-theme-barenaked-ladies.mp3" },
  ];

  const $ = (id: string) => document.getElementById(id)!;

  const audio    = $('cp-audio') as HTMLAudioElement;
  const mini     = $('cp-toggle');
  const player   = $('cp-player');
  const cassette = $('cp-cassette');
  const eq       = $('cp-eq');
  const svgTitle = $('cp-svg-title');
  const svgArtist = $('cp-svg-artist');
  const timeL    = $('cp-time-l');
  const timeR    = $('cp-time-r');
  const progBar  = $('cp-prog');
  const playG    = $('cp-play-g');
  const icoPlay  = playG.querySelector('.cp-ico-play') as SVGElement;
  const icoPause = playG.querySelector('.cp-ico-pause') as SVGElement;
  const volFill  = $('cp-vol-fill');
  const volArea  = $('cp-vol-area');
  const miniNote = mini.querySelector('.cp-mini-note') as SVGElement;

  let idx = 0;
  let seeking = false;

  const STATE_KEY = 'acm-cassette-player-state';
  type SavedState = { idx: number; time: number; paused: boolean; volume: number };

  const readSavedState = (): SavedState | null => {
    try {
      const raw = sessionStorage.getItem(STATE_KEY);
      if (!raw) return null;
      const s = JSON.parse(raw);
      if (typeof s?.idx !== 'number' || typeof s?.time !== 'number') return null;
      return s;
    } catch { return null; }
  };

  const writeSavedState = () => {
    try {
      const s: SavedState = {
        idx,
        time: audio.currentTime || 0,
        paused: audio.paused,
        volume: audio.volume,
      };
      sessionStorage.setItem(STATE_KEY, JSON.stringify(s));
    } catch { /* ignore quota errors */ }
  };

  const fmt = (s: number) => {
    if (!isFinite(s) || s < 0) return '0:00';
    return `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, '0')}`;
  };

  // Failsafe: if the CDN copy 404s / fails, fall back to the origin-local mp3
  // for the current track and reload once. Re-armed per loadTrack.
  let mediaFellBack = false;
  audio.addEventListener('error', () => {
    if (mediaFellBack) return;
    const local = PLAYLIST[idx]?.src;
    if (!local || audio.src.endsWith(local)) return;
    mediaFellBack = true;
    const wasPlaying = !audio.paused && !audio.ended;
    const at = audio.currentTime || 0;
    audio.src = local;
    audio.load();
    if (at > 0) audio.addEventListener('loadedmetadata', () => {
      try { audio.currentTime = at; } catch { /* ignore */ }
    }, { once: true });
    if (wasPlaying) audio.play().catch(() => {});
  });

  function loadTrack(i: number, autoplay = false, startTime = 0) {
    idx = ((i % PLAYLIST.length) + PLAYLIST.length) % PLAYLIST.length;
    const t = PLAYLIST[idx];
    mediaFellBack = false;
    audio.src = getMediaUrl(t.src);
    audio.load();
    svgTitle.textContent = t.title;
    svgArtist.textContent = t.artist;
    timeL.textContent = fmt(startTime);
    timeR.textContent = '0:00';
    progBar.setAttribute('width', '0');
    if (startTime > 0) {
      const applyStart = () => {
        try { audio.currentTime = startTime; } catch { /* ignore */ }
      };
      if (audio.readyState >= 1) applyStart();
      else audio.addEventListener('loadedmetadata', applyStart, { once: true });
    }
    if (autoplay) audio.play().catch(() => {});
  }

  const saved = readSavedState();
  if (saved) {
    audio.volume = Math.min(1, Math.max(0, saved.volume));
    volFill.style.width = `${audio.volume * 100}%`;
    loadTrack(saved.idx, !saved.paused, saved.time);
  } else {
    loadTrack(0);
    audio.volume = 0.7;
  }

  // Persist state on every nav-out and periodically while playing
  window.addEventListener('pagehide', writeSavedState);
  window.addEventListener('beforeunload', writeSavedState);
  setInterval(() => { if (!audio.paused) writeSavedState(); }, 1000);

  /* ─── Audio events ─── */
  audio.addEventListener('timeupdate', () => {
    if (seeking || !audio.duration) return;
    timeL.textContent = fmt(audio.currentTime);
    const pct = (audio.currentTime / audio.duration) * 200;
    progBar.setAttribute('width', String(pct));
  });

  audio.addEventListener('loadedmetadata', () => {
    timeR.textContent = fmt(audio.duration);
  });

  audio.addEventListener('ended', () => loadTrack(idx + 1, true));

  audio.addEventListener('play', () => {
    icoPlay.style.display = 'none';
    icoPause.style.display = '';
    cassette.classList.add('cp-playing');
    eq.classList.add('cp-eq-active');
    miniNote.style.display = 'none';
    writeSavedState();
  });

  audio.addEventListener('pause', () => {
    icoPlay.style.display = '';
    icoPause.style.display = 'none';
    cassette.classList.remove('cp-playing');
    eq.classList.remove('cp-eq-active');
    miniNote.style.display = '';
    writeSavedState();
  });

  /* ─── SVG button clicks ─── */
  playG.addEventListener('click', () => {
    if (audio.paused) audio.play().catch(() => {});
    else audio.pause();
  });
  playG.style.cursor = 'pointer';

  $('cp-prev').addEventListener('click', () => {
    if (audio.currentTime > 3) { audio.currentTime = 0; return; }
    loadTrack(idx - 1, true);
  });
  $('cp-prev').style.cursor = 'pointer';

  $('cp-next').addEventListener('click', () => loadTrack(idx + 1, true));
  $('cp-next').style.cursor = 'pointer';

  /* ─── Progress bar click-to-seek ─── */
  const progBg = document.querySelector('.cp-c-prog-bg') as SVGRectElement;
  const progFill = progBar as SVGRectElement;

  function seekFromEvent(e: PointerEvent) {
    if (!audio.duration) return;
    const rect = progBg.getBoundingClientRect();
    let pct = (e.clientX - rect.left) / rect.width;
    pct = Math.min(1, Math.max(0, pct));
    audio.currentTime = pct * audio.duration;
    progFill.setAttribute('width', String(pct * 200));
    timeL.textContent = fmt(audio.currentTime);
  }

  let progDragging = false;
  progBg.style.cursor = 'pointer';
  progFill.style.cursor = 'pointer';

  const progHitArea = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
  progHitArea.setAttribute('x', '40');
  progHitArea.setAttribute('y', '150');
  progHitArea.setAttribute('width', '200');
  progHitArea.setAttribute('height', '13');
  progHitArea.setAttribute('fill', 'transparent');
  progHitArea.style.cursor = 'pointer';
  progBg.parentElement!.appendChild(progHitArea);

  progHitArea.addEventListener('pointerdown', (e) => {
    progDragging = true;
    seeking = true;
    progHitArea.setPointerCapture(e.pointerId);
    seekFromEvent(e);
  });

  progHitArea.addEventListener('pointermove', (e) => {
    if (progDragging) seekFromEvent(e);
  });

  const progUp = () => {
    progDragging = false;
    seeking = false;
  };
  progHitArea.addEventListener('pointerup', progUp);
  progHitArea.addEventListener('pointercancel', progUp);

  /* ─── Morph expand / collapse ─── */
  let morphTween: gsap.core.Tween | null = null;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function getClosedClip() {
    const w = mini.offsetWidth || 52;
    const ph = player.offsetHeight;
    const pw = player.offsetWidth;
    const br = Math.round(parseFloat(getComputedStyle(mini).borderRadius)) || 14;
    return `inset(${ph - w}px 0px 0px ${pw - w}px round ${br}px)`;
  }

  // Open: GSAP power3.out expand from button corner
  mini.addEventListener('click', () => {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    if (morphTween) morphTween.kill();
    mini.classList.add('cp-hidden');
    player.style.opacity = '1';
    player.style.pointerEvents = 'auto';
    player.style.transition = 'none';
    morphTween = gsap.fromTo(player,
      { clipPath: getClosedClip() },
      { clipPath: 'inset(0px 0px 0px 0px round 18px)', duration: 0.5, ease: 'power3.out',
        onComplete: () => { player.style.transition = ''; } }
    );
  });

  // Close: CSS transition, button appears immediately, opacity clears after
  $('cp-minimize').addEventListener('click', () => {
    if (morphTween) morphTween.kill();
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    mini.classList.remove('cp-hidden');
    player.style.pointerEvents = 'none';
    player.style.opacity = '1';
    player.style.transition = 'clip-path 0.35s cubic-bezier(0.4,0,0.6,1)';
    requestAnimationFrame(() => { player.style.clipPath = getClosedClip(); });
    closeTimer = setTimeout(() => {
      player.style.opacity = '0';
      player.style.transition = '';
      closeTimer = null;
    }, 390);
  });

  /* ─── Elastic volume slider ─── */
  const MAX_OV = 50;
  const decay = (v: number, mx: number) => {
    if (mx === 0) return 0;
    const e = v / mx;
    return (2 * (1 / (1 + Math.exp(-e)) - 0.5)) * mx;
  };

  (() => {
    const area = volArea;
    const fill = volFill;
    const wrap = area.querySelector('.cp-slider-wrap') as HTMLElement;
    let dragging = false;

    area.addEventListener('pointerdown', (ev) => {
      dragging = true;
      area.setPointerCapture(ev.pointerId);
      area.classList.add('cp-dragging');
      wrap.style.transition = 'height 0.15s ease';
      tick(ev);
    });

    area.addEventListener('pointermove', (ev) => { if (dragging) tick(ev); });

    const up = () => {
      if (!dragging) return;
      dragging = false;
      area.classList.remove('cp-dragging');
      wrap.style.transition = 'all 0.5s cubic-bezier(0.34,1.56,0.64,1)';
      wrap.style.transform = '';
    };
    area.addEventListener('pointerup', up);
    area.addEventListener('pointercancel', up);
    area.addEventListener('lostpointercapture', up);

    function tick(ev: PointerEvent) {
      const { left, right, width } = area.getBoundingClientRect();
      let v = (ev.clientX - left) / width;
      v = Math.min(1, Math.max(0, v));
      fill.style.width = `${v * 100}%`;
      audio.volume = v;

      if (ev.clientX < left) {
        const ov = decay(left - ev.clientX, MAX_OV);
        wrap.style.transform = `scaleX(${1 + ov / width}) scaleY(${1 - ov * 0.004})`;
        wrap.style.transformOrigin = 'right center';
      } else if (ev.clientX > right) {
        const ov = decay(ev.clientX - right, MAX_OV);
        wrap.style.transform = `scaleX(${1 + ov / width}) scaleY(${1 - ov * 0.004})`;
        wrap.style.transformOrigin = 'left center';
      } else {
        wrap.style.transform = '';
      }
    }
  })();
</script>

<style>
  /* ── Mini button ── */
  .cp-mini {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    /* Glassmorphic */
    background: linear-gradient(
      145deg,
      rgba(255,255,255,0.12) 0%,
      rgba(8,8,14,0.52) 55%,
      rgba(6,6,10,0.48) 100%
    );
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.22),
      inset 0 -1px 0 rgba(0,0,0,0.3),
      0 4px 24px rgba(0,0,0,0.45),
      0 1px 6px rgba(0,0,0,0.3);
    cursor: pointer;
    z-index: 990;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,253,208,0.5);
    /* Morph: fade + scale on hide/show */
    opacity: 1;
    transform: scale(1);
    transition:
      opacity 0.18s ease,
      transform 0.18s cubic-bezier(0.16,1,0.3,1);
  }
  .cp-mini:hover { transform: scale(1.08); }
  .cp-mini.cp-hidden {
    opacity: 0;
    transform: scale(0.85);
    pointer-events: none;
  }

  :global(html[data-theme="light"]) .cp-mini {
    background: linear-gradient(
      145deg,
      rgba(255,255,255,0.7) 0%,
      rgba(240,235,225,0.55) 100%
    );
    border-color: rgba(0,0,0,0.1);
    color: rgba(26,26,26,0.6);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.9),
      0 4px 24px rgba(0,0,0,0.12);
  }

  /* ── Equalizer bars ── */
  .cp-eq {
    display: none;
    align-items: flex-end;
    gap: 3px;
    height: 20px;
  }
  .cp-eq-bar {
    width: 3px;
    border-radius: 1.5px;
    background: #F95F4A;
  }
  .cp-eq-bar:nth-child(1) { height: 8px; }
  .cp-eq-bar:nth-child(2) { height: 14px; }
  .cp-eq-bar:nth-child(3) { height: 18px; }
  .cp-eq-bar:nth-child(4) { height: 10px; }

  .cp-eq.cp-eq-active { display: flex; }
  .cp-eq.cp-eq-active ~ .cp-mini-note { display: none; }
  .cp-eq.cp-eq-active .cp-eq-bar:nth-child(1) { animation: eqBar1 0.65s ease-in-out infinite; }
  .cp-eq.cp-eq-active .cp-eq-bar:nth-child(2) { animation: eqBar2 0.78s ease-in-out infinite; }
  .cp-eq.cp-eq-active .cp-eq-bar:nth-child(3) { animation: eqBar3 0.55s ease-in-out infinite; }
  .cp-eq.cp-eq-active .cp-eq-bar:nth-child(4) { animation: eqBar4 0.72s ease-in-out infinite; }

  @keyframes eqBar1 {
    0%, 100% { height: 6px; } 25% { height: 18px; } 50% { height: 10px; } 75% { height: 20px; }
  }
  @keyframes eqBar2 {
