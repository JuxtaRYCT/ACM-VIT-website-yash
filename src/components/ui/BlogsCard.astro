---
interface Props {
  bgUrl: string;
  link: string;
}

import { getAssetUrl } from "../../utils/cdn";
const { bgUrl, link } = Astro.props;

const imageUrl = bgUrl.startsWith("http") ? bgUrl : getAssetUrl(bgUrl);
---

<a
  href={link}
  rel="noopener noreferrer"
  class="relative w-full sm:w-[40vw] lg:w-[14vw] aspect-[1.6] rounded-lg bg-white overflow-hidden flex items-end justify-center cursor-pointer transition-transform duration-300 hover:scale-105"
>
  <!-- Background Pattern -->
  <img
    src={imageUrl}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <div
    class="w-[97%] h-[96.5%] flex justify-center items-center absolute z-20 pointer-events-none"
  >
    <img
      src={getAssetUrl("/ui/bloglayout.webp")}
      alt="Background Pattern"
      class="absolute w-full h-full object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>

</a>
