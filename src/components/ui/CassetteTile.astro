---
/**
 * CassetteTile - a link styled as a physical cassette: corner screws, a cream
 * label sticker (title + desc), and a deck with two reels that spin on hover.
 * Accent-themed and reusable. Pass the icon via the `icon` slot.
 */
export interface Props {
  title: string;
  desc: string;
  href: string;
  accent?: string;
  tag?: string;
}
const { title, desc, href, accent = "#F95F4A", tag = "SIDE A" } = Astro.props;

// Cassette reel gear ("Pencil Thingy"), centered (33,33) in 67x67.
const REEL_GEAR =
  "M32.865 9.595C36.091 9.595 39.165 10.246 41.963 11.424L39.137 16.32L44.222 19.256L47.044 14.366C51.943 18.09 55.333 23.696 56.135 30.107H50.48V35.98H56.136C55.335 42.398 51.941 48.009 47.036 51.734L44.213 46.844L39.128 49.779L41.954 54.673C39.159 55.849 36.088 56.5 32.865 56.5C29.638 56.5 26.563 55.847 23.765 54.668L26.596 49.767L21.511 46.831L18.684 51.727C13.784 48.001 10.396 42.393 9.596 35.98H15.251V30.107H9.597C10.399 23.693 13.791 18.083 18.694 14.359L21.519 19.252L26.604 16.316L23.777 11.42C26.572 10.244 29.643 9.595 32.865 9.595Z";
---

<a
  href={href}
  class="cassette-tile group"
  style={`--accent: ${accent};`}
  data-cassette-tile
>
  <span class="screw screw-tl"></span>
  <span class="screw screw-tr"></span>
  <span class="screw screw-bl"></span>
  <span class="screw screw-br"></span>

  <!-- Label sticker -->
  <div class="tile-sticker">
    <div class="sticker-top">
      <span class="sticker-brand">
        <span class="sticker-icon"><slot name="icon" /></span>
        ACM-VIT
      </span>
      <span class="sticker-side">{tag}</span>
    </div>
    <h3 class="tile-title">{title}</h3>
    <p class="tile-desc">{desc}</p>
  </div>

  <!-- Deck with reels -->
  <div class="tile-deck">
    <span class="reel">
      <svg viewBox="0 0 67 67" aria-hidden="true"><path d={REEL_GEAR} /></svg>
    </span>
    <span class="tile-window"></span>
    <span class="reel">
      <svg viewBox="0 0 67 67" aria-hidden="true"><path d={REEL_GEAR} /></svg>
    </span>
  </div>

  <span class="tile-play">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
    Play
  </span>
</a>

<style>
  .cassette-tile {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem 1.25rem 1.1rem;
    border-radius: 18px;
    text-decoration: none;
    background:
      linear-gradient(160deg, #1b1b1b 0%, #0f0f0f 100%);
    border: 1px solid rgba(254, 252, 217, 0.1);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }
  .cassette-tile::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/backgrounds/noise.webp");
    background-size: cover;
    opacity: 0.06;
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  .cassette-tile::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      120% 80% at 50% 0%,
      color-mix(in srgb, var(--accent) 18%, transparent),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }
  .cassette-tile:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    box-shadow:
      0 22px 50px rgba(0, 0, 0, 0.5),
      0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .cassette-tile:hover::after {
    opacity: 1;
  }

  /* Corner screws */
  .screw {
    position: absolute;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--accent) 70%, transparent);
    background: rgba(0, 0, 0, 0.4);
    z-index: 3;
  }
  .screw-tl { top: 10px; left: 10px; }
  .screw-tr { top: 10px; right: 10px; }
  .screw-bl { bottom: 10px; left: 10px; }
  .screw-br { bottom: 10px; right: 10px; }

  /* Label sticker */
  .tile-sticker {
    position: relative;
    z-index: 2;
    background: #fefcd9;
    border-radius: 10px;
    padding: 0.85rem 1rem 1rem;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .sticker-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .sticker-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "PolySans Mono", monospace;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: #1a1a1a;
  }
  .sticker-icon {
    display: inline-flex;
    color: var(--accent);
  }
  .sticker-icon :global(svg) {
    width: 16px;
    height: 16px;
  }
  .sticker-side {
    font-family: "PolySans Mono", monospace;
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    color: var(--accent);
    padding: 0.12rem 0.45rem;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: 999px;
  }
  .tile-title {
    margin: 0;
    font-family: "PolySans Trial", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.05;
    color: #141414;
    letter-spacing: -0.01em;
  }
  .tile-desc {
    margin: 0.35rem 0 0;
    font-family: "PolySans Mono", monospace;
    font-size: 0.68rem;
    line-height: 1.4;
    color: rgba(20, 20, 20, 0.62);
  }

  /* Deck */
  .tile-deck {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 0.4rem;
  }
  .reel {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
  }
  .reel svg {
    width: 100%;
    height: 100%;
  }
  .reel svg path {
    fill: color-mix(in srgb, var(--accent) 85%, white 0%);
  }
  .cassette-tile:hover .reel svg {
    animation: tileReelSpin 3s linear infinite;
    transform-origin: 50% 50%;
  }
  .reel:last-of-type svg {
    animation-direction: reverse;
  }
  @keyframes tileReelSpin {
    to { transform: rotate(360deg); }
  }
  .tile-window {
    flex: 1;
    height: 10px;
    border-radius: 4px;
    background: repeating-linear-gradient(
      90deg,
      rgba(254, 252, 217, 0.18) 0 4px,
      transparent 4px 9px
    );
    border: 1px solid rgba(254, 252, 217, 0.12);
  }

  .tile-play {
    position: relative;
    z-index: 2;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: "PolySans Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.55;
    transform: translateX(-2px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  .cassette-tile:hover .tile-play {
    opacity: 1;
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cassette-tile:hover .reel svg {
      animation: none;
    }
  }

  /* Light mode: keep the cassette shell dark (it's a physical object). */
  :global(html[data-theme="light"]) .cassette-tile {
    border-color: rgba(0, 0, 0, 0.12);
  }
</style>
