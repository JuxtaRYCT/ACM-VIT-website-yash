---
import Cassette from "./Cassette.astro";
import { getAssetUrl } from "../../utils/cdn";
import { getProjectCassetteByTitle } from "../../data/projectCassettes";

/**
 * ProjectCassetteCard - renders a project using the EXACT same cassette art as
 * the /projects page (looked up by title), with title + desc. Reuses the
 * .dsg-event-card shell so it inherits the AOI page's light/dark styling.
 * Falls back to a provided image, then a plain coloured tape.
 */
export interface Props {
  title: string;
  desc: string;
  domainColor?: string;
  fallbackImage?: string;
}

const { title, desc, domainColor = "#F95F4A", fallbackImage } = Astro.props;
const proj = getProjectCassetteByTitle(title);

const href = proj && proj.url !== "#" ? proj.url : undefined;
const color = proj?.color ?? domainColor;
const Tag = href ? "a" : "div";
---

<Tag
  class="dsg-event-card proj-cass-card"
  data-dsg-animate="fade-up"
  style={`--pc: ${color};`}
  {...href ? { href } : {}}
>
  <div class="proj-cass-tape">
    {
      proj?.kind === "svg" ? (
        <img
          src={getAssetUrl(proj.cassetteSvg)}
          alt={title}
          class="proj-cass-svg"
          loading="lazy"
          decoding="async"
        />
      ) : proj?.kind === "overlay" ? (
        <Cassette
          color={proj.color}
          overlaySrc={getAssetUrl(proj.image)}
          overlaySizePercent={proj.sizePercent}
          overlaySizeAxis={proj.sizeAxis}
          offsetYPercent={proj.offsetY}
          alt={title}
        />
      ) : fallbackImage ? (
        <img
          src={getAssetUrl(fallbackImage)}
          alt={title}
          class="proj-cass-svg"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <Cassette color={color} alt={title} />
      )
    }
  </div>
  <h4>{title}</h4>
  <p>{desc}</p>
</Tag>

<style>
  .proj-cass-tape {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .proj-cass-tape :global(.cassette-container) {
    width: 100%;
    max-width: 100%;
  }
  .proj-cass-svg {
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: 12px;
  }
  .proj-cass-card:hover .proj-cass-tape :global(.cassette-container),
  .proj-cass-card:hover .proj-cass-svg {
    transform: scale(1.02);
    transition: transform 0.3s ease;
  }
</style>
