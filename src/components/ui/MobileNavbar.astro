<script>
  // @ts-nocheck
  import { gsap } from "gsap";
  import { Flip } from "gsap/Flip";
  gsap.registerPlugin(Flip);

  function initMobileNavbar() {
    const root = document.getElementById("mn-root");
    const pill = document.getElementById("mn-pill");
    const label = document.getElementById("mn-label");
    const dot = document.getElementById("mn-section-dot");
    if (!root || !pill || !label) return;

    const lockedLabel = root.dataset.lockedLabel === "true";

    const panelNav = pill.querySelector('[data-panel="nav"]') as HTMLElement;
    const panelMenu = pill.querySelector('[data-panel="menu"]') as HTMLElement;
    const panelMusic = pill.querySelector('[data-panel="music"]') as HTMLElement;
    const panelSub = pill.querySelector('[data-panel="submenu"]') as HTMLElement;
    const panelBlog = pill.querySelector('[data-panel="blog"]') as HTMLElement;
    const panelNotes = pill.querySelector('[data-panel="notes"]') as HTMLElement;
    const panelMerch = pill.querySelector('[data-panel="merch"]') as HTMLElement;
    const panels = { nav: panelNav, menu: panelMenu, music: panelMusic, submenu: panelSub, blog: panelBlog, notes: panelNotes, merch: panelMerch };
    type PanelState = keyof typeof panels;

    const labelMap: Record<string, string> = {
      home: "Home", about: "About", domains: "Domains", events: "Events",
      projects: "Projects", "acm-w": "ACM-W", community: "Community",
      team: "Team", blogs: "Blogs", partners: "Partners", gallery: "Gallery",
      contact: "Contact", more: "More",
    };

    /* ── Section tracking ── */
    function setActiveSection(id: string) {
      if (lockedLabel) return;
      const text =
        labelMap[id] ||
        (id ? id.charAt(0).toUpperCase() + id.slice(1).replace(/-/g, " ") : "Home");
      if (label.textContent !== text) {
        if (dot) {
          if (id === "acm-w") dot.setAttribute("data-pink", "");
          else dot.removeAttribute("data-pink");
        }
        gsap.timeline()
          .to(label, { y: -8, opacity: 0, duration: 0.14, ease: "power2.in" })
          .add(() => { label.textContent = text; })
          .fromTo(label, { y: 8, opacity: 0 }, { y: 0, opacity: 1, duration: 0.2, ease: "power2.out" });
      }
      // Active link highlight in menu
      pill.querySelectorAll(".mn-link").forEach((l) => {
        if (l.getAttribute("data-mn-link") === id) l.setAttribute("data-active", id);
        else l.removeAttribute("data-active");
      });
    }
    window.addEventListener("nav:section", (e: any) => setActiveSection(e.detail?.id));

    /* ── Morph between states (Flip) ── */
    let morphing = false;
    function morphTo(nextState: PanelState) {
      const cur = pill.dataset.state as PanelState;
      if (morphing || cur === nextState) return;
      morphing = true;

      const curPanel = panels[cur];
      const nextPanel = panels[nextState];

      const state = Flip.getState(pill);
      curPanel.style.display = "none";
      nextPanel.style.display = "flex";
      pill.dataset.state = nextState;

      Flip.from(state, {
        duration: 0.42,
        ease: "power3.out",
        absolute: false,
        onComplete: () => { morphing = false; },
      });

      // Fade panel contents in
      gsap.fromTo(
        nextPanel.children,
        { opacity: 0, y: 8 },
        { opacity: 1, y: 0, duration: 0.28, stagger: 0.035, ease: "power2.out", delay: 0.05 },
      );
    }

    /* ── Theme toggle ── */
    const themeBtn = document.getElementById("mn-theme-btn");
    const moonIcon = document.getElementById("mn-theme-moon");
    const sunIcon = document.getElementById("mn-theme-sun");
    function syncThemeIcons() {
      const isLight = document.documentElement.getAttribute("data-theme") === "light";
      moonIcon?.classList.toggle("hidden", isLight);
      sunIcon?.classList.toggle("hidden", !isLight);
    }
    syncThemeIcons();
    themeBtn?.addEventListener("click", () => {
      const fn = (window as any).acmToggleTheme;
      if (typeof fn === "function") {
        // Reveal from the theme button's center, not the desktop bulb.
        const r = themeBtn.getBoundingClientRect();
        fn(r.left + r.width / 2, r.top + r.height / 2);
      } else {
        // Fallback: flip data-theme directly
        const html = document.documentElement;
        if (html.getAttribute("data-theme") === "light") {
          html.removeAttribute("data-theme");
          localStorage.setItem("acm-theme", "dark");
        } else {
          html.setAttribute("data-theme", "light");
          localStorage.setItem("acm-theme", "light");
        }
      }
      setTimeout(syncThemeIcons, 50);
    });
    // React to theme changes from elsewhere (bulb pull)
    new MutationObserver(syncThemeIcons).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    document.getElementById("mn-menu-btn")?.addEventListener("click", () => {
      morphTo("menu");
    });
    document.getElementById("mn-music-btn")?.addEventListener("click", () => {
      morphTo("music");
    });
    pill.querySelectorAll("[data-mn-close]").forEach((btn) => {
      btn.addEventListener("click", () => morphTo("nav"));
    });

    /* ── Deterministic rAF smooth scroll ──
       scrollIntoView({behavior:"smooth"}) is unreliable on mobile Safari (often
       jumps instantly). Animate window.scrollTo ourselves so it's smooth on
       every mobile browser, and recompute target top at click time. */
    // The site scrolls the <body> element (Layout sets html,body{height:100%;
    // overflow-x:hidden} → body becomes the scroll container, NOT the window).
    // Detect the element that actually scrolls so this works on every page.
    function getScroller(): HTMLElement {
      const se = (document.scrollingElement || document.documentElement) as HTMLElement;
      if (se && se.scrollHeight > se.clientHeight + 2) return se;
      if (document.body.scrollHeight > document.body.clientHeight + 2) return document.body;
      return se || document.documentElement;
    }

    let scrollRaf = 0;
    function smoothScrollToY(destY: number, duration = 620) {
      const scroller = getScroller();
      const startY = scroller.scrollTop;
      const max = scroller.scrollHeight - scroller.clientHeight;
      const target = Math.max(0, Math.min(destY, max));
      const dist = target - startY;
      if (Math.abs(dist) < 2) return;
      const t0 = performance.now();
      const ease = (p: number) =>
        p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2; // easeInOutCubic
      cancelAnimationFrame(scrollRaf);
      const step = (now: number) => {
        const p = Math.min(1, (now - t0) / duration);
        // Set scrollTop directly (not scrollTo{behavior}), else CSS
        // scroll-behavior:smooth restarts a native tween each frame and stalls.
        scroller.scrollTop = startY + dist * ease(p);
        if (p < 1) scrollRaf = requestAnimationFrame(step);
      };
      scrollRaf = requestAnimationFrame(step);
    }

    /* ── Navigate helper (smooth same-page scroll, else default nav) ──
       Same-page hash links (e.g. "/#partners") scroll smoothly in-page.
       Cross-page links (e.g. "/blogs", or "/#x" when not on that page) fall
       through to default navigation. Returns true if handled locally. */
    function navigateHref(href: string, e?: Event) {
      const hashIdx = href.indexOf("#");
      if (hashIdx === -1) return false;

      const path = href.slice(0, hashIdx);
      const id = href.slice(hashIdx + 1);
      if (!id) return false;

      const samePage = path === "" || path === window.location.pathname;
      const target = samePage ? document.getElementById(id) : null;
      if (!target) return false;

      // Handle it ourselves; stop the desktop Header click handler from also
      // firing its own (conflicting) scrollIntoView on the same target.
      e?.preventDefault();
      e?.stopPropagation();

      // Offset for the section's scroll-margin (page-section = 84px), minus a
      // touch so it sits a bit lower than the very top on mobile.
      const cs = getComputedStyle(target);
      const marginTop = parseInt(cs.scrollMarginTop || "0", 10) || 0;
      const destY = getScroller().scrollTop + target.getBoundingClientRect().top - marginTop;
      smoothScrollToY(destY);
      history.pushState(null, "", href);
      return true;
    }

    /* ── Submenu (subsections of a section, mirrors desktop megamenu) ── */
    let subData: { subsections: Record<string, any[]>; sectionTitles: Record<string, string> } = {
      subsections: {}, sectionTitles: {},
    };
    try {
      const raw = document.getElementById("mn-sub-data")?.textContent;
      if (raw) subData = JSON.parse(raw);
    } catch {}

    const subTitle = document.getElementById("mn-sub-title");
    const subGlyph = document.getElementById("mn-sub-glyph");
    const subSubtitle = document.getElementById("mn-sub-subtitle");
    const subList = document.getElementById("mn-sub-list");
    const subGoto = document.getElementById("mn-sub-goto");
    let subSectionHref = "";

    // X glyph for the red close button.
    const CLOSE_SVG =
      `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>`;

    function openSubmenu(sectionId: string, sectionHref: string) {
      const items = subData.subsections[sectionId];
      if (!items || !subList) return;
      subSectionHref = sectionHref;
      const title = subData.sectionTitles[sectionId] || sectionId;
      if (subTitle) subTitle.textContent = title;
      if (subGlyph) subGlyph.textContent = title.charAt(0).toUpperCase();
      if (subSubtitle)
        subSubtitle.textContent = `${items.length} ${items.length === 1 ? "section" : "sections"}`;

      subList.innerHTML = "";
      // One round button per subsection (alternating light/dark like the ref).
      items.forEach((it, i) => {
        const btn = document.createElement("a");
        btn.href = it.href;
        btn.className = "mn-sub-btn " + (i % 2 === 0 ? "is-light" : "is-dark");
        btn.innerHTML =
          `<span class="mn-sub-btn-circle"><span class="mn-sub-btn-glyph"></span></span>` +
          `<span class="mn-sub-btn-label"></span>`;
        (btn.querySelector(".mn-sub-btn-glyph") as HTMLElement).textContent =
          it.title.charAt(0).toUpperCase();
        (btn.querySelector(".mn-sub-btn-label") as HTMLElement).textContent = it.title;
        btn.addEventListener("click", (e) => {
          morphTo("nav");
          navigateHref(it.href, e);
        });
        subList.appendChild(btn);
      });

      // Red close button → dismiss the pill back to nav.
      const close = document.createElement("button");
      close.type = "button";
      close.className = "mn-sub-btn is-red";
      close.setAttribute("aria-label", "Close");
      close.innerHTML =
        `<span class="mn-sub-btn-circle">${CLOSE_SVG}</span>` +
        `<span class="mn-sub-btn-label">Close</span>`;
      close.addEventListener("click", () => morphTo("nav"));
      subList.appendChild(close);

      subList.scrollTop = 0;
      morphTo("submenu");
    }

    subGoto?.addEventListener("click", () => {
      morphTo("nav");
      // Cross-page (or non-hash) section links: navigateHref can't smooth-scroll,
      // so fall back to a real navigation.
      if (!navigateHref(subSectionHref) && subSectionHref) {
        window.location.href = subSectionHref;
      }
    });

    // Row tap → smooth-scroll to the section (or navigate cross-page).
    pill.querySelectorAll(".mn-link").forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href") || "";
        morphTo("nav");
        navigateHref(href, e);
      });
    });
    // Caret tap → open the subsection submenu (doesn't trigger the row scroll).
    pill.querySelectorAll("[data-mn-caret]").forEach((caret) => {
      caret.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = caret.getAttribute("data-mn-caret") || "";
        const link = caret.closest("li")?.querySelector(".mn-link");
        const href = link?.getAttribute("href") || "";
        openSubmenu(id, href);
      });
    });
    document.addEventListener("pointerdown", (e) => {
      if (pill.dataset.state === "nav") return;
      const target = e.target as Node;
      if (!pill.contains(target)) morphTo("nav");
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && pill.dataset.state !== "nav") morphTo("nav");
    });

    /* ── Blog tools wiring (proxies to the hidden BlogDock on blog pages) ──
       On mobile the standalone dock pill is hidden (see BlogDock.astro); we
       surface its Listen / Notes / Share actions here and forward clicks to the
       dock's real buttons, mirroring their state back. ── */
    const blogBtn = document.getElementById("mn-blog-btn");
    const dock = document.querySelector("[data-blog-dock-root]");
    if (blogBtn && dock) {
      blogBtn.classList.remove("hidden");
      blogBtn.classList.add("flex");

      const dockListen = dock.querySelector("[data-listen-btn]") as HTMLElement | null;
      const dockShare = dock.querySelector("[data-share-btn]") as HTMLElement | null;

      const listenCtl = document.getElementById("mn-blog-listen");
      const listenPlay = document.getElementById("mn-blog-listen-play");
      const listenStop = document.getElementById("mn-blog-listen-stop");
      const listenLabel = document.getElementById("mn-blog-listen-label");
      const shareDefault = document.getElementById("mn-blog-share-default");
      const shareCopied = document.getElementById("mn-blog-share-copied");
      const shareLabel = document.getElementById("mn-blog-share-label");

      // Attention pulse until the user opens the tools the first time.
      blogBtn.classList.add("mn-attn");
      blogBtn.addEventListener("click", () => {
        blogBtn.classList.remove("mn-attn");
        morphTo("blog");
      });

      // Listen: forward to dock, mirror active state via its button's class.
      listenCtl?.addEventListener("click", () => dockListen?.click());
      function syncListen() {
        const on = !!dockListen?.classList.contains("is-active");
        listenCtl?.classList.toggle("is-active", on);
        listenPlay?.classList.toggle("hidden", on);
        listenStop?.classList.toggle("hidden", !on);
        if (listenLabel) listenLabel.textContent = on ? "Stop" : "Listen";
      }
      if (dockListen) {
        new MutationObserver(syncListen).observe(dockListen, {
          attributes: true, attributeFilter: ["class"],
        });
        syncListen();
      }

      // Notes: morph the pill into an in-pill scratchpad, synced to the dock's
      // hidden textarea (which persists to localStorage).
      const dockNotesInput = dock.querySelector("[data-scratchpad-input]") as HTMLTextAreaElement | null;
      const notesInput = document.getElementById("mn-notes-input") as HTMLTextAreaElement | null;
      document.getElementById("mn-blog-notes")?.addEventListener("click", () => {
        if (notesInput && dockNotesInput) notesInput.value = dockNotesInput.value;
        morphTo("notes");
        setTimeout(() => notesInput?.focus(), 320);
      });
      pill.querySelector("[data-mn-notes-back]")?.addEventListener("click", () => morphTo("blog"));
      // Mirror typing into the dock textarea + fire its input handler to save.
      notesInput?.addEventListener("input", () => {
        if (!dockNotesInput) return;
        dockNotesInput.value = notesInput.value;
        dockNotesInput.dispatchEvent(new Event("input", { bubbles: true }));
      });

      // Share: forward + mirror the copied confirmation.
      document.getElementById("mn-blog-share")?.addEventListener("click", () => {
        dockShare?.click();
      });
      if (dockShare) {
        new MutationObserver(() => {
          const copied = !dock.querySelector("[data-share-icon-copied]")?.classList.contains("hidden");
          shareDefault?.classList.toggle("hidden", copied);
          shareCopied?.classList.toggle("hidden", !copied);
          if (shareLabel) shareLabel.textContent = copied ? "Copied" : "Share";
        }).observe(dock.querySelector("[data-share-icon-copied]") as HTMLElement, {
          attributes: true, attributeFilter: ["class"],
        });
      }
    }

    /* ── Merch collection wiring (proxies to the hidden merch dock on merch
       view pages). The standalone [data-vw-dock] is hidden on mobile (see the
       merch view CSS); we surface its prev / dots / next here and forward taps
       to the real controls, mirroring the active item back. ── */
    const merchDock = document.querySelector("[data-vw-dock]");
    const merchBtn = document.getElementById("mn-merch-btn");
    if (merchDock && merchBtn) {
      merchBtn.classList.remove("hidden");
      merchBtn.classList.add("flex");
      merchBtn.addEventListener("click", () => morphTo("merch"));

      const realDots = Array.from(merchDock.querySelectorAll("[data-nav]")) as HTMLElement[];
      const realPrev = merchDock.querySelector('[data-arrow="prev"]') as HTMLElement | null;
      const realNext = merchDock.querySelector('[data-arrow="next"]') as HTMLElement | null;
      const dotsWrap = document.getElementById("mn-merch-dots");
      const merchName = document.getElementById("mn-merch-name");

      // Build one mirror dot per real nav dot (same accent + label).
      realDots.forEach((rd, i) => {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "mn-merch-dot";
        b.setAttribute("aria-label", rd.getAttribute("aria-label") || `Item ${i + 1}`);
        b.style.setProperty("--dot-c", rd.style.getPropertyValue("--dot-c") || "#f95f4a");
        b.innerHTML = "<span></span>";
        b.addEventListener("click", () => rd.click());
        dotsWrap?.appendChild(b);
      });

      const mirrorDots = Array.from(dotsWrap?.querySelectorAll(".mn-merch-dot") || []) as HTMLElement[];
      function syncMerch() {
        let activeIdx = 0;
        realDots.forEach((rd, i) => {
          const on = rd.classList.contains("active");
          mirrorDots[i]?.classList.toggle("is-active", on);
          if (on) activeIdx = i;
        });
        if (merchName)
          merchName.textContent = realDots[activeIdx]?.getAttribute("aria-label") || "-";
      }
      realDots.forEach((rd) =>
        new MutationObserver(syncMerch).observe(rd, { attributes: true, attributeFilter: ["class"] }),
      );
      syncMerch();

      document.getElementById("mn-merch-prev")?.addEventListener("click", () => realPrev?.click());
      document.getElementById("mn-merch-next")?.addEventListener("click", () => realNext?.click());
    }

    /* ── Music player wiring (controls existing CassettePlayer audio + state) ── */
    const audio = document.getElementById("cp-audio") as HTMLAudioElement | null;
    const cpSvgTitle = document.getElementById("cp-svg-title");
    const cpSvgArtist = document.getElementById("cp-svg-artist");
    const cpPrev = document.getElementById("cp-prev");
    const cpNext = document.getElementById("cp-next");
    const cpPlayG = document.getElementById("cp-play-g");

    const trackTitle = document.getElementById("mn-track-title");
    const trackArtist = document.getElementById("mn-track-artist");
    const timeCur = document.getElementById("mn-time-cur");
    const timeDur = document.getElementById("mn-time-dur");
    const progFill = document.getElementById("mn-prog-fill");
    const progTrack = document.getElementById("mn-prog-track");
    const playBtn = document.getElementById("mn-play");
    const playIcon = document.getElementById("mn-play-icon");
    const pauseIcon = document.getElementById("mn-pause-icon");
    const eqWrap = document.getElementById("mn-music-eq");
    const noteIcon = document.getElementById("mn-music-note");

    const fmt = (s: number) => {
      if (!isFinite(s) || s < 0) return "0:00";
      return `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, "0")}`;
    };

    function syncTrackText() {
      if (trackTitle && cpSvgTitle) trackTitle.textContent = cpSvgTitle.textContent || "-";
      if (trackArtist && cpSvgArtist) trackArtist.textContent = cpSvgArtist.textContent || "-";
    }
    syncTrackText();

    if (audio) {
      audio.addEventListener("timeupdate", () => {
        if (!audio.duration) return;
        if (timeCur) timeCur.textContent = fmt(audio.currentTime);
        if (progFill) (progFill as HTMLElement).style.width = `${(audio.currentTime / audio.duration) * 100}%`;
      });
      audio.addEventListener("loadedmetadata", () => {
        if (timeDur) timeDur.textContent = fmt(audio.duration);
        syncTrackText();
      });
      const reflect = () => {
        const playing = !audio.paused;
        playIcon?.classList.toggle("hidden", playing);
        pauseIcon?.classList.toggle("hidden", !playing);
        if (playing) {
          eqWrap?.classList.add("is-playing");
          if (noteIcon) (noteIcon as HTMLElement).style.display = "none";
        } else {
          eqWrap?.classList.remove("is-playing");
          if (noteIcon) (noteIcon as HTMLElement).style.display = "";
        }
        syncTrackText();
      };
      audio.addEventListener("play", reflect);
      audio.addEventListener("pause", reflect);
      reflect();
    }

    playBtn?.addEventListener("click", () => {
      if (!audio) return;
      if (audio.paused) audio.play().catch(() => {});
      else audio.pause();
    });
    document.getElementById("mn-prev")?.addEventListener("click", () => {
      cpPrev?.dispatchEvent(new MouseEvent("click"));
      setTimeout(syncTrackText, 50);
    });
    document.getElementById("mn-next")?.addEventListener("click", () => {
      cpNext?.dispatchEvent(new MouseEvent("click"));
      setTimeout(syncTrackText, 50);
    });
    progTrack?.addEventListener("pointerdown", (e) => {
      if (!audio || !audio.duration) return;
      const r = (progTrack as HTMLElement).getBoundingClientRect();
      const pct = Math.min(1, Math.max(0, (e.clientX - r.left) / r.width));
      audio.currentTime = pct * audio.duration;
    });

    /* ── Intro (clip-path approach):
         1) Pill drops in as bare orange music circle (clip tight around btn,
            pill bg + shadow invisible)
         2) Single locked tween: pill bg + shadow fade in, clip-path opens left,
            pill translates back to 0 → music btn slides into right slot while
            pill forms around it
         3) Cross-dissolve label + theme + menu after pill fully formed
    ── */
    let played = false;
    function playIntro() {
      if (played) return;
      played = true;

      const themeBtnEl = document.getElementById("mn-theme-btn");
      const menuBtnEl = document.getElementById("mn-menu-btn");
      const musicBtnEl = document.getElementById("mn-music-btn");
      const labelArea = panelNav.children[0] as HTMLElement | undefined;
      const popEls = [themeBtnEl, menuBtnEl].filter(Boolean) as HTMLElement[];

      const PILL_W = 320;
      const RIGHT_PAD = 16; // panel-nav px-4
      const Y_PAD = 8;      // panel-nav py-2
      const BTN_W = 36;

      const musicLeftInPill = PILL_W - RIGHT_PAD - BTN_W;       // 268
      const musicCenterInPill = PILL_W - RIGHT_PAD - BTN_W / 2; // 286

      // Tight clip exactly around music btn — pill bg/border invisible during drop
      const tightClip =
        `inset(${Y_PAD}px ${RIGHT_PAD}px ${Y_PAD}px ${musicLeftInPill}px round ${BTN_W / 2}px)`;
      const expandedClip = `inset(0px 0px 0px 0px round 28px)`;

      // Translate pill left so music btn center sits at viewport center initially
      const dx = -(musicCenterInPill - PILL_W / 2); // -126

      const dropBg = "rgba(30, 30, 30, 0)";
      const finalBg = "rgba(30, 30, 30, 1)";
      const dropShadow = "0 0 0 0 rgba(0,0,0,0), 0 0 0 0 rgba(249,95,74,0)";
      const finalShadow =
        "0 10px 28px rgba(0,0,0,0.55), 0 0 0 1px rgba(249,95,74,0.45)";

      // Initial state: only music btn visible
      gsap.set(pill, {
        opacity: 0,
        y: 140,
        scale: 0.7,
        x: dx,
        clipPath: tightClip,
        backgroundColor: dropBg,
        boxShadow: dropShadow,
      });
      if (labelArea) gsap.set(labelArea, { opacity: 0 });
      gsap.set(popEls, { opacity: 0 });

      const tl = gsap.timeline();

      // Phase 1: drop in (just the music btn)
      tl.to(pill, {
        opacity: 1,
        y: -8,
        scale: 1.05,
        duration: 0.55,
        ease: "power2.out",
      })
        .to(pill, {
          y: 0,
          scale: 1,
          duration: 0.4,
          ease: "power3.out",
        })

        // Phase 2: single tween - pill forms (bg+shadow+clip) while music
        // slides into right slot. All locked to same ease/duration.
        .to(pill, {
          x: 0,
          clipPath: expandedClip,
          backgroundColor: finalBg,
          boxShadow: finalShadow,
          duration: 0.85,
          ease: "power2.inOut",
          onComplete: () => {
            gsap.set(pill, {
              clearProps: "clipPath,backgroundColor,boxShadow",
            });
          },
        })

        // Phase 3: cross-dissolve label + theme + menu
        .to(
          [labelArea, ...popEls].filter(Boolean),
          {
            opacity: 1,
            duration: 0.4,
            ease: "power2.out",
            stagger: 0.05,
          },
          ">0.05",
        );
    }

    const INTRO_DELAY = 1000;
    if (sessionStorage.getItem("preloaderShown")) {
      setTimeout(playIntro, INTRO_DELAY);
    } else {
      window.addEventListener(
        "preloader:done",
        () => setTimeout(playIntro, INTRO_DELAY),
        { once: true },
      );
      setTimeout(playIntro, 3500);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMobileNavbar, { once: true });
  } else {
    initMobileNavbar();
  }
</script>
