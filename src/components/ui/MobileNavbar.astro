---
// Mobile bottom navbar. Single pill morphs between 3 states:
//   nav   - section label + menu/music buttons
//   menu  - section list grid + close
//   music - track info + transport controls + progress + close
// Solid #1e1e1e fill. GSAP morph between states.

export interface Props {
  /** Static label for subpages (e.g. "Z0D1AK"). Falls back to live section in nav state. */
  pageTitle?: string;
}

const { pageTitle } = Astro.props;
const initialLabel = pageTitle || "Home";
const lockedLabel = !!pageTitle;

// Subsections mirror the desktop megamenu (Header.astro `dropdowns`).
// Sections listed here show a caret and open a submenu on tap.
interface SubItem { title: string; desc: string; href: string; }
const subsections: Record<string, SubItem[]> = {
  about: [
    { title: "ACM-VIT", desc: "Our chapter's mission & culture", href: "/#about-acmvit" },
    { title: "VIT University", desc: "One of India's top tech universities", href: "/#about-vit" },
    { title: "ACM Global", desc: "World's largest computing society", href: "/#about-acm" },
  ],
  domains: [
    { title: "Tech", desc: "App Dev, Web, FOSS, DevOps", href: "/domains/tech" },
    { title: "Competitive Coding", desc: "Codeforces, ICPC, C++", href: "/domains/cc" },
    { title: "Design", desc: "UI/UX, Motion Graphics, 3D", href: "/domains/design" },
    { title: "Research", desc: "AI/ML, Blockchain, Quantum", href: "/domains/research" },
    { title: "Management", desc: "Operations & coordination", href: "/domains/management" },
  ],
  events: [
    { title: "Code2Create", desc: "24-hour hackathon", href: "/#events" },
    { title: "Cryptic Hunt", desc: "Online cryptographic treasure hunt", href: "/#events" },
    { title: "inspiHer", desc: "Celebrating women in technology", href: "/#events" },
    { title: "Forktober", desc: "Open source contribution drive", href: "/#events" },
    { title: "The Neural Hack", desc: "Deep dive into AI & ML", href: "/#events" },
  ],
  projects: [
    { title: "ACMOne", desc: "Centralized chapter management platform", href: "/#projects" },
    { title: "ExamCooker", desc: "Exam prep hub for VIT students", href: "/#projects" },
    { title: "CLI RPG", desc: "Terminal-based role-playing game", href: "/#projects" },
    { title: "UniPool", desc: "Campus carpooling made easy", href: "/#projects" },
    { title: "Localhost", desc: "Local development toolkit", href: "/#projects" },
    { title: "OCS Website", desc: "Open community showcase site", href: "/#projects" },
  ],
  "acm-w": [
    { title: "Our Mission", desc: "Supporting women in computing", href: "/#acm-w" },
    { title: "Initiatives", desc: "Programs & activities", href: "/#acm-w-content" },
    { title: "Showcase", desc: "Highlights of our work", href: "/#acm-w-bento" },
  ],
  community: [
    { title: "Outreach", desc: "Beyond The Norm workshops for schools", href: "/community#community-outreach" },
    { title: "SDG Initiative", desc: "Digital learning for rural communities", href: "/community#community-sdg" },
    { title: "International Award", desc: "Outstanding School Service", href: "/community#community-award" },
    { title: "Code of Conduct", desc: "ACM ethical principles & values", href: "/community#community-conduct" },
    { title: "ACM-W", desc: "Inclusion & women in tech", href: "/community#acm-w" },
  ],
  team: [
    { title: "Faculty", desc: "Dr. Aswani Kumar Cherukuri", href: "/#team" },
    { title: "Board", desc: "Core leadership team", href: "/#team" },
    { title: "ACM-W Board", desc: "Women's chapter leadership", href: "/#team" },
  ],
  blogs: [
    { title: "All Blogs", desc: "Browse every article we've published", href: "/blogs" },
    { title: "Hashnode", desc: "Our latest technical deep-dives", href: "/blogs#all-blogs" },
    { title: "Medium", desc: "Earlier publications & tutorials", href: "/blogs#all-blogs" },
  ],
  more: [
    { title: "Code of Conduct", desc: "ACM ethical principles & values", href: "/code-of-conduct" },
    { title: "Merchandise", desc: "Official ACM-VIT merch & collectibles", href: "/merchandise" },
    { title: "GREP Newsletter", desc: "Our bi-annual technical newsletter", href: "/grep" },
    { title: "z0d1ak", desc: "ACM-VIT's competitive CTF team", href: "/z0d1ak" },
    { title: "Achievements", desc: "Awards, recognitions & milestones", href: "/achievements" },
    { title: "Cassette Builder", desc: "Design your own custom cassette", href: "/cassette-builder" },
    { title: "Calendar", desc: "Upcoming events & important dates", href: "/calendar" },
  ],
};

// Section labels used by the submenu header (title-case).
const sectionTitles: Record<string, string> = {
  about: "About", domains: "Domains", events: "Events", projects: "Projects",
  "acm-w": "ACM-W", community: "Community", team: "Team", blogs: "Blogs", more: "More",
};

const navItems = [
  { id: "about", label: "About", href: "/#about" },
  { id: "domains", label: "Domains", href: "/#domains" },
  { id: "events", label: "Events", href: "/#events" },
  { id: "projects", label: "Projects", href: "/#projects" },
  { id: "acm-w", label: "ACM-W", href: "/#acm-w" },
  { id: "community", label: "Community", href: "/community" },
  { id: "team", label: "Team", href: "/#team" },
  { id: "blogs", label: "Blogs", href: "/blogs" },
  { id: "partners", label: "Partners", href: "/#partners" },
  { id: "gallery", label: "Gallery", href: "/#gallery" },
  { id: "contact", label: "Contact", href: "/#contact" },
  { id: "more", label: "More", href: "/#more" },
].map((item) => ({ ...item, hasSub: !!subsections[item.id] }));
---

<div
  id="mn-root"
  class="mn-root pointer-events-none fixed left-1/2 z-[60] -translate-x-1/2"
  style="bottom: calc(16px + env(safe-area-inset-bottom, 0px));"
  data-locked-label={lockedLabel ? "true" : undefined}
>
  <div id="mn-pill" class="mn-pill pointer-events-auto overflow-hidden" data-state="nav">
    <!-- ── NAV state: label + buttons ── -->
    <div data-panel="nav" class="mn-panel mn-panel-nav flex items-center justify-between gap-2 px-4 py-2">
      <div class="flex min-w-0 items-center gap-2">
        <span
          id="mn-section-dot"
          class="mn-section-dot inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#F95F4A]"
        ></span>
        <span
          id="mn-label"
          class="mn-label min-w-0 truncate text-[11px] font-['PolySans_Trial'] uppercase tracking-[0.14em] text-[#FEFCD9]"
          >{initialLabel}</span
        >
      </div>
      <div class="flex flex-shrink-0 items-center gap-1.5">
        <button
          id="mn-blog-btn"
          aria-label="Article tools"
          class="mn-blog-btn mn-btn hidden h-9 w-9 flex-shrink-0 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
        </button>
        <button
          id="mn-merch-btn"
          aria-label="Browse collection"
          class="mn-merch-btn mn-btn hidden h-9 w-9 flex-shrink-0 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"></path>
          </svg>
        </button>
        <button
          id="mn-menu-btn"
          aria-label="Open menu"
          class="mn-btn flex h-9 w-9 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <circle cx="5" cy="5" r="1.6"></circle>
            <circle cx="12" cy="5" r="1.6"></circle>
            <circle cx="19" cy="5" r="1.6"></circle>
            <circle cx="5" cy="12" r="1.6"></circle>
            <circle cx="12" cy="12" r="1.6"></circle>
            <circle cx="19" cy="12" r="1.6"></circle>
            <circle cx="5" cy="19" r="1.6"></circle>
            <circle cx="12" cy="19" r="1.6"></circle>
            <circle cx="19" cy="19" r="1.6"></circle>
          </svg>
        </button>
        <button
          id="mn-theme-btn"
          aria-label="Toggle theme"
          class="mn-btn flex h-9 w-9 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg id="mn-theme-moon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
          </svg>
          <svg id="mn-theme-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
        </button>
        <button
          id="mn-music-btn"
          aria-label="Open music player"
          class="mn-btn-primary relative flex h-9 w-9 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <span
            id="mn-music-eq"
            class="mn-music-eq hidden items-end gap-[2px]"
            aria-hidden="true"
          >
            <span class="mn-eq-bar h-[5px]"></span>
            <span class="mn-eq-bar h-[10px]"></span>
            <span class="mn-eq-bar h-[14px]"></span>
            <span class="mn-eq-bar h-[7px]"></span>
          </span>
          <svg
            id="mn-music-note"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
        </button>
      </div>
    </div>

    <!-- ── MENU state: section grid ── -->
    <div data-panel="menu" class="mn-panel mn-panel-menu hidden flex-col gap-2 px-3 py-3">
      <div class="flex items-center justify-between px-2 pb-1">
        <span class="text-[10px] font-['PolySans_Trial'] uppercase tracking-[0.22em] text-[#FEFCD9]/55"
          >Navigate</span
        >
        <button
          data-mn-close
          aria-label="Close"
          class="mn-close flex h-7 w-7 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
      <ul class="grid grid-cols-2 gap-1.5">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              data-mn-link={item.id}
              data-mn-sub={item.hasSub ? "true" : undefined}
              class="mn-link flex items-center gap-2.5 rounded-2xl px-3 py-2.5 text-[#FEFCD9] active:bg-white/10"
            >
              <span class="mn-link-dot h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#F95F4A]/55"></span>
              <span class="min-w-0 flex-1 truncate text-[11px] font-['PolySans_Trial'] uppercase tracking-[0.1em]">
                {item.label}
              </span>
              {item.hasSub && (
                <span
                  data-mn-caret={item.id}
                  class="mn-link-caret-hit -my-2 -mr-1 flex flex-shrink-0 items-center px-2 py-2"
                  aria-hidden="true"
                >
                  <svg
                    class="mn-link-caret h-3 w-3 text-[#FEFCD9]/40"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- ── SUBMENU state: FaceTime-style section panel (built from data) ── -->
    <div data-panel="submenu" class="mn-panel mn-panel-sub hidden flex-col gap-3.5 px-4 py-3.5">
      <!-- Header: avatar glyph + title/subtitle + info (go to section) -->
      <div class="flex items-center gap-3">
        <span id="mn-sub-avatar" class="mn-sub-avatar flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full">
          <span id="mn-sub-glyph" class="mn-sub-glyph">-</span>
        </span>
        <div class="min-w-0 flex-1">
          <p id="mn-sub-title" class="mn-sub-title truncate">-</p>
          <p id="mn-sub-subtitle" class="mn-sub-subtitle truncate">-</p>
        </div>
        <button
          id="mn-sub-goto"
          aria-label="Go to section"
          class="mn-sub-info flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 11v5" stroke-width="2" stroke-linecap="round" />
            <circle cx="12" cy="7.7" r="1.15" fill="currentColor" stroke="none" />
          </svg>
        </button>
      </div>
      <!-- Round subsection buttons + red "hang up" back button (built in JS) -->
      <div id="mn-sub-list" class="mn-sub-grid flex max-h-[42vh] flex-wrap justify-center gap-x-3 gap-y-3 overflow-y-auto"></div>
    </div>

    <!-- Subsection data for client submenu build -->
    <script type="application/json" id="mn-sub-data" set:html={JSON.stringify({ subsections, sectionTitles })}></script>

    <!-- ── MUSIC state: compact player ── -->
    <div data-panel="music" class="mn-panel mn-panel-music hidden flex-col gap-3 px-4 py-3">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-['PolySans_Trial'] uppercase tracking-[0.22em] text-[#FEFCD9]/55">Now Playing</p>
          <p id="mn-track-title" class="truncate text-[13px] font-['PolySans_Trial'] text-[#FEFCD9]">-</p>
          <p id="mn-track-artist" class="truncate text-[10px] font-['PolySans_Mono'] uppercase tracking-[0.12em] text-[#FEFCD9]/55">-</p>
        </div>
        <button
          data-mn-close
          aria-label="Close"
          class="mn-close mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Progress -->
      <div class="flex items-center gap-2">
        <span id="mn-time-cur" class="text-[10px] font-['PolySans_Mono'] text-[#FEFCD9]/50">0:00</span>
        <div id="mn-prog-track" class="relative h-1 flex-1 cursor-pointer rounded-full bg-[#FEFCD9]/15">
          <div id="mn-prog-fill" class="h-full rounded-full bg-[#F95F4A]" style="width:0%"></div>
        </div>
        <span id="mn-time-dur" class="text-[10px] font-['PolySans_Mono'] text-[#FEFCD9]/50">0:00</span>
      </div>

      <!-- Transport -->
      <div class="flex items-center justify-center gap-6">
        <button id="mn-prev" aria-label="Previous track" class="mn-trans flex h-9 w-9 items-center justify-center text-[#FEFCD9] active:scale-90 transition-transform">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 18V6l-9 6 9 6zM6 6h2v12H6z"/>
          </svg>
        </button>
        <button id="mn-play" aria-label="Play" class="mn-play flex h-12 w-12 items-center justify-center rounded-full bg-[#F95F4A] text-[#FEFCD9] active:scale-90 transition-transform">
          <svg id="mn-play-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg id="mn-pause-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="hidden">
            <rect x="6" y="5" width="4" height="14" rx="1"/>
            <rect x="14" y="5" width="4" height="14" rx="1"/>
          </svg>
        </button>
        <button id="mn-next" aria-label="Next track" class="mn-trans flex h-9 w-9 items-center justify-center text-[#FEFCD9] active:scale-90 transition-transform">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 6v12l9-6-9-6zm10 0h2v12h-2z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ── BLOG state: article tools (proxies to hidden BlogDock) ── -->
    <div data-panel="blog" class="mn-panel mn-panel-blog hidden flex-col gap-3 px-4 py-3">
      <div class="flex items-center justify-between px-1">
        <span class="text-[10px] font-['PolySans_Trial'] uppercase tracking-[0.22em] text-[#FEFCD9]/55">Article</span>
        <button
          data-mn-close
          aria-label="Close"
          class="mn-close flex h-7 w-7 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="flex items-center justify-around gap-2 pb-1">
        <button id="mn-blog-listen" class="mn-blog-ctl flex flex-col items-center gap-1.5">
          <span class="mn-blog-icon flex h-12 w-12 items-center justify-center rounded-full">
            <svg id="mn-blog-listen-play" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
            </svg>
            <svg id="mn-blog-listen-stop" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <rect x="6" y="4" width="4" height="16" rx="1" />
              <rect x="14" y="4" width="4" height="16" rx="1" />
            </svg>
          </span>
          <span id="mn-blog-listen-label" class="text-[9px] font-['PolySans_Trial'] uppercase tracking-[0.12em] text-[#FEFCD9]/60">Listen</span>
        </button>
        <button id="mn-blog-notes" class="mn-blog-ctl flex flex-col items-center gap-1.5">
          <span class="mn-blog-icon flex h-12 w-12 items-center justify-center rounded-full">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
            </svg>
          </span>
          <span class="text-[9px] font-['PolySans_Trial'] uppercase tracking-[0.12em] text-[#FEFCD9]/60">Notes</span>
        </button>
        <button id="mn-blog-share" class="mn-blog-ctl flex flex-col items-center gap-1.5">
          <span class="mn-blog-icon flex h-12 w-12 items-center justify-center rounded-full">
            <svg id="mn-blog-share-default" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" />
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
            </svg>
            <svg id="mn-blog-share-copied" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span id="mn-blog-share-label" class="text-[9px] font-['PolySans_Trial'] uppercase tracking-[0.12em] text-[#FEFCD9]/60">Share</span>
        </button>
      </div>
    </div>

    <!-- ── NOTES state: in-pill scratchpad (synced to hidden BlogDock notes) ── -->
    <div data-panel="notes" class="mn-panel mn-panel-notes hidden flex-col gap-2 px-3 py-3">
      <div class="flex items-center justify-between px-1">
        <button
          data-mn-notes-back
          aria-label="Back to article tools"
          class="mn-close flex h-7 w-7 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <span class="text-[10px] font-['PolySans_Trial'] uppercase tracking-[0.22em] text-[#FEFCD9]/55">Scratchpad</span>
        <button
          data-mn-close
          aria-label="Close"
          class="mn-close flex h-7 w-7 items-center justify-center rounded-full transition-transform active:scale-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
      <textarea
        id="mn-notes-input"
        placeholder="Write a quick note..."
