---
import Cassette from "./Cassette.astro";
import FillButton from "./FillButton.astro";
import { getAssetUrl } from "../../utils/cdn";

/**
 * ProjectCard - a single full-height project showcase card.
 * Cassette on the left, description + CTA on the right, on a dashed
 * cassette-deck grid. CTA uses the shared FillButton ("Learn More") and
 * links to the project's detail page. Theme/light-mode compatible.
 */
export interface Props {
  project: {
    slug?: string;
    cassette: { src: string; alt: string };
    textContent: { blocks: string[] };
    buttons: {
      primary: { backgroundColor: string };
      icons?: Array<{
        type: string;
        iconColor: string;
        url?: string;
      }>;
    };
    colors: {
      textColor: string;
      hoverShadow: string;
    };
  };
}

const { project } = Astro.props;
const accent = project.buttons.primary.backgroundColor;
const learnMoreHref = project.slug ? `/projects/${project.slug}` : "#";
const icons = project.buttons.icons ?? [];
---

<section
  class="project-card hero p-[clamp(24px,4vw,48px)] text-white h-[calc(100vh-112px)] w-full"
  style={{
    "--textColor": project.colors.textColor,
    "--hoverShadow": project.colors.hoverShadow,
    "--proj-color": accent,
    "--proj-color-secondary": "#FEFCD9",
  }}
>
  <div class="parent grid grid-cols-9 grid-rows-5 gap-0 h-full w-full">
    <div class="div1 col-start-1 col-end-6 row-start-1 row-end-6 flex items-center justify-center">
      <Cassette
        overlaySrc={getAssetUrl(project.cassette.src)}
        alt={project.cassette.alt}
        color={accent}
      />
    </div>

    <div class="div2 col-start-6 col-end-10 row-start-1 row-end-6 border-l-2 border-r-2 border-dashed border-[#999999]/50">
    </div>
    <div
      class="div3 col-start-1 col-end-10 row-start-3 row-end-4 border-t-2 border-b-2 border-dashed border-[#999999]/50"
      style="mask-image: linear-gradient(to right, transparent 45%, black 55%); -webkit-mask-image: linear-gradient(to right, transparent 45%, black 55%);"
    >
    </div>

    <div class="div4 col-start-6 col-end-10 row-start-1 row-end-3">
      <div class="content-section text-(--textColor) flex flex-col gap-5 justify-center px-5 h-full">
        <div class="content-block border-none p-2.5 relative my-1">
          <p class="description font-['PolySans_Trial'] text-lg lg:text-xl leading-[1.5] m-0 text-(--textColor) font-light wrap-break-word">
            {project.textContent.blocks[0]}
          </p>
        </div>
      </div>
    </div>

    <div class="div5 col-start-6 col-end-10 row-start-3 row-end-4 flex items-center justify-center relative z-20">
      <div class="action-buttons flex gap-6 items-center justify-center m-0">
        <FillButton href={learnMoreHref} label="Learn More" />

        {
          icons.map((icon) => (
            <a
              href={icon.url || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="icon-btn w-11 h-11 rounded-full flex items-center justify-center p-0 border border-[var(--proj-color)] bg-transparent cursor-pointer transition-all duration-300 hover:-translate-y-[3px] hover:bg-[var(--proj-color)] hover:shadow-[0_8px_20px_var(--hoverShadow)] group"
              aria-label={icon.type}
            >
              <img
                src={getAssetUrl(`/icons/${icon.type}-icon.webp`)}
                alt={icon.type}
                width="22"
                class="transition-all duration-300"
                style={`filter: brightness(0) saturate(100%) invert(${icon.iconColor === "#FEFCD9" ? "96%" : "0%"});`}
                loading="lazy"
                decoding="async"
              />
            </a>
          ))
        }
      </div>
    </div>

    <div class="div6 col-start-6 col-end-10 row-start-4 row-end-6">
      <div class="content-section text-(--textColor) flex flex-col gap-5 justify-center px-5 h-full">
        <div class="content-block border-none p-2.5 relative my-1">
          <p class="description font-['PolySans_Trial'] text-lg lg:text-xl leading-[1.5] m-0 text-(--textColor) font-light wrap-break-word">
            {project.textContent.blocks[1]}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 769px) and (max-width: 1099px) {
    .project-card .parent {
      grid-template-columns: repeat(10, minmax(0, 1fr));
    }

    .project-card .div1 {
      grid-column: 1 / 5;
      justify-content: flex-end;
    }

    .project-card .div1 > div {
      transform: scale(0.7);
      transform-origin: center right;
    }

    .project-card .div2,
    .project-card .div4,
    .project-card .div5,
    .project-card .div6 {
      grid-column: 5 / 11;
    }

    .project-card .div3 {
      grid-column: 1 / 11;
      mask-image: linear-gradient(to right, transparent 39.5%, black 40%) !important;
      -webkit-mask-image: linear-gradient(to right, transparent 39.5%, black 40%) !important;
    }

    .project-card .content-section {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .project-card .content-block {
      padding: 0.225rem;
    }

    .project-card .description {
      font-size: 0.95rem;
      line-height: 1.4;
    }

    .project-card .action-buttons {
      gap: 0.7rem;
    }
  }

  @media (max-height: 760px) {
    .project-card .parent {
      grid-template-rows:
        minmax(0, 1.05fr)
        minmax(0, 0.9fr)
        minmax(64px, 0.55fr)
        minmax(0, 1.3fr)
        minmax(0, 1.2fr);
    }

    .project-card .content-section {
      gap: 0.75rem;
    }

    .project-card .description {
      font-size: 1rem;
      line-height: 1.35;
    }
  }

  @media (max-height: 560px) {
    .project-card .hero {
      height: auto;
      min-height: 520px;
    }

    .project-card .parent {
      grid-template-rows:
        minmax(0, 1fr)
        minmax(0, 0.8fr)
        minmax(72px, 0.8fr)
        minmax(0, 1.6fr)
        minmax(0, 1.4fr);
    }

    .project-card .description {
      font-size: 0.95rem;
      line-height: 1.3;
    }

    .project-card .action-buttons {
      gap: 1.25rem;
    }
  }
</style>
