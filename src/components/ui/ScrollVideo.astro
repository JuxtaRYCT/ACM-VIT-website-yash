---
import { getAssetUrl } from "../../utils/cdn";

interface Props {
    webmSrc?: string;
    lightWebmSrc?: string;
    startTime?: number;
    endTime?: number;
}

const {
    webmSrc = "/videos/dark_bg.webm",
    lightWebmSrc = "/videos/light_bg.webm",
    startTime = 0,
    endTime = undefined,
} = Astro.props;

const normalizedWebmSrc = webmSrc.startsWith("/") ? webmSrc : `/${webmSrc}`;
const normalizedLightWebmSrc = lightWebmSrc.startsWith("/") ? lightWebmSrc : `/${lightWebmSrc}`;
---

<div class="scroll-video-container" data-scroll-video-container>
    <video
        class="scroll-video scroll-video-dark"
        data-scroll-video
        data-scroll-video-dark
        data-start-time={startTime}
        data-end-time={endTime ?? ""}
        muted
        playsinline
        preload="auto"
    >
        <source src={getAssetUrl(normalizedWebmSrc)} type="video/webm" />
    </video>

    <video
        class="scroll-video scroll-video-light"
        data-scroll-video-light
        data-start-time={startTime}
        data-end-time={endTime ?? ""}
        muted
        playsinline
        preload="auto"
    >
        <source src={getAssetUrl(normalizedLightWebmSrc)} type="video/webm" />
    </video>

    <div class="scroll-video-overlay" data-scroll-video-overlay></div>

    <div class="scroll-video-content" data-scroll-video-content>
        <slot />
    </div>
</div>

<style>
    .scroll-video-container {
        position: relative;
        width: 100%;
    }

    .scroll-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        z-index: -1;
        pointer-events: none;
        opacity: 0;
        transform: translateZ(0);
        backface-visibility: hidden;
        will-change: opacity, transform;
        transition: opacity 0.6s ease-out;
    }

    .scroll-video.visible {
        opacity: 1;
    }

    /* Light mode: swap visibility without killing decoder */
    :global(html[data-theme="light"]) .scroll-video-dark {
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .scroll-video-light {
        visibility: hidden;
        pointer-events: none;
    }

    :global(html[data-theme="light"]) .scroll-video-light {
        visibility: visible;
    }

    .scroll-video-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: black;
        opacity: 0;
        z-index: -1;
        pointer-events: none;
        transition: opacity 0.6s ease-out;
    }

    .scroll-video-overlay.visible {
        opacity: 0.6;
    }

    .scroll-video-content {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function createSmoothScrubber(video: HTMLVideoElement, container: HTMLElement, overlay: HTMLElement | null) {
        if (!video || video.dataset.scrollInit === "true") return;
        video.dataset.scrollInit = "true";

        const startTime = parseFloat(video.dataset.startTime || "0");
        // Forward we let the video PLAY (native frame-accurate decode = smoothest
        // possible). Backward we can't play, so we ease currentTime in small steps
        // (videos are all-intra, so backward seeks are cheap and stay smooth).
        const snapStep = 0.02;

        const setupScrollTrigger = () => {
            const videoDuration = video.duration;
            if (!videoDuration || isNaN(videoDuration) || videoDuration === Infinity) return;

            video.removeEventListener("loadedmetadata", setupScrollTrigger);
            video.removeEventListener("durationchange", setupScrollTrigger);
            video.removeEventListener("canplay", setupScrollTrigger);
            video.removeEventListener("canplaythrough", setupScrollTrigger);
            video.removeEventListener("loadeddata", setupScrollTrigger);

            const endTime = video.dataset.endTime
                ? parseFloat(video.dataset.endTime)
                : videoDuration;
            const playDuration = endTime - startTime;

            video.pause();
            video.currentTime = startTime;

            let targetTime = startTime;
            let renderedTime = startTime; // our own smooth cursor, NOT video.currentTime
            let rafId = 0;
            let isPlaying = false;
            let lastFrameAt = 0;
            let seekBusy = false; // a seek is in flight - don't issue another

            const clamp = (t: number) => Math.max(startTime, Math.min(endTime, t));

            // Backward smoothness: only request the next seek once the previous one
            // has actually landed. Setting currentTime again mid-seek makes the
            // browser cancel/coalesce seeks and drop frames -> the jitter.
            const onSeeked = () => {
                seekBusy = false;
            };
            video.addEventListener("seeked", onSeeked);

            const seekTo = (t: number) => {
                const clamped = clamp(t);
                if (seekBusy) return;
                if (Math.abs(video.currentTime - clamped) < 1e-3) return;
                seekBusy = true;
                video.currentTime = clamped;
            };

            const tick = (now: number) => {
                rafId = 0;
                const delta = lastFrameAt ? Math.min((now - lastFrameAt) / 1000, 0.05) : 1 / 60;
                lastFrameAt = now;

                // While playing forward, the decoder owns the position - track it.
                if (isPlaying) renderedTime = video.currentTime;

                const diff = targetTime - renderedTime;
                const absDiff = Math.abs(diff);

                // Settled - stop and pause.
                if (absDiff <= snapStep) {
                    if (isPlaying) {
                        video.pause();
                        isPlaying = false;
                    }
                    video.playbackRate = 1;
                    renderedTime = targetTime;
                    lastFrameAt = 0;
                    return;
                }

                if (diff > 0) {
                    // FORWARD: play natively, nudge rate to track the scroll target.
                    const rate = Math.min(Math.max(absDiff * 3, 0.5), 4);
                    video.playbackRate = rate;
                    if (!isPlaying) {
                        seekBusy = false;
                        video.play().catch(() => {});
                        isPlaying = true;
                    }
                } else {
                    // BACKWARD: can't play in reverse. Ease our own cursor and seek
                    // to it, one in-flight seek at a time.
                    if (isPlaying) {
                        video.pause();
                        isPlaying = false;
                    }
                    const ease = 1 - Math.exp(-delta / 0.12);
                    renderedTime = clamp(renderedTime + diff * ease);
                    seekTo(renderedTime);
                }

                rafId = requestAnimationFrame(tick);
            };

            const schedule = () => {
                if (!rafId) rafId = requestAnimationFrame(tick);
            };

            ScrollTrigger.create({
                trigger: container,
                start: "top top",
                end: "bottom bottom",
                scrub: true,
                invalidateOnRefresh: true,
                onUpdate: (self) => {
                    targetTime = clamp(startTime + self.progress * playDuration);
                    schedule();
                },
                onRefresh: (self) => {
                    targetTime = clamp(startTime + self.progress * playDuration);
                    if (isPlaying) {
                        video.pause();
                        isPlaying = false;
                    }
                    renderedTime = targetTime;
                    seekBusy = false;
                    video.currentTime = targetTime;
                },
            });

            ScrollTrigger.create({
                trigger: container,
                start: "top 90%",
                end: "bottom 60%",
                onEnter: () => {
                    video.classList.add("visible");
                    overlay?.classList.add("visible");
                    document.body.classList.add("scroll-video-active");
                },
                onLeave: () => {
                    video.classList.remove("visible");
                    overlay?.classList.remove("visible");
                    document.body.classList.remove("scroll-video-active");
                    video.pause();
                    isPlaying = false;
                },
                onEnterBack: () => {
                    video.classList.add("visible");
                    overlay?.classList.add("visible");
                    document.body.classList.add("scroll-video-active");
                },
                onLeaveBack: () => {
                    video.classList.remove("visible");
                    overlay?.classList.remove("visible");
                    document.body.classList.remove("scroll-video-active");
                    video.pause();
                    isPlaying = false;
                },
            });

            window.requestAnimationFrame(() => ScrollTrigger.refresh());
        };

        video.addEventListener("loadedmetadata", setupScrollTrigger);
        video.addEventListener("durationchange", setupScrollTrigger);
        video.addEventListener("canplay", setupScrollTrigger);
        video.addEventListener("canplaythrough", setupScrollTrigger);
        video.addEventListener("loadeddata", setupScrollTrigger);

        if (video.readyState >= 1) setupScrollTrigger();

        video.pause();
        video.currentTime = startTime;
    }

    function initScrollVideo() {
        const container = document.querySelector(
            "[data-scroll-video-container]",
        ) as HTMLElement;
        const overlay = document.querySelector(
            "[data-scroll-video-overlay]",
        ) as HTMLElement;

        if (!container) return;

        // Both videos are same-length, all-intra _bg.webm, so they share the same
        // eased-seek scrubber for identical, butter-smooth scroll in both directions.
        const darkVideo = document.querySelector(
            "[data-scroll-video-dark]",
        ) as HTMLVideoElement;
        if (darkVideo) createSmoothScrubber(darkVideo, container, overlay);

        const lightVideo = document.querySelector(
            "[data-scroll-video-light]",
        ) as HTMLVideoElement;
        if (lightVideo) createSmoothScrubber(lightVideo, container, overlay);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initScrollVideo);
    } else {
        initScrollVideo();
    }
</script>
