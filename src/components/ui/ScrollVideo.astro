---
import fs from "node:fs";
import path from "node:path";
import { getAssetUrl } from "../../utils/cdn";

interface Props {
    webmSrc?: string;
    lightWebmSrc?: string;
    startTime?: number;
    endTime?: number;
}

const {
    webmSrc = "/videos/dark_bg.webm",
    lightWebmSrc = "/videos/light_bg.webm",
} = Astro.props;

const norm = (s: string) => (s.startsWith("/") ? s : `/${s}`);
const normalizedWebmSrc = norm(webmSrc);
const normalizedLightWebmSrc = norm(lightWebmSrc);

// Count extracted frames at build time (used for the scroll-up canvas player).
const framesRoot = path.join(process.cwd(), "public/frames");
const countFrames = (dir: string) => {
    try {
        return fs
            .readdirSync(path.join(framesRoot, dir))
            .filter((f) => f.endsWith(".jpg")).length;
    } catch {
        return 0;
    }
};
const darkCount = countFrames("dark");
const lightCount = countFrames("light");
---

<div
    class="scroll-video-container"
    data-scroll-video-container
    data-dark-count={darkCount}
    data-light-count={lightCount}
>
    <!-- Scroll DOWN: native video playback -->
    <video
        class="scroll-media scroll-media-dark"
        data-scroll-video
        data-fwd-video
        data-theme-pair="dark"
        muted
        playsinline
        preload="auto"
    >
        <source src={getAssetUrl(normalizedWebmSrc)} type="video/webm" />
    </video>
    <video
        class="scroll-media scroll-media-light"
        data-fwd-video
        data-theme-pair="light"
        muted
        playsinline
        preload="auto"
    >
        <source src={getAssetUrl(normalizedLightWebmSrc)} type="video/webm" />
    </video>

    <!-- Scroll UP: smoothed canvas frame player -->
    <canvas class="scroll-media dir-hidden" data-scroll-frames></canvas>

    <div class="scroll-video-overlay" data-scroll-video-overlay></div>

    <div class="scroll-video-content" data-scroll-video-content>
        <slot />
    </div>
</div>

<style>
    .scroll-video-container {
        position: relative;
        width: 100%;
    }

    .scroll-media {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        z-index: -1;
        pointer-events: none;
        opacity: 0;
        transform: translateZ(0);
        backface-visibility: hidden;
        will-change: opacity;
        transition: opacity 0.6s ease-out;
    }

    .scroll-media.visible {
        opacity: 1;
    }

    /* Direction swap: hide the inactive medium instantly (no cross-fade) */
    .scroll-media.dir-hidden {
        opacity: 0 !important;
        transition: none !important;
    }

    /* Theme swap for the videos (canvas draws the correct theme itself) */
    :global(html[data-theme="light"]) .scroll-media-dark {
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .scroll-media-light {
        visibility: hidden;
        pointer-events: none;
    }

    :global(html[data-theme="light"]) .scroll-media-light {
        visibility: visible;
    }

    .scroll-video-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: black;
        opacity: 0;
        z-index: -1;
        pointer-events: none;
        transition: opacity 0.6s ease-out;
    }

    .scroll-video-overlay.visible {
        opacity: 0.6;
    }

    .scroll-video-content {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { getAssetUrl } from "../../utils/cdn";

    gsap.registerPlugin(ScrollTrigger);

    type Theme = "dark" | "light";

    function initScrollMedia() {
        const container = document.querySelector(
            "[data-scroll-video-container]",
        ) as HTMLElement | null;
        const canvas = document.querySelector(
            "[data-scroll-frames]",
        ) as HTMLCanvasElement | null;
        const darkVideo = document.querySelector(
            '[data-fwd-video][data-theme-pair="dark"]',
        ) as HTMLVideoElement | null;
        const lightVideo = document.querySelector(
            '[data-fwd-video][data-theme-pair="light"]',
        ) as HTMLVideoElement | null;
        const overlay = document.querySelector(
            "[data-scroll-video-overlay]",
        ) as HTMLElement | null;

        if (!container || !canvas || !darkVideo || !lightVideo) return;
        if (canvas.dataset.scrollInit === "true") return;
        canvas.dataset.scrollInit = "true";

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const counts: Record<Theme, number> = {
            dark: parseInt(container.dataset.darkCount || "0", 10),
            light: parseInt(container.dataset.lightCount || "0", 10),
        };

        const frames: Record<Theme, HTMLImageElement[]> = { dark: [], light: [] };
        const requested: Record<Theme, boolean> = { dark: false, light: false };

        const frameUrl = (theme: Theme, i: number) =>
            getAssetUrl(`/frames/${theme}/${String(i + 1).padStart(4, "0")}.jpg`);

        const currentTheme = (): Theme =>
            document.documentElement.dataset.theme === "light" ? "light" : "dark";

        let theme: Theme = currentTheme();
        const activeVideo = (): HTMLVideoElement =>
            theme === "dark" ? darkVideo : lightVideo;

        // ---- shared scroll state ------------------------------------------
        let dir = 1; // 1 = down (video), -1 = up (canvas)
        let targetProgress = 0; // 0..1 from scroll
        let renderedProgress = 0; // 0..1 canonical cursor
        let prevProgress = 0;
        let rafId = 0;
        let lastFrameAt = 0;
        let isPlaying = false;

        const snapTime = 0.02; // seconds, forward settle threshold
        const smoothing = 0.09; // canvas ease time constant (s)
        const eps = 1e-4;
        const dirEps = 0.0008; // scroll-delta noise floor for direction flips

        // ---- frame loading (for scroll-up canvas) -------------------------
        const loadTheme = (t: Theme) => {
            if (requested[t]) return;
            requested[t] = true;
            const total = counts[t];
            for (let i = 0; i < total; i++) {
                const img = new Image();
                img.decoding = "async";
                img.src = frameUrl(t, i);
                img.onload = () => {
                    if (dir < 0 && t === theme) drawAt(renderedProgress);
                };
                frames[t][i] = img;
            }
        };

        // ---- canvas drawing -----------------------------------------------
        const sizeCanvas = () => {
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.round(window.innerWidth * dpr);
            canvas.height = Math.round(window.innerHeight * dpr);
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        const pickImage = (t: Theme, idx: number): HTMLImageElement | null => {
            const arr = frames[t];
            const ready = (img?: HTMLImageElement) =>
                !!img && img.complete && img.naturalWidth > 0;
            if (ready(arr[idx])) return arr[idx];
            for (let d = 1; d < arr.length; d++) {
                if (ready(arr[idx - d])) return arr[idx - d];
                if (ready(arr[idx + d])) return arr[idx + d];
            }
            return null;
        };

        const drawCover = (img: HTMLImageElement, alpha: number) => {
            const cw = window.innerWidth;
            const ch = window.innerHeight;
            const iw = img.naturalWidth;
            const ih = img.naturalHeight;
            const scale = Math.max(cw / iw, ch / ih);
            const dw = iw * scale;
            const dh = ih * scale;
            ctx.globalAlpha = alpha;
            ctx.drawImage(img, (cw - dw) / 2, (ch - dh) / 2, dw, dh);
        };

        // Sub-frame crossfade: base frame opaque, next frame blended by fraction.
        const drawAt = (p: number) => {
            const n = counts[theme];
            if (n <= 0) return;
            const f = Math.max(0, Math.min(n - 1, p * (n - 1)));
            const i0 = Math.floor(f);
            const i1 = Math.min(n - 1, i0 + 1);
            const frac = f - i0;
            const imgA = pickImage(theme, i0);
            const imgB = i1 !== i0 ? pickImage(theme, i1) : imgA;
            if (!imgA && !imgB) return;
            ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            if (imgA) drawCover(imgA, 1);
            if (imgB && imgB !== imgA && frac > 0.001) drawCover(imgB, frac);
            ctx.globalAlpha = 1;
        };

        // ---- direction visibility -----------------------------------------
        const showVideo = () => {
            darkVideo.classList.remove("dir-hidden");
            lightVideo.classList.remove("dir-hidden");
            canvas.classList.add("dir-hidden");
        };
        const showCanvas = () => {
            darkVideo.classList.add("dir-hidden");
            lightVideo.classList.add("dir-hidden");
            canvas.classList.remove("dir-hidden");
        };

        // ---- main loop -----------------------------------------------------
        const tick = (now: number) => {
            rafId = 0;
            const delta = lastFrameAt
                ? Math.min((now - lastFrameAt) / 1000, 0.05)
                : 1 / 60;
            lastFrameAt = now;

            if (dir > 0) {
                // SCROLL DOWN -> play the real video forward (native smooth).
                const v = activeVideo();
                const dur = v.duration;
                if (!dur || isNaN(dur) || dur === Infinity) {
                    rafId = requestAnimationFrame(tick);
                    return;
                }
                const cur = v.currentTime;
                renderedProgress = cur / dur;
                const diff = targetProgress * dur - cur;

                if (Math.abs(diff) <= snapTime) {
                    if (isPlaying) {
                        v.pause();
                        isPlaying = false;
                    }
                    v.playbackRate = 1;
                    lastFrameAt = 0;
                    return;
                }
                if (diff > 0) {
                    v.playbackRate = Math.min(Math.max(diff * 3, 0.5), 4);
                    if (!isPlaying) {
                        v.play().catch(() => {});
                        isPlaying = true;
                    }
                } else if (isPlaying) {
                    // brief overshoot before a direction flip - just hold
                    v.pause();
                    isPlaying = false;
                }
                rafId = requestAnimationFrame(tick);
            } else {
                // SCROLL UP -> eased canvas frame player (smooth backward).
                const diff = targetProgress - renderedProgress;
                if (Math.abs(diff) <= eps) {
                    renderedProgress = targetProgress;
                    drawAt(renderedProgress);
                    lastFrameAt = 0;
                    return;
                }
                const ease = 1 - Math.exp(-delta / smoothing);
                renderedProgress += diff * ease;
                drawAt(renderedProgress);
                rafId = requestAnimationFrame(tick);
            }
        };

        const schedule = () => {
            if (!rafId) {
                lastFrameAt = 0;
                rafId = requestAnimationFrame(tick);
            }
        };

        const setDir = (nd: number) => {
            if (nd === dir) return;
            dir = nd;
            const v = activeVideo();
            if (dir > 0) {
                // -> video: seat it on the current frame, then play.
                if (v.duration) {
                    try {
                        v.currentTime = renderedProgress * v.duration;
                    } catch {}
                }
                showVideo();
            } else {
                // -> canvas: sync cursor from the video, then ease/draw.
                darkVideo.pause();
                lightVideo.pause();
                isPlaying = false;
                if (v.duration) renderedProgress = v.currentTime / v.duration;
                showCanvas();
                drawAt(renderedProgress);
            }
            lastFrameAt = 0;
            schedule();
        };

        // ---- wiring --------------------------------------------------------
        sizeCanvas();
        loadTheme(theme);
        const otherTheme: Theme = theme === "dark" ? "light" : "dark";
        const idle = (cb: () => void) =>
            "requestIdleCallback" in window
                ? (window as any).requestIdleCallback(cb)
                : setTimeout(cb, 1500);
        idle(() => loadTheme(otherTheme));

        let resizeRaf = 0;
        window.addEventListener("resize", () => {
            if (resizeRaf) return;
            resizeRaf = requestAnimationFrame(() => {
                resizeRaf = 0;
                sizeCanvas();
                if (dir < 0) drawAt(renderedProgress);
            });
        });

        const themeObserver = new MutationObserver(() => {
            const next = currentTheme();
            if (next === theme) return;
            const old = activeVideo();
            theme = next;
            loadTheme(theme);
            const v = activeVideo();
            if (dir > 0) {
                old.pause();
                isPlaying = false;
                if (v.duration) {
                    try {
                        v.currentTime = renderedProgress * v.duration;
                    } catch {}
                }
                schedule();
            } else {
                drawAt(renderedProgress);
            }
        });
        themeObserver.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["data-theme"],
        });

        ScrollTrigger.create({
            trigger: container,
            start: "top top",
            end: "bottom bottom",
            scrub: true,
            invalidateOnRefresh: true,
            onUpdate: (self) => {
                const np = self.progress;
                const d = np - prevProgress;
                prevProgress = np;
                targetProgress = np;
                if (d > dirEps) setDir(1);
                else if (d < -dirEps) setDir(-1);
                schedule();
            },
            onRefresh: (self) => {
                targetProgress = self.progress;
                renderedProgress = self.progress;
                prevProgress = self.progress;
                sizeCanvas();
                const v = activeVideo();
                if (dir > 0) {
                    if (v.duration) {
                        try {
                            v.currentTime = renderedProgress * v.duration;
                        } catch {}
                    }
                } else {
                    drawAt(renderedProgress);
                }
            },
        });

        ScrollTrigger.create({
            trigger: container,
            start: "top 90%",
            end: "bottom 60%",
            onEnter: () => show(),
            onLeave: () => hide(),
            onEnterBack: () => show(),
            onLeaveBack: () => hide(),
        });

        function show() {
            darkVideo.classList.add("visible");
            lightVideo.classList.add("visible");
            canvas.classList.add("visible");
            overlay?.classList.add("visible");
            document.body.classList.add("scroll-video-active");
        }
        function hide() {
            darkVideo.classList.remove("visible");
            lightVideo.classList.remove("visible");
            canvas.classList.remove("visible");
            overlay?.classList.remove("visible");
            document.body.classList.remove("scroll-video-active");
            darkVideo.pause();
            lightVideo.pause();
            isPlaying = false;
        }

        // Start in down/video mode.
        showVideo();
        window.requestAnimationFrame(() => ScrollTrigger.refresh());
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initScrollMedia);
    } else {
        initScrollMedia();
    }
</script>
