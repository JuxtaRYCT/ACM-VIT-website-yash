---
import BlogMarqueeCard from "../components/ui/BlogMarqueeCard.astro";
import AnimatedButton from "../components/ui/AnimatedButton.astro";
import { getAssetUrl } from "../utils/cdn";
import { getAllPosts } from "../lib/blog";

const fallbackCover = "/blogs/placeholder.webp";

type MarqueeBlog = {
  link: string;
  bgUrl: string;
  title: string;
  author: string;
  readingTime: number;
  tag: string;
};

let blogs: MarqueeBlog[] = [];
try {
  const posts = await getAllPosts();
  blogs = posts.slice(0, 10).map((post) => ({
    link: `/blogs/${post.source}/${post.slug}`,
    bgUrl: post.coverImage || fallbackCover,
    title: post.title,
    author: post.author,
    readingTime: post.readingTime,
    tag: post.tags?.[0] ?? post.source,
  }));
} catch {
  blogs = [];
}

// Split into two rows that scroll in opposite directions.
const mid = Math.ceil(blogs.length / 2);
const rowTop = blogs.slice(0, mid);
const rowBottom = blogs.slice(mid);
// Duplicate each row so the CSS translateX(-50%) loop is seamless.
const loopTop = [...rowTop, ...rowTop];
const loopBottom = [...rowBottom, ...rowBottom];
---

<div
  class="flex flex-col space-y-12 md:space-y-16 items-center justify-start pt-16 md:pt-20 w-full min-h-screen"
>
  <div
    class="blogs-title-bar bg-[#F95F4A] w-11/12 rounded-full h-[10vh] md:h-[15vh] lg:h-[20vh] grid grid-cols-[1fr_auto_1fr] items-center px-2 md:px-8 text-stone-900 border border-[#fefcd9]"
  >
    <div
      id="rotate-svg"
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative justify-self-start"
    >
      <img
        src={getAssetUrl("/icons/rotate.webp")}
        class="rotate-svg w-full h-full block"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="flex items-center justify-center h-full">
      <span
        class="blogs-title font-normal font-['PolySans_Trial'] text-4xl sm:text-6xl md:text-8xl lg:text-[150px] leading-none text-center transform translate-y-[5%]"
      >
        BLOGS
      </span>
    </div>

    <div
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative justify-self-end"
    >
      <img
        src={getAssetUrl("/icons/rotate.webp")}
        class="rotate-svg w-full h-full block"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>

  <div class="w-11/12 md:w-5/6 lg:w-2/3 max-w-6xl justify-start">
    <span
      class="text-[#F95F4A] font-light font-['PolySans_Trial'] text-lg leading-relaxed max-w-4xl max-[640px]:text-base max-[640px]:leading-[1.45] max-[640px]:max-w-[28rem] max-[480px]:text-[0.95rem] max-[480px]:leading-[1.4]"
    >
      Our blogs take you behind the scenes of the technologies shaping the world
      today.
    </span>
    <span
      class="text-white font-light font-['PolySans_Trial'] text-lg leading-relaxed max-w-4xl max-[640px]:text-base max-[640px]:leading-[1.45] max-[640px]:max-w-[28rem] max-[480px]:text-[0.95rem] max-[480px]:leading-[1.4]"
    >
      Whether it’s LLMs, UI/UX, microchips, or Web3, we break it down so anyone
      can follow. Find your next read just below.
    </span>
  </div>

  <!-- Auto-scrolling marquee (two rows, opposite directions) -->
  <div class="blogs-marquee w-full flex flex-col gap-5 md:gap-6">
    <div class="marquee-viewport">
      <div class="marquee-row" style="--dur: 46s;">
        {
          loopTop.map((blog) => (
            <BlogMarqueeCard {...blog} />
          ))
        }
      </div>
    </div>

    {
      rowBottom.length > 0 && (
        <div class="marquee-viewport">
          <div class="marquee-row marquee-reverse" style="--dur: 54s;">
            {loopBottom.map((blog) => (
              <BlogMarqueeCard {...blog} />
            ))}
          </div>
        </div>
      )
    }
  </div>

  <div class="flex justify-center w-full mt-8">
    <AnimatedButton
      text="Still curious? Dive deeper into our brainwaves"
      href="/blogs"
    />
  </div>
</div>

<style>
  @media (max-height: 700px) {
    .blogs-title-bar {
      height: clamp(72px, 24vh, 160px);
    }

    .blogs-title {
      font-size: clamp(2rem, 16vh, 6rem);
      line-height: 0.9;
    }
  }

  @media (max-height: 400px) {
    .blogs-title-bar {
      height: clamp(56px, 28vh, 120px);
    }

    .blogs-title {
      font-size: clamp(1.6rem, 14vh, 4rem);
    }
  }
  @media (max-width: 480px) {
    .blogs-title-bar {
      height: clamp(56px, 28vh, 120px);
    }

    .blogs-title {
      font-size: clamp(1.8rem, 14vh, 4rem);
    }
  }
</style>

<style>
  /* Edge-faded viewport so cards dissolve at both ends. */
  .marquee-viewport {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .marquee-row {
    display: flex;
    width: max-content;
    padding: 0.75rem 0;
    animation: marquee-scroll var(--dur, 48s) linear infinite;
    will-change: transform;
  }
  .marquee-reverse {
    animation-direction: reverse;
  }

  /* Two duplicated sets => shift by half for a seamless loop. */
  @keyframes marquee-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  /* Pause when hovering anywhere in the marquee. */
  .blogs-marquee:hover .marquee-row {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-row {
      animation: none;
    }
    .marquee-viewport {
      overflow-x: auto;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  gsap.to(".rotate-svg", {
    rotation: 360,
    repeat: -1,
    duration: 5,
    ease: "linear",
  });
</script>

