---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";
---

<section
  id="community-hoc"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div
    class="max-w-[1400px] mx-auto flex flex-col md:grid md:grid-cols-10 md:grid-rows-5 gap-0 relative z-10 md:min-h-[640px]"
  >
    <!-- Horizontal Lines (Grid Row 3) -->
    <div
      class="hidden md:block col-start-1 col-end-11 row-start-3 row-end-4 border-t-2 border-b-2 border-dashed border-[#999999]/50 pointer-events-none z-20"
      style="mask-image: linear-gradient(to right, black 50%, transparent 50%); -webkit-mask-image: linear-gradient(to right, black 50%, transparent 50%);"
    ></div>

    <!-- Left: Title + Pixel Heart (Rows 1-2) -->
    <div
      class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-1 md:row-end-3 md:border-r-2 md:border-dashed md:border-[#999999]/50"
    >
      <div class="p-6 md:p-10 flex items-start h-full">
        <div class="flex items-start gap-6">
          <h1
            class="text-5xl sm:text-6xl md:text-7xl lg:text-[7rem] leading-[0.85] font-bold text-[#FFFDD0] uppercase tracking-tighter"
          >
            HOUR<br />OF <span class="text-[#FF5F4A]">CODE</span>
          </h1>
          <img
            src={getAssetUrl("/community/pixel-heart.png")}
            alt="Pixel heart"
            class="w-16 md:w-24 lg:w-28 mt-2 flex-shrink-0"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <!-- Left: Subtitle (Row 3) -->
    <div
      class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-3 md:row-end-4 md:border-r-2 md:border-dashed md:border-[#999999]/50"
    >
      <div class="px-6 md:px-10 py-4 md:py-0 flex items-center h-full">
        <div
          class="text-[#FF5F4A] text-2xl sm:text-3xl md:text-4xl font-bold font-['Inter'] leading-tight md:leading-none"
        >
          MAKING TECHNOLOGY<br />ACCESSIBLE
        </div>
      </div>
    </div>

    <!-- Left: Description (Rows 4-5) -->
    <div
      class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-4 md:row-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50"
    >
      <div class="p-6 md:p-10 h-full flex items-end">
        <div
          class="text-left text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg"
        >
          ACM-VIT volunteers visited government schools to introduce
          underprivileged students to computers and programming fundamentals.
          The initiative focused on improving computer literacy and exposing
          young students to technology who otherwise may not have had access
          to such opportunities. Through interactive sessions and hands-on
          activities, we sparked curiosity and opened doors to a world of
          possibilities.
        </div>
      </div>
    </div>

    <!-- Right: Classroom Photo (Full height) -->
    <div
      class="relative h-[50vh] md:h-full group md:col-start-6 md:col-end-11 md:row-start-1 md:row-end-6"
    >
      <div class="absolute inset-0">
        <img
          src={getAssetUrl("/community/hour-of-code.png")}
          alt="Hour of Code - ACM-VIT volunteers teaching at a government school"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <!-- Subtle gradient overlay for depth -->
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"
      ></div>
      <!-- Stats overlay -->
      <div class="absolute bottom-6 right-6 md:bottom-10 md:right-10 z-10">
        <div class="flex gap-6 text-[#FFFDD0]">
          <div class="text-right">
            <span class="text-2xl md:text-3xl font-bold tracking-tight">200+</span>
            <p class="text-gray-400 font-mono text-[0.6rem] mt-0.5 uppercase">Students Reached</p>
          </div>
          <div class="text-right">
            <span class="text-2xl md:text-3xl font-bold tracking-tight">3</span>
            <p class="text-gray-400 font-mono text-[0.6rem] mt-0.5 uppercase">Schools Visited</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
