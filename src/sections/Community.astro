---
import AnimatedButton from "../components/ui/AnimatedButton.astro";
---

<section class="community-landing relative w-full overflow-hidden">
  <div class="landing-inner">
    <!-- Left: Cassette -->
    <div class="landing-cassette">
      <img
        src="/community/cassette-igniting-minds.png"
        alt="Igniting Minds cassette"
        class="landing-cassette-img"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- Right: Heading + text + CTA -->
    <div class="landing-right">
      <h2 class="landing-heading">
        COMM<span class="accent">UNITY</span>
      </h2>
      <p class="landing-text">
        At ACM-VIT, technology is more than just code - it's a tool to
        uplift, empower, and create meaningful change. Our
        community-driven initiatives aim to spark curiosity,
        strengthen digital literacy, and bring the power of
        technology closer to those who need it most. Here's how
        we're taking that step forward.
      </p>
      <div class="landing-cta">
        <AnimatedButton text="Unravel the tape" href="/community" />
      </div>
    </div>
  </div>
</section>

<style>
  .community-landing {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 3rem;
    padding-bottom: 6rem;
  }

  .landing-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    width: 100%;
    max-width: 1500px;
    padding: 2rem clamp(2rem, 5vw, 4rem);
    opacity: 0;
    transform: translateY(30px);
    animation: landingReveal 1s ease 0.3s forwards;
  }

  @keyframes landingReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .landing-cassette {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .landing-cassette-img {
    width: clamp(320px, 38vw, 560px);
    height: auto;
    filter: drop-shadow(0 24px 60px rgba(0, 0, 0, 0.55));
    animation: cassetteHover 5s ease-in-out infinite;
  }

  @keyframes cassetteHover {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(0.4deg); }
  }

  .landing-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    min-width: 0;
  }

  .landing-heading {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: clamp(2.75rem, 6.2vw, 7.5rem);
    line-height: 0.85;
    color: #FFFDD0;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    margin: 0;
    white-space: nowrap;
  }

  .landing-heading .accent {
    color: #FF5F4A;
  }

  .landing-text {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: clamp(0.95rem, 1.15vw, 1.15rem);
    line-height: 1.6;
    color: rgba(254, 252, 217, 0.78);
    font-weight: 400;
    margin: 0;
    max-width: 56ch;
  }

  .landing-cta {
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .landing-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    .landing-right {
      align-items: center;
      margin: 0 auto;
    }
    .landing-cassette-img {
      width: clamp(280px, 70vw, 480px);
    }
  }
</style>
