---
import AnimatedButton from "../components/ui/AnimatedButton.astro";
---

<section class="community-landing relative w-full overflow-hidden">
  <div class="landing-inner">
    <!-- Cassette -->
    <div class="landing-cassette">
      <img
        src="/community/cassette-igniting-minds.png"
        alt="Igniting Minds cassette"
        class="landing-cassette-img"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Decorative tape line -->
    <svg class="landing-tape" viewBox="0 0 400 120" preserveAspectRatio="none" aria-hidden="true">
      <path
        d="M 200 0 C 200 30, 80 40, 80 60 C 80 80, 320 80, 320 100 C 320 110, 200 115, 200 120"
        fill="none"
        stroke="#4A2F1A"
        stroke-width="2"
        stroke-linecap="round"
        opacity="0.4"
      />
    </svg>

    <!-- Text -->
    <div class="landing-content">
      <div class="chapter-pill"><span>CHAPTER 4 : IGNITING MINDS</span></div>
      <p class="landing-text">
        at acm-vit, technology is more than just code — it's a tool to
        uplift, empower, and create meaningful change. our
        community-driven initiatives aim to spark curiosity and bring
        the power of technology closer to those who need it most.
      </p>
    </div>

    <!-- CTA -->
    <div class="landing-cta">
      <AnimatedButton text="Unravel the tape" href="/community" />
    </div>
  </div>
</section>

<style>
  .community-landing {
    height: 100vh;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .landing-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    gap: 1rem;
    opacity: 0;
    transform: translateY(30px);
    animation: landingReveal 1s ease 0.3s forwards;
  }

  @keyframes landingReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .landing-cassette {
    width: clamp(200px, 28vw, 340px);
    position: relative;
  }

  .landing-cassette-img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 16px 48px rgba(0, 0, 0, 0.5));
    animation: cassetteHover 5s ease-in-out infinite;
  }

  @keyframes cassetteHover {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(0.4deg); }
  }

  .landing-tape {
    width: 200px;
    height: 60px;
    opacity: 0;
    animation: tapeReveal 0.8s ease 0.8s forwards;
  }

  @keyframes tapeReveal {
    to { opacity: 1; }
  }

  .landing-content {
    max-width: 540px;
  }

  .chapter-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.4rem;
    background: #FF5F4A;
    border-radius: 100px;
    font-family: "PolySans Mono", "Inter", monospace;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: white;
    text-transform: uppercase;
    white-space: nowrap;
    margin-bottom: 1.5rem;
  }

  .landing-text {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: clamp(0.88rem, 1.5vw, 1.15rem);
    line-height: 1.55;
    color: #FF5F4A;
    font-weight: 400;
    text-transform: lowercase;
  }

  .landing-cta {
    margin-top: 1rem;
  }

  @media (max-width: 640px) {
    .chapter-pill {
      font-size: 0.55rem;
      padding: 0.35rem 1rem;
      letter-spacing: 0.1em;
    }
  }
</style>
