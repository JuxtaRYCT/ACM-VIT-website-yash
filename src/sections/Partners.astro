---
import PartnerCasetteSingular from "../components/ui/PartnerCasetteSingular.astro";
import { reader } from "../utils/reader";
import { getAssetUrl } from "../utils/cdn";

const partnersData = await reader.singletons.partners.read();
const partners = partnersData?.items ?? [];

const marqueeRepeat = 4;
const marqueeRows = [
  {
    items: partners.filter((_, index) => index % 4 === 0),
    reverse: false,
  },
  {
    items: partners.filter((_, index) => index % 4 === 1),
    reverse: true,
  },
  {
    items: partners.filter((_, index) => index % 4 === 2),
    reverse: false,
  },
  {
    items: partners.filter((_, index) => index % 4 === 3),
    reverse: true,
  },
];
---

<div
  id="partners-container"
  class="relative flex flex-wrap gap-6 justify-center items-center w-full pt-18 pb-64 overflow-hidden"
>
  <div
    id="Cassette-pos-1"
    class="partners-floating w-full flex justify-center mt-0 relative"
  >
    <img
      id="partners-svg"
      src={getAssetUrl("/cassettes/partners-cassette.webp")}
      alt="Partners Image"
      class="max-w-[300px] md:max-w-[500px] w-auto object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div
    class="partners-carousel w-[80vw] pb-24 flex flex-wrap gap-6 justify-center items-center relative z-10"
  >
    <div class="partners-track flex flex-wrap gap-6 justify-center items-center">
      {
        partners.map((partner) => (
          <div class="partners-card">
            <PartnerCasetteSingular
              title={partner.title}
              imageUrl={getAssetUrl(partner.imageUrl)}
              link={partner.link}
            />
          </div>
        ))
      }
    </div>
    <div class="partners-marquee">
      {marqueeRows.map((row) => (
        <div
          class={`partners-marquee-row${row.reverse ? " is-reverse" : ""}`}
        >
          {Array.from({ length: marqueeRepeat }).map((_, index) => (
            <div
              class="partners-marquee-group"
              aria-hidden={index === 0 ? undefined : "true"}
            >
              {row.items.map((partner) => (
                <div class="partners-card">
                  <PartnerCasetteSingular
                    title={partner.title}
                    imageUrl={getAssetUrl(partner.imageUrl)}
                    link={partner.link}
                  />
                </div>
              ))}
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .partners-floating {
    position: fixed;
    left: 0;
    right: 0;
    bottom: -140px;
    z-index: 20;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    will-change: opacity;
  }

  .partners-floating.is-fixed {
    opacity: 1;
  }

  .partners-marquee {
    display: none;
  }

  .partners-marquee-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--gap);
  }

  .partners-marquee-row.is-reverse .partners-marquee-group {
    animation-direction: reverse;
  }

  .partners-marquee-group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    flex-wrap: nowrap;
    gap: var(--gap);
    animation: partners-marquee var(--duration) linear infinite;
    will-change: transform;
  }

  @keyframes partners-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-100% - var(--gap)));
    }
  }

  /* Phones and tablets (incl. iPad in both orientations / any touch device)
     get the animated marquee instead of the static wrap grid. */
  @media (max-width: 1024px), (pointer: coarse) {
    #partners-container {
      overflow: visible;
    }

    .partners-floating {
      bottom: 24px;
    }
    .partners-carousel {
      width: 100vw;
      padding: 0 6vw 5rem;
      overflow: visible;
    }

    .partners-card {
      flex: 0 0 auto;
    }

    .partners-track {
      display: none;
    }

    .partners-marquee {
      display: flex;
      flex-direction: column;
      gap: var(--gap);
      padding: 0.5rem 1vw;
      --duration: 40s;
      --gap: 0.9rem;
    }

    /* Smaller cassettes so 4 marquee rows fit without a tall section. */
    .partners-marquee .partner-casette-shell {
      width: 28vw;
      height: 17vw;
    }
  }

  /* On tablets the 28vw cassettes get too big / too tall - cap to a smaller,
     shorter fixed size. */
  @media (min-width: 640px) {
    .partners-marquee .partner-casette-shell {
      width: 150px;
      height: 70px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const pos1 = document.getElementById("Cassette-pos-1");
    const section = document.getElementById("partners");
    const gallery = document.getElementById("gallery");

    if (!pos1 || !section) return;

    let inPartners = false;
    let inGallery = false;
    const updateVisibility = () => {
      const isActive = inPartners && !inGallery;
      pos1.classList.toggle("is-fixed", isActive);
      document.body.classList.toggle("partners-active", isActive);
    };

    const partnersObserver = new IntersectionObserver(
      ([entry]) => {
        inPartners = entry.isIntersecting;
        updateVisibility();
      },
      {
        root: null,
        rootMargin: "-15% 0px -15% 0px",
        threshold: 0,
      }
    );

    partnersObserver.observe(section);

    if (gallery) {
      const galleryObserver = new IntersectionObserver(
        ([entry]) => {
          inGallery = entry.isIntersecting;
          updateVisibility();
        },
        {
          root: null,
          rootMargin: "0px 0px 0px 0px",
          threshold: 0,
        }
      );

      galleryObserver.observe(gallery);
    }
  });
</script>
