---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";
---

<section
  id="community-ksl"
  class="relative z-20 py-12 md:py-24 border-t border-white/10 overflow-hidden"
>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
    <!-- KSL Word Graphics -->
    <div class="ksl-words flex flex-wrap items-center justify-center gap-4 md:gap-6 mb-10 md:mb-16">
      <img
        src={getAssetUrl("/community/ksl-kick.png")}
        alt="KICK"
        class="ksl-word h-16 sm:h-20 md:h-28 lg:h-36"
        loading="lazy"
        decoding="async"
      />
      <img
        src={getAssetUrl("/community/ksl-start.png")}
        alt="START"
        class="ksl-word h-16 sm:h-20 md:h-28 lg:h-36"
        loading="lazy"
        decoding="async"
        style="animation-delay: 0.1s;"
      />
      <img
        src={getAssetUrl("/community/ksl-learn.png")}
        alt="LEARN"
        class="ksl-word h-16 sm:h-20 md:h-28 lg:h-36"
        loading="lazy"
        decoding="async"
        style="animation-delay: 0.2s;"
      />
    </div>

    <!-- Content Grid -->
    <div class="md:grid md:grid-cols-2 gap-12 lg:gap-20">
      <!-- Left: Title + Subtitle -->
      <div class="mb-8 md:mb-0">
        <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
          Fresher Initiative
        </p>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.9] mb-6"
        >
          HELPING FRESHERS<br />
          <span class="text-[#FF5F4A]">BEGIN THEIR JOURNEY</span>
        </h2>
        <div class="w-16 h-[2px] bg-[#FF5F4A] mb-6"></div>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-md">
          Starting college can be overwhelming, especially for students
          entering the world of technology for the first time. KSL was
          created to help first-year students find their footing and
          build confidence from day one.
        </p>
      </div>

      <!-- Right: What KSL Covers -->
      <div class="space-y-5">
        <div class="ksl-item">
          <div class="ksl-num">01</div>
          <div>
            <h3 class="text-[#FFFDD0] text-lg font-semibold mb-1">College Ecosystem</h3>
            <p class="text-gray-400 text-sm font-mono leading-relaxed">
              Navigate the campus, understand club culture, and make the most of university life.
            </p>
          </div>
        </div>

        <div class="ksl-item">
          <div class="ksl-num">02</div>
          <div>
            <h3 class="text-[#FFFDD0] text-lg font-semibold mb-1">Technology Domains</h3>
            <p class="text-gray-400 text-sm font-mono leading-relaxed">
              Explore web development, app development, machine learning, cybersecurity, and more.
            </p>
          </div>
        </div>

        <div class="ksl-item">
          <div class="ksl-num">03</div>
          <div>
            <h3 class="text-[#FFFDD0] text-lg font-semibold mb-1">Technical Skills</h3>
            <p class="text-gray-400 text-sm font-mono leading-relaxed">
              Hands-on workshops covering Git, Linux, programming fundamentals, and essential dev tools.
            </p>
          </div>
        </div>

        <div class="ksl-item">
          <div class="ksl-num">04</div>
          <div>
            <h3 class="text-[#FFFDD0] text-lg font-semibold mb-1">Mentorship Network</h3>
            <p class="text-gray-400 text-sm font-mono leading-relaxed">
              Connect with seniors and mentors who guide freshers through their first semester and beyond.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ksl-word {
    opacity: 0;
    transform: translateY(12px);
    animation: kslWordIn 0.6s ease forwards;
  }

  @keyframes kslWordIn {
    from {
      opacity: 0;
      transform: translateY(12px) rotate(-2deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(0deg);
    }
  }

  .ksl-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    background: linear-gradient(
      135deg,
      rgba(255, 95, 74, 0.04) 0%,
      rgba(13, 14, 13, 0.3) 100%
    );
    transition: all 0.3s ease;
  }

  .ksl-item:hover {
    border-color: rgba(255, 95, 74, 0.2);
    background: linear-gradient(
      135deg,
      rgba(255, 95, 74, 0.08) 0%,
      rgba(13, 14, 13, 0.4) 100%
    );
    transform: translateX(4px);
  }

  .ksl-num {
    color: #FF5F4A;
    font-family: "PolySans Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    padding-top: 0.15rem;
    flex-shrink: 0;
    opacity: 0.7;
  }
</style>
