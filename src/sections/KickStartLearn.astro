---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";

const items = [
  {
    num: "01",
    title: "College Ecosystem",
    body: "Navigate the campus, understand club culture, and make the most of university life.",
  },
  {
    num: "02",
    title: "Technology Domains",
    body: "Explore web development, app development, machine learning, cybersecurity, and more.",
  },
  {
    num: "03",
    title: "Technical Skills",
    body: "Hands-on workshops covering Git, Linux, programming fundamentals, and essential dev tools.",
  },
  {
    num: "04",
    title: "Mentorship Network",
    body: "Connect with seniors and mentors who guide freshers through their first semester and beyond.",
  },
];
---

<section
  id="community-ksl"
  class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden"
>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <!-- KSL word graphics -->
    <div class="ksl-words flex flex-wrap items-center justify-center gap-4 md:gap-6 mb-12 md:mb-16">
      <img src={getAssetUrl("/community/ksl-kick.png")} alt="KICK" class="ksl-word h-16 sm:h-20 md:h-28 lg:h-32" loading="lazy" decoding="async" />
      <img src={getAssetUrl("/community/ksl-start.png")} alt="START" class="ksl-word h-16 sm:h-20 md:h-28 lg:h-32" loading="lazy" decoding="async" style="animation-delay: 0.1s;" />
      <img src={getAssetUrl("/community/ksl-learn.png")} alt="LEARN" class="ksl-word h-16 sm:h-20 md:h-28 lg:h-32" loading="lazy" decoding="async" style="animation-delay: 0.2s;" />
    </div>

    <div class="grid md:grid-cols-2 gap-10 lg:gap-16">
      <!-- Left: intro -->
      <div>
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Fresher Initiative
        </p>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.9]">
          HELPING FRESHERS<br /><span class="text-[#FF5F4A]">BEGIN THEIR JOURNEY</span>
        </h2>
        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-md">
          Starting college can be overwhelming, especially for students entering
          the world of technology for the first time. KSL was created to help
          first-year students find their footing and build confidence from day
          one.
        </p>
      </div>

      <!-- Right: what KSL covers -->
      <div class="grid gap-4">
        {items.map((item) => (
          <div class="flex gap-4 items-start rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 transition-all duration-300 hover:border-[#FF5F4A]/25 hover:bg-[#FF5F4A]/[0.03]">
            <span class="text-[#FF5F4A] font-mono text-xs font-semibold tracking-[0.2em] pt-1 opacity-70">{item.num}</span>
            <div>
              <h3 class="text-[#FFFDD0] text-lg font-semibold mb-1">{item.title}</h3>
              <p class="text-gray-400 text-sm font-mono leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .ksl-word {
    opacity: 0;
    transform: translateY(12px);
    animation: kslWordIn 0.6s ease forwards;
  }
  @keyframes kslWordIn {
    from { opacity: 0; transform: translateY(12px) rotate(-2deg); }
    to { opacity: 1; transform: translateY(0) rotate(0deg); }
  }
</style>
