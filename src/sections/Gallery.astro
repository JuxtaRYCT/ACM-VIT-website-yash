---
// Gallery.astro
import { getAssetUrl } from "../utils/cdn";
import ProofGallery from "../components/overlays/ProofGallery.astro";
import AnimatedButton from "../components/ui/AnimatedButton.astro";
---

<section
  class="gallery-section relative w-full pt-16 pb-0 sm:pt-24 sm:pb-0"
>
  <div class="gallery-frame relative w-full overflow-hidden">
    <img
      src={getAssetUrl("/gallery/gallery-hero.png")}
      alt="ACM-VIT Gallery"
      class="gallery-image w-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="gallery-btn-row">
    <AnimatedButton
      text="Proof We Actually Do Stuff - View Photos!"
      onclick="window.openProofGallery()"
    />
  </div>
  <ProofGallery />
</section>

<script>
  // Ensure the function is available (if ProofGallery script hasn't run yet, though it should have)
  // Actually, Astro scripts module hoist, so it might be fine, but let's be safe.
</script>

<style>
  .gallery-section {
    font-family: "PolySans Trial", "PolySans", system-ui, sans-serif;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .gallery-section * {
    -webkit-user-select: none;
    user-select: none;
  }

  .gallery-section img {
    -webkit-user-drag: none;
  }

  .gallery-btn-row {
    position: relative;
    z-index: 10;
    margin-top: -40%;
    margin-bottom: 20%;
  }

  .gallery-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(3, 3, 3, 0) 40%,
      rgba(3, 3, 3, 0.55) 100%
    );
    pointer-events: none;
  }

  .gallery-image {
    filter: grayscale(1);
    transition: filter 0.3s ease;
  }

  .gallery-frame:hover .gallery-image {
    filter: grayscale(0.2);
  }
</style>
