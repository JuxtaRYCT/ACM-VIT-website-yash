---
import AnimatedButton from "../components/ui/AnimatedButton.astro";
---

<section class="grep-section relative min-h-screen overflow-hidden flex items-center justify-center">
  <!-- Keyboard SVG background — injected via JS for hover interactivity -->
  <div class="keyboard-bg absolute inset-0 flex items-center justify-center pointer-events-none" id="grep-keyboard-bg"></div>

  <!-- Mailbox illustration -->
  <div class="absolute left-6 bottom-6 sm:left-12 sm:bottom-12 opacity-70">
    <img src="/assets/grep/mailbox.svg" alt="" class="w-40 sm:w-56 md:w-64" />
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center text-center px-6">
    <h2 class="grep-title text-[#2023FE] leading-[0.85]">
      <span class="block">gr</span>
      <span class="block">ep</span>
    </h2>
    <p class="grep-by mt-4 text-[#efefef] text-lg sm:text-xl">
      by acm-vit
    </p>
    <p class="grep-desc mt-5 max-w-md text-[#efefef] text-sm sm:text-base leading-relaxed">
      ACM-VIT's quarterly newsletter — your one-stop source for community updates, event recaps, tech deep-dives, and everything happening at ACM-VIT.
    </p>

    <!-- Email signup -->
    <form class="grep-email-form mt-8 flex flex-col sm:flex-row items-center gap-3 w-full max-w-md" id="grep-subscribe-form">
      <input
        type="email"
        name="email"
        required
        placeholder="Enter your email to subscribe"
        class="w-full flex-1 rounded-lg border border-[#2023FE]/30 bg-white/5 px-4 py-2.5 text-sm text-[#efefef] placeholder:text-[#efefef]/30 outline-none transition-colors focus:border-[#2023FE] focus:bg-white/[0.08]"
      />
      <button
        type="submit"
        class="rounded-lg bg-[#2023FE] px-6 py-2.5 text-sm font-semibold text-white transition-all hover:bg-[#1a1cf0] active:scale-[0.97] whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="grep-subscribe-status mt-2 text-xs text-[#efefef] hidden"></p>

    <div class="mt-8">
      <AnimatedButton
        text="Learn More"
        href="/grep-reader"
        class="grep-btn"
        iconBg="#2023FE"
      />
    </div>
  </div>
</section>

<style>
  @font-face {
    font-family: "ChessType";
    src: url("/fonts/ChessType.ttf") format("truetype");
    font-display: swap;
  }

  .grep-section {
    --selection-color: #2023FE;
  }

  .grep-section ::selection {
    background: var(--selection-color);
    color: white;
  }

  .grep-title {
    font-family: "ChessType", monospace;
    font-size: clamp(3.5rem, 8vw, 7rem);
  }

  .grep-by {
    font-family: "Borel", cursive;
  }

  /* Animated button — blue theme override */
  .grep-section :global(.grep-btn) {
    background: #2023FE;
  }

  .grep-section :global(.grep-btn:hover) {
    box-shadow: 0 8px 30px rgba(32, 35, 254, 0.25);
  }

  .grep-section :global(.grep-btn .anim-btn-label) {
    color: white;
  }

  /* Keyboard background — scaled up to bleed off screen, 10% opacity */
  .keyboard-bg {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .keyboard-bg :global(svg) {
    width: 200%;
    height: auto;
    max-height: none;
    opacity: 0.2;
    flex-shrink: 0;
  }

  .keyboard-bg :global(rect) {
    fill: rgba(255, 255, 255, 0.3) !important;
    transition: fill 0.15s ease, filter 0.15s ease;
    pointer-events: auto;
    cursor: default;
  }

  .keyboard-bg :global(rect:hover) {
    fill: rgba(32, 35, 254, 0.15) !important;
    filter: drop-shadow(0 0 4px rgba(32, 35, 254, 0.06));
  }

  .keyboard-bg :global(path) {
    fill: rgba(255, 255, 255, 0.3) !important;
    transition: fill 0.15s ease;
    pointer-events: none;
  }

  .keyboard-bg :global(rect:hover ~ path) {
    fill: rgba(255, 255, 255, 0.15) !important;
  }

  /* ── Light mode ── */
  :global(html[data-theme="light"]) .grep-title {
    color: #2023FE;
  }

  :global(html[data-theme="light"]) .grep-by,
  :global(html[data-theme="light"]) .grep-desc,
  :global(html[data-theme="light"]) .grep-subscribe-status {
    color: #3a3a3a;
  }

  :global(html[data-theme="light"]) .grep-email-form input {
    color: #1c1917;
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(32, 35, 254, 0.25);
  }

  :global(html[data-theme="light"]) .grep-email-form input::placeholder {
    color: rgba(0, 0, 0, 0.35);
  }

  :global(html[data-theme="light"]) .keyboard-bg :global(rect) {
    fill: rgba(0, 0, 0, 0.06) !important;
  }

  :global(html[data-theme="light"]) .keyboard-bg :global(rect:hover) {
    fill: rgba(249, 95, 74, 0.2) !important;
    filter: drop-shadow(0 0 4px rgba(249, 95, 74, 0.08));
  }

  :global(html[data-theme="light"]) .keyboard-bg :global(path) {
    fill: rgba(0, 0, 0, 0.06) !important;
  }

  :global(html[data-theme="light"]) .keyboard-bg :global(rect:hover ~ path) {
    fill: rgba(0, 0, 0, 0.12) !important;
  }

  :global(html[data-theme="light"]) .grep-section :global(.grep-btn) {
    background: #2023FE;
  }

  :global(html[data-theme="light"]) .grep-section :global(.grep-btn .anim-btn-label) {
    color: white;
  }
</style>

<script>
  // Inject keyboard SVG inline for CSS hover interactivity
  const container = document.getElementById("grep-keyboard-bg");
  if (container) {
    fetch("/assets/grep/keyboard.svg")
      .then((r) => r.text())
      .then((svg) => {
        container.innerHTML = svg;
      });
  }

  // Import Borel from Google Fonts
  if (!document.querySelector('link[href*="Borel"]')) {
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href =
      "https://fonts.googleapis.com/css2?family=Borel&display=swap";
    document.head.appendChild(link);
  }
</script>
