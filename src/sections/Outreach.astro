---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";

const stats = [
  { value: "200+", label: "Students Reached" },
  { value: "3", label: "Schools Visited" },
  { value: "7-9", label: "Classes Engaged" },
];
---

<div id="community" class="absolute -top-24 pointer-events-none" aria-hidden="true"></div>
<section
  id="community-outreach"
  class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden"
>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Left: copy -->
      <div>
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Beyond the Norm · School Outreach
        </p>

        <div class="flex items-start gap-5">
          <h2
            class="text-5xl sm:text-6xl md:text-6xl lg:text-7xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85]"
          >
            HOUR OF<br /><span class="text-[#FF5F4A]">CODE</span>
          </h2>
          <img
            src={getAssetUrl("/community/pixel-heart.png")}
            alt="Pixel heart"
            class="w-14 md:w-20 mt-1 flex-shrink-0"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>

        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-xl mb-6">
          ACM-VIT volunteers take computing beyond the campus. Through our Hour
          of Code and Beyond the Norm outreach, we visit government schools to
          introduce students of classes 7 to 9 to programming fundamentals,
          flowcharts, and digital logic. Interactive demonstrations and hands-on
          activities spark curiosity in young minds who otherwise may not have
          access to technology, opening doors to a world of possibilities.
        </p>

        <!-- Stats -->
        <div class="flex flex-wrap gap-3">
          {stats.map((s) => (
            <div class="flex-1 min-w-[110px] rounded-2xl border border-white/[0.06] bg-white/[0.02] px-5 py-4 transition-all duration-300 hover:border-[#FF5F4A]/30 hover:bg-[#FF5F4A]/[0.04]">
              <p class="text-2xl md:text-3xl font-bold text-[#FFFDD0] tracking-tight">{s.value}</p>
              <p class="text-gray-400 font-mono text-[0.65rem] mt-1 uppercase tracking-wider">{s.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: image -->
      <div class="relative">
        <div class="relative rounded-3xl overflow-hidden border border-white/[0.06] aspect-[4/5] md:aspect-[5/6]">
          <img
            src={getAssetUrl("/outreach/outreach-event.webp")}
            alt="ACM-VIT volunteers teaching at a government school"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute bottom-6 left-6 right-6 flex items-center gap-3">
            <span class="text-[#FF5F4A] text-2xl sm:text-3xl font-bold leading-tight">
              BEYOND<br />THE NORM
            </span>
            <img
              src={getAssetUrl("/outreach/beyond-norm-logo.webp")}
              alt="Beyond the Norm"
              class="h-9 sm:h-11 w-auto"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
