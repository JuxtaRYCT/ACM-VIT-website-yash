---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";
import AnimatedButton from "../components/ui/AnimatedButton.astro";

const yearsSince = new Date().getFullYear() - 2009;
---

<!-- Summer Bootcamp -->
<section
  id="community-bootcamp"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div
    class="max-w-[1400px] mx-auto md:grid md:grid-cols-10 gap-0 relative z-10"
  >
    <!-- Left: Content -->
    <div class="md:col-start-1 md:col-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50 p-6 md:p-10">
      <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
        Online Learning
      </p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85] mb-4">
        SUMMER<br /><span class="text-[#FF5F4A]">BOOTCAMP</span>
      </h2>
      <div class="w-16 h-[2px] bg-[#FF5F4A] my-6"></div>
      <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg mb-6">
        ACM-VIT conducted extensive summer bootcamps through YouTube and
        other online platforms, enabling students from anywhere to learn
        valuable technical skills at their own pace. Free, accessible,
        and designed for real learning.
      </p>
    </div>

    <!-- Right: Topics Grid -->
    <div class="md:col-start-6 md:col-end-11 p-6 md:p-10 flex items-center">
      <div class="grid grid-cols-2 gap-4 w-full">
        <div class="cp-topic-card">
          <span class="cp-topic-icon">&#60;/&#62;</span>
          <span class="cp-topic-label">Web Development</span>
        </div>
        <div class="cp-topic-card">
          <span class="cp-topic-icon">&#128241;</span>
          <span class="cp-topic-label">App Development</span>
        </div>
        <div class="cp-topic-card">
          <span class="cp-topic-icon">&#123;&#125;</span>
          <span class="cp-topic-label">Programming Fundamentals</span>
        </div>
        <div class="cp-topic-card">
          <span class="cp-topic-icon">&#9881;</span>
          <span class="cp-topic-label">Emerging Technologies</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Forktober Fest -->
<section
  id="community-forktober"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div
    class="max-w-[1400px] mx-auto flex flex-col md:grid md:grid-cols-10 gap-0 relative z-10"
  >
    <!-- Right content first on desktop -->
    <div class="order-2 md:order-1 md:col-start-1 md:col-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50 p-6 md:p-10 flex items-center">
      <div class="space-y-5 w-full">
        <div class="cp-step">
          <div class="cp-step-num">01</div>
          <div>
            <h3 class="text-[#FFFDD0] text-base font-semibold mb-1">Understand Open Source</h3>
            <p class="text-gray-400 text-xs font-mono leading-relaxed">
              Learn what open-source software is and why it matters for developers and the world.
            </p>
          </div>
        </div>
        <div class="cp-step">
          <div class="cp-step-num">02</div>
          <div>
            <h3 class="text-[#FFFDD0] text-base font-semibold mb-1">First Contributions</h3>
            <p class="text-gray-400 text-xs font-mono leading-relaxed">
              Guided sessions to make your very first open-source PR — from fork to merge.
            </p>
          </div>
        </div>
        <div class="cp-step">
          <div class="cp-step-num">03</div>
          <div>
            <h3 class="text-[#FFFDD0] text-base font-semibold mb-1">Git & GitHub Mastery</h3>
            <p class="text-gray-400 text-xs font-mono leading-relaxed">
              Workshops covering branches, rebasing, conflict resolution, and collaborative workflows.
            </p>
          </div>
        </div>
        <div class="cp-step">
          <div class="cp-step-num">04</div>
          <div>
            <h3 class="text-[#FFFDD0] text-base font-semibold mb-1">Global Collaboration</h3>
            <p class="text-gray-400 text-xs font-mono leading-relaxed">
              Mentorship, blogs, and contribution drives connecting students with developers worldwide.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Title -->
    <div class="order-1 md:order-2 md:col-start-6 md:col-end-11 p-6 md:p-10">
      <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
        Open Source Month
      </p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85] mb-4">
        FORKTOBER<br /><span class="text-[#FF5F4A]">FEST</span>
      </h2>
      <div class="w-16 h-[2px] bg-[#FF5F4A] my-6"></div>
      <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
        ACM-VIT's month-long celebration of open-source development.
        Workshops, mentorship sessions, blog posts, and contribution
        drives designed specifically for beginners stepping into the
        world of collaborative software.
      </p>
    </div>
  </div>
</section>

<!-- Open Source Culture + Technical Knowledge Sharing -->
<section
  id="community-opensource"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
    <div class="text-center mb-12 md:mb-16">
      <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
        Building a Culture
      </p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.9] mb-4">
        OPEN SOURCE &<br /><span class="text-[#FF5F4A]">KNOWLEDGE SHARING</span>
      </h2>
      <div class="w-16 h-[2px] bg-[#FF5F4A] mx-auto mt-6 mb-8"></div>
      <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-2xl mx-auto">
        ACM-VIT has consistently fostered a strong culture of open-source contribution and
        free technical education. Building contributors, not just consumers.
      </p>
    </div>

    <!-- Achievement Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <div class="cp-achievement">
        <div class="cp-achievement-badge">GSoC</div>
        <h3 class="text-[#FFFDD0] text-lg font-bold mb-2">Google Summer of Code</h3>
        <p class="text-gray-400 text-xs font-mono leading-relaxed">
          Members selected for GSoC, contributing to major open-source organizations worldwide.
        </p>
      </div>
      <div class="cp-achievement">
        <div class="cp-achievement-badge">GSoD</div>
        <h3 class="text-[#FFFDD0] text-lg font-bold mb-2">Google Season of Docs</h3>
        <p class="text-gray-400 text-xs font-mono leading-relaxed">
          Technical writing contributions improving documentation for open-source projects.
        </p>
      </div>
      <div class="cp-achievement">
        <div class="cp-achievement-badge">MLH</div>
        <h3 class="text-[#FFFDD0] text-lg font-bold mb-2">MLH Fellowships</h3>
        <p class="text-gray-400 text-xs font-mono leading-relaxed">
          Major League Hacking fellowship recipients, gaining industry experience through open source.
        </p>
      </div>
    </div>

    <!-- Technical Knowledge Row -->
    <div class="cp-knowledge-bar">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
        <div class="flex-shrink-0">
          <p class="text-[#FF5F4A] font-mono text-xs tracking-[0.2em] uppercase">
            Technical Sessions
          </p>
          <h3 class="text-[#FFFDD0] text-xl md:text-2xl font-bold uppercase tracking-tight">
            Free Learning for Everyone
          </h3>
        </div>
        <div class="h-px md:h-12 md:w-px bg-white/10 flex-shrink-0"></div>
        <p class="text-gray-400 text-xs font-mono leading-relaxed">
          ACM-VIT regularly publishes educational content and conducts technical sessions —
          making quality technical education accessible, helping students stay updated with
          industry trends, and encouraging continuous learning outside formal coursework.
          Recent contributions include work on projects like SGLang,
          demonstrating active participation in modern open-source ecosystems.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- SDG Initiative (Expanded) -->
<section
  id="community-sdg-expanded"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div
    class="max-w-[1400px] mx-auto md:grid md:grid-cols-10 gap-0 relative z-10"
  >
    <!-- Left: Title -->
    <div class="md:col-start-1 md:col-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50 p-6 md:p-10">
      <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
        Technology for Social Good
      </p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85] mb-4">
        SDG<br /><span class="text-[#FF5F4A]">INITIATIVE</span>
      </h2>
      <div class="w-16 h-[2px] bg-[#FF5F4A] my-6"></div>
      <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
        Every year, ACM-VIT conducts events centered around the United Nations
        Sustainable Development Goals. Participants are challenged to use technology
        and innovation to address real-world problems.
      </p>
    </div>

    <!-- Right: Focus Areas -->
    <div class="md:col-start-6 md:col-end-11 p-6 md:p-10 flex items-center">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 w-full">
        <div class="cp-sdg-tag">Education</div>
        <div class="cp-sdg-tag">Healthcare</div>
        <div class="cp-sdg-tag">Sustainability</div>
        <div class="cp-sdg-tag">Climate Action</div>
        <div class="cp-sdg-tag">Social Equality</div>
        <div class="cp-sdg-tag">Innovation</div>
      </div>
    </div>
  </div>
</section>

<!-- CASA -->
<section
  id="community-casa"
  class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
>
  <div
    class="max-w-[1400px] mx-auto flex flex-col md:grid md:grid-cols-10 gap-0 relative z-10"
  >
    <div class="md:col-start-1 md:col-end-11 p-6 md:p-10">
      <div class="md:grid md:grid-cols-2 gap-12 lg:gap-20">
        <!-- Left -->
        <div>
          <p class="text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-4">
            Student Well-being
          </p>
          <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85] mb-4">
            CASA
          </h2>
          <p class="text-[#FF5F4A] text-lg md:text-xl font-semibold mb-6">
            Campaign Against Substance Abuse
          </p>
          <div class="w-16 h-[2px] bg-[#FF5F4A] mb-6"></div>
          <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
            Under VIT's larger CASA initiative, ACM-VIT organizes awareness
            programs focused on the dangers and consequences of substance abuse.
            The goal is to create a healthier and more informed student community.
          </p>
        </div>

        <!-- Right: Program Includes -->
        <div class="mt-8 md:mt-0 flex items-center">
          <div class="space-y-4 w-full">
            <div class="cp-casa-item">
              <span class="cp-casa-dot"></span>
              <span class="text-gray-300 text-sm font-mono">Expert-led awareness sessions</span>
            </div>
            <div class="cp-casa-item">
              <span class="cp-casa-dot"></span>
              <span class="text-gray-300 text-sm font-mono">Interactions with trained counselors</span>
            </div>
            <div class="cp-casa-item">
              <span class="cp-casa-dot"></span>
              <span class="text-gray-300 text-sm font-mono">Educational discussions on mental health and well-being</span>
            </div>
            <div class="cp-casa-item">
              <span class="cp-casa-dot"></span>
              <span class="text-gray-300 text-sm font-mono">Peer support network development</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Closing Impact Statement -->
<section class="relative z-20 py-16 md:py-28 border-t border-white/10 overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.04]"
    style={`background-image: url(${getAssetUrl("/backgrounds/background_pattern.webp")}); background-size: cover;`}
  ></div>
  <div class="max-w-[1000px] mx-auto px-6 md:px-10 relative z-10 text-center">
    <div class="w-12 h-[2px] bg-[#FF5F4A] mx-auto mb-8"></div>
    <p class="text-[#FFFDD0] text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold leading-snug tracking-tight">
      For {yearsSince} years, ACM-VIT has not only built technologists, developers, and
      innovators — it has built <span class="text-[#FF5F4A]">communities</span>,
      empowered students, and created opportunities for thousands of individuals
      to learn, grow, and make an <span class="text-[#FF5F4A]">impact</span>.
    </p>
    <div class="w-12 h-[2px] bg-[#FF5F4A] mx-auto mt-8"></div>
  </div>
</section>

<style>
  /* Topic cards (Summer Bootcamp) */
  .cp-topic-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    background: linear-gradient(
      145deg,
      rgba(255, 95, 74, 0.06) 0%,
      rgba(13, 14, 13, 0.4) 100%
    );
    transition: all 0.35s ease;
    text-align: center;
  }

  .cp-topic-card:hover {
    border-color: rgba(255, 95, 74, 0.25);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(255, 95, 74, 0.08);
  }

  .cp-topic-icon {
    font-size: 1.5rem;
    color: #FF5F4A;
    font-family: "PolySans Mono", monospace;
  }

  .cp-topic-label {
    color: #FFFDD0;
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Step items (Forktober) */
  .cp-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    border-left: 2px solid rgba(255, 95, 74, 0.3);
    transition: all 0.3s ease;
  }

  .cp-step:hover {
    border-left-color: #FF5F4A;
    background: rgba(255, 95, 74, 0.03);
    padding-left: 1.5rem;
  }

  .cp-step-num {
    color: #FF5F4A;
    font-family: "PolySans Mono", monospace;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    padding-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* Achievement cards (Open Source) */
  .cp-achievement {
    padding: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    background: linear-gradient(
      150deg,
      rgba(255, 95, 74, 0.05) 0%,
      rgba(13, 14, 13, 0.5) 50%,
      rgba(255, 95, 74, 0.02) 100%
    );
    transition: all 0.4s ease;
  }

  .cp-achievement:hover {
    border-color: rgba(255, 95, 74, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3),
                0 0 20px rgba(255, 95, 74, 0.04);
  }

  .cp-achievement-badge {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: rgba(255, 95, 74, 0.15);
    border: 1px solid rgba(255, 95, 74, 0.3);
    border-radius: 6px;
    color: #FF5F4A;
    font-family: "PolySans Mono", monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Knowledge bar */
  .cp-knowledge-bar {
    padding: 1.5rem 2rem;
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 95, 74, 0.02);
  }

  /* SDG tags */
  .cp-sdg-tag {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    border: 1px solid rgba(255, 95, 74, 0.2);
    border-radius: 10px;
    color: #FF5F4A;
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    background: rgba(255, 95, 74, 0.04);
  }

  .cp-sdg-tag:hover {
    background: rgba(255, 95, 74, 0.12);
    border-color: rgba(255, 95, 74, 0.5);
    transform: scale(1.03);
  }

  /* CASA items */
  .cp-casa-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .cp-casa-item:hover {
    border-color: rgba(255, 95, 74, 0.15);
    background: rgba(255, 95, 74, 0.03);
  }

  .cp-casa-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #FF5F4A;
    flex-shrink: 0;
  }
</style>
