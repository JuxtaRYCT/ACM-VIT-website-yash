---
import "../styles/globals.css";

const bootcampTopics = [
  { icon: "</>", label: "Web Development" },
  { icon: "▤", label: "App Development" },
  { icon: "{ }", label: "Programming Fundamentals" },
  { icon: "⚙", label: "Emerging Technologies" },
];

const forktoberSteps = [
  { num: "01", title: "Understand Open Source", body: "Learn what open-source software is and why it matters for developers and the world." },
  { num: "02", title: "First Contributions", body: "Guided sessions to make your very first open-source PR - from fork to merge." },
  { num: "03", title: "Git & GitHub Mastery", body: "Workshops covering branches, rebasing, conflict resolution, and collaborative workflows." },
  { num: "04", title: "Global Collaboration", body: "Mentorship, blogs, and contribution drives connecting students with developers worldwide." },
];

const achievements = [
  { badge: "GSoC", title: "Google Summer of Code", body: "Members selected for GSoC, contributing to major open-source organizations worldwide." },
  { badge: "GSoD", title: "Google Season of Docs", body: "Technical writing contributions improving documentation for open-source projects." },
  { badge: "MLH", title: "MLH Fellowships", body: "Major League Hacking fellowship recipients, gaining industry experience through open source." },
];

const casaPoints = [
  "Expert-led awareness sessions",
  "Interactions with trained counselors",
  "Educational discussions on mental health and well-being",
  "Peer support network development",
];
---

<!-- Summer Bootcamp -->
<section id="community-bootcamp" class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Online Learning
        </p>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85]">
          SUMMER<br /><span class="text-[#FF5F4A]">BOOTCAMP</span>
        </h2>
        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
          ACM-VIT conducts extensive summer bootcamps through YouTube and other
          online platforms, enabling students from anywhere to learn valuable
          technical skills at their own pace. Free, accessible, and designed for
          real learning.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {bootcampTopics.map((t) => (
          <div class="flex flex-col items-center text-center gap-3 rounded-2xl border border-white/[0.06] bg-white/[0.02] px-4 py-7 transition-all duration-300 hover:border-[#FF5F4A]/30 hover:bg-[#FF5F4A]/[0.04] hover:-translate-y-1">
            <span class="text-2xl text-[#FF5F4A] font-mono">{t.icon}</span>
            <span class="text-[#FFFDD0] text-sm font-semibold uppercase tracking-wide">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Forktober Fest -->
<section id="community-forktober" class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="order-2 md:order-1 grid gap-4">
        {forktoberSteps.map((s) => (
          <div class="flex gap-4 items-start rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 transition-all duration-300 hover:border-[#FF5F4A]/25 hover:bg-[#FF5F4A]/[0.03]">
            <span class="text-[#FF5F4A] font-mono text-xs font-semibold tracking-[0.2em] pt-1 opacity-70">{s.num}</span>
            <div>
              <h3 class="text-[#FFFDD0] text-base font-semibold mb-1">{s.title}</h3>
              <p class="text-gray-400 text-xs font-mono leading-relaxed">{s.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="order-1 md:order-2">
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Open Source Month
        </p>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85]">
          FORKTOBER<br /><span class="text-[#FF5F4A]">FEST</span>
        </h2>
        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
          ACM-VIT's month-long celebration of open-source development. Workshops,
          mentorship sessions, blog posts, and contribution drives designed
          specifically for beginners stepping into the world of collaborative
          software.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Open Source & Knowledge Sharing -->
<section id="community-opensource" class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
        Building a Culture
      </p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.9]">
        OPEN SOURCE &<br /><span class="text-[#FF5F4A]">KNOWLEDGE SHARING</span>
      </h2>
      <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] mx-auto my-7"></div>
      <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed">
        ACM-VIT has consistently fostered a strong culture of open-source
        contribution and free technical education. Building contributors, not
        just consumers.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      {achievements.map((a) => (
        <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-7 transition-all duration-300 hover:border-[#FF5F4A]/30 hover:bg-[#FF5F4A]/[0.04] hover:-translate-y-1">
          <span class="inline-block px-3 py-1 rounded-md bg-[#FF5F4A]/15 border border-[#FF5F4A]/30 text-[#FF5F4A] font-mono text-xs font-bold tracking-[0.15em] uppercase mb-4">{a.badge}</span>
          <h3 class="text-[#FFFDD0] text-lg font-bold mb-2">{a.title}</h3>
          <p class="text-gray-400 text-xs font-mono leading-relaxed">{a.body}</p>
        </div>
      ))}
    </div>

    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
        <div class="flex-shrink-0">
          <p class="text-[#FF5F4A] font-mono text-[0.7rem] tracking-[0.2em] uppercase mb-1">Technical Sessions</p>
          <h3 class="text-[#FFFDD0] text-xl md:text-2xl font-bold uppercase tracking-tight">Free Learning for Everyone</h3>
        </div>
        <div class="h-px md:h-12 md:w-px bg-white/10 flex-shrink-0"></div>
        <p class="text-gray-400 text-xs md:text-sm font-mono leading-relaxed">
          ACM-VIT regularly publishes educational content and conducts technical
          sessions - making quality technical education accessible, helping
          students stay updated with industry trends, and encouraging continuous
          learning. Recent contributions include work on projects like SGLang,
          demonstrating active participation in modern open-source ecosystems.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CASA -->
<section id="community-casa" class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Student Well-being
        </p>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.85]">
          CASA
        </h2>
        <p class="text-[#FF5F4A] text-lg md:text-xl font-semibold mt-3">Campaign Against Substance Abuse</p>
        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-lg">
          Under VIT's larger CASA initiative, ACM-VIT organizes awareness
          programs focused on the dangers and consequences of substance abuse.
          The goal is to create a healthier and more informed student community.
        </p>
      </div>

      <div class="grid gap-3">
        {casaPoints.map((p) => (
          <div class="flex items-center gap-3 rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-4 transition-all duration-300 hover:border-[#FF5F4A]/20 hover:bg-[#FF5F4A]/[0.03]">
            <span class="w-2 h-2 rounded-full bg-[#FF5F4A] flex-shrink-0"></span>
            <span class="text-gray-300 text-sm font-mono">{p}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
