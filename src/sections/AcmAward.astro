---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";
import AnimatedButton from "../components/ui/AnimatedButton.astro";

const yearsSince = new Date().getFullYear() - 2009;
---

<!-- ACM International Award -->
<section id="community-award" class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Left: copy -->
      <div class="order-2 md:order-1">
        <p class="inline-flex items-center gap-2.5 text-[#FF5F4A] text-xs font-mono tracking-[0.3em] uppercase mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F4A] shadow-[0_0_10px_#FF5F4A]"></span>
          Community Recognition
        </p>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5.5rem] font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.86]">
          ACM<br /><span class="text-[#FF5F4A]">INTERNATIONAL</span><br />AWARD
        </h2>
        <div class="w-14 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] my-7"></div>
        <h3 class="text-[#FFFDD0] text-xl sm:text-2xl font-semibold mb-4">Outstanding School Service</h3>
        <p class="text-gray-300 text-sm md:text-base font-mono leading-relaxed max-w-xl mb-4">
          ACM-VIT has been awarded the ACM International Chapter Award for
          Outstanding School Service.
        </p>
        <p class="text-gray-400 text-sm md:text-base font-mono leading-relaxed max-w-xl mb-8">
          The recognition reflects a year of community-first work across
          outreach, student initiatives, and chapter-led experiences built with
          the same intent that defines the rest of ACM-VIT.
        </p>
        <div class="[&_.anim-btn-anchor]:justify-start">
          <AnimatedButton
            text="Check out the awards and more"
            href="https://www.acm.org/chapters/student-chapter-excellence-awards"
            target="_blank"
          />
        </div>
      </div>

      <!-- Right: image -->
      <div class="order-1 md:order-2 relative rounded-3xl overflow-hidden border border-white/[0.06] aspect-[4/3] md:aspect-square bg-white/[0.02]">
        <img
          src={getAssetUrl("/ui/ui-acm-celeb.webp")}
          alt="ACM-VIT with the ACM International Chapter Award"
          class="absolute inset-0 w-full h-full object-contain p-4"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<!-- Closing impact statement -->
<section class="relative z-20 py-16 md:py-24 border-t border-white/10 overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.04]"
    style={`background-image: url(${getAssetUrl("/backgrounds/backgrounds-background-pattern.webp")}); background-size: cover;`}
    aria-hidden="true"
  ></div>
  <div class="max-w-[1000px] mx-auto px-6 md:px-10 relative z-10 text-center">
    <div class="w-12 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] mx-auto mb-8"></div>
    <p class="text-[#FFFDD0] text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold leading-snug tracking-tight">
      For {yearsSince} years, ACM-VIT has not only built technologists, developers, and
      innovators - it has built <span class="text-[#FF5F4A]">communities</span>,
      empowered students, and created opportunities for thousands of individuals
      to learn, grow, and make an <span class="text-[#FF5F4A]">impact</span>.
    </p>
    <div class="w-12 h-[3px] rounded-full bg-gradient-to-r from-[#FF5F4A] to-[#ff007a] mx-auto mt-8"></div>
  </div>
</section>
