  { name: "email", url: "mailto:hello@acmvit.in", icon: "mail" },
  { name: "github", url: "https://github.com/ACM-VIT", icon: "github" },
  { name: "youtube", url: "https://www.youtube.com/@acm_vit", icon: "youtube" },
  { name: "x", url: "https://x.com/acm_vit", icon: "x" },
  { name: "acmvit", url: "https://www.instagram.com/acmvit", icon: "instagram" },
  { name: "acmwvit", url: "https://www.instagram.com/acmwvit", icon: "instagram" },
  { name: "lifeatacm", url: "https://www.instagram.com/lifeatacm", icon: "heart" },
  { name: "c2c", url: "https://www.instagram.com/c2c.acmvit", icon: "code" },
