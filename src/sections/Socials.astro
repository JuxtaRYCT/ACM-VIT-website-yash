const ICON_SVGS: Record<string, string> = {
  globe: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
  github: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 00-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 004 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  hashnode: `<svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M22.351 8.019l-6.37-6.37a5.63 5.63 0 00-7.962 0l-6.37 6.37a5.63 5.63 0 000 7.962l6.37 6.37a5.63 5.63 0 007.962 0l6.37-6.37a5.63 5.63 0 000-7.962zM12 15.953a3.953 3.953 0 110-7.906 3.953 3.953 0 010 7.906z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  x: `<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 010-10 2 2 0 011.4-1.4 49.56 49.56 0 0116.2 0A2 2 0 0121.5 7a24.12 24.12 0 010 10 2 2 0 01-1.4 1.4 49.55 49.55 0 01-16.2 0A2 2 0 012.5 17"/><path d="m10 15 5-3-5-3z"/></svg>`,
  heart: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0016.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 002 8.5c0 2.3 1.5 4.05 3 5.5l7 7z"/></svg>`,
  code: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  spotify: `<svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.622.622 0 11-.277-1.215c3.809-.871 7.077-.496 9.712 1.115a.623.623 0 01.207.857zm1.224-2.723a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 11-.452-1.491c3.632-1.102 8.147-.568 11.232 1.329a.78.78 0 01.257 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.935.935 0 11-.542-1.79c3.532-1.072 9.404-.865 13.115 1.338a.936.936 0 01-.95 1.612z"/></svg>`,
};
---

<section id="socials" class="socials-section page-section relative min-h-[200vh] z-[5]">
  <!-- Boombox pinned; the #more section above lifts like a curtain to reveal it -->
  <div class="sticky top-0 left-0 w-full h-screen flex items-center justify-center overflow-hidden bg-[#060606]">
    <h2 class="sr-only">Socials</h2>

    <!-- ══════ BOOMBOX ══════ -->
    <div class="boombox">

      <!-- ── Handle ── -->
      <div class="boombox-handle">
        <div class="handle-post handle-post-l"></div>
        <div class="handle-bar">
          <span class="handle-grip"></span>
          <span class="handle-grip"></span>
          <span class="handle-grip"></span>
          <span class="handle-grip"></span>
          <span class="handle-grip"></span>
        </div>
        <div class="handle-post handle-post-r"></div>
      </div>

      <!-- ── Main Body ── -->
      <div class="boombox-body">

        <!-- Corner screws -->
        <div class="bb-screw bb-screw-tl"></div>
        <div class="bb-screw bb-screw-tr"></div>
        <div class="bb-screw bb-screw-bl"></div>
        <div class="bb-screw bb-screw-br"></div>

        <!-- ── Tuner / Marquee Strip ── -->
        <div class="tuner-row">
          <div class="tuner-strip">
            <div class="tuner-marks" aria-hidden="true"></div>
            <div class="tuner-needle"></div>
            <div class="tuner-marquee">
              <span>NOW PLAYING&ensp;-&ensp;ACM VIT SOCIALS&ensp;-&ensp;CONNECT WITH US&ensp;-&ensp;NOW PLAYING&ensp;-&ensp;ACM VIT SOCIALS&ensp;-&ensp;CONNECT WITH US&ensp;-&ensp;</span>
            </div>
          </div>
        </div>

        <!-- ── EQ Buttons Row ── -->
        <div class="eq-row">
          {Array.from({length: 20}).map((_, i) => (
            <div class:list={['eq-btn', i % 3 === 0 ? 'eq-btn-accent' : '']}></div>
          ))}
        </div>

        <!-- ── Main Area: Speakers + Center Panel ── -->
        <div class="boombox-main">

          <!-- Left Speaker -->
          <div class="speaker-wrap">
            <div class="speaker">
              <div class="speaker-grill"></div>
              <div class="speaker-ring speaker-ring-outer"></div>
              <div class="speaker-ring speaker-ring-mid"></div>
              <div class="speaker-dome"></div>
            </div>
          </div>

          <!-- Center Panel -->
          <div class="center-panel">

            <div class="socials-title">SOCIALS</div>


            <!-- Cassette peeking out of the deck slot (only top portion visible) -->
            <div class="cassette-deck">
              <div class="cassette-slot">
              <svg class="cassette-svg" viewBox="0 0 280 175" xmlns="http://www.w3.org/2000/svg">
                <!-- Body -->
                <rect class="cassette-body" x="0.75" y="0.75" width="278.5" height="173.5" rx="11" />

                <!-- Cover area (top ~65%) -->
                <path class="cassette-cover" d="
                  M 18 10
                  L 22 10 L 28 16 L 252 16 L 258 10 L 262 10
                  Q 266 10 266 14
                  L 266 120
                  L 14 120
                  L 14 14
                  Q 14 10 18 10
                  Z
                " />

                <!-- Cover inner shadow lines -->
                <line class="cover-line" x1="20" y1="22" x2="260" y2="22" />
                <line class="cover-line" x1="20" y1="114" x2="260" y2="114" />

                <!-- Left reel -->
                <g class="reel reel-left">
                  <circle cx="92" cy="62" r="24" class="reel-outer" />
                  <circle cx="92" cy="62" r="16" class="reel-mid" />
                  <circle cx="92" cy="62" r="5.5" class="reel-hub" />
                  <g class="reel-spokes-l" style="transform-origin: 92px 62px">
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" />
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" transform="rotate(60, 92, 62)" />
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" transform="rotate(120, 92, 62)" />
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" transform="rotate(180, 92, 62)" />
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" transform="rotate(240, 92, 62)" />
                    <line x1="92" y1="43" x2="92" y2="38" class="reel-spoke" transform="rotate(300, 92, 62)" />
                  </g>
                  <circle cx="92" cy="62" r="19" class="reel-tape reel-tape-left" />
                </g>

                <!-- Right reel -->
                <g class="reel reel-right">
                  <circle cx="188" cy="62" r="24" class="reel-outer" />
                  <circle cx="188" cy="62" r="16" class="reel-mid" />
                  <circle cx="188" cy="62" r="5.5" class="reel-hub reel-hub-accent" />
                  <g class="reel-spokes-r" style="transform-origin: 188px 62px">
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" />
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" transform="rotate(60, 188, 62)" />
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" transform="rotate(120, 188, 62)" />
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" transform="rotate(180, 188, 62)" />
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" transform="rotate(240, 188, 62)" />
                    <line x1="188" y1="43" x2="188" y2="38" class="reel-spoke" transform="rotate(300, 188, 62)" />
                  </g>
                  <circle cx="188" cy="62" r="10" class="reel-tape reel-tape-right" />
                </g>

                <!-- Tape path between reels -->
                <path class="tape-path" d="M 68 62 A 24 24 0 0 0 92 86 L 188 86 A 24 24 0 0 0 212 62" />

                <!-- Tape window (transparent opening) -->
                <rect class="tape-window" x="118" y="73" width="44" height="16" rx="3" />

                <!-- Center post -->
                <circle class="center-post" cx="140" cy="62" r="2.5" />

                <!-- Label strip -->
                <rect class="cassette-label" x="58" y="95" width="164" height="18" rx="9" />
                <text class="label-text" x="140" y="107" text-anchor="middle" dominant-baseline="middle">
                  BECAUSE TECHNOLOGY MATTERS
                </text>

                <!-- Bottom area -->
                <path class="cassette-bump" d="M 85 132 L 98 158 Q 100 162 104 162 L 176 162 Q 180 162 182 158 L 195 132" />

                <!-- Pin holes row -->
                <g class="pin-holes">
                  <circle cx="90" cy="143" r="1.8" />
                  <circle cx="102" cy="143" r="1.8" />
                  <circle cx="114" cy="143" r="1.8" />
                  <circle cx="126" cy="143" r="1.8" />
                  <circle cx="140" cy="143" r="2.2" />
                  <circle cx="154" cy="143" r="1.8" />
                  <circle cx="166" cy="143" r="1.8" />
                  <circle cx="178" cy="143" r="1.8" />
                  <circle cx="190" cy="143" r="1.8" />
                </g>
              </svg>
              </div>
            </div>

            <!-- ── Control Knobs (centered, drive the player) ── -->
            <div class="knob-console">
              <div class="knob-unit">
                <div class="tuner-knob" id="knob-vol" role="slider" tabindex="0" aria-label="Volume" aria-valuemin="0" aria-valuemax="100">
                  <div class="tuner-knob-inner"></div>
                  <span class="knob-notch"></span>
                </div>
                <span class="knob-label">VOL</span>
              </div>
              <div class="knob-unit">
                <div class="tuner-knob" id="knob-seek" role="slider" tabindex="0" aria-label="Seek" aria-valuemin="0" aria-valuemax="100">
                  <div class="tuner-knob-inner"></div>
                  <span class="knob-notch"></span>
                </div>
                <span class="knob-label">SEEK</span>
              </div>
              <div class="knob-unit">
                <div class="tuner-knob" id="knob-speed" role="slider" tabindex="0" aria-label="Playback speed" aria-valuemin="0" aria-valuemax="100">
                  <div class="tuner-knob-inner"></div>
                  <span class="knob-notch"></span>
                </div>
                <span class="knob-label">SPEED</span>
              </div>
              <div class="knob-unit">
                <div class="tuner-knob" id="knob-track" role="slider" tabindex="0" aria-label="Track select">
                  <div class="tuner-knob-inner"></div>
                  <span class="knob-notch"></span>
                </div>
                <span class="knob-label">TRACK</span>
              </div>
            </div>

            <!-- Transport Controls -->
            <div class="transport-row">
              <button class="transport-btn" data-action="rewind" aria-label="Rewind">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M11 18V6l-8.5 6 8.5 6zm.5-6l8.5 6V6l-8.5 6z"/></svg>
              </button>
              <button class="transport-btn" data-action="stop" aria-label="Stop">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
              </button>
              <button class="transport-btn transport-play" data-action="play" aria-label="Play">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </button>
              <button class="transport-btn" data-action="forward" aria-label="Fast Forward">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M4 18l8.5-6L4 6v12zm9-12v12l8.5-6L13 6z"/></svg>
              </button>
            </div>

            <!-- Social Buttons Grid -->
            <div class="social-grid">
              {SOCIALS.map((social) => (
                <a
                  href={social.url}
                  class="social-btn"
                  target={social.url.startsWith('mailto:') ? undefined : '_blank'}
                  rel={social.url.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
                  aria-label={social.name}
                >
                  <div class="social-btn-face">
                    <Fragment set:html={ICON_SVGS[social.icon]} />
                    <span class="social-btn-label">{social.name}</span>
                  </div>
                </a>
              ))}
            </div>

          </div>

          <!-- Right Speaker -->
          <div class="speaker-wrap">
            <div class="speaker">
              <div class="speaker-grill"></div>
              <div class="speaker-ring speaker-ring-outer"></div>
              <div class="speaker-ring speaker-ring-mid"></div>
              <div class="speaker-dome"></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════
     BOOMBOX - Full-screen cassette player
     ══════════════════════════════════════ */

  .boombox {
    width: 100%;
    max-width: none;
    height: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* ── Handle ── */
  .boombox-handle {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 44px;
    padding: 0 18%;
    position: relative;
    z-index: 2;
  }

  .handle-post {
    width: 14px;
    height: 36px;
    background: linear-gradient(180deg, #2a3240 0%, #222a36 100%);
    border: 1.5px solid rgba(255,255,255,0.06);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    flex-shrink: 0;
  }

  .handle-bar {
    flex: 1;
    height: 18px;
    background: linear-gradient(180deg, #343e4e 0%, #2a3240 100%);
    border: 1.5px solid rgba(255,255,255,0.08);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0 12px;
  }

  .handle-grip {
    width: 10px;
    height: 8px;
    border-radius: 3px;
    background: #1a2030;
    border: 1px solid rgba(255,255,255,0.06);
  }

  /* ── Main Body ── */
  .boombox-body {
    position: relative;
    background: linear-gradient(180deg,
      #ff7a66 0%,
      #fb6b53 15%,
      #F95F4A 50%,
      #e8513d 85%,
      #d4452f 100%
    );
    border: 2.5px solid rgba(255,255,255,0.12);
    border-radius: 18px;
    box-shadow:
      inset 0 2px 0 rgba(255,255,255,0.06),
      inset 0 -3px 8px rgba(0,0,0,0.4),
      0 30px 80px rgba(0,0,0,0.6),
      0 10px 30px rgba(0,0,0,0.4);
    padding: 16px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
    flex: 1;
    min-height: 0;
  }

  /* ── Checkerboard texture ── */
  .boombox-body::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(0,0,0,0.07) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.07) 75%),
      linear-gradient(45deg, rgba(0,0,0,0.07) 25%, transparent 25%, transparent 75%, rgba(0,0,0,0.07) 75%);
    background-position: 0 0, 22px 22px;
    background-size: 44px 44px;
    opacity: 0.6;
    pointer-events: none;
    z-index: 0;
  }

  .boombox-body > .tuner-row,
  .boombox-body > .eq-row,
  .boombox-body > .boombox-main {
    position: relative;
    z-index: 1;
  }

  /* ── Corner Screws ── */
  .bb-screw {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, #F95F4A, #c4442e);
    opacity: 0.55;
    z-index: 10;
    box-shadow: inset 0 -1px 2px rgba(0,0,0,0.4);
  }
  .bb-screw-tl { top: 10px; left: 10px; }
  .bb-screw-tr { top: 10px; right: 10px; }
  .bb-screw-bl { bottom: 10px; left: 10px; }
  .bb-screw-br { bottom: 10px; right: 10px; }

  /* ── Tuner Strip ── */
  .tuner-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 8px;
  }

  .knob-console {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(16px, 4vw, 40px);
    padding: 4px 0 2px;
  }

  .knob-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .knob-label {
    font-family: 'PolySans Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    color: rgba(254,252,217,0.8);
    text-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }

  .tuner-knob {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 38% 30%, #232f3d 0%, #11161e 55%, #070a0f 100%);
    border: 2px solid rgba(255,255,255,0.16);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: grab;
    touch-action: none;
    box-shadow:
      inset 0 -3px 6px rgba(0,0,0,0.6),
      inset 0 2px 3px rgba(255,255,255,0.08),
      0 3px 8px rgba(0,0,0,0.5);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .tuner-knob:hover,
  .tuner-knob:focus-visible {
    border-color: rgba(249,95,74,0.4);
    outline: none;
  }

  .tuner-knob.knob-grabbing {
    cursor: grabbing;
    border-color: rgba(249,95,74,0.6);
  }

  .tuner-knob-inner {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #2a3848, #141c26);
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: inset 0 1px 2px rgba(255,255,255,0.06);
  }

  /* Pointer notch shows rotation */
  .knob-notch {
    position: absolute;
    top: 4px;
    left: 50%;
    width: 3px;
    height: 12px;
    margin-left: -1.5px;
    border-radius: 2px;
    background: #F95F4A;
    box-shadow: 0 0 6px rgba(249,95,74,0.8);
  }

  .tuner-strip {
    flex: 1;
    height: 30px;
    background: #060a10;
    border: 1.5px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }

  .tuner-marks {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0px,
      transparent 8px,
      rgba(255,255,255,0.06) 8px,
      rgba(255,255,255,0.06) 9px
    );
    z-index: 0;
  }

  .tuner-needle {
    position: absolute;
    top: 2px;
    bottom: 2px;
    left: 52%;
    width: 2px;
    background: #F95F4A;
    border-radius: 1px;
    box-shadow: 0 0 6px rgba(249,95,74,0.6);
    z-index: 2;
  }

  .tuner-marquee {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    overflow: hidden;
    z-index: 1;
  }

  .tuner-marquee span {
    font-family: 'PolySans Mono', monospace;
    font-size: 10px;
    color: rgba(249,95,74,0.7);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
    animation: marqueeScroll 20s linear infinite;
    text-shadow: 0 0 6px rgba(249,95,74,0.3);
  }

  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── EQ Buttons Row ── */
  .eq-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 2px 30px;
  }

  .eq-btn {
    width: 100%;
    max-width: 40px;
    height: 14px;
    border-radius: 3px;
    background: #0e141c;
    border: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
    cursor: pointer;
  }

  .eq-btn:hover {
    background: #1a2030;
    border-color: rgba(255,255,255,0.1);
  }

  .eq-btn-accent {
    border-color: rgba(249,95,74,0.15);
  }

  .eq-btn-accent:hover {
    border-color: rgba(249,95,74,0.35);
    box-shadow: 0 0 6px rgba(249,95,74,0.1);
  }

  /* ── Main Area (speakers + center) ── */
  .boombox-main {
    display: flex;
    align-items: stretch;
    gap: 16px;
    flex: 1;
    min-height: 0;
  }

  /* ── Speakers ── */
  .speaker-wrap {
    flex: 0 0 28%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  .speaker {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #0a0e14;
    position: relative;
    box-shadow:
      inset 0 4px 20px rgba(0,0,0,0.5),
      inset 0 -2px 10px rgba(0,0,0,0.3),
      0 2px 8px rgba(0,0,0,0.3);
    overflow: hidden;
  }

  .speaker-grill {
    position: absolute;
    inset: 6%;
    border-radius: 50%;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.06) 1.2px, transparent 1.2px);
    background-size: 8px 8px;
  }

  .speaker-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .speaker-ring-outer {
    inset: 12%;
  }

  .speaker-ring-mid {
    inset: 30%;
  }

  .speaker-dome {
    position: absolute;
    inset: 40%;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, rgba(255,255,255,0.06), rgba(0,0,0,0.2));
    border: 1px solid rgba(255,255,255,0.05);
  }

  /* ── Speaker pulse while music plays ── */
  .speaker-dome,
  .speaker-ring-mid {
    transform-origin: center;
    will-change: transform;
  }

  .boombox.bb-music-on .speaker-dome {
    animation: speakerThump 0.5s ease-in-out infinite;
  }
  .boombox.bb-music-on .speaker-ring-mid {
    animation: speakerThump 0.5s ease-in-out infinite;
  }
  .boombox.bb-music-on .speaker-ring-outer {
    animation: speakerGlow 0.5s ease-in-out infinite;
  }
  /* Right speaker slightly offbeat for life */
  .boombox.bb-music-on .speaker-wrap:last-child .speaker-dome,
  .boombox.bb-music-on .speaker-wrap:last-child .speaker-ring-mid,
  .boombox.bb-music-on .speaker-wrap:last-child .speaker-ring-outer {
    animation-delay: 0.25s;
  }

  @keyframes speakerThump {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.07); }
  }

  @keyframes speakerGlow {
    0%, 100% { border-color: rgba(255,255,255,0.04); }
    50% { border-color: rgba(249,95,74,0.22); }
  }

  @media (prefers-reduced-motion: reduce) {
    .boombox.bb-music-on .speaker-dome,
    .boombox.bb-music-on .speaker-ring-mid,
    .boombox.bb-music-on .speaker-ring-outer {
      animation: none;
    }
  }

  /* ── Center Panel ── */
  .center-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }

  .socials-title {
    font-family: 'PolySans Bulky Wide', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 1.05;
    text-align: center;
    color: #1e1e1e;
    padding-top: 8px;
  }

  /* ── Cassette (glass, reused from preloader) ── */
  .cassette-deck {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-height: 0;
  }

  /* Slot: clips the cassette so only the top ~60% peeks out */
  .cassette-slot {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 280 / 120;
    overflow: hidden;
    border-radius: 14px 14px 0 0;
  }

  .cassette-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Slot mouth - cassette fades into the deck at the cut edge */
  .cassette-slot::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 26px;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.35) 45%, transparent 100%);
    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.6);
    border-top: 1px solid rgba(0,0,0,0.5);
    pointer-events: none;
  }

  .cassette-body {
    fill: #161616;
    stroke: rgba(255,255,255,0.15);
    stroke-width: 1.5;
  }

  .cassette-cover {
    fill: #0d0d0d;
    stroke: rgba(255,255,255,0.12);
    stroke-width: 0.75;
  }

  .cover-line {
    stroke: rgba(255,255,255,0.14);
    stroke-width: 0.5;
  }

  /* Reels */
  .reel-outer { fill: none; stroke: rgba(255,255,255,0.4); stroke-width: 1.2; }
  .reel-mid   { fill: none; stroke: rgba(255,255,255,0.22); stroke-width: 0.8; }
  .reel-hub   { fill: none; stroke: rgba(255,255,255,0.55); stroke-width: 1.5; }
  .reel-hub-accent { stroke: #FEFCD9; }
  .reel-spoke { stroke: rgba(255,255,255,0.3); stroke-width: 1.5; stroke-linecap: round; }

  .reel-tape { fill: none; stroke: rgba(255,255,255,0.14); stroke-width: 5; }
  .reel-tape-left  { stroke-width: 7; stroke: rgba(255,255,255,0.17); }
  .reel-tape-right { stroke-width: 3; stroke: rgba(255,255,255,0.12); }

  .reel-spokes-l { animation: reelSpin 2s linear infinite; }
  .reel-spokes-r { animation: reelSpin 1.4s linear infinite reverse; }

  @keyframes reelSpin {
    to { transform: rotate(360deg); }
  }

  .tape-path { fill: none; stroke: rgba(255,255,255,0.2); stroke-width: 0.8; }

  .tape-window {
    fill: rgba(0,0,0,0.22);
    stroke: rgba(255,255,255,0.2);
    stroke-width: 0.6;
  }

  .center-post { fill: rgba(255,255,255,0.35); }

  .cassette-label {
    fill: none;
    stroke: rgba(255,255,255,0.24);
    stroke-width: 0.8;
  }

  .label-text {
    font-family: 'PolySans Mono', 'Courier New', monospace;
    font-size: 5px;
    letter-spacing: 0.1em;
    fill: rgba(254,252,217,0.85);
    font-weight: 500;
    text-transform: uppercase;
  }

  .cassette-bump { fill: none; stroke: rgba(255,255,255,0.2); stroke-width: 0.8; }

  .pin-holes circle { fill: rgba(255,255,255,0.2); }

  /* ── Transport Controls ── */
  .transport-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .transport-btn {
    width: 36px;
    height: 30px;
    border-radius: 5px;
    background: #0e141c;
    border: 1.5px solid rgba(255,255,255,0.06);
    box-shadow:
      inset 0 -1px 2px rgba(0,0,0,0.3),
      0 2px 4px rgba(0,0,0,0.3);
    color: rgba(254,252,217,0.35);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
    padding: 0;
  }

  .transport-btn:hover {
    color: rgba(254,252,217,0.7);
    background: #161c28;
    border-color: rgba(255,255,255,0.1);
  }

  .transport-btn:active {
    transform: translateY(1px);
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.5);
  }

  .transport-play {
    width: 38px;
    height: 32px;
    background: #FEFCD9;
    border-color: rgba(0,0,0,0.2);
    color: #1a1a1a;
    border-radius: 6px;
    box-shadow: 0 0 10px rgba(254,252,217,0.25), 0 2px 4px rgba(0,0,0,0.35);
  }

  .transport-play:hover {
    background: #fff;
    color: #1a1a1a;
    box-shadow: 0 0 16px rgba(254,252,217,0.4), 0 2px 6px rgba(0,0,0,0.4);
  }

  /* ── Social Buttons Grid ── */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px 10px;
    padding: 4px 0;
  }

  .social-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    outline: none;
  }

  .social-btn-face {
    width: 100%;
    max-width: 96px;
    aspect-ratio: 1;
    border-radius: 14px;
    padding: 6px;
    background: linear-gradient(180deg, #1c2434 0%, #121a26 100%);
    border: 1.5px solid rgba(255,255,255,0.05);
    box-shadow:
      inset 0 -2px 4px rgba(0,0,0,0.3),
      inset 0 1px 2px rgba(255,255,255,0.03),
      0 3px 10px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    color: rgba(254,252,217,0.55);
    transition: all 0.22s cubic-bezier(0.25,0.1,0.25,1);
    will-change: transform, box-shadow;
  }

  .social-btn:hover .social-btn-face {
    color: #F95F4A;
    border-color: rgba(249,95,74,0.25);
    box-shadow:
      inset 0 -2px 4px rgba(0,0,0,0.3),
      0 0 20px rgba(249,95,74,0.12),
      0 6px 14px rgba(0,0,0,0.5);
    transform: translateY(-2px);
  }

  .social-btn:active .social-btn-face {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 6px rgba(0,0,0,0.5),
      0 0 10px rgba(249,95,74,0.06);
    transition-duration: 0.06s;
  }

  .social-btn:focus-visible .social-btn-face {
    outline: 2px solid #F95F4A;
    outline-offset: 2px;
  }

  .social-btn-label {
    font-family: 'PolySans Trial', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: rgba(254,252,217,0.9);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
    text-align: center;
    line-height: 1.1;
    word-break: break-word;
  }

  .social-btn:hover .social-btn-label {
    color: #FEFCD9;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .boombox { width: 96vw; }
    .speaker-wrap { flex: 0 0 24%; }
    .social-grid { grid-template-columns: repeat(3, 1fr); }
    .social-btn-face { max-width: 64px; }
  }

  @media (max-width: 640px) {
    .boombox-body { padding: 12px 12px 16px; gap: 8px; }
    .speaker-wrap { display: none; }
    .boombox-main { gap: 0; }
    .social-grid { grid-template-columns: repeat(3, 1fr); gap: 10px 12px; }
    .social-btn-face {
      max-width: 68px;
      border-radius: 12px;
    }
    .social-btn-face :global(svg) {
      width: 22px;
      height: 22px;
    }
    .social-btn-label { font-size: 9px; }
    .boombox-handle { padding: 0 10%; }
    .eq-row { padding: 2px 10px; gap: 3px; }
    .cassette-svg { max-width: 300px; }
  }

  /* ══════ LIGHT MODE ══════ */
  :global(html[data-theme="light"]) .boombox-body {
    background: linear-gradient(180deg,
      #ff8a78 0%,
      #fb6b53 15%,
