  }

  :global(html[data-theme="light"]) .handle-bar {
    background: linear-gradient(180deg, #96a2b0, #8a96a4);
    border-color: rgba(0,0,0,0.08);
  }

  :global(html[data-theme="light"]) .handle-grip {
    background: #7a8694;
    border-color: rgba(0,0,0,0.06);
  }

  :global(html[data-theme="light"]) .tuner-strip {
    background: #1a1e24;
  }

  :global(html[data-theme="light"]) .tuner-knob {
