---
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";
import AnimatedButton from "../components/ui/AnimatedButton.astro";
---

<div class="min-h-screen overflow-x-hidden">
  <!-- Part A: Outreach Event -->
  <div id="community" class="absolute -top-24 pointer-events-none"></div>
  <section
    id="community-outreach"
    class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
  >
    <div
      class="max-w-[1400px] mx-auto md:grid md:grid-cols-10 md:grid-rows-5 gap-0 relative z-10 md:min-h-[600px]"
    >
      <!-- Horizontal Lines (Grid Row 3) - Visible on Left -->
      <div
        class="hidden md:block col-start-1 col-end-11 row-start-3 row-end-4 border-t-2 border-b-2 border-dashed border-[#999999]/50 pointer-events-none z-20"
        style="mask-image: linear-gradient(to right, black 50%, transparent 50%); -webkit-mask-image: linear-gradient(to right, black 50%, transparent 50%);"
      >
      </div>

      <!-- Left: Text Content -->
      <!-- Top Section - Title (Rows 1-2) -->
      <div
        class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-1 md:row-end-3 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="p-6 md:p-10 flex items-start h-full">
          <h1
            class="text-5xl sm:text-6xl md:text-7xl lg:text-[8rem] leading-[0.85] font-bold text-[#FFFDD0] uppercase tracking-tighter break-words"
          >
            OUTREACH<br />
            <span class="text-[#FF5F4A]">EVENT</span>
          </h1>
        </div>
      </div>

      <!-- Middle Section - Beyond the Norm (Row 3) -->
      <div
        class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-3 md:row-end-4 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="px-6 md:px-10 py-4 md:py-0 flex items-center h-full">
          <div class="relative">
            <div
              class="text-[#FF5F4A] text-3xl sm:text-4xl md:text-5xl font-bold font-['Inter'] leading-tight md:leading-none"
            >
              BEYOND <img
                src={getAssetUrl("/outreach/beyond-norm-logo.webp")}
                alt="Logo"
                class="inline h-8 sm:h-10 md:h-12 ml-2 align-baseline"
                loading="lazy"
                decoding="async"
              /><br />THE NORM
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Section - Empty/Mobile Desc (Rows 4-5) -->
      <div
        class="flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-4 md:row-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="p-6 md:p-10 h-full block md:hidden">
          <div
            class="text-left text-gray-300 text-lg font-mono leading-relaxed max-[640px]:text-base max-[480px]:text-[0.95rem]"
          >
            Our outreach initiative brought the world of computing to students
            of classes 7 to 9, using the theme "Flowcharts and Digital Logic."
            Through interactive demonstrations, simplified explanations of
            binary thinking, and real-life examples of logic gates, students
            discovered how computers "think" and solve problems. The session not
            only introduced them to structured problem-solving through
            flowcharts but also connected everyday technology to the
            fundamentals of digital design, sparking curiosity and encouraging
            young learners to explore the world of computing.
          </div>
        </div>
      </div>

      <!-- Right: Image and Description (Rows 1-5) -->
      <div
        class="relative h-[50vh] md:h-full group md:col-start-6 md:col-end-11 md:row-start-1 md:row-end-6"
      >
        <!-- Image -->
        <div class="absolute inset-0">
          <img
            src={getAssetUrl("/outreach/outreach-event.webp")}
            alt="Outreach Event"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Overlay Text - Only on desktop -->
        <div
          class="hidden md:block absolute bottom-8 right-10 left-10 text-right text-gray-300 text-lg font-mono leading-relaxed max-w-lg ml-auto z-10"
        >
          Our outreach initiative brought the world of computing to students of
          classes 7 to 9, using the theme "Flowcharts and Digital Logic."
          Through interactive demonstrations, simplified explanations of binary
          thinking, and real-life examples of logic gates, students discovered
          how computers "think" and solve problems. The session not only
          introduced them to structured problem-solving through flowcharts but
          also connected everyday technology to the fundamentals of digital
          design, sparking curiosity and encouraging young learners to explore
          the world of computing.
        </div>
      </div>
    </div>
  </section>

  <!-- Part B: SDG Section -->
  <section
    id="community-sdg"
    class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
  >
    <div
      class="max-w-[1400px] mx-auto flex flex-col md:grid md:grid-cols-10 md:grid-rows-5 gap-0 relative z-10 md:min-h-[600px]"
    >
      <!-- Horizontal Lines (Grid Row 3) - Visible on Left -->
      <div
        class="hidden md:block col-start-1 col-end-11 row-start-3 row-end-4 border-t-2 border-b-2 border-dashed border-[#999999]/50 pointer-events-none z-20"
        style="mask-image: linear-gradient(to right, black 50%, transparent 50%); -webkit-mask-image: linear-gradient(to right, black 50%, transparent 50%);"
      >
      </div>

      <!-- Left Side -->
      <!-- Top Section - Empty (Rows 1-2) -->
      <div
        class="hidden md:flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-1 md:row-end-3 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="hidden md:block h-full p-10"></div>
      </div>

      <!-- Middle Section - Educate Young Minds (Row 3) -->
      <div
        class="flex flex-col h-full order-2 md:order-1 md:col-start-1 md:col-end-6 md:row-start-3 md:row-end-4 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="px-6 md:px-6 py-4 md:py-0 flex items-center h-full">
          <div class="relative">
            <div
              class="text-[#FF5F4A] text-3xl sm:text-4xl md:text-5xl font-bold font-['Inter'] leading-tight md:leading-none"
            >
              EDUCATE <img
                src={getAssetUrl("/outreach/beyond-norm-logo.webp")}
                alt="Logo"
                class="inline h-8 sm:h-10 md:h-12 ml-2 align-baseline"
                loading="lazy"
                decoding="async"
              /><br />YOUNG MINDS
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Section - Description (Rows 4-5) -->
      <div
        class="flex flex-col h-full order-3 md:order-1 md:col-start-1 md:col-end-6 md:row-start-4 md:row-end-6 md:border-r-2 md:border-dashed md:border-[#999999]/50"
      >
        <div class="p-6 md:p-2 h-full flex items-start md:items-end">
          <div
            class="text-left text-gray-300 text-lg font-mono leading-relaxed max-w-lg max-[640px]:text-base max-[480px]:text-[0.95rem]"
          >
            Aligned with UN Sustainable Development Goal 4: Quality Education.
            This workshop focused on reducing the digital learning gap in rural
            communities. Participants explored modern web technologies and
            learned how simple digital tools can strengthen classrooms with
            limited resources. By combining technical learning with real social
            impact, the session emphasized ACM-VIT's commitment to inclusive,
            technology-driven growth, empowering participants to support better
            educational access in rural areas.
          </div>
        </div>
      </div>

      <!-- Right Side: SDG Title (Rows 1-5) -->
      <div
        class="p-6 md:p-10 flex flex-col justify-start h-full order-1 md:order-2 md:col-start-6 md:col-end-11 md:row-start-1 md:row-end-6"
      >
        <div
          class="md:h-[43%] flex flex-col items-start justify-start gap-4 md:gap-6 pt-0 md:pt-8"
        >
          <h1
            class="text-6xl sm:text-7xl md:text-[8rem] leading-none font-bold text-[#FFFDD0] uppercase tracking-tighter"
          >
            SDG
          </h1>
          <h2
            class="text-2xl sm:text-3xl md:text-4xl text-[#FF5F4A] font-normal leading-tight"
          >
            Simplifying Digital<br />
            Learning for Rural Schools
          </h2>
        </div>
        <!-- Empty spacers maintained for spacing emulation if needed, or removed if handled by simple flow -->
        <div class="hidden md:flex md:h-[14%] items-center"></div>
        <div class="hidden md:flex md:h-[43%] items-end justify-end"></div>
      </div>
    </div>
  </section>

  <section
    id="community-award"
    class="relative z-20 py-12 md:py-20 border-t border-white/10 overflow-hidden"
  >
    <div
      class="max-w-[1400px] mx-auto flex flex-col md:grid md:grid-cols-10 md:grid-rows-5 gap-0 relative z-10 md:min-h-[640px]"
    >
      <div
        class="order-2 md:order-1 flex flex-col h-full md:col-start-1 md:col-end-6 md:row-start-1 md:row-end-6"
      >
        <div class="p-6 md:p-10 md:pr-14 h-full flex flex-col justify-between gap-8">
          <div class="space-y-6">
            <p
              class="text-[#FF5F4A] text-lg font-mono tracking-[0.28em] max-[640px]:text-base max-[480px]:text-[0.95rem]"
            >
              Community Recognition
            </p>
            <h1
              class="community-award-title text-5xl sm:text-6xl md:text-7xl lg:text-[6.75rem] leading-[0.86] font-bold text-[#FFFDD0] uppercase tracking-tighter"
            >
              ACM<br />
              <span class="text-[#FF5F4A]">INTERNATIONAL</span><br />
              AWARD
            </h1>
          </div>

          <div class="max-w-xl space-y-5">
            <h2
              class="text-[#FFFDD0] text-xl sm:text-2xl md:text-3xl font-semibold leading-tight"
            >
              Outstanding School Service
            </h2>
            <p
              class="text-gray-300 text-lg font-mono leading-relaxed max-[640px]:text-base max-[480px]:text-[0.95rem]"
            >
              Happy to announce that ACM-VIT has been awarded the ACM
              International Chapter Award for Outstanding School Service.
            </p>
            <p
              class="text-gray-400 text-lg font-mono leading-relaxed max-[640px]:text-base max-[480px]:text-[0.95rem]"
            >
              The recognition reflects a year of community-first work across
              outreach, student initiatives, and chapter-led experiences built
              with the same intent that defines the rest of ACM-VIT.
            </p>
            <AnimatedButton
              text="Check out the awards and more"
              href="https://www.acm.org/chapters/student-chapter-excellence-awards"
              target="_blank"
            />
          </div>
        </div>
      </div>

      <div
        class="order-1 md:order-2 relative md:col-start-6 md:col-end-11 md:row-start-1 md:row-end-6 min-h-[320px] sm:min-h-[420px] md:min-h-0"
      >
        <div class="absolute inset-0 p-4 md:p-10 md:pl-32 flex items-center justify-center">
          <div
            class="relative h-full w-full flex items-center justify-center overflow-hidden"
          >
            <img
              src={getAssetUrl("/ui/acm-celeb.png")}
              alt="ACM-VIT with the ACM International Chapter Award"
              class="max-h-full w-full object-contain object-center"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .bg-dots-pattern {
    background-image: radial-gradient(#333 1px, transparent 1px);
    background-size: 20px 20px;
  }

  @media (max-width: 399.98px) {
    .community-award-title {
      font-size: 2.4rem;
    }
  }
</style>
