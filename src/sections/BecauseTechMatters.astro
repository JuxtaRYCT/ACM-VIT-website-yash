---
// Because Technology Matters
---

<div class="relative -mt-28">
  <section
    class="btm-section w-screen min-h-[130vh] relative flex items-center justify-center overflow-hidden"
    id="tech-hero"
  >
    <!-- Main text -->
    <div class="btm-text-container relative z-10" id="textContainer">
      <div class="btm-line btm-line-1">
        <span class="btm-word btm-word-accent">because</span>
      </div>
      <div class="btm-line btm-line-2">
        <span class="btm-word">technology</span>
      </div>
      <div class="btm-line btm-line-3">
        <span class="btm-word btm-word-outline">matters</span>
      </div>
    </div>
  </section>
</div>

<style>
  .btm-section {
    position: relative;
    background: transparent;
  }

  /* ── Typography ── */
  .btm-text-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 12vw;
    width: 100%;
  }

  .btm-line {
    overflow: visible;
    opacity: 0;
    transform: translateY(60px);
  }

  .btm-word {
    font-family: "PolySans Bulky Wide", sans-serif;
    font-size: clamp(3rem, 8vw, 8rem);
    font-weight: 800;
    line-height: 1.05;
    color: #FEFCD9;
    display: inline-block;
    transition: color 0.6s ease, -webkit-text-stroke 0.6s ease;
  }

  .btm-word-accent {
    color: #f95f4a;
  }

  .btm-word-outline {
    color: transparent;
    -webkit-text-stroke: 2.5px #FEFCD9;
    transition: -webkit-text-stroke-color 0.6s ease;
  }

  /* ── Light mode ── */
  :global(html[data-theme="light"]) .btm-word {
    color: #1a1a1a;
  }
  :global(html[data-theme="light"]) .btm-word-accent {
    color: #f95f4a;
  }
  :global(html[data-theme="light"]) .btm-word-outline {
    -webkit-text-stroke-color: #1a1a1a;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .btm-text-container {
      padding-left: 8vw;
    }
    .btm-word {
      font-size: clamp(2.2rem, 10vw, 4rem);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initBTM = () => {
    const section = document.getElementById("tech-hero");
    if (!section) return;

    const lines = section.querySelectorAll(".btm-line");

    // Text reveal - staggered
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 70%",
        end: "top 20%",
        scrub: 0.6,
      },
    });

    lines.forEach((line, i) => {
      tl.to(
        line,
        {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power3.out",
        },
        i * 0.3
      );
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBTM);
  } else {
    initBTM();
  }
</script>
