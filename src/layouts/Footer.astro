---
// Footer.astro
import { getAssetUrl, getMediaUrl } from "../utils/cdn";

const currentYear = new Date().getFullYear();

// Social icons - brand marks from Simple Icons (simpleicons.org), 24x24 viewBox.
// Inlined as SVG so every glyph renders at identical size and recolors via
// currentColor (clean orange hover, no per-asset padding mismatch).
const socials: { label: string; href: string; path: string }[] = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/acmvit",
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z",
  },
  {
    label: "X",
    href: "https://x.com/acm_vit",
    path: "M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z",
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/acmvit",
    path: "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0Zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.897 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.897-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03Zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162ZM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4Zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439Z",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@acm_vit",
    path: "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
  {
    label: "Hashnode",
    href: "https://blog.acmvit.in",
    path: "M22.351 8.019l-6.37-6.37a5.63 5.63 0 0 0-7.962 0l-6.37 6.37a5.63 5.63 0 0 0 0 7.962l6.37 6.37a5.63 5.63 0 0 0 7.962 0l6.37-6.37a5.63 5.63 0 0 0 0-7.962zM12 15.953a3.953 3.953 0 1 1 0-7.906 3.953 3.953 0 0 1 0 7.906z",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/acmvitvellore",
    path: "M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 0 1 1-1h3V2.5h-3a5 5 0 0 0-5 5v2.01h-2l-.396 3.98h2.396v8.01Z",
  },
];

const socialLinksHtml = socials
  .map(
    (s) =>
      `<a href="${s.href}" aria-label="${s.label}" target="_blank" rel="noopener noreferrer" class="footer-social"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="${s.path}"/></svg></a>`
  )
  .join("");

type FooterLink = { label: string; href: string };
type FooterColumn = { title: string; links: FooterLink[] };

const footerNav: FooterColumn[] = [
  {
    title: "Explore",
    links: [
      { label: "About", href: "/#about" },
      { label: "Domains", href: "/#domains" },
      { label: "Events", href: "/#events" },
      { label: "Projects", href: "/#projects" },
      { label: "ACM-W", href: "/#acm-w" },
      { label: "Community", href: "/#community" },
    ],
  },
  {
    title: "Domains",
    links: [
      { label: "Tech", href: "/domains/tech" },
      { label: "Competitive Coding", href: "/domains/cc" },
      { label: "Design", href: "/domains/design" },
      { label: "Management", href: "/domains/management" },
      { label: "Research", href: "/domains/research" },
    ],
  },
  {
    title: "Events",
    links: [
      { label: "All Events", href: "/events" },
      { label: "Code2Create", href: "/events/code2create" },
      { label: "Cryptic Hunt", href: "/events/cryptic-hunt" },
      { label: "Reverse Coding", href: "/events/reverse-coding" },
      { label: "Forktober", href: "/events/forktober" },
      { label: "The Tiny Hack", href: "/events/the-tiny-hack" },
      { label: "Apptitude", href: "/events/apptitude" },
    ],
  },
  {
    title: "Projects",
    links: [
      { label: "All Projects", href: "/projects" },
      { label: "ACMOne", href: "/projects/acmone" },
      { label: "ExamCooker", href: "/projects/examcooker" },
      { label: "CLI-RPG", href: "/projects/cli-rpg" },
      { label: "UniPool", href: "/projects/unipool" },
      { label: "LOCALHOST", href: "/projects/localhost" },
      { label: "OCS-25", href: "/projects/ocs-25" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blogs", href: "/blogs" },
      { label: "GREP Newsletter", href: "/grep" },
      { label: "Gallery", href: "/gallery" },
      { label: "Achievements", href: "/achievements" },
      { label: "Merchandise", href: "/merchandise" },
      { label: "Cassette Builder", href: "/cassette-builder" },
      { label: "Design Guide", href: "/design-guide" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Team", href: "/team" },
      { label: "Partners", href: "/partners" },
      { label: "z0d1ak", href: "/z0d1ak" },
      { label: "Calendar", href: "/calendar" },
      { label: "FAQs", href: "/faqs" },
      { label: "Code of Conduct", href: "/code-of-conduct" },
    ],
  },
];

// Nested .map() JSX misbehaves inside <template> elements, so pre-render the
// footer columns to a trusted HTML string and inject with set:html.
const footerColumnsHtml = footerNav
  .map(
    (col) => `
      <div class="flex flex-col gap-4">
        <h3 class="footer-col-title">${col.title}</h3>
        <ul class="flex flex-col gap-2.5">
          ${col.links
            .map(
              (l) =>
                `<li><a href="${l.href}" class="footer-link">${l.label}</a></li>`
            )
            .join("")}
        </ul>
      </div>`
  )
  .join("");
---

<div data-variant-host>
  <template data-variant="desktop">
    <footer
      id="footer"
      class="footer-gradient relative w-full overflow-hidden m-0 p-0 flex flex-col"
    >
      <div class="relative z-10 hidden md:block px-6 lg:px-16 pt-16 pb-24">
        <div
          class="mx-auto flex w-full max-w-[1600px] flex-col gap-14 lg:flex-row lg:gap-20"
        >
          <!-- Identity -->
          <div class="flex shrink-0 flex-col gap-7 lg:w-[300px]">
            <h2 class="footer-title text-yellow-50">
              association for<br />computing machinery
            </h2>

            <span class="footer-status" style="--dot: #0270f3">
              <span class="footer-status-dot"></span>
              ALL SYSTEMS OPTIMAL
            </span>

            <a
              href="https://w3w.co/static.grips.limelight"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative block h-36 w-56 overflow-hidden rounded-xl border border-zinc-800"
            >
              <img
                src={getAssetUrl("/footer/footer-vit-map.webp")}
                alt="Map to Vellore Institute of Technology"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <span
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"
              ></span>
              <span
                class="absolute bottom-2 left-3 font-['PolySans_Trial'] text-[11px] text-white/90"
                >Vellore, India</span
              >
            </a>

            <a href="/sitemap" class="footer-sitemap-btn group">
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
              </svg>
              <span>View sitemap</span>
              <svg
                class="footer-sitemap-arrow"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>

          <!-- Link grid -->
          <nav
            aria-label="Footer navigation"
            class="grid grow grid-cols-2 gap-x-8 gap-y-10 md:grid-cols-3 xl:grid-cols-6"
            set:html={footerColumnsHtml}
          >
          </nav>
        </div>
      </div>

      <!-- Social icons above the video -->
      <div
        class="footer-socials footer-socials--desktop hidden md:flex relative z-10 flex-row items-center justify-center gap-6 pb-8"
        set:html={socialLinksHtml}
      >
      </div>

      <!-- Footer video banner with overlaid bottom section -->
      <div class="footer-video hidden md:block relative z-10 w-full mt-auto overflow-hidden">
        <video
          class="block w-full h-auto"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src={getMediaUrl("/videos/videos-footer-walkman.webm")} type="video/webm" />
          <source src={getMediaUrl("/videos/videos-footer-walkman.mp4")} type="video/mp4" />
        </video>
        <div class="footer-video-tint" aria-hidden="true"></div>
        <div class="footer-video-fade" aria-hidden="true"></div>
        <span class="footer-wordmark">because technology matters</span>
        <div class="footer-acm-block" aria-hidden="true">
          <span class="footer-acm-mark">acm</span>
        </div>

        <!-- Copyright pinned bottom-left -->
        <p class="absolute bottom-3 left-12 z-30 text-[10px] lg:text-xs font-light text-white">
          © {currentYear}&nbsp;ACM-VIT. All rights reserved.
        </p>

        <!-- Location pinned bottom-right -->
        <p class="absolute bottom-3 right-12 z-30 text-[10px] lg:text-xs font-light text-white">
          Vellore, Tamil Nadu, India
        </p>

        <!-- Bottom section overlaid on the video, pushed lower -->
        <div class="absolute inset-0 z-20 flex w-full flex-col items-center justify-end pb-20 lg:pb-28">
        <div
          class="flex flex-col items-center justify-center z-30 relative"
        >
          <div class="flex items-center gap-2">
            <img
              src={getAssetUrl("/footer/footer-pixel-heart.webp")}
              alt="pixel heart"
              class="w-5 h-5 lg:w-6 lg:h-6"
              loading="lazy"
              decoding="async"
            />
            <span
              class="text-sm lg:text-base text-white font-['PolySans_Trial']"
              >crafted with love by ACM-VIT</span
            >
          </div>
        </div>
        </div>
      </div>
    </footer>
  </template>

  <template data-variant="mobile">
    <!-- Phone Screen Version -->
    <footer
      id="footer"
      class="footer-gradient relative w-full h-auto overflow-hidden pb-0 flex flex-col"
    >
      <!-- Content -->
      <div class="relative z-10 flex flex-col gap-8 px-5 sm:px-8 pt-8 pb-6">
        <!-- Identity -->
        <div class="flex flex-col items-center gap-4 text-center">
          <h2 class="footer-title footer-title--mobile text-yellow-50">
            association for<br />computing machinery
          </h2>
          <span class="footer-status" style="--dot: #0270f3">
            <span class="footer-status-dot"></span>
            All systems online
          </span>
        </div>

        <!-- Link grid -->
        <nav
          aria-label="Footer navigation"
          class="grid grid-cols-2 gap-x-6 gap-y-8"
          set:html={footerColumnsHtml}
        >
        </nav>

        <a href="/sitemap" class="footer-sitemap-btn group self-start">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          <span>View sitemap</span>
          <svg
            class="footer-sitemap-arrow"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

      <!-- Copyright + socials above the video -->
      <div class="relative z-10 flex flex-col items-center gap-4 pb-5">
        <!-- Social Icons -->
        <div
          class="footer-socials footer-socials--mobile flex flex-row items-center gap-5 flex-wrap justify-center"
          set:html={socialLinksHtml}
        >
        </div>
        <p class="text-white text-[10px] font-light text-center">
          © {currentYear}&nbsp;ACM-VIT. All rights reserved.
        </p>
      </div>

      <!-- Footer video banner (mobile) with overlaid bottom section -->
      <div class="footer-video relative z-10 w-full mt-auto overflow-hidden">
        <video
          class="block w-full h-auto"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src={getMediaUrl("/videos/videos-footer-walkman.webm")} type="video/webm" />
          <source src={getMediaUrl("/videos/videos-footer-walkman.mp4")} type="video/mp4" />
        </video>
        <div class="footer-video-tint" aria-hidden="true"></div>
        <div class="footer-video-fade" aria-hidden="true"></div>
        <span class="footer-wordmark">because technology matters</span>

        <!-- Bottom section overlaid on the video, pushed lower -->
        <div class="absolute inset-0 z-20 flex w-full flex-col items-center justify-end px-4 pb-12">
        <div
          class="flex flex-col items-center justify-center gap-3 z-30 relative"
        >
          <div class="flex items-center gap-2">
            <img
              src={getAssetUrl("/footer/footer-pixel-heart.webp")}
              alt="pixel heart"
              class="w-5 h-5 sm:w-6 sm:h-6 md:w-7 md:h-7"
              loading="lazy"
              decoding="async"
            />
            <span class="text-white text-xs sm:text-sm md:text-base font-['PolySans_Trial']"
              >crafted with love by ACM-VIT</span
            >
          </div>
        </div>
        </div>
      </div>
    </footer>
  </template>
</div>

<style>
  /* Footer identity title */
  .footer-title {
    font-family: "PolySans Bulky Wide", sans-serif;
    font-weight: 700;
    text-transform: lowercase;
    font-size: 1.6rem;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .footer-title--mobile {
    font-size: 1.25rem;
  }

  /* Status badge - mirrors .proj-status-badge on /projects/[project] */
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 6px 12px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.02);
    font-family: "PolySans Mono", monospace;
    font-size: 0.62rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0270f3;
  }
  .footer-status-dot {
    position: relative;
    /* top: 1px; */
    bottom: 2px;
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot);
    box-shadow: 0 0 12px var(--dot);
    animation: footer-status-pulse 5s ease-in-out infinite;
  }
  @keyframes footer-status-pulse {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.18);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .footer-status-dot {
      animation: none;
    }
  }

  /* Column heading + nav link live inside set:html content, so they miss
     Astro's scoping attribute - target them globally. */
  :global(.footer-col-title) {
    font-family: "PolySans Trial", sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    padding-bottom: 0.55rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.14);
  }

  :global(.footer-link) {
    display: inline-block;
    font-family: "PolySans Trial", sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  :global(.footer-link:hover),
  :global(.footer-link:focus-visible) {
    color: #fff;
    outline: none;
  }

  /* Sitemap button */
  .footer-sitemap-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    padding: 0.6rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 9999px;
    font-family: "PolySans Trial", sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.02);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }
  .footer-sitemap-btn:hover,
  .footer-sitemap-btn:focus-visible {
    border-color: var(--color-primary-orange, #f95f4a);
    background: rgba(249, 95, 74, 0.08);
    color: #fff;
    outline: none;
  }
  .footer-sitemap-arrow {
    transition: transform 0.2s ease;
  }
  .footer-sitemap-btn:hover .footer-sitemap-arrow,
  .footer-sitemap-btn:focus-visible .footer-sitemap-arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.footer-link),
    .footer-sitemap-btn,
    .footer-sitemap-arrow {
      transition: none;
    }
  }

  /* Full-footer tonal transition: blends section above into the black video band.
     Transparent at top (matches the section above), ramps to solid black by the
     point the video begins, so there is no hard seam anywhere. */
  .footer-gradient {
    /* Solid black base so the translucent top never reveals the page bg
       (stays dark in light theme too). Gradient still blends the seam. */
    background-color: #000;
    background-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.4) 14%,
      rgba(0, 0, 0, 0.82) 24%,
      #000 32%,
      #000 100%
    );
  }

  /* Small tagline over the video */
  .footer-wordmark {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1.25rem;
    z-index: 3;
    width: 100%;
    text-align: center;
    font-family: "PolySans Bulky Wide", sans-serif;
    font-weight: 700;
    text-transform: lowercase;
    line-height: 1;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.75);
    pointer-events: none;
    user-select: none;
  }

  /* Big 'acm' wordmark, right side of footer video */
  .footer-acm-block {
    position: absolute;
    right: 10rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    pointer-events: none;
    user-select: none;
  }
  .footer-acm-mark {
    font-family: "PolySans Bulky Wide", sans-serif;
    font-weight: 700;
    text-transform: lowercase;
    line-height: 0.9;
    font-size: clamp(6rem, 16vw, 16rem);
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.9);
    overflow: hidden;
  }
  .footer-acm-letter {
    display: inline-block;
    transform-origin: 50% 100%;
    will-change: transform, opacity;
  }

  /* Social icons: inline Simple Icons SVG. Uniform box, currentColor fill,
     slow ease to website orange on hover. */
  :global(.footer-social) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.45);
    transition:
      color 0.45s ease,
      transform 0.3s ease;
  }
  :global(.footer-social:hover),
  :global(.footer-social:focus-visible) {
    color: #fff;
    transform: scale(1.1);
    outline: none;
  }
  :global(.footer-social svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* Facebook glyph fills ~80% of its 24 viewBox, the rest ~100%. Scale the
     others down so every mark reads at the same visual size as Facebook. */
  :global(.footer-social:not([aria-label="Facebook"]) svg) {
    transform: scale(0.8);
  }
  :global(.footer-socials--desktop .footer-social) {
    width: 1.65rem;
    height: 1.65rem;
  }
  :global(.footer-socials--mobile .footer-social) {
    width: 1.4rem;
    height: 1.4rem;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.footer-social) {
      transition: none;
    }
    :global(.footer-social:hover),
    :global(.footer-social:focus-visible) {
      transform: none;
    }
  }

  /* Orangish tint over footer video */
  .footer-video-tint {
    position: absolute;
    inset: 0;
    background: #f95f4a;
    mix-blend-mode: multiply;
    opacity: 0.55;
    pointer-events: none;
  }
  /* Fade top of video into footer background - soft ramp, no hard black cap */
  .footer-video-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      #000 0%,
      #000 20%,
      rgba(0, 0, 0, 0.7) 45%,
      rgba(0, 0, 0, 0) 78%
    );
    pointer-events: none;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initFooterAcm = () => {
    const marks = document.querySelectorAll<HTMLElement>(".footer-acm-mark");
    marks.forEach((mark) => {
      if (mark.dataset.acmInit === "1") return;
      mark.dataset.acmInit = "1";

      // Split into per-letter spans
      const text = mark.textContent || "";
      mark.textContent = "";
      const letters: HTMLElement[] = [];
      [...text].forEach((ch) => {
        const span = document.createElement("span");
        span.className = "footer-acm-letter";
        span.textContent = ch;
        mark.appendChild(span);
        letters.push(span);
      });

      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (reduceMotion) {
        gsap.set(letters, { yPercent: 0, opacity: 1 });
        return;
      }

      gsap.set(letters, { yPercent: 120, rotation: -6, opacity: 0 });

      ScrollTrigger.create({
        trigger: mark,
        start: "top 90%",
        once: true,
        onEnter: () => {
          gsap.to(letters, {
            yPercent: 0,
            rotation: 0,
            opacity: 1,
            duration: 0.85,
            ease: "power3.out",
            stagger: 0.08,
          });
        },
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFooterAcm);
  } else {
    initFooterAcm();
  }
  // Re-init when variant templates mount (variant host)
  document.addEventListener("variants-mounted", initFooterAcm);
</script>
