---
// Footer.astro
import { getAssetUrl } from "../utils/cdn";

const currentYear = new Date().getFullYear();

type FooterLink = { label: string; href: string };
type FooterColumn = { title: string; links: FooterLink[] };

const footerNav: FooterColumn[] = [
  {
    title: "Explore",
    links: [
      { label: "About", href: "/#about" },
      { label: "Domains", href: "/#domains" },
      { label: "Events", href: "/#events" },
      { label: "Projects", href: "/#projects" },
      { label: "ACM-W", href: "/#acm-w" },
      { label: "Community", href: "/#community" },
    ],
  },
  {
    title: "Domains",
    links: [
      { label: "Tech", href: "/domains/tech" },
      { label: "Competitive Coding", href: "/domains/cc" },
      { label: "Design", href: "/domains/design" },
      { label: "Management", href: "/domains/management" },
      { label: "Research", href: "/domains/research" },
    ],
  },
  {
    title: "Events",
    links: [
      { label: "All Events", href: "/events" },
      { label: "Code2Create", href: "/events/code2create" },
      { label: "Cryptic Hunt", href: "/events/cryptic-hunt" },
      { label: "Reverse Coding", href: "/events/reverse-coding" },
      { label: "Forktober", href: "/events/forktober" },
      { label: "The Tiny Hack", href: "/events/the-tiny-hack" },
      { label: "Apptitude", href: "/events/apptitude" },
    ],
  },
  {
    title: "Projects",
    links: [
      { label: "All Projects", href: "/projects" },
      { label: "ACMOne", href: "/projects/acmone" },
      { label: "ExamCooker", href: "/projects/examcooker" },
      { label: "CLI-RPG", href: "/projects/cli-rpg" },
      { label: "UniPool", href: "/projects/unipool" },
      { label: "LOCALHOST", href: "/projects/localhost" },
      { label: "OCS-25", href: "/projects/ocs-25" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blogs", href: "/blogs" },
      { label: "GREP Newsletter", href: "/grep" },
      { label: "Gallery", href: "/gallery" },
      { label: "Achievements", href: "/achievements" },
      { label: "Merchandise", href: "/merchandise" },
      { label: "Cassette Builder", href: "/cassette-builder" },
      { label: "Design Guide", href: "/design-guide" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Team", href: "/team" },
      { label: "Partners", href: "/partners" },
      { label: "z0d1ak", href: "/z0d1ak" },
      { label: "Calendar", href: "/calendar" },
      { label: "FAQs", href: "/faqs" },
      { label: "Code of Conduct", href: "/code-of-conduct" },
    ],
  },
];

// Nested .map() JSX misbehaves inside <template> elements, so pre-render the
// footer columns to a trusted HTML string and inject with set:html.
const footerColumnsHtml = footerNav
  .map(
    (col) => `
      <div class="flex flex-col gap-4">
        <h3 class="footer-col-title">${col.title}</h3>
        <ul class="flex flex-col gap-2.5">
          ${col.links
            .map(
              (l) =>
                `<li><a href="${l.href}" class="footer-link">${l.label}</a></li>`
            )
            .join("")}
        </ul>
      </div>`
  )
  .join("");
---

<div data-variant-host>
  <template data-variant="desktop">
    <footer
      id="footer"
      class="footer-gradient relative w-full overflow-hidden m-0 p-0 flex flex-col"
    >
      <div class="relative z-10 hidden md:block px-6 lg:px-16 pt-16 pb-24">
        <div
          class="mx-auto flex w-full max-w-[1600px] flex-col gap-14 lg:flex-row lg:gap-20"
        >
          <!-- Identity -->
          <div class="flex shrink-0 flex-col gap-7 lg:w-[300px]">
            <h2 class="footer-title text-yellow-50">
              association for<br />computing machinery
            </h2>

            <span class="footer-status" style="--dot: #0270f3">
              <span class="footer-status-dot"></span>
              All systems online
            </span>

            <a
              href="https://w3w.co/static.grips.limelight"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative block h-36 w-56 overflow-hidden rounded-xl border border-zinc-800"
            >
              <img
                src={getAssetUrl("/footer/VIT-Map.png")}
                alt="Map to Vellore Institute of Technology"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <span
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"
              ></span>
              <span
                class="absolute bottom-2 left-3 font-['PolySans_Trial'] text-[11px] text-white/90"
                >Vellore, India</span
              >
            </a>

            <a href="/sitemap" class="footer-sitemap-btn group">
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
              </svg>
              <span>View sitemap</span>
              <svg
                class="footer-sitemap-arrow"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </div>

          <!-- Link grid -->
          <nav
            aria-label="Footer navigation"
            class="grid grow grid-cols-2 gap-x-8 gap-y-10 md:grid-cols-3 xl:grid-cols-6"
            set:html={footerColumnsHtml}
          >
          </nav>
        </div>
      </div>

      <!-- Footer video banner with overlaid bottom section -->
      <div class="footer-video hidden md:block relative z-10 w-full mt-auto overflow-hidden">
        <video
          class="block w-full h-auto"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src={getAssetUrl("/videos/footer-walkman.webm")} type="video/webm" />
          <source src={getAssetUrl("/videos/footer-walkman.mp4")} type="video/mp4" />
        </video>
        <div class="footer-video-tint" aria-hidden="true"></div>
        <div class="footer-video-fade" aria-hidden="true"></div>
        <span class="footer-wordmark">because technology matters</span>

        <!-- Copyright pinned bottom-left -->
        <p class="absolute bottom-3 left-12 z-30 text-[10px] lg:text-xs font-light text-white">
          © {currentYear}&nbsp;ACM-VIT. All rights reserved.
        </p>

        <!-- Location pinned bottom-right -->
        <p class="absolute bottom-3 right-12 z-30 text-[10px] lg:text-xs font-light text-white">
          Vellore, India
        </p>

        <!-- Bottom section overlaid on the video, pushed lower -->
        <div class="absolute inset-0 z-20 flex w-full flex-col items-center justify-end pb-20 lg:pb-28">
        <div
          class="flex flex-col items-center justify-center z-30 relative"
        >
          <div class="flex items-center gap-2">
            <img
              src={getAssetUrl("/footer/pixel-heart.webp")}
              alt="pixel heart"
              class="w-5 h-5 lg:w-6 lg:h-6"
              loading="lazy"
              decoding="async"
            />
            <span
              class="text-sm lg:text-base text-white font-['PolySans_Trial']"
              >crafted with love by ACM-VIT</span
            >
          </div>
        </div>
        </div>
      </div>
    </footer>
  </template>

  <template data-variant="mobile">
    <!-- Phone Screen Version -->
    <footer
      id="footer"
      class="footer-gradient relative w-full h-auto overflow-hidden pb-0 flex flex-col"
    >
      <!-- Content -->
      <div class="relative z-10 flex flex-col gap-8 px-5 sm:px-8 pt-8 pb-6">
        <!-- Identity -->
        <div class="flex flex-col items-center gap-4 text-center">
          <h2 class="footer-title footer-title--mobile text-yellow-50">
            association for<br />computing machinery
          </h2>
          <span class="footer-status" style="--dot: #0270f3">
            <span class="footer-status-dot"></span>
            All systems online
          </span>
        </div>

        <!-- Link grid -->
        <nav
          aria-label="Footer navigation"
          class="grid grid-cols-2 gap-x-6 gap-y-8"
          set:html={footerColumnsHtml}
        >
        </nav>

        <a href="/sitemap" class="footer-sitemap-btn group self-start">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          <span>View sitemap</span>
          <svg
            class="footer-sitemap-arrow"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

      <!-- Copyright above the video -->
      <p class="relative z-10 text-white text-[10px] font-light text-center pb-4">
        © {currentYear}&nbsp;ACM-VIT. All rights reserved.
      </p>

      <!-- Footer video banner (mobile) with overlaid bottom section -->
      <div class="footer-video relative z-10 w-full mt-auto overflow-hidden">
        <video
          class="block w-full h-auto"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src={getAssetUrl("/videos/footer-walkman.webm")} type="video/webm" />
          <source src={getAssetUrl("/videos/footer-walkman.mp4")} type="video/mp4" />
        </video>
        <div class="footer-video-tint" aria-hidden="true"></div>
        <div class="footer-video-fade" aria-hidden="true"></div>
        <span class="footer-wordmark">because technology matters</span>

        <!-- Bottom section overlaid on the video, pushed lower -->
        <div class="absolute inset-0 z-20 flex w-full flex-col items-center justify-end px-4 pb-12">
        <div
          class="flex flex-col items-center justify-center gap-3 z-30 relative"
        >
          <div class="flex items-center gap-2">
            <img
              src={getAssetUrl("/footer/pixel-heart.webp")}
              alt="pixel heart"
              class="w-5 h-5 sm:w-6 sm:h-6 md:w-7 md:h-7"
              loading="lazy"
              decoding="async"
            />
            <span class="text-white text-xs sm:text-sm md:text-base font-['PolySans_Trial']"
              >crafted with love by ACM-VIT</span
            >
          </div>
        </div>
        </div>
      </div>
    </footer>
  </template>
</div>

<style>
  /* Footer identity title */
  .footer-title {
    font-family: "PolySans Bulky Wide", sans-serif;
    font-weight: 700;
    text-transform: lowercase;
    font-size: 1.6rem;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .footer-title--mobile {
    font-size: 1.25rem;
  }

  /* Status badge - mirrors .proj-status-badge on /projects/[project] */
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 6px 12px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.02);
    font-family: "PolySans Mono", monospace;
    font-size: 0.62rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0270f3;
  }
  .footer-status-dot {
    position: relative;
    /* top: 1px; */
    bottom: 2px;
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot);
    box-shadow: 0 0 12px var(--dot);
    animation: footer-status-pulse 5s ease-in-out infinite;
  }
  @keyframes footer-status-pulse {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.18);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .footer-status-dot {
      animation: none;
    }
  }

  /* Column heading + nav link live inside set:html content, so they miss
     Astro's scoping attribute - target them globally. */
  :global(.footer-col-title) {
    font-family: "PolySans Trial", sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    padding-bottom: 0.55rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.14);
  }

  :global(.footer-link) {
    display: inline-block;
    font-family: "PolySans Trial", sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  :global(.footer-link:hover),
  :global(.footer-link:focus-visible) {
    color: #fff;
    outline: none;
  }

  /* Sitemap button */
  .footer-sitemap-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    padding: 0.6rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 9999px;
    font-family: "PolySans Trial", sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.02);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }
  .footer-sitemap-btn:hover,
  .footer-sitemap-btn:focus-visible {
    border-color: var(--color-primary-orange, #f95f4a);
    background: rgba(249, 95, 74, 0.08);
    color: #fff;
    outline: none;
  }
  .footer-sitemap-arrow {
    transition: transform 0.2s ease;
  }
  .footer-sitemap-btn:hover .footer-sitemap-arrow,
  .footer-sitemap-btn:focus-visible .footer-sitemap-arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.footer-link),
    .footer-sitemap-btn,
    .footer-sitemap-arrow {
      transition: none;
    }
  }

  /* Full-footer tonal transition: blends section above into the black video band.
     Transparent at top (matches the section above), ramps to solid black by the
     point the video begins, so there is no hard seam anywhere. */
  .footer-gradient {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.4) 14%,
      rgba(0, 0, 0, 0.82) 24%,
      #000 32%,
      #000 100%
    );
  }

  /* Small tagline over the video */
  .footer-wordmark {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1.25rem;
    z-index: 3;
    width: 100%;
    text-align: center;
    font-family: "PolySans Bulky Wide", sans-serif;
    font-weight: 700;
    text-transform: lowercase;
    line-height: 1;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.75);
    pointer-events: none;
    user-select: none;
  }

  /* Orangish tint over footer video */
  .footer-video-tint {
    position: absolute;
    inset: 0;
    background: #f95f4a;
    mix-blend-mode: multiply;
    opacity: 0.55;
    pointer-events: none;
  }
  /* Fade top of video into footer background - soft ramp, no hard black cap */
  .footer-video-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      #000 0%,
      #000 20%,
      rgba(0, 0, 0, 0.7) 45%,
      rgba(0, 0, 0, 0) 78%
    );
    pointer-events: none;
  }
</style>
