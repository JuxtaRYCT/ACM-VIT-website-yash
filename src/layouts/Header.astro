    // ── Tilt micro-interaction ──
    document.querySelectorAll("[data-tilt]").forEach((tile) => {
      tile.addEventListener("mousemove", (e) => {
        const rect = tile.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;
        const rotateX = (0.5 - y) * 8;
        const rotateY = (x - 0.5) * 8;
        tile.style.transform =
          `perspective(600px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
      });
      tile.addEventListener("mouseleave", () => {
        tile.style.transform = "";
      });
    });

    // ── Bubble intro animation (GSAP) ──
    if (pill) {
      let introFired = false;

      // ── Subpage intro: circle drop → Flip expand → gooey breakoff ──
      if (pill.dataset.subpage === 'true') {
        introFired = true;

        const gooeyWrap = document.getElementById('pillIslandWrap');
        const backBubble = document.querySelector('.subpage-back-bubble');
        const label = pill.querySelector('.subpage-island-label');
        const bubbleIcon = backBubble ? backBubble.querySelector('svg') : null;
        const solidDark = 'rgba(18, 14, 14, 0.92)';

        // Start as collapsed circle
        pill.classList.add('pill-collapsed');
        pill.style.transition = 'none';
        gsap.set(pill, { opacity: 0, y: -24, scale: 0.7 });
        if (label) gsap.set(label, { opacity: 0, maxWidth: 0, padding: 0 });
        if (backBubble) {
          gsap.set(backBubble, {
            opacity: 0, x: -30, marginLeft: 0,
            background: solidDark,
            backdropFilter: 'none', webkitBackdropFilter: 'none',
            borderColor: 'transparent', boxShadow: 'none',
          });
        }
        if (bubbleIcon) gsap.set(bubbleIcon, { opacity: 0 });

        function playSubpageIntro() {
        const dropTl = gsap.timeline({ delay: 0.25 });

        // Phase 1: Circle drops in
        dropTl.to(pill, {
          opacity: 1, y: 8, scale: 1.05,
          duration: 0.35, ease: 'power2.out',
        })
        // Phase 2: Bounce back
        .to(pill, { y: -5, scale: 1, duration: 0.2, ease: 'power2.inOut' })
        // Phase 3: Settle
        .to(pill, { y: 0, duration: 0.15, ease: 'power2.out' })
        // Phase 4: Flip expand circle → pill
        .add(() => {
          if (label) gsap.set(label, { opacity: 1, maxWidth: 300, padding: '0 4px' });

          const state = Flip.getState(pill);
          pill.classList.remove('pill-collapsed');
          pill.classList.add('pill-intro-play');

          Flip.from(state, {
            duration: 0.4,
            ease: 'power3.out',
            clearProps: 'all',
            onComplete() {
              // Phase 5: Gooey breakoff - bubble breaks from pill edge
              pill.style.transition = 'none';
              pill.style.background = solidDark;
              pill.style.backdropFilter = 'none';
              pill.style.webkitBackdropFilter = 'none';
              pill.style.borderColor = 'transparent';
              pill.style.boxShadow = 'none';

              if (backBubble) gsap.set(backBubble, { opacity: 1 });
              if (gooeyWrap) gooeyWrap.classList.add('gooey-active');

              const breakTl = gsap.timeline({
                onComplete() {
                  pill.style.transition = '';
                  pill.style.background = '';
                  pill.style.backdropFilter = '';
                  pill.style.webkitBackdropFilter = '';
                  pill.style.borderColor = '';
                  pill.style.boxShadow = '';
                  if (backBubble) {
                    gsap.set(backBubble, {
                      clearProps: 'x,marginLeft,background,backdropFilter,webkitBackdropFilter,borderColor,boxShadow',
                    });
                  }
                },
              });

              // Bubble slides out - gooey metaball bridge
              breakTl.to(backBubble, {
                x: 0, marginLeft: 8,
                duration: 0.2, ease: 'power3.out',
              })
              // Bridge snap - restore pill to glass
              .add(() => {
                if (gooeyWrap) gooeyWrap.classList.remove('gooey-active');
                pill.style.background = '';
                pill.style.backdropFilter = '';
                pill.style.webkitBackdropFilter = '';
                pill.style.boxShadow = '';
                pill.style.borderColor = '';
              }, '<0.15')
              // Bubble dark → orange
              .to(backBubble, {
                background: '#F95F4A',
                borderColor: 'rgba(254, 252, 217, 0.35)',
                duration: 0.15, ease: 'power2.out',
              }, '<0.02')
              // Show back arrow icon
              .to(bubbleIcon, {
                opacity: 1, duration: 0.15, ease: 'power2.out',
              }, '<0.04');
            },
          });
        });

        } // end playSubpageIntro

        // Wait for preloader to finish before playing subpage intro
        window.addEventListener("preloader:done", () => {
          setTimeout(playSubpageIntro, 500);
        }, { once: true });

        // ── Subpage hover: pill only (not bubble), debounced ──
        let hoverTimer = null;
        pill.addEventListener('mouseenter', () => {
          clearTimeout(hoverTimer);
          pill.classList.add('subpage-expanded');
        });
        pill.addEventListener('mouseleave', () => {
          hoverTimer = setTimeout(() => {
            pill.classList.remove('subpage-expanded');
          }, 150);
        });
      }

      function triggerPillIntro() {
        if (introFired) return;
        introFired = true;

        const dots = pill.querySelectorAll(".nav-dot");
        const navItems = pill.querySelectorAll(".nav-item");

        // Start collapsed as small circle, kill CSS transitions during intro
        pill.classList.add("pill-collapsed");
        pill.style.transition = "none";
        gsap.set(pill, { opacity: 0, y: -24, scale: 0.7 });
        gsap.set(dots, { opacity: 0 });

        const pillTl = gsap.timeline({
          onComplete: () => {
            pill.classList.add("pill-intro-play");
          },
        });

        // Phase 1: Circle drops in from above, overshoots down
        pillTl.to(pill, {
          opacity: 1,
          y: 8,
          scale: 1.05,
          duration: 0.35,
          ease: "power2.out",
        })
        // Phase 2: Bounce back up
        .to(pill, {
          y: -5,
          scale: 1,
          duration: 0.2,
          ease: "power2.inOut",
        })
        // Phase 3: Settle + expand circle → pill (Flip)
        .to(pill, {
          y: 0,
          duration: 0.15,
          ease: "power2.out",
          onStart: () => {
            const state = Flip.getState(pill);
            pill.classList.remove("pill-collapsed");

            Flip.from(state, {
              duration: 0.5,
              ease: "power3.out",
              clearProps: "all",
              onComplete: () => {
                // Restore CSS transitions now that intro is done
                pill.style.transition = "";
                // Phase 4: Dots stagger in after expansion
                gsap.to(dots, {
                  opacity: 1,
                  duration: 0.25,
                  ease: "power2.out",
                  stagger: 0.025,
                });
              },
            });
          },
        });
      }

      // If preloader already shown before, 500ms delay then drop
      if (sessionStorage.getItem("preloaderShown")) {
        setTimeout(triggerPillIntro, 500);
      } else {
        // First visit - wait for preloader to fully finish
        window.addEventListener("preloader:done", () => {
          setTimeout(triggerPillIntro, 500);
        }, { once: true });
      }
    }

    // ── Scroll progress bar ──
    const progressFill = document.getElementById("pillProgressFill");

    function updateScrollProgress() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;

      if (progressFill) {
        progressFill.style.width = `${(progress * 100).toFixed(1)}%`;
      }
    }

    window.addEventListener("scroll", updateScrollProgress, { passive: true });
    updateScrollProgress();
  });
</script>
