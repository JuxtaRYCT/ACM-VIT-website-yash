<script>
  // @ts-nocheck
  import { gsap } from "gsap";
  import { Flip } from "gsap/Flip";
  gsap.registerPlugin(Flip);

  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id], footer[id]");

    // Section → nav-item mapping
    const idMapping = {
      work: "events",
      "igniting-minds-section": "community",
      "community-outreach": "community",
      "community-sdg": "community",
      "community-conduct": "community",
      "community-award": "community",
      "projects-intro": "projects",
    };

    // ── Dot nav active state ──
    function setActiveItem(navSection) {
      const items = document.querySelectorAll(".nav-desktop .nav-item");
      items.forEach((item) => {
        item.classList.remove("active", "pink-mode");
      });

      if (!navSection) return;

      const target = document.querySelector(
        `.nav-desktop .nav-item[data-section="${navSection}"]`
      );
      if (!target) return;

      target.classList.add("active");
      if (navSection === "acm-w") target.classList.add("pink-mode");
    }

    function applyNavState(sectionId) {
      if (!sectionId || sectionId === "footer") {
        setActiveItem(null);
        window.dispatchEvent(new CustomEvent("nav:section", { detail: { id: "home" } }));
        return;
      }
      const mappedId = idMapping[sectionId] || sectionId;
      setActiveItem(mappedId);
      window.dispatchEvent(new CustomEvent("nav:section", { detail: { id: mappedId } }));
    }

    // ── Scroll tracking ──
    let currentSectionId = null;
    let rafPending = false;
    let lastScrollY = window.scrollY || window.pageYOffset;

    function getActiveSection() {
      const focusLine = window.innerHeight * 0.3;
      let activeSection = null;
      let closestSection = null;
      let closestDistance = Infinity;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= focusLine && rect.bottom >= focusLine) {
          activeSection = section;
        }
        let distance = 0;
        if (rect.top > focusLine) {
          distance = rect.top - focusLine;
        } else if (rect.bottom < focusLine) {
          distance = focusLine - rect.bottom;
        }
        if (distance < closestDistance) {
          closestDistance = distance;
          closestSection = section;
        }
      });

      return activeSection || closestSection;
    }

    function updateActiveSection() {
      rafPending = false;
      const scrollY = window.scrollY || window.pageYOffset;
      lastScrollY = scrollY;
      const activeSection = getActiveSection();
      if (!activeSection) return;
      const id = activeSection.getAttribute("id");
      if (!id || id === currentSectionId) return;
      currentSectionId = id;
      applyNavState(id);
    }

    function scheduleNavUpdate() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(updateActiveSection);
    }

    const observer = new IntersectionObserver(
      () => scheduleNavUpdate(),
      { root: null, rootMargin: "-20% 0px -60% 0px", threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
    window.addEventListener("scroll", scheduleNavUpdate, { passive: true });

    // ── Smooth scroll ──
    document.addEventListener("click", (e) => {
      const el = e.target instanceof Element ? e.target.closest('a[href*="#"]') : null;
      if (!el) return;
      const href = el.getAttribute("href");
      if (!href) return;

      // Extract section id from href (handles both "#about" and "/#about")
      const hashIndex = href.indexOf("#");
      if (hashIndex === -1) return;
      const id = href.slice(hashIndex + 1);
      if (!id) return;

      // If on a different page, let the browser navigate to /#section
      const hrefPath = href.slice(0, hashIndex) || "/";
      if (hrefPath !== "/" && hrefPath !== window.location.pathname) return;

      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();

      // Contact (200vh) and More (curtain + pinned boombox below it) sit below
      // lazy-loaded content, so a captured scrollIntoView target goes stale and
      // lands short. Hash nav lets the browser resolve the correct position - CSS
      // scroll-behavior: smooth keeps it smooth.
      if (id === "contact" || id === "more") {
        window.location.hash = id;
        applyNavState(id);
        currentSectionId = id;
        return;
      }

      target.scrollIntoView({ behavior: "smooth", block: "start" });
      // Clean URL - no hash
      history.replaceState(null, "", window.location.pathname);
      applyNavState(id);
      currentSectionId = id;
    });

    scheduleNavUpdate();

    // ── Clean hash from URL on load (after browser scrolls to target) ──
    if (window.location.hash) {
      const hashId = window.location.hash.slice(1);
      requestAnimationFrame(() => {
        history.replaceState(null, "", window.location.pathname);
        if (hashId) applyNavState(hashId);
      });
    }

    // ── Megamenu interaction ──
    const megamenu = document.getElementById("navMegamenu");
    const megamenuPanels = megamenu ? megamenu.querySelectorAll(".megamenu-panel") : [];
    const sectionsWithDropdowns = ["about", "community", "domains", "events", "projects", "acm-w", "team", "more"];
    let megamenuTimer = null;
    let currentPanel = null;

    const pill = document.getElementById("headerPill");

    function showMegamenu(section) {
      if (!megamenu) return;
      megamenuPanels.forEach((p) => p.classList.remove("active"));
      const panel = megamenu.querySelector(`[data-panel="${section}"]`);
      if (!panel) return;
      panel.classList.add("active");
      currentPanel = section;
      megamenu.classList.add("open");
      if (pill) pill.classList.add("pill-menu-open");
    }

    function hideMegamenu() {
      if (!megamenu) return;
      megamenu.classList.remove("open");
      currentPanel = null;
      if (pill) pill.classList.remove("pill-menu-open");
      setTimeout(() => {
        if (!currentPanel) {
          megamenuPanels.forEach((p) => p.classList.remove("active"));
