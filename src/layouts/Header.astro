---
// Header.astro
---

<header
  class="site-header fixed top-5 left-0 right-0 z-50 w-full px-4 py-2 pointer-events-none"
>
  <div
    class="header-inner relative max-w-fit mx-auto flex justify-center pointer-events-auto"
  >
    <nav>
      <!-- Desktop nav -->
      <div class="nav-desktop">
        <div class="header-pill">
          <a href="#about" class="nav-item" data-section="about">
            <span class="nav-dot"></span>
            <span class="nav-label">About</span>
          </a>
          <a href="#domains" class="nav-item" data-section="domains">
            <span class="nav-dot"></span>
            <span class="nav-label">Domains</span>
          </a>
          <a href="#events" class="nav-item" data-section="events">
            <span class="nav-dot"></span>
            <span class="nav-label">Events</span>
          </a>
          <a href="#projects" class="nav-item" data-section="projects">
            <span class="nav-dot"></span>
            <span class="nav-label">Projects</span>
          </a>
          <a href="#acm-w" class="nav-item" data-section="acm-w">
            <span class="nav-dot"></span>
            <span class="nav-label">ACM-W</span>
          </a>
          <button
            class="nav-item more-toggle"
            data-section="more"
            aria-controls="desktopMoreMenu"
            aria-expanded="false"
          >
            <span class="nav-dot"></span>
            <span class="nav-label">More</span>
          </button>
        </div>
      </div>

      <!-- Desktop More dropdown -->
      <div id="desktopMoreMenu" class="more-menu">
        <ul class="more-list">
          <li><a href="#blogs">Blogs</a></li>
          <li><a href="#partners">Partners</a></li>
          <li><a href="#contact">Contact Us</a></li>
          <li><a href="#community">Community</a></li>
          <li><a href="#team">Team</a></li>
        </ul>
      </div>

      <!-- Mobile nav -->
      <div class="nav-mobile">
        <button
          id="mobile-menu-btn"
          class="pointer-events-auto w-12 h-12 flex items-center justify-center rounded-full bg-[rgba(0,0,0,0.35)] border border-[#FEFCD9] backdrop-blur transition-transform active:scale-95"
          aria-label="Toggle menu"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#FEFCD9"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <div
          id="mobile-menu-overlay"
          class="fixed inset-0 bg-black/95 z-[100] translate-x-full transition-transform duration-300 flex flex-col items-center justify-center"
        >
          <button
            id="mobile-menu-close"
            class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center text-[#FEFCD9]"
          >
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <ul class="flex flex-col gap-6 text-center">
            {
              [
                "about",
                "domains",
                "events",
                "projects",
                "acm-w",
                "blogs",
                "partners",
                "contact",
                "community",
                "team",
              ].map((item) => (
                <li>
                  <a
                    href={`#${item}`}
                    class="mobile-nav-link text-3xl font-light font-['PolySans_Trial'] uppercase text-[#FEFCD9] hover:text-[#F95F4A] transition-colors"
                  >
                    {item.replace("-", " ")}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* ── Pill container ── */
  .header-pill {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 10px 16px;
    background: rgba(6, 2, 2, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(254, 252, 217, 0.14);
    border-radius: 100px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  /* ── Each nav item ── */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 5px 10px;
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    border: none;
    background: transparent;
    transition: gap 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-item.active {
    gap: 8px;
  }

  /* ── Dot ── */
  .nav-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(254, 252, 217, 0.32);
    flex-shrink: 0;
    transition: background 0.35s ease, transform 0.35s ease;
  }

  .nav-item.active .nav-dot {
    background: #fefcd9;
  }

  .nav-item:hover:not(.active) .nav-dot {
    background: rgba(254, 252, 217, 0.6);
  }

  /* ── Label: hidden until active, expands via max-width ── */
  .nav-label {
    font-size: 13px;
    font-family: "PolySans Trial", sans-serif;
    color: #fefcd9;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 400;
    white-space: nowrap;
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-width 0.38s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.22s ease;
  }

  .nav-item.active .nav-label {
    max-width: 200px;
    opacity: 1;
  }

  /* ── Pink mode for ACM-W ── */
  .nav-item.active.pink-mode .nav-dot {
    background: #ff007a;
  }

  .nav-item.active.pink-mode .nav-label {
    color: #ff007a;
  }

  /* ── More dropdown ── */
  .more-menu {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(8px) scale(0.96);
    transform-origin: top center;
    width: 180px;
    border: 1px solid rgba(254, 252, 217, 0.14);
    border-radius: 18px;
    background: rgba(6, 2, 2, 0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    padding: 10px 12px;
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    z-index: 60;
    opacity: 0;
    transition:
      opacity 0.18s ease,
      transform 0.24s cubic-bezier(0.22, 0.61, 0.36, 1);
    pointer-events: none;
  }

  .more-menu.open {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
    pointer-events: auto;
  }

  .more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }

  .more-list a {
    text-decoration: none;
    color: rgba(254, 252, 217, 0.75);
    font-family: "PolySans Trial", sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s ease;
    display: block;
    padding: 2px 4px;
  }

  .more-list a:hover {
    color: #f95f4a;
  }

  .more-list li {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.2s ease,
      transform 0.25s ease;
  }

  .more-menu.open .more-list li {
    opacity: 1;
    transform: translateY(0);
  }

  .more-menu.open .more-list li:nth-child(1) { transition-delay: 0.02s; }
  .more-menu.open .more-list li:nth-child(2) { transition-delay: 0.06s; }
  .more-menu.open .more-list li:nth-child(3) { transition-delay: 0.10s; }
  .more-menu.open .more-list li:nth-child(4) { transition-delay: 0.14s; }
  .more-menu.open .more-list li:nth-child(5) { transition-delay: 0.18s; }

  /* ── Layout ── */
  .nav-desktop {
    display: block;
    position: relative;
    transform: scale(var(--nav-bar-scale, 1));
    transform-origin: top center;
    transition: transform 160ms ease;
  }

  .nav-mobile {
    display: none;
    position: relative;
    pointer-events: auto;
  }

  /* ── Mobile breakpoints ── */
  @media (max-width: 952px) {
    body.partners-active .site-header {
      z-index: 200;
    }
    body.mobile-menu-open #mobile-menu-btn {
      opacity: 0;
      pointer-events: none;
    }
    .site-header {
      top: 15px;
      bottom: auto;
      padding: 0 15px;
    }
    .header-inner {
      justify-content: flex-end;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
    }
    body.hero-in-view .header-inner {
      justify-content: center;
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 45px;
      height: 45px;
    }
    #mobile-menu-close {
      top: 15px;
      right: 15px;
      bottom: auto;
      left: auto;
      transform: none;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
    .nav-desktop {
      display: none;
      transform: none;
    }
    .nav-mobile {
      display: block;
    }
  }

  @media screen and (max-width: 480px) {
    .site-header {
      top: 10px;
      padding: 0 10px;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 35px;
      height: 35px;
    }
    #mobile-menu-btn svg,
    #mobile-menu-close svg {
      width: 20px;
      height: 20px;
    }
    #mobile-menu-close {
      top: 10px;
      right: 10px;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id], footer[id]");

    // Mobile Menu
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    function toggleMobileMenu(show) {
      if (show) {
        mobileMenuOverlay.classList.remove("translate-x-full");
        document.body.classList.add("mobile-menu-open");
      } else {
        mobileMenuOverlay.classList.add("translate-x-full");
        document.body.classList.remove("mobile-menu-open");
      }
    }

    if (mobileMenuBtn) mobileMenuBtn.addEventListener("click", () => toggleMobileMenu(true));
    if (mobileMenuClose) mobileMenuClose.addEventListener("click", () => toggleMobileMenu(false));
    mobileNavLinks.forEach((link) => link.addEventListener("click", () => toggleMobileMenu(false)));

    // Section → nav-item mapping
    const idMapping = {
      work: "events",
      "igniting-minds-section": "about",
      "projects-intro": "projects",
      "community-outreach": "community",
      "community-sdg": "community",
      "community-conduct": "community",
      "community-speaker": "community",
    };

    const moreSectionIds = ["blogs", "partners", "contact", "community", "team"];

    const moreSectionLabels = {
      blogs: "Blogs",
      partners: "Partners",
      contact: "Contact",
      community: "Community",
      team: "Team",
    };

    // ── Dot nav active state ──
    function setActiveItem(navSection, labelOverride = null) {
      const items = document.querySelectorAll(".nav-desktop .nav-item");
      items.forEach((item) => {
        item.classList.remove("active", "pink-mode");
        // Reset more button label
        if (item.dataset.section === "more") {
          item.querySelector(".nav-label").textContent = "More";
        }
      });

      if (!navSection) return;

      const target = document.querySelector(
        `.nav-desktop .nav-item[data-section="${navSection}"]`
      );
      if (!target) return;

      target.classList.add("active");
      if (navSection === "acm-w") target.classList.add("pink-mode");
      if (labelOverride) target.querySelector(".nav-label").textContent = labelOverride;
    }

    function applyNavState(sectionId) {
      if (!sectionId || sectionId === "footer") {
        setActiveItem(null);
        return;
      }

      const mappedId = idMapping[sectionId] || sectionId;

      if (moreSectionIds.includes(mappedId)) {
        const label = moreSectionLabels[mappedId] || "More";
        setActiveItem("more", label);
        return;
      }

      setActiveItem(mappedId);
    }

    // ── Scroll tracking ──
    let currentSectionId = null;
    let rafPending = false;
    let lastScrollY = window.scrollY || window.pageYOffset;
    let scrollDirection = "down";

    function getActiveSection() {
      const focusLine = window.innerHeight * 0.3;
      let activeSection = null;
      let closestSection = null;
      let closestDistance = Infinity;
      let closestPosition = null;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= focusLine && rect.bottom >= focusLine) {
          activeSection = section;
        }
        let distance = 0;
        let position = null;
        if (rect.top > focusLine) {
          distance = rect.top - focusLine;
          position = "below";
        } else if (rect.bottom < focusLine) {
          distance = focusLine - rect.bottom;
          position = "above";
        }
        if (distance < closestDistance) {
          closestDistance = distance;
          closestSection = section;
          closestPosition = position;
        }
      });

      return activeSection || closestSection;
    }

    function updateActiveSection() {
      rafPending = false;
      const scrollY = window.scrollY || window.pageYOffset;
      if (scrollY !== lastScrollY) {
        scrollDirection = scrollY > lastScrollY ? "down" : "up";
        lastScrollY = scrollY;
      }
      const activeSection = getActiveSection();
      if (!activeSection) return;
      const id = activeSection.getAttribute("id");
      if (!id || id === currentSectionId) return;
      currentSectionId = id;
      applyNavState(id);
    }

    function scheduleNavUpdate() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(updateActiveSection);
    }

    const observer = new IntersectionObserver(
      () => scheduleNavUpdate(),
      { root: null, rootMargin: "-20% 0px -60% 0px", threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
    window.addEventListener("scroll", scheduleNavUpdate, { passive: true });

    // ── More dropdown ──
    const toggles = Array.from(document.querySelectorAll(".more-toggle"));
    const moreMenuLinks = document.querySelectorAll("#desktopMoreMenu a");

    const getMenuFor = (tg) => {
      const id = tg.getAttribute("aria-controls");
      return id ? document.getElementById(id) : null;
    };

    const openMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "true");
      menu.classList.add("open");
    };

    const closeMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "false");
      menu.classList.remove("open");
    };

    const allMenus = () => toggles.map(getMenuFor).filter(Boolean);
    const closeAll = () =>
      toggles.forEach((tg) => {
        const m = getMenuFor(tg);
        if (m) closeMenu(tg, m);
      });

    let suppressNextDocClick = false;

    toggles.forEach((tg) => {
      const menu = getMenuFor(tg);
      if (!menu) return;

      tg.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        suppressNextDocClick = true;
        setTimeout(() => { suppressNextDocClick = false; }, 0);
        const expanded = tg.getAttribute("aria-expanded") === "true";
        toggles.forEach((ot) => {
          if (ot !== tg) { const om = getMenuFor(ot); if (om) closeMenu(ot, om); }
        });
        expanded ? closeMenu(tg, menu) : openMenu(tg, menu);
      });

      let hoverTimer = null;
      const startCloseTimer = () => { hoverTimer = setTimeout(() => closeMenu(tg, menu), 220); };
      const clearCloseTimer = () => { if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; } };

      tg.addEventListener("mouseenter", () => openMenu(tg, menu));
      tg.addEventListener("mouseleave", () => startCloseTimer());
      menu.addEventListener("mouseenter", () => clearCloseTimer());
      menu.addEventListener("mouseleave", () => startCloseTimer());
    });

    moreMenuLinks.forEach((link) => link.addEventListener("click", () => closeAll()));

    document.addEventListener("click", (e) => {
      if (suppressNextDocClick) return;
      const t = e.target;
      if (!(t instanceof Node)) return;
      const withinToggle = toggles.some((tg) => tg.contains(t));
      const withinMenu = allMenus().some((m) => m.contains(t));
      if (!withinToggle && !withinMenu) closeAll();
    });

    // ── Smooth scroll ──
    document.addEventListener("click", (e) => {
      const el = e.target instanceof Element ? e.target.closest('a[href^="#"]') : null;
      if (!el) return;
      const href = el.getAttribute("href");
      if (!href || href.length < 2) return;
      const id = href.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      closeAll();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);
      applyNavState(id);
      currentSectionId = id;
    });

    scheduleNavUpdate();
  });
</script>
