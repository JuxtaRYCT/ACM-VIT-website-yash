    }

    function startHideTimer() {
      megamenuTimer = setTimeout(hideMegamenu, 180);
    }

    function cancelHideTimer() {
      if (megamenuTimer) {
        clearTimeout(megamenuTimer);
        megamenuTimer = null;
      }
    }

    // Nav item hover → show panel
    document.querySelectorAll(".nav-desktop .nav-item").forEach((item) => {
      const section = item.getAttribute("data-section");
      if (!sectionsWithDropdowns.includes(section)) return;

      item.addEventListener("mouseenter", () => {
        cancelHideTimer();
        showMegamenu(section);
      });
      item.addEventListener("mouseleave", () => {
        startHideTimer();
      });
    });

    // Megamenu hover → keep open
    if (megamenu) {
      megamenu.addEventListener("mouseenter", () => {
        cancelHideTimer();
      });
      megamenu.addEventListener("mouseleave", () => {
        startHideTimer();
      });
    }

    // Close megamenu on scroll
    window.addEventListener("scroll", () => {
      if (currentPanel) hideMegamenu();
    }, { passive: true });

    // Close megamenu when clicking a tile
    if (megamenu) {
      megamenu.querySelectorAll(".megamenu-tile").forEach((tile) => {
        tile.addEventListener("click", () => {
          hideMegamenu();
