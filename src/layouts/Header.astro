---
// Header.astro
---

<header
  class="site-header fixed top-5 left-0 right-0 z-50 w-full px-4 py-2 pointer-events-none"
>
  <div
    class="header-inner relative max-w-fit mx-auto flex justify-center pointer-events-auto"
  >
    <nav>
      <!-- Desktop nav -->
      <div class="nav-desktop">
        <div class="header-pill" id="headerPill">
          <a href="#about" class="nav-item" data-section="about" style="--dot-i:0">
            <span class="nav-dot"></span>
            <span class="nav-label">About</span>
          </a>
          <a href="#community" class="nav-item" data-section="community" style="--dot-i:1">
            <span class="nav-dot"></span>
            <span class="nav-label">Community</span>
          </a>
          <a href="#domains" class="nav-item" data-section="domains" style="--dot-i:2">
            <span class="nav-dot"></span>
            <span class="nav-label">Domains</span>
          </a>
          <a href="#events" class="nav-item" data-section="events" style="--dot-i:3">
            <span class="nav-dot"></span>
            <span class="nav-label">Events</span>
          </a>
          <a href="#projects" class="nav-item" data-section="projects" style="--dot-i:4">
            <span class="nav-dot"></span>
            <span class="nav-label">Projects</span>
          </a>
          <a href="#acm-w" class="nav-item" data-section="acm-w" style="--dot-i:5">
            <span class="nav-dot"></span>
            <span class="nav-label">ACM-W</span>
          </a>
          <a href="#team" class="nav-item" data-section="team" style="--dot-i:6">
            <span class="nav-dot"></span>
            <span class="nav-label">Team</span>
          </a>
          <a href="#blogs" class="nav-item" data-section="blogs" style="--dot-i:7">
            <span class="nav-dot"></span>
            <span class="nav-label">Blogs</span>
          </a>
          <a href="#partners" class="nav-item" data-section="partners" style="--dot-i:8">
            <span class="nav-dot"></span>
            <span class="nav-label">Partners</span>
          </a>
          <a href="#gallery" class="nav-item" data-section="gallery" style="--dot-i:9">
            <span class="nav-dot"></span>
            <span class="nav-label">Gallery</span>
          </a>
          <a href="#contact" class="nav-item" data-section="contact" style="--dot-i:10">
            <span class="nav-dot"></span>
            <span class="nav-label">Contact</span>
          </a>
        </div>
      </div>

      <!-- Mobile nav -->
      <div class="nav-mobile">
        <button
          id="mobile-menu-btn"
          class="pointer-events-auto w-12 h-12 flex items-center justify-center rounded-full bg-[rgba(0,0,0,0.35)] border border-[#FEFCD9] backdrop-blur transition-transform active:scale-95"
          aria-label="Toggle menu"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#FEFCD9"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <div
          id="mobile-menu-overlay"
          class="fixed inset-0 bg-black/95 z-[100] translate-x-full transition-transform duration-300 flex flex-col items-center justify-center"
        >
          <button
            id="mobile-menu-close"
            class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center text-[#FEFCD9]"
          >
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <ul class="flex flex-col gap-6 text-center">
            {
              [
                "about",
                "community",
                "domains",
                "events",
                "projects",
                "acm-w",
                "team",
                "blogs",
                "partners",
                "gallery",
                "contact",
              ].map((item) => (
                <li>
                  <a
                    href={`#${item}`}
                    class="mobile-nav-link text-3xl font-light font-['PolySans_Trial'] uppercase text-[#FEFCD9] hover:text-[#F95F4A] transition-colors"
                  >
                    {item.replace("-", " ")}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* ── Bubble intro keyframes ── */

  /* Phase 1: drop in as a circle from above + bounce */
  @keyframes pillDrop {
    0% {
      transform: translateY(-36px) scale(0.7);
      /* all 4 sides = calc(50% - 19px): top/bottom% resolve against height,
         left/right% against width → always 38×38px centered → perfect circle */
      clip-path: inset(calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) round 999px);
      opacity: 0;
    }
    28% {
      opacity: 1;
      transform: translateY(7px) scale(1.05);
      clip-path: inset(calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) round 999px);
    }
    46% {
      transform: translateY(-2px) scale(0.98);
      clip-path: inset(calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) round 999px);
    }
    60% {
      transform: translateY(0) scale(1);
      clip-path: inset(calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) round 999px);
    }
    /* Phase 2: expand sideways then settle */
    80% {
      transform: translateY(0) scaleY(1.02);
      clip-path: inset(0 -6px 0 -6px round 100px);
    }
    92% {
      transform: translateY(0) scaleY(1);
      clip-path: inset(0 1px 0 1px round 100px);
    }
    100% {
      transform: translateY(0) scaleY(1);
      clip-path: inset(0 0px 0 0px round 100px);
      opacity: 1;
    }
  }

  @keyframes navDotsAppear {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ── Pill container ── */
  .header-pill {
    /* astro-liquid-glass tokens (scoped to pill) */
    --glass-bg: rgba(6, 2, 2, 0.22);
    --glass-blur: 32px;
    --glass-saturate: 220%;
    --glass-border: rgba(249, 95, 74, 0.75);
    --glass-highlight: rgba(255, 255, 255, 0.18);
    --glass-shadow: rgba(0, 0, 0, 0.5);
    --lens-edge-light: transparent;
    --lens-edge-dark: transparent;

    /* astro-liquid-glass .glass base styles (ported from package) */
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    position: relative;

    display: flex;
    align-items: center;
    gap: 0;
    padding: 10px 16px;
    border-radius: 100px;
    box-shadow:
      0 8px 32px var(--glass-shadow),
      0 0 18px rgba(249, 95, 74, 0.10),
      0 0 6px rgba(249, 95, 74, 0.08),
      inset 0 1px 0 var(--glass-highlight),
      inset 0 0 12px rgba(249, 95, 74, 0.04);
    transition:
      box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      padding 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    /* Hidden until triggered */
    opacity: 0;
    clip-path: inset(calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) calc(50% - 19px) round 999px);
  }

  /* astro-liquid-glass lens-edge light effect (::before) + top highlight (::after) */
  .header-pill::before,
  .header-pill::after {
    border-radius: inherit;
    content: "";
    pointer-events: none;
    position: absolute;
  }

  /* Diagonal lens refraction — light top-left, dark bottom-right */
  .header-pill::before {
    background: linear-gradient(
      135deg,
      var(--lens-edge-light) 0%,
      transparent 40%,
      transparent 60%,
      var(--lens-edge-dark) 100%
    );
    inset: 0;
    opacity: 0.85;
  }

  /* Top inner highlight — like a glass rim catching light */
  .header-pill::after {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent);
    height: 50%;
    left: 0;
    right: 0;
    top: 0;
  }

  /* Playing state — triggered by JS after preloader */
  .header-pill.pill-intro-play {
    animation: pillDrop 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* Dots appear after pill expands */
  .header-pill.pill-intro-play .nav-dot {
    animation: navDotsAppear 0.35s ease both;
    animation-delay: calc(0.55s + var(--dot-i, 0) * 0.03s);
  }

  /* Hover state */
  .header-pill:hover {
    --glass-border: rgba(249, 95, 74, 1.0);
    --glass-bg: rgba(6, 2, 2, 0.32);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.55),
      0 0 24px rgba(249, 95, 74, 0.14),
      0 0 8px rgba(249, 95, 74, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      inset 0 0 16px rgba(249, 95, 74, 0.06);
    padding: 10px 20px;
  }

  /* ── Each nav item ── */
  .nav-item {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 5px 10px;
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    border: none;
    background: transparent;
    transition: gap 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* Hover on pill — expand all items */
  .header-pill:hover .nav-item {
    gap: 7px;
  }

  .nav-item.active {
    gap: 8px;
  }

  /* ── Dot ── */
  .nav-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(254, 252, 217, 0.28);
    flex-shrink: 0;
    transition:
      background 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.38s cubic-bezier(0.25, 0.1, 0.25, 1),
      box-shadow 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .nav-item.active .nav-dot {
    background: #fefcd9;
    box-shadow: 0 0 8px rgba(254, 252, 217, 0.5);
  }

  .header-pill:hover .nav-item:not(.active) .nav-dot {
    background: rgba(254, 252, 217, 0.5);
    transform: scale(1.15);
  }

  .header-pill:hover .nav-item.active .nav-dot {
    transform: scale(1.2);
  }

  /* ── Label: hidden until active or pill hovered ── */
  .nav-label {
    font-size: 12px;
    font-family: "PolySans Trial", sans-serif;
    color: #fefcd9;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 400;
    white-space: nowrap;
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      opacity 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* Show all labels on pill hover */
  .header-pill:hover .nav-label {
    max-width: 120px;
    opacity: 0.8;
  }

  /* Active label always visible, full opacity */
  .nav-item.active .nav-label {
    max-width: 120px;
    opacity: 1;
  }

  /* On hover + active: full opacity */
  .header-pill:hover .nav-item.active .nav-label {
    opacity: 1;
  }

  /* ── Pink mode for ACM-W ── */
  .nav-item.active.pink-mode .nav-dot {
    background: #ff007a;
    box-shadow: 0 0 8px rgba(255, 0, 122, 0.5);
  }

  .nav-item.active.pink-mode .nav-label {
    color: #ff007a;
  }

  /* ── Layout ── */
  .nav-desktop {
    display: block;
    position: relative;
    transform: scale(var(--nav-bar-scale, 1));
    transform-origin: top center;
    transition: transform 160ms ease;
  }

  .nav-mobile {
    display: none;
    position: relative;
    pointer-events: auto;
  }

  /* ── Mobile breakpoints ── */
  @media (max-width: 952px) {
    body.partners-active .site-header {
      z-index: 200;
    }
    body.mobile-menu-open #mobile-menu-btn {
      opacity: 0;
      pointer-events: none;
    }
    .site-header {
      top: 15px;
      bottom: auto;
      padding: 0 15px;
    }
    .header-inner {
      justify-content: flex-end;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
    }
    body.hero-in-view .header-inner {
      justify-content: center;
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 45px;
      height: 45px;
    }
    #mobile-menu-close {
      top: 15px;
      right: 15px;
      bottom: auto;
      left: auto;
      transform: none;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
    .nav-desktop {
      display: none;
      transform: none;
    }
    .nav-mobile {
      display: block;
    }
  }

  @media screen and (max-width: 480px) {
    .site-header {
      top: 10px;
      padding: 0 10px;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 35px;
      height: 35px;
    }
    #mobile-menu-btn svg,
    #mobile-menu-close svg {
      width: 20px;
      height: 20px;
    }
    #mobile-menu-close {
      top: 10px;
      right: 10px;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id], footer[id]");

    // Mobile Menu
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    function toggleMobileMenu(show) {
      if (show) {
        mobileMenuOverlay.classList.remove("translate-x-full");
        document.body.classList.add("mobile-menu-open");
      } else {
        mobileMenuOverlay.classList.add("translate-x-full");
        document.body.classList.remove("mobile-menu-open");
      }
    }

    if (mobileMenuBtn) mobileMenuBtn.addEventListener("click", () => toggleMobileMenu(true));
    if (mobileMenuClose) mobileMenuClose.addEventListener("click", () => toggleMobileMenu(false));
    mobileNavLinks.forEach((link) => link.addEventListener("click", () => toggleMobileMenu(false)));

    // Section → nav-item mapping
    const idMapping = {
      work: "events",
      "igniting-minds-section": "community",
      "community-outreach": "community",
      "community-sdg": "community",
      "community-conduct": "community",
      "community-speaker": "community",
      "community-award": "community",
      "projects-intro": "projects",
    };

    // ── Dot nav active state ──
    function setActiveItem(navSection) {
      const items = document.querySelectorAll(".nav-desktop .nav-item");
      items.forEach((item) => {
        item.classList.remove("active", "pink-mode");
      });

      if (!navSection) return;

      const target = document.querySelector(
        `.nav-desktop .nav-item[data-section="${navSection}"]`
      );
      if (!target) return;

      target.classList.add("active");
      if (navSection === "acm-w") target.classList.add("pink-mode");
    }

    function applyNavState(sectionId) {
      if (!sectionId || sectionId === "footer") {
        setActiveItem(null);
        return;
      }
      const mappedId = idMapping[sectionId] || sectionId;
      setActiveItem(mappedId);
    }

    // ── Scroll tracking ──
    let currentSectionId = null;
    let rafPending = false;
    let lastScrollY = window.scrollY || window.pageYOffset;

    function getActiveSection() {
      const focusLine = window.innerHeight * 0.3;
      let activeSection = null;
      let closestSection = null;
      let closestDistance = Infinity;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= focusLine && rect.bottom >= focusLine) {
          activeSection = section;
        }
        let distance = 0;
        if (rect.top > focusLine) {
          distance = rect.top - focusLine;
        } else if (rect.bottom < focusLine) {
          distance = focusLine - rect.bottom;
        }
        if (distance < closestDistance) {
          closestDistance = distance;
          closestSection = section;
        }
      });

      return activeSection || closestSection;
    }

    function updateActiveSection() {
      rafPending = false;
      const scrollY = window.scrollY || window.pageYOffset;
      lastScrollY = scrollY;
      const activeSection = getActiveSection();
      if (!activeSection) return;
      const id = activeSection.getAttribute("id");
      if (!id || id === currentSectionId) return;
      currentSectionId = id;
      applyNavState(id);
    }

    function scheduleNavUpdate() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(updateActiveSection);
    }

    const observer = new IntersectionObserver(
      () => scheduleNavUpdate(),
      { root: null, rootMargin: "-20% 0px -60% 0px", threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
    window.addEventListener("scroll", scheduleNavUpdate, { passive: true });

    // ── Smooth scroll ──
    document.addEventListener("click", (e) => {
      const el = e.target instanceof Element ? e.target.closest('a[href^="#"]') : null;
      if (!el) return;
      const href = el.getAttribute("href");
      if (!href || href.length < 2) return;
      const id = href.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);
      applyNavState(id);
      currentSectionId = id;
    });

    scheduleNavUpdate();

    // ── Bubble intro animation ──
    const pill = document.getElementById("headerPill");
    if (pill) {
      let introFired = false;
      function triggerPillIntro() {
        if (introFired) return;
        introFired = true;
        pill.classList.add("pill-intro-play");
      }

      // Fire after preloader done, with a small settle delay
      window.addEventListener("preloader:done", () => {
        setTimeout(triggerPillIntro, 60);
      }, { once: true });

      // Fallback: fire 2.5s after load if preloader event never fires
      window.addEventListener("load", () => {
        setTimeout(triggerPillIntro, 2500);
      }, { once: true });
    }
  });
</script>
