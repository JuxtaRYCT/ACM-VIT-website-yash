---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import "../styles/calendar.css";
import "../styles/calendar-agenda.css";
import { getAssetUrl } from "../utils/cdn";
import Footer from "../layouts/Footer.astro";
import EventCalendar from "../components/calendar/EventCalendar.astro";
import CalendarAgenda from "../components/calendar/CalendarAgenda.astro";
---

<Layout pageTitle="Calendar" backHref="/#events">
  <section class="calendar-page relative overflow-hidden pt-8 md:pt-16 pb-0">
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.06]"
      style={`background-image: url(${getAssetUrl("/backgrounds/backgrounds-background-pattern.webp")}); background-size: cover;`}
    ></div>

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
      <p class="text-[#FF5F4A] text-xs sm:text-sm font-mono tracking-[0.3em] uppercase mb-8 md:mb-12">
        ACM-VIT - Events Calendar
      </p>

      <h1 class="text-[clamp(3.5rem,10vw,12rem)] font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.82]">
        CALEN<span class="text-[#FF5F4A]">DAR</span>
      </h1>

      <div class="w-20 h-[3px] bg-[#FF5F4A] my-8 md:my-10"></div>

      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 mb-12">
        <p class="text-gray-300 font-mono text-xs sm:text-sm leading-relaxed uppercase max-w-xl">
          Stay on top of everything happening at ACM-VIT - workshops, hackathons, meetups, and more.
        </p>
        <div class="cal-view-switcher" id="cal-view-switcher">
          <button class="cal-switch-btn cal-switch-active" data-calview="agenda">Agenda</button>
          <button class="cal-switch-btn" data-calview="traditional">Traditional</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Agenda View (default) -->
  <section class="calendar-body relative z-10 pb-24" id="cal-agenda-section">
    <div class="max-w-[1400px] mx-auto px-4 md:px-10">
      <CalendarAgenda />
    </div>
  </section>

  <!-- Traditional View (hidden by default) -->
  <section class="calendar-body relative z-10 pb-24 hidden" id="cal-traditional-section">
    <div class="max-w-[1400px] mx-auto px-4 md:px-10">
      <EventCalendar />
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const agendaSec = document.getElementById('cal-agenda-section')!;
  const tradSec = document.getElementById('cal-traditional-section')!;
  const btns = document.querySelectorAll<HTMLButtonElement>('[data-calview]');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.calview;
      btns.forEach(b => b.classList.remove('cal-switch-active'));
      btn.classList.add('cal-switch-active');

      if (view === 'agenda') {
        agendaSec.classList.remove('hidden');
        tradSec.classList.add('hidden');
      } else {
        agendaSec.classList.add('hidden');
        tradSec.classList.remove('hidden');
      }
    });
  });
</script>
