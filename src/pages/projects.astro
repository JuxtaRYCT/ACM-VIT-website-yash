---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import "../styles/projects.css";
import { getAssetUrl } from "../utils/cdn";
import Cassette from "../components/ui/Cassette.astro";
import Footer from "../layouts/Footer.astro";
import { forktoberByYear, forktoberYears } from "../data/forktoberProjectsData";

const FORKTOBER_COLOR = "#EFEFEF";

const overlayProjects = [
  {
    name: "ACMOne",
    color: "#F95F4A",
    image: "/projects/items/0/cassetteSrc.webp",
    alt: "ACMOne",
    url: "/projects/acmone",
    sizePercent: 85,
    sizeAxis: "width" as const,
    offsetY: -5,
  },
  {
    name: "ExamCooker",
    color: "#2664e4",
    image: "/projects/items/1/cassetteSrc.webp",
    alt: "ExamCooker",
    url: "/projects/examcooker",
    sizePercent: 80,
    sizeAxis: "width" as const,
    offsetY: -3,
  },
  {
    name: "CLI-RPG",
    color: "#16A34A",
    image: "/projects/items/2/cassetteSrc.webp",
    alt: "CLI RPG",
    url: "/projects/cli-rpg",
    sizePercent: 75,
    sizeAxis: "width" as const,
    offsetY: -5,
  },
  {
    name: "UniPool",
    color: "#7100FF",
    image: "/projects/items/3/cassetteSrc.webp",
    alt: "UniPool",
    url: "/projects/unipool",
    sizePercent: 80,
    sizeAxis: "width" as const,
    offsetY: -3,
  },
  {
    name: "Localhost",
    color: "#eb5757",
    image: "/projects/items/4/cassetteSrc.webp",
    alt: "Localhost",
    url: "https://localhost.acmvit.in",
    sizePercent: 85,
    sizeAxis: "width" as const,
    offsetY: -5,
  },
  {
    name: "OCS",
    color: "#8710DB",
    image: "/projects/items/5/cassetteSrc.webp",
    alt: "OCS Website",
    url: "https://os.acmvit.in",
    sizePercent: 100,
    sizeAxis: "width" as const,
    offsetY: 0,
  },
];

const svgProjects = [
  { name: "Conclave", color: "#FF6B35", cassetteSvg: "/projects/cassettes/conclave.svg", alt: "Conclave", url: "https://github.com/ACM-VIT/conclave" },
  { name: "TAGRED", color: "#E53E3E", cassetteSvg: "/projects/cassettes/tagred.svg", alt: "TAGRED", url: "https://github.com/ACM-VIT/TAGRED" },
  { name: "WENVY", color: "#38B2AC", cassetteSvg: "/projects/cassettes/wenvy.svg", alt: "WENVY", url: "https://github.com/ACM-VIT/wenvy" },
  { name: "CLI-TOP", color: "#48BB78", cassetteSvg: "/projects/cassettes/cli-top.svg", alt: "CLI-TOP", url: "https://github.com/ACM-VIT" },
  { name: "FORM", color: "#805AD5", cassetteSvg: "/projects/cassettes/form.svg", alt: "FORM", url: "https://github.com/ACM-VIT" },
  { name: "CODIGO", color: "#DD6B20", cassetteSvg: "/projects/cassettes/codigo.svg", alt: "CODIGO", url: "https://github.com/ACM-VIT" },
  { name: "OCS 2022", color: "#8710DB", cassetteSvg: "/projects/cassettes/ocs-22.svg", alt: "OCS 2022", url: "https://github.com/ACM-VIT" },
  { name: "OCS 2023", color: "#9F40DB", cassetteSvg: "/projects/cassettes/ocs-23.svg", alt: "OCS 2023", url: "https://github.com/ACM-VIT" },
  { name: "OCS 2026", color: "#B721FF", cassetteSvg: "/projects/cassettes/ocs-26.svg", alt: "OCS 2026", url: "https://github.com/ACM-VIT" },
];
---

<Layout pageTitle="Projects" backHref="/#projects">
  <section class="proj-page">
    <!-- Tubelight (dark mode only) -->
    <div class="proj-tubelight-wrap">
      <img
        id="proj-tubelight"
        src={getAssetUrl("/effects/white_tubelight.webp")}
        alt=""
        class="proj-tubelight"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- Tagline -->
    <p class="proj-tagline">Not prototypes. Not demos. We make the real thing.</p>

    <!-- Grid -->
    <div class="proj-grid">
      {overlayProjects.map((proj) => {
        const isExternal = /^https?:\/\//.test(proj.url);
        return (
        <a
          href={proj.url}
          {...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          class="proj-card"
          style={`--card-glow: ${proj.color};`}
        >
          <div class="proj-card-inner">
            <Cassette
              color={proj.color}
              overlaySrc={proj.image}
              alt={proj.alt}
              overlaySizePercent={proj.sizePercent}
              overlaySizeAxis={proj.sizeAxis}
              offsetYPercent={proj.offsetY}
            />
          </div>
        </a>
        );
      })}
      {svgProjects.map((proj) => (
        <a
          href={proj.url}
          target="_blank"
          rel="noopener noreferrer"
          class="proj-card"
          style={`--card-glow: ${proj.color};`}
        >
          <div class="proj-card-inner proj-svg-cassette">
            <img
              src={getAssetUrl(proj.cassetteSvg)}
              alt={proj.alt}
              class="proj-svg-cassette-img"
              loading="lazy"
              decoding="async"
            />
          </div>
        </a>
      ))}
    </div>

    <!-- Forktober projects -->
    <section class="proj-forktober" aria-labelledby="forktober-heading">
      <div class="proj-forktober-header">
        <p class="proj-forktober-eyebrow">Open Source · Hacktoberfest</p>
        <h2 id="forktober-heading" class="proj-forktober-title">Projects under <span>Forktober</span></h2>
        <p class="proj-forktober-sub">Repositories ACM-VIT opens up to student contributors every October.</p>
      </div>

      {forktoberYears.map((year) => (
        <div class="proj-forktober-year-block">
          <div class="proj-forktober-year-label">
            <span class="proj-forktober-year-num">{year}</span>
            <span class="proj-forktober-year-meta">{forktoberByYear[year].length} repositories</span>
          </div>
          <div class="proj-grid proj-grid--forktober">
            {forktoberByYear[year].map((p) => (
              <a
                href={`/projects/${p.slug}`}
                class="proj-card proj-card--forktober"
                style={`--card-glow: ${FORKTOBER_COLOR};`}
                aria-label={`${p.title} — Forktober ${year}`}
              >
                <div class="proj-card-inner">
                  <Cassette color={FORKTOBER_COLOR} alt={p.title} />
                  <div class="proj-forktober-overlay">
                    <span class="proj-forktober-overlay-name">{p.title}</span>
                    <span class="proj-forktober-overlay-year">Forktober · {p.years.join(", ")}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Bottom glow -->
    <div class="proj-bottom-glow">
      <div class="proj-tubelight-wrap proj-tubelight-wrap--bottom">
        <img
          id="proj-tubelight-bottom"
          src={getAssetUrl("/effects/white_tubelight.webp")}
          alt=""
          class="proj-tubelight"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .proj-card::after {
    box-shadow: 0 0 8px 1px var(--card-glow, transparent);
  }

  .proj-svg-cassette-img {
    width: 100%;
    height: 100%;
    display: block;
  }

  :global(html[data-theme="light"]) .proj-svg-cassette {
    background: #1a1a1a;
    border-radius: 16px;
  }

  :global(html[data-theme="light"]) .proj-svg-cassette-img {
    filter: sepia(0.15) brightness(0.98);
  }

  /* ── Forktober section ── */
  .proj-forktober {
    max-width: 1400px;
    margin: 4rem auto 2rem;
    padding: 0 1.5rem;
    position: relative;
    z-index: 2;
  }
  .proj-forktober-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .proj-forktober-eyebrow {
    font-family: 'PolySans Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(254, 252, 217, 0.55);
    margin: 0 0 0.75rem;
  }
  .proj-forktober-title {
    font-family: 'PolySans Trial', sans-serif;
    font-size: clamp(2rem, 4.2vw, 3rem);
    font-weight: 800;
    color: #FFFDD0;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
  }
  .proj-forktober-title span { color: #EFEFEF; opacity: 0.85; }
  .proj-forktober-sub {
    font-family: 'PolySans Trial', sans-serif;
    font-size: 0.95rem;
    color: rgba(254, 252, 217, 0.55);
    max-width: 640px;
    margin: 1rem auto 0;
    line-height: 1.6;
  }

  .proj-forktober-year-block {
    margin-top: 3rem;
  }
  .proj-forktober-year-label {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .proj-forktober-year-num {
    font-family: 'PolySans Trial', sans-serif;
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #FFFDD0;
    letter-spacing: -0.02em;
  }
  .proj-forktober-year-meta {
    font-family: 'PolySans Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(254, 252, 217, 0.45);
  }

  .proj-card--forktober .proj-card-inner {
    position: relative;
  }
  .proj-forktober-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    text-align: center;
    pointer-events: none;
    z-index: 5;
  }
  .proj-forktober-overlay-name {
    font-family: 'PolySans Trial', sans-serif;
    font-weight: 800;
    font-size: clamp(1.1rem, 2.2vw, 1.55rem);
    color: #FEFCD9;
    letter-spacing: -0.01em;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0,0,0,0.7), 0 0 2px rgba(0,0,0,0.5);
  }
  .proj-forktober-overlay-year {
    font-family: 'PolySans Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(254, 252, 217, 0.72);
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  :global(html[data-theme="light"]) .proj-forktober-title { color: #1a1a1a; }
  :global(html[data-theme="light"]) .proj-forktober-title span { color: #555; }
  :global(html[data-theme="light"]) .proj-forktober-eyebrow,
  :global(html[data-theme="light"]) .proj-forktober-sub { color: rgba(26, 26, 26, 0.6); }
  :global(html[data-theme="light"]) .proj-forktober-year-num { color: #1a1a1a; }
  :global(html[data-theme="light"]) .proj-forktober-year-meta { color: rgba(26, 26, 26, 0.5); }
  :global(html[data-theme="light"]) .proj-forktober-year-label { border-bottom-color: rgba(0,0,0,0.1); }
  :global(html[data-theme="light"]) .proj-forktober-overlay-name {
    color: #FEFCD9;
    text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 0 2px rgba(0,0,0,0.6);
  }
  :global(html[data-theme="light"]) .proj-forktober-overlay-year {
    color: rgba(254, 252, 217, 0.78);
    text-shadow: 0 1px 4px rgba(0,0,0,0.7);
  }
</style>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const tubelights = [
      document.getElementById("proj-tubelight"),
      document.getElementById("proj-tubelight-bottom"),
    ].filter(Boolean);

    tubelights.forEach((el) => {
      const tl = gsap.timeline({ delay: 0.3 });

      tl.to(el, { opacity: 0.3, duration: 0.05, ease: "none" })
        .to(el, { opacity: 0, duration: 0.05, ease: "none" })
        .to(el, { opacity: 0.5, duration: 0.08, ease: "none" })
        .to(el, { opacity: 0.1, duration: 0.05, ease: "none" })
        .to(el, { opacity: 0.6, duration: 0.1, ease: "none" })
        .to(el, { opacity: 0.2, duration: 0.06, ease: "none" })
        .to(el, { opacity: 0.7, duration: 0.12, ease: "none" })
        .to(el, { opacity: 0.3, duration: 0.05, ease: "none" })
        .to(el, { opacity: 0.8, duration: 0.3, ease: "power2.out" })
        .to(el, { opacity: 0.75, duration: 0.15, ease: "sine.inOut", yoyo: true, repeat: 1 });
    });
  });
</script>
