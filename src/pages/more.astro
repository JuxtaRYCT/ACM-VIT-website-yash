---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import Footer from "../layouts/Footer.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import CassetteTile from "../components/ui/CassetteTile.astro";

const items = [
  {
    title: "Code of Conduct",
    desc: "ACM ethical principles & community values",
    href: "/code-of-conduct",
    icon: "shield",
    accent: "#F95F4A",
    tag: "SIDE A",
  },
  {
    title: "Merchandise",
    desc: "Official ACM-VIT merch & collectibles",
    href: "/merchandise",
    icon: "bag",
    accent: "#FF007A",
    tag: "DROP",
  },
  {
    title: "GREP Newsletter",
    desc: "Our bi-annual technical newsletter",
    href: "/grep",
    icon: "mail",
    accent: "#135DE2",
    tag: "EP",
  },
  {
    title: "z0d1ak",
    desc: "ACM-VIT's competitive CTF team",
    href: "/z0d1ak",
    icon: "terminal",
    accent: "#42CD9D",
    tag: "LIVE",
  },
  {
    title: "Achievements",
    desc: "Awards, recognitions & milestones",
    href: "/achievements",
    icon: "trophy",
    accent: "#F2C94C",
    tag: "HITS",
  },
  {
    title: "Cassette Builder",
    desc: "Design & download your own custom cassette",
    href: "/cassette-builder",
    icon: "cassette",
    accent: "#9B51E0",
    tag: "MIX",
  },
  {
    title: "Calendar",
    desc: "Upcoming events & important dates",
    href: "/calendar",
    icon: "calendar",
    accent: "#008080",
    tag: "TOUR",
  },
];

const icons: Record<string, string> = {
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  bag: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  terminal: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  trophy: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6"/><path d="M18 9h1.5a2.5 2.5 0 000-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 19.24 7 20v2"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 19.24 17 20v2"/><path d="M18 2H6v7a6 6 0 0012 0V2z"/></svg>`,
  cassette: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/><path d="M10 12h4"/><path d="M7 19l2-4h6l2 4"/></svg>`,
  calendar: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
};
---

<Layout pageTitle="More" backHref="/">
  <main class="more-page relative w-full overflow-hidden">
    <!-- Background -->
    <div class="more-glow" aria-hidden="true"></div>
    <div class="more-grid-bg" aria-hidden="true">
      <span class="mg-v" style="left: 20%"></span>
      <span class="mg-v" style="left: 50%"></span>
      <span class="mg-v" style="left: 80%"></span>
    </div>

    <div class="more-inner relative z-10 mx-auto w-full max-w-6xl px-5 pb-24 pt-32 sm:px-8">
      <SectionHeading
        eyebrow="ACM-VIT · The B-Sides"
        title="More"
        accent="Tapes"
        subtitle="Flip the cassette - here's everything else we make. Press play on any of them."
        align="left"
        class="mb-16 !px-0"
      />

      <div class="more-rack">
        {
          items.map((item, i) => (
            <div class="tile-wrap" style={`--i: ${i}`}>
              <CassetteTile
                title={item.title}
                desc={item.desc}
                href={item.href}
                accent={item.accent}
                tag={item.tag}
              >
                <Fragment slot="icon" set:html={icons[item.icon]} />
              </CassetteTile>
            </div>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .more-page {
    background: #050505;
    min-height: 100vh;
  }
  :global(html[data-theme="light"]) .more-page {
    background: transparent;
  }

  .more-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(45% 30% at 20% 8%, rgba(249, 95, 74, 0.2), transparent 70%),
      radial-gradient(40% 35% at 85% 50%, rgba(255, 0, 122, 0.1), transparent 70%);
  }
  .more-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .mg-v {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      rgba(254, 252, 217, 0.06) 0 3px,
      transparent 3px 18px
    );
  }
  :global(html[data-theme="light"]) .mg-v {
    background: repeating-linear-gradient(
      to bottom,
      rgba(38, 59, 51, 0.07) 0 3px,
      transparent 3px 18px
    );
  }

  .more-rack {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .tile-wrap {
    opacity: 0;
    transform: translateY(18px);
    animation: tileIn 0.55s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: calc(var(--i) * 0.07s);
  }
  @keyframes tileIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .tile-wrap {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
