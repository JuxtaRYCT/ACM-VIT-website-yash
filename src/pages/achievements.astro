---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import Footer from "../layouts/Footer.astro";
import FillButton from "../components/ui/FillButton.astro";
import AnimatedButton from "../components/ui/AnimatedButton.astro";
import { getAssetUrl } from "../utils/cdn";
import { stats, achievements } from "../data/achievementsData.ts";
import {
  current as z0d1akCurrent,
  bestWorldRank,
  achievements as z0d1akResults,
} from "../data/z0d1akData.ts";

// z0d1ak's podium finishes (top 3), best first.
const z0d1akPodiums = z0d1akResults
  .filter((r) => r.place <= 3)
  .sort((a, b) => a.place - b.place);
const ordinal = (n: number) => {
  const s = ["th", "st", "nd", "rd"], v = n % 100;
  return n + (s[(v - 20) % 10] || s[v] || s[0]);
};

// ACM-VIT students who led the SGLang docs migration. GitHub handles link to
// profiles; the one display name without a handle renders as plain text.
const sglangContributors: { label: string; handle?: string }[] = [
  { label: "Adhyan-Jain", handle: "Adhyan-Jain" },
  { label: "Maitri-shah29", handle: "Maitri-shah29" },
  { label: "architnigam", handle: "architnigam" },
  { label: "Nakul-Sinha", handle: "Nakul-Sinha" },
  { label: "divyamagrawal06", handle: "divyamagrawal06" },
  { label: "A-Taman", handle: "A-Taman" },
  { label: "nimeshas", handle: "nimeshas" },
  { label: "IshhanKheria", handle: "IshhanKheria" },
  { label: "Krishang-Zinzuwadia", handle: "Krishang-Zinzuwadia" },
  { label: "pokymono", handle: "pokymono" },
  { label: "Ishitajoshii", handle: "Ishitajoshii" },
  { label: "AdityaVKochar", handle: "AdityaVKochar" },
];
---

<Layout pageTitle="Achievements" backHref="/">
  <!-- Fixed gold-lit backdrop -->
  <div class="hall" aria-hidden="true">
    <div class="a-glow"></div>
    <div class="a-grid">
      <span class="ag-v" style="left: 18%"></span>
      <span class="ag-v" style="left: 50%"></span>
      <span class="ag-v" style="left: 82%"></span>
    </div>
    <canvas id="dustfield"></canvas>
  </div>

  <main class="a-page" id="top">
    <!-- ───────────────────────── HERO ───────────────────────── -->
    <section class="hero">
      <div class="hero-top">
        <p class="eyebrow" data-h>Awards · Recognitions · Milestones</p>
        <p class="tagline" data-h>
          Every late night and every shipped build, cast in gold.
        </p>
      </div>

      <h1 class="wordmark" data-h>Achievements</h1>

      <div class="hero-horizon"><span class="hh-glow"></span></div>
    </section>

    <!-- ─────────────── FEATURED · ACM INTERNATIONAL AWARD ─────────────── -->
    <section class="feature" id="feature">
      <div class="feature-copy">
        <p class="eyebrow" data-reveal>Community Recognition</p>
        <h2 class="feature-title" data-reveal>
          <span class="ft-cream">ACM</span> International Award
        </h2>
        <h3 class="feature-sub" data-reveal>Outstanding School Service</h3>
        <p class="feature-term" data-reveal>Term 2025-2026</p>
        <div class="feature-body" data-reveal>
          <p>
            Happy to announce that ACM-VIT has been awarded the ACM International
            Chapter Award for Outstanding School Service.
          </p>
          <p>
            The recognition reflects a year of community-first work across
            outreach, student initiatives, and chapter-led experiences built with
            the same intent that defines the rest of ACM-VIT.
          </p>
        </div>
        <div class="feature-cta" data-reveal>
          <AnimatedButton text="Check out the awards and more" href="#reel" iconBg="#d4af37" />
        </div>
      </div>

      <div class="feature-badge" data-reveal>
        <img
          src={getAssetUrl("/ui/ui-acm-celeb.png")}
          alt="ACM Student Chapter Excellence Award - Outstanding School Service"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ─────────────── FEATURED · ACM-W EMERGING CHAPTER ─────────────── -->
    <section class="feature feature-w" id="acm-w">
      <div class="feature-copy">
        <p class="eyebrow" data-reveal>ACM-W Recognition</p>
        <h2 class="feature-title" data-reveal>
          <span class="ft-cream">Emerging</span> Chapter Award
        </h2>
        <h3 class="feature-sub" data-reveal>
          Vellore Institute of Technology ACM-W Student Chapter, Vellore
        </h3>
        <p class="feature-term" data-reveal>Year 2023</p>
        <div class="feature-body" data-reveal>
          <p>
            The VIT ACM-W Student Chapter was recognized with the ACM-W Emerging
            Chapter Award, celebrating a young chapter making early, visible
            impact for women in computing.
          </p>
          <p>
            The award marks the chapter's first year of momentum - the events,
            mentorship and community it built to bring more women into tech at
            VIT Vellore.
          </p>
        </div>
      </div>

      <div class="feature-badge" data-reveal>
        <img
          class="feature-w-art"
          src={getAssetUrl("/acmw/acmw-hero.png")}
          alt="ACM-W VIT - Emerging Chapter Award 2023"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ─────────────────── z0d1ak · CAPTURE THE FLAG ─────────────────── -->
    <section class="chapter z-section" id="z0d1ak">
      <header class="ch-head" data-reveal>
        <p class="ch-num">Capture The Flag</p>
        <h2 class="ch-title">z0d1ak on the board</h2>
        <p class="ch-body">
          ACM-VIT's competitive CTF team climbed to World #{bestWorldRank} and
          India #{z0d1akCurrent.countryRank} on CTFtime, across
          {z0d1akCurrent.events} events in {z0d1akCurrent.year}.
        </p>
      </header>

      <div class="z-stats" data-reveal>
        <div class="astat">
          <span class="astat-num">#{bestWorldRank}</span>
          <span class="astat-label">Best World Rank</span>
          <span class="astat-sub">All-time peak</span>
        </div>
        <div class="astat">
          <span class="astat-num">#{z0d1akCurrent.countryRank}</span>
          <span class="astat-label">India Rank</span>
          <span class="astat-sub">CTFtime {z0d1akCurrent.year}</span>
        </div>
        <div class="astat">
          <span class="astat-num">{z0d1akCurrent.events}</span>
          <span class="astat-label">Events Played</span>
          <span class="astat-sub">Season {z0d1akCurrent.year}</span>
        </div>
      </div>

      <div class="z-podiums" data-reveal>
        {
          z0d1akPodiums.map((r) => (
            <div class="z-pod">
              <span class="z-pod-place">{ordinal(r.place)}</span>
              <span class="z-pod-event">{r.event}</span>
            </div>
          ))
        }
      </div>

      <div class="z-highlight" data-reveal>
        <div class="z-hl-copy">
          <span class="z-hl-tag">1st Place · Override.exe</span>
          <h3 class="z-hl-title">A first offline CTF title</h3>
          <p class="z-hl-body">
            z0d1ak secured first place at Override.exe, an offline Capture The
            Flag contest hosted by Scaler School of Technology, Bengaluru. The
            result marks the team's first victory at an in-person CTF.
          </p>
        </div>
        <div class="z-hl-photos">
          <img
            src={getAssetUrl("/achievements/achievements-override-cheque.jpeg")}
            alt="z0d1ak with the Override.exe winners' cheque at Scaler School of Technology"
            loading="lazy"
            decoding="async"
          />
          <img
            src={getAssetUrl("/achievements/achievements-override-scoreboard.jpeg")}
            alt="Override.exe scoreboard with z0d1ak in first place"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div class="z-cta" data-reveal>
        <FillButton label="Explore z0d1ak" href="/z0d1ak" class="a-fill primary" />
      </div>
    </section>

    <!-- ─────────────────── OPEN SOURCE · SGLANG ─────────────────── -->
    <section class="chapter os-section" id="sglang">
      <header class="ch-head" data-reveal>
        <p class="ch-num">Open Source</p>
        <h2 class="ch-title">Contributing to SGLang</h2>
        <p class="ch-body">
          ACM-VIT students led the migration of SGLang's documentation to a new
          Mintlify-based system, building on the original docs and cookbook that
          the project's authors first wrote.
        </p>
      </header>

      <div class="os-authors" data-reveal>
        {
          sglangContributors.map((c) =>
            c.handle ? (
              <a
                class="os-chip"
                href={`https://github.com/${c.handle}`}
                target="_blank"
                rel="noopener"
              >
                @{c.handle}
              </a>
            ) : (
              <span class="os-chip os-chip-static">{c.label}</span>
            ),
          )
        }
      </div>

      <p class="os-advisors" data-reveal>
        Advised by
        <a href="https://github.com/adarshxs" target="_blank" rel="noopener">@adarshxs</a>
        (ACM-VIT) and
        <a href="https://github.com/wisclmy0611" target="_blank" rel="noopener">@wisclmy0611</a>,
        <a href="https://github.com/Richardczl98" target="_blank" rel="noopener">@Richardczl98</a>
        (LMSYS).
      </p>

      <div class="os-ctas" data-reveal>
        <FillButton
          label="View the repository"
          href="https://github.com/sgl-project/sglang"
          external
          class="a-fill primary"
        />
        <FillButton
          label="See the announcement"
          href="https://x.com/lmsysorg/status/2046652338027602236"
          external
          class="a-fill"
        />
      </div>
    </section>

    <!-- ─────────────────── YC STARTUP SCHOOL ─────────────────── -->
    <section class="chapter yc-section" id="yc-startup-school">
      <header class="ch-head" data-reveal>
        <p class="ch-num">Out in the World</p>
        <h2 class="ch-title">YC Startup School, Bengaluru</h2>
      </header>

      <div class="yc-copy" data-reveal>
        <p>
          On April 19, ACM-VIT members headed to the YC Startup School in
          Bengaluru.
        </p>
        <p>
          We connected with a strong crowd of ambitious builders from across
          India, heard direct and practical advice straight from the YC partners
          and founders, and walked away with genuinely valuable insights on what
          it takes to build at the next level.
        </p>
        <p>
          In the age where anyone can build anything, the people you build with
          matter so much, and we're so glad we got to connect with so many great
          people.
        </p>
        <p>
          Grateful for the experience (+ the credits & merch!) and excited to
          bring it back to our community at VIT.
        </p>
      </div>

      <div class="yc-photos" data-reveal>
        <img
          src={getAssetUrl("/achievements/achievements-yc-team.jpeg")}
          alt="ACM-VIT students at the YC Startup School India backdrop"
          loading="lazy"
          decoding="async"
        />
        <img
          src={getAssetUrl("/achievements/achievements-yc-panel.jpeg")}
          alt="Startup advice panel from YC partners on stage"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="yc-cta" data-reveal>
        <FillButton
          label="Read the post"
          href="https://x.com/ACM_VIT/status/2045928863201636697"
          external
          class="a-fill primary"
        />
      </div>
    </section>

    <!-- ─────────────── CLOUDFLARE IRL · WENVY ─────────────── -->
    <section class="chapter hack-section" id="wenvy">
      <header class="ch-head" data-reveal>
        <p class="ch-num">Hackathon Win</p>
        <h2 class="ch-title">Cloudflare IRL Hackathon</h2>
        <p class="ch-body">
          On 13 June 2026, an ACM-VIT team won the Cloudflare IRL Hackathon in
          Bengaluru for building Wenvy - Git for your environment files. Tired of
          teammates passing secrets around over Slack and WhatsApp, they built a
          safer way to version, track and share env files.
        </p>
      </header>

      <div class="hack-photos" data-reveal>
        <figure class="hack-fig">
          <img
            src={getAssetUrl("/achievements/achievements-wenvy-team.jpeg")}
            alt="The ACM-VIT team behind Wenvy at the Cloudflare IRL Hackathon"
            loading="lazy"
            decoding="async"
          />
          <figcaption>The developers behind Wenvy</figcaption>
        </figure>
        <figure class="hack-fig">
          <img
            src={getAssetUrl("/achievements/achievements-wenvy-cloudflare.jpeg")}
            alt="Cloudflare IRL Hackathon, Bengaluru title screen"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Cloudflare IRL Hackathon, Bengaluru</figcaption>
        </figure>
      </div>

      <div class="hack-cta" data-reveal>
        <FillButton label="Learn more about Wenvy" href="/projects/wenvy" class="a-fill primary" />
        <FillButton label="Visit wenvy.dev" href="https://wenvy.dev" external class="a-fill" />
      </div>
    </section>

    <!-- ───────────────────── STAT BAND ───────────────────── -->
    <section class="stat-band">
      <div class="a-stats" data-reveal>
        {
          stats.map((s) => (
            <div class="astat">
              <span class="astat-num">{s.num}</span>
              <span class="astat-label">{s.label}</span>
              {s.sub && <span class="astat-sub">{s.sub}</span>}
            </div>
          ))
        }
      </div>
    </section>

    <!-- ─────────────────── THE REEL ─────────────────── -->
    <section class="chapter" id="reel">
      <header class="ch-head" data-reveal>
        <p class="ch-num">The Reel</p>
        <h2 class="ch-title">Moments worth keeping</h2>
        <p class="ch-body">
          A running record of what ACM-VIT and its members have earned along the
          way.
        </p>
      </header>

      <div class="reel">
        {
          achievements.map((a, i) => (
            <article class="ach-card" data-reveal style={`--d:${i * 0.05}s`}>
              <div class="ach-year">{a.year}</div>
              <div class="ach-body">
                <div class="ach-top">
                  <h3 class="ach-title">{a.title}</h3>
                  {a.place && <span class="ach-place">{a.place}</span>}
                </div>
                <p class="ach-org">{a.org}</p>
                <p class="ach-blurb">{a.blurb}</p>
              </div>
              {a.image && (
                <img
                  class="ach-asset"
                  src={getAssetUrl(a.image)}
                  alt={a.title}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </article>
          ))
        }
      </div>
    </section>

    <!-- ───────────────────── CLOSING SENDOFF ───────────────────── -->
    <section class="sendoff">
      <p class="eyebrow" data-reveal>The Next One</p>
      <h2 class="sendoff-title" data-reveal>Still counting</h2>
      <p class="sendoff-lead" data-reveal>
        The best line on this list has not been written yet. Come build it with
        us.
      </p>
      <div class="sendoff-ctas" data-reveal>
        <FillButton label="Explore our work" href="/projects" class="a-fill primary" />
        <FillButton label="Meet the team" href="/team" class="a-fill" />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap");
</style>

<style>
  :root {
    --serif: "Cormorant Garamond", Georgia, serif;
    --label: "PolySans Mono", "Inter", system-ui, sans-serif;
    --ink: #fefcd9;
    --ink-soft: rgba(254, 252, 217, 0.72);
    --muted: rgba(254, 252, 217, 0.42);
    --gold: #d4af37; /* theme colour */
    --gold-bright: #f2d16b;
    --gold-deep: #a67c1e;
    --bg-0: #0a0805; /* warm near-black */
    --line: rgba(212, 175, 55, 0.16);
  }

  :global(.diamond-grid) { display: none !important; }
  :global(body) { background: var(--bg-0); }

  .hall {
    position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none;
    background: var(--bg-0);
  }
  .a-glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(46% 40% at 50% 6%, rgba(242, 209, 107, 0.16), transparent 70%),
      radial-gradient(50% 42% at 50% 108%, rgba(212, 175, 55, 0.14), transparent 72%);
  }
  .a-grid { position: absolute; inset: 0; }
  .ag-v {
    position: absolute; top: 0; bottom: 0; width: 2px;
    background: repeating-linear-gradient(
      to bottom, rgba(212, 175, 55, 0.07) 0 3px, transparent 3px 18px);
  }
  #dustfield { position: absolute; inset: 0; display: block; }

  /* ── Page scaffold ── */
  .a-page { position: relative; z-index: 1; color: var(--ink); font-family: var(--serif); overflow-x: clip; }
  .a-page section { padding: clamp(7rem, 16vh, 12rem) clamp(1.25rem, 6vw, 5rem); }

  .eyebrow, .ch-num {
    font-family: var(--label);
    font-size: 0.62rem; letter-spacing: 0.32em; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .eyebrow::before, .ch-num::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); flex: none;
  }

  /* ── HERO ── */
  .hero {
    position: relative; min-height: 92svh; overflow: hidden;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
  }
  .hero-top {
    position: relative; z-index: 4;
    display: flex; flex-direction: column; align-items: center;
  }
  .hero .eyebrow { color: var(--ink-soft); margin-bottom: 1.6rem; }

  .wordmark {
    position: relative; z-index: 2;
    font-family: var(--serif); font-weight: 500;
    font-size: clamp(3rem, 12vw, 9.5rem); line-height: 0.9;
    letter-spacing: 0.01em;
    background: linear-gradient(180deg, var(--gold-bright), var(--gold) 45%, var(--gold-deep));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
    text-shadow: 0 0 90px rgba(212, 175, 55, 0.35);
  }
  .tagline {
    font-weight: 400; font-style: italic;
    font-size: clamp(1.1rem, 2.4vw, 1.6rem);
    color: var(--ink-soft); max-width: 34ch; line-height: 1.5;
    margin-top: 1.6rem;
  }

  .hero-horizon {
    position: absolute; left: 50%; bottom: -10vh; transform: translateX(-50%);
    width: 130%; height: 40vh; z-index: 0; pointer-events: none;
  }
  .hh-glow {
    position: absolute; inset: 0;
    background: radial-gradient(58% 60% at 50% 100%,
      rgba(242, 209, 107, 0.5) 0%, rgba(212, 175, 55, 0.28) 34%, transparent 72%);
    animation: hh-breathe 9s ease-in-out infinite;
  }
  @keyframes hh-breathe {
    0%, 100% { transform: scale(1); opacity: 0.85; }
    50%      { transform: scale(1.07); opacity: 1; }
  }

  /* ── Featured award ── */
  .feature {
    position: relative; overflow: hidden;
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    max-width: 1300px; margin: 0 auto;
  }
  .feature-copy { position: relative; z-index: 1; max-width: 46rem; }
  .feature-title {
    font-family: "PolySans Trial", sans-serif; font-weight: 800;
    font-size: clamp(2.6rem, 7vw, 5.5rem); line-height: 0.92;
    letter-spacing: -0.02em; text-transform: uppercase;
    color: var(--gold); margin: 1.2rem 0 0;
    text-shadow: 0 0 60px rgba(212, 175, 55, 0.2);
  }
  .feature-title .ft-cream { color: var(--ink); }
  .feature-sub {
    font-family: "PolySans Trial", sans-serif; font-weight: 700;
    font-size: clamp(1.3rem, 3vw, 2rem); color: var(--ink);
    margin: 2rem 0 0;
  }
  .feature-term {
    font-family: var(--label); font-size: 0.66rem; letter-spacing: 0.24em;
    text-transform: uppercase; color: var(--gold); margin: 0.9rem 0 0;
    display: inline-flex; align-items: center; gap: 0.55rem;
  }
  .feature-term::before {
    content: ""; width: 22px; height: 1px; background: var(--gold); flex: none;
  }
  .feature-body { margin-top: 1.4rem; display: flex; flex-direction: column; gap: 1.1rem; max-width: 40rem; }
  .feature-body p {
    font-family: var(--label); font-size: clamp(0.9rem, 1.5vw, 1.02rem);
    line-height: 1.7; color: var(--ink-soft); margin: 0;
  }
  .feature-cta { margin-top: 2.4rem; }
  .feature-cta :global(.anim-btn-anchor) { justify-content: flex-start; width: auto; }

  .feature-badge {
    position: relative; z-index: 1;
    display: flex; justify-content: center; align-items: center;
  }
  .feature-badge img {
    width: min(100%, 460px); height: auto;
    filter: drop-shadow(0 18px 44px rgba(0, 0, 0, 0.5)) drop-shadow(0 0 30px rgba(212, 175, 55, 0.18));
  }

  /* ── ACM-W variant: pink accents ── */
  .feature-w { --pink: #ff007a; }
  .feature-w .feature-title { color: var(--pink); text-shadow: 0 0 60px rgba(255, 0, 122, 0.22); }
  .feature-w .feature-term { color: var(--pink); }
  .feature-w .feature-term::before { background: var(--pink); }
  .feature-w-art {
    border-radius: 16px;
    border: 1px solid rgba(255, 0, 122, 0.35);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.5), 0 0 42px rgba(255, 0, 122, 0.22);
    filter: none !important;
    aspect-ratio: 4 / 3; object-fit: cover;
  }

  /* ── Stat band ── */
  .stat-band { padding-top: clamp(2rem, 5vh, 3.5rem) !important; }
  .a-stats {
    max-width: 1000px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(1rem, 3vw, 2.5rem);
    text-align: center;
  }
  .astat { display: flex; flex-direction: column; gap: 0.6rem; }
  .astat-num {
    font-family: var(--serif); font-weight: 500;
    font-size: clamp(2.6rem, 6vw, 4.5rem); line-height: 1; color: var(--gold-bright);
    text-shadow: 0 0 34px rgba(212, 175, 55, 0.28);
  }
  .astat-label { font-family: var(--label); font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink); }
  .astat-sub { font-family: var(--label); font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }

  /* ── Chapter head ── */
  .ch-head { max-width: 640px; margin: 0 auto clamp(3rem, 7vh, 5rem); text-align: center; }
  .ch-num { color: var(--gold); }
  .ch-title {
    font-family: var(--serif); font-weight: 400;
