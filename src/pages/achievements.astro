<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ───────────── Drifting gold dust ───────────── */
  (function dustfield() {
    const canvasEl = document.getElementById("dustfield") as HTMLCanvasElement | null;
    if (!canvasEl) return;
    const ctxRef = canvasEl.getContext("2d");
    if (!ctxRef) return;
    const canvas: HTMLCanvasElement = canvasEl;
    const ctx: CanvasRenderingContext2D = ctxRef;
    let w = 0, h = 0, dpr = 1, t = 0, scrollY = 0;
    let motes: { x: number; y: number; r: number; base: number; tw: number; sp: number; depth: number }[] = [];

    function init() {
      const count = Math.min(120, Math.floor((w * h) / 16000));
      motes = [];
      for (let i = 0; i < count; i++) {
        motes.push({
          x: Math.random() * w, y: Math.random() * h,
          r: 0.3 + Math.random() * 1.2,
          base: 0.14 + Math.random() * 0.45,
          tw: Math.random() * Math.PI * 2,
          sp: 0.003 + Math.random() * 0.008,
          depth: 0.2 + Math.random() * 1,
        });
      }
    }
    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      canvas.style.width = w + "px"; canvas.style.height = h + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      init();
    }
    function frame() {
      t += 1;
      ctx.clearRect(0, 0, w, h);
      for (const s of motes) {
        const tw = reduce ? 0.7 : 0.55 + 0.45 * Math.sin(s.tw + t * s.sp * 5);
        let yy = s.y - scrollY * 0.04 * s.depth;
        yy = ((yy % h) + h) % h;
        ctx.globalAlpha = s.base * tw;
        ctx.fillStyle =
          document.documentElement.getAttribute("data-theme") === "light"
            ? "#b8901f"
            : "#e9c96b";
        ctx.beginPath();
        ctx.arc(s.x, yy, s.r, 0, 6.2832);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      requestAnimationFrame(frame);
    }
    window.addEventListener("scroll", () => { scrollY = window.scrollY; }, { passive: true });
    window.addEventListener("resize", resize);
    resize();
    requestAnimationFrame(frame);
  })();

  /* ───────────── Hero reveal (waits for the preloader to lift) ───────────── */
  (function hero() {
    const startHero = () => {
      if (reduce) {
        gsap.set("[data-h]", { opacity: 1 });
        return;
      }
      const tl = gsap.timeline({ delay: 0.1, defaults: { ease: "power3.out" } });
      tl.fromTo(".eyebrow[data-h]", { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.7 })
        .fromTo(".wordmark", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1.1 }, "-=0.3")
        .fromTo(".tagline", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.8 }, "-=0.6");
    };

    let started = false;
    const go = () => { if (started) return; started = true; startHero(); };
    window.addEventListener("preloader:done", go, { once: true });
    if (!document.getElementById("preloader")) go();
    else window.setTimeout(go, 6000);
  })();

  /* ───────────── Scroll reveals ───────────── */
  gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((el) => {
    if (reduce) { gsap.set(el, { opacity: 1 }); return; }
    gsap.fromTo(el, { opacity: 0, y: 30 }, {
      opacity: 1, y: 0, duration: 1, ease: "power3.out",
      scrollTrigger: { trigger: el, start: "top 86%" },
    });
  });

  ScrollTrigger.refresh();
</script>
