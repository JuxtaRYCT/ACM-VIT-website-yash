<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    const swatch = target?.closest<HTMLElement>("[data-copy-hex]");
    if (!swatch) return;

    const hex = swatch.dataset.copyHex;
    if (!hex) return;

    navigator.clipboard?.writeText(hex).then(() => {
      swatch.classList.add("is-copied");
      window.setTimeout(() => swatch.classList.remove("is-copied"), 1400);
    });
  });

  function initDesignGuideReveal() {
    const els = document.querySelectorAll<HTMLElement>("[data-reveal]");
    if (!els.length) return;

    import("gsap").then(({ gsap }) => {
      import("gsap/ScrollTrigger").then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        els.forEach((el) => {
          if (reduce) {
            gsap.set(el, { opacity: 1 });
            return;
          }
          gsap.fromTo(
            el,
            { opacity: 0, y: 24 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: { trigger: el, start: "top 88%" },
            },
          );
        });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDesignGuideReveal);
  } else {
    initDesignGuideReveal();
  }
</script>
