---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { reader } from "../utils/reader";

// Sections
import Hero from "../sections/Hero.astro";
import About from "../sections/About.astro";
import Domains from "../sections/Domains.astro";
import Events from "../sections/Events.astro";
import ProjectsIntro from "../sections/ProjectsIntro.astro";
import Projects from "../sections/Projects.astro";
import AcmWMotto from "../sections/AcmWMotto.astro";
import AcmWContent from "../sections/AcmWContent.astro";
import AcmWBento from "../sections/AcmWBento.astro";
import Board from "../sections/Board.astro";
import Blogs from "../sections/Blogs.astro";
import Partners from "../sections/Partners.astro";
import Community from "../sections/Community.astro";
import Gallery from "../sections/Gallery.astro";
import ContactUs from "../sections/ContactUs.astro";
import BecauseTechMatters from "../sections/BecauseTechMatters.astro";
import GrepSideTab from "../components/ui/GrepSideTab.astro";

// Responsive variants
import AboutPhone from "../responsive/AboutPhone.astro";
import DomainsPhone from "../responsive/DomainsPhone.astro";
import ProjectScreenPhone from "../responsive/ProjectScreenPhone.astro";
import GalleryPhone from "../responsive/GalleryPhone.astro";
import ContactUsPhone from "../responsive/ContactUsPhone.astro";
import AnimatedButton from "../components/ui/AnimatedButton.astro";

// UI components
import LegendPins from "../components/ui/LegendPins.astro";
import ScrollVideo from "../components/ui/ScrollVideo.astro";

// Layout components
import Footer from "../layouts/Footer.astro";

const projectsCms = await reader.singletons.projects.read();
const projectsData = (projectsCms?.items ?? [])
  .filter((project) => project.cassetteSrc && project.cassetteAlt && project.description1)
  .map((p) => ({
  cassette: { src: p.cassetteSrc, alt: p.cassetteAlt },
  textContent: { blocks: [p.description1, ...(p.description2 ? [p.description2] : [])] },
  buttons: {
    primary: {
      backgroundColor: p.primaryBgColor,
      textColor: p.primaryTextColor || 'white',
      borderColor: p.primaryBorderColor || '#FEFCD9',
      ...(p.primaryBorderRadius ? { borderRadius: p.primaryBorderRadius } : {}),
    },
    visitWebsite: {
      text: p.visitWebsiteText || 'VISIT WEBSITE',
      backgroundColor: p.visitWebsiteBgColor || p.primaryBgColor,
      textColor: p.visitWebsiteTextColor || 'white',
      borderColor: p.visitWebsiteBorderColor || '#FEFCD9',
      url: p.visitWebsiteUrl || '',
      ...(p.visitWebsiteBorderRadius ? { borderRadius: p.visitWebsiteBorderRadius } : {}),
    },
    icons: (p.icons ?? []).map((icon) => ({
      type: icon.type || '',
      backgroundColor: icon.backgroundColor || '',
      textColor: icon.textColor || '',
      borderColor: icon.borderColor || '',
      iconColor: icon.iconColor || '',
      ...(icon.borderRadius ? { borderRadius: icon.borderRadius } : {}),
      url: icon.url || '',
    })),
  },
  colors: {
    textColor: p.textColor || 'white',
    contentBlockBackground: p.contentBlockBackground || 'rgba(0, 0, 0, 0.15)',
    hoverShadow: p.hoverShadow || '',
  },
}));

const videoStartTime = 0;
const videoEndTime = undefined; // Use full video duration (set to specific seconds if needed)
---

<Layout>
    <ScrollVideo
        webmSrc="/videos/ACMWebsiteVid.webm"
        mp4Src="/videos/ACMWebsiteVid.mp4"
        startTime={videoStartTime}
        endTime={videoEndTime}
    >
        <section id="home" class="page-section relative">
            <div class="relative h-screen w-screen">
                <Hero />
            </div>
            <LegendPins />
            <BecauseTechMatters />
        </section>

        <section id="about" class="page-section">
            <div data-variant-host>
                <template data-variant="desktop">
                    <About />
                </template>
                <template data-variant="mobile">
                    <AboutPhone />
                </template>
            </div>
        </section>
    </ScrollVideo>


    <section id="domains" class="page-section">
        <div data-variant-host>
            <template data-variant="desktop">
                <Domains />
            </template>
            <template data-variant="mobile">
                <DomainsPhone />
            </template>
        </div>
    </section>

    <section id="events" class="page-section">
        <Events />
    </section>

    <ProjectsIntro />

    <section id="projects" class="page-section">
        <div data-variant-host>
            <template data-variant="desktop">
                <Projects projects={projectsData} />
            </template>
            <template data-variant="mobile">
                <ProjectScreenPhone projects={projectsData} />
            </template>
        </div>
        <div class="w-full flex justify-center py-10">
            <AnimatedButton
                text="Checkout all cool projects"
                href="/projects"
            />
        </div>
    </section>

    <section id="acm-w" class="page-section">
        <AcmWMotto />
        <AcmWContent />
        <AcmWBento />
    </section>

    <section id="community" class="page-section">
        <Community />
    </section>

    <Board />

    <section id="blogs" class="page-section">
        <Blogs />
    </section>

    <section id="partners" class="page-section">
        <Partners />
    </section>

    <section id="gallery" class="page-section">
        <div data-variant-host>
            <template data-variant="desktop">
                <Gallery />
            </template>
            <template data-variant="mobile">
                <GalleryPhone />
            </template>
        </div>
    </section>

    <section id="contact" class="page-section">
        <div
            data-variant-host
            data-variant-query="(max-width: 1024px), (pointer: coarse)"
        >
            <template data-variant="desktop">
                <ContactUs />
            </template>
            <template data-variant="mobile">
                <ContactUsPhone />
            </template>
        </div>
    </section>

    <GrepSideTab />
    <Footer />
</Layout>
