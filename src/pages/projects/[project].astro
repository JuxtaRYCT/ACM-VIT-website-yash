<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    gsap.ticker.wake();
    const art = document.querySelector('.proj-hero [data-anim="in"]');
    if (art) {
      const icon = art.querySelector('.proj-hero-art-icon');
      if (icon) gsap.to(icon, { y: -10, duration: 3, ease: "sine.inOut", yoyo: true, repeat: -1 });
    }

    // Intersection-observer-based reveal — avoids gsap.ticker autoSleep races on this page.
    const revealEls = document.querySelectorAll(
      '.proj-section [data-anim="up"], .proj-section-narrow [data-anim="up"], .proj-endroad[data-anim="up"]'
    );
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('is-in');
            io.unobserve(e.target);
          }
        });
      }, { rootMargin: "0px 0px -12% 0px", threshold: 0.05 });
      revealEls.forEach((el) => io.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add('is-in'));
    }

    // Resolve real GitHub display names (best effort)
    const ghNodes = document.querySelectorAll<HTMLElement>('[data-gh-user]');
    ghNodes.forEach(async (node) => {
      const user = node.dataset.ghUser;
      if (!user) return;
      try {
        const res = await fetch(`https://api.github.com/users/${user}`, { headers: { Accept: 'application/vnd.github+json' } });
        if (!res.ok) return;
        const data = await res.json() as { name?: string; login?: string };
        const display = data.name?.trim() || data.login;
        if (!display) return;
        const nameEl = node.querySelector<HTMLElement>('[data-gh-name]');
        if (nameEl) nameEl.textContent = display;
      } catch { /* silent */ }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
