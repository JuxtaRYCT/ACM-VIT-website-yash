---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../layouts/Footer.astro";
import BentoGrid from "../../components/blog/BentoGrid.astro";
import BlogList from "../../components/blog/BlogList.astro";
import { getAllPosts } from "../../lib/blog";
import { getAssetUrl } from "../../utils/cdn";
import "../../styles/globals.css";
import "../../styles/blog.css";

const posts = await getAllPosts();
const featuredPosts = posts.slice(0, 5);
const allPosts = posts;
---

<Layout pageTitle="Blogs" backHref="/#blogs">
  {/* Hero section */}
  <section class="blog-reader relative overflow-hidden pt-8 md:pt-16 pb-0">
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.06]"
      style={`background-image: url(${getAssetUrl("/backgrounds/background_pattern.webp")}); background-size: cover;`}
    />

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
      {/* Breadcrumb */}
      <p class="text-[#FF5F4A] text-xs sm:text-sm font-mono tracking-[0.3em] uppercase mb-8 md:mb-12">
        ACM-VIT &mdash; Blog
      </p>

      {/* Title with tape reel decorations */}
      <div class="flex items-start gap-6">
        {/* Tape reel — nested divs instead of CSS pseudo-elements */}
        <div class="hidden md:flex items-center justify-center w-12 h-12 rounded-full border-2 border-white/[0.12] relative flex-shrink-0 mt-4 animate-[spin_8s_linear_infinite]">
          <div class="w-4 h-4 rounded-full border-2 border-white/[0.08]" />
          <div class="absolute w-1.5 h-1.5 rounded-full bg-[#F95F4A]/40" />
        </div>

        <div>
          <h1 class="text-[clamp(3.5rem,10vw,12rem)] font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.82]">
            BL<span class="text-[#FF5F4A]">OGS</span>
          </h1>
        </div>

        <div class="hidden md:flex items-center justify-center w-12 h-12 rounded-full border-2 border-white/[0.12] relative flex-shrink-0 mt-4 animate-[spin_8s_linear_infinite_reverse]">
          <div class="w-4 h-4 rounded-full border-2 border-white/[0.08]" />
          <div class="absolute w-1.5 h-1.5 rounded-full bg-[#F95F4A]/40" />
        </div>
      </div>

      <div class="w-20 h-[3px] bg-[#FF5F4A] my-8 md:my-10" />

      <p class="text-gray-300 font-mono text-xs sm:text-sm leading-relaxed uppercase max-w-xl mb-12">
        Deep dives into AI, Web3, systems design, and everything that keeps us up at night.
        From Hashnode and Medium &mdash; always fresh, always nerdy.
      </p>
    </div>
  </section>

  {/* Featured Bento Grid */}
  {featuredPosts.length >= 5 && (
    <section class="relative z-10 pb-16 md:pb-24">
      <div class="max-w-[1400px] mx-auto px-4 md:px-10">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-2 h-2 rounded-full bg-[#F95F4A] animate-pulse" />
          <span class="text-xs font-mono text-gray-500 uppercase tracking-widest">Latest</span>
        </div>
        <BentoGrid posts={featuredPosts} />
      </div>
    </section>
  )}

  {/* Tape separator */}
  <div class="max-w-[1400px] mx-auto px-6 md:px-10">
    <div class="flex items-center gap-4 py-4">
      <div class="flex-1 h-px bg-white/[0.08]" />
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full border border-white/[0.15]" />
        <div class="w-16 h-1 bg-white/[0.08] rounded-full" />
        <div class="w-3 h-3 rounded-full border border-white/[0.15]" />
      </div>
      <div class="flex-1 h-px bg-white/[0.08]" />
    </div>
  </div>

  {/* All posts list */}
  <section class="relative z-10 pb-24">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
      <BlogList posts={allPosts} />
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray('.blog-card-anim').forEach((card, i) => {
    gsap.from(card as Element, {
      y: 40,
      opacity: 0,
      duration: 0.6,
      delay: i * 0.1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card as Element,
        start: 'top 90%',
        once: true,
      },
    });
  });

  gsap.utils.toArray('#blog-grid a').forEach((item, i) => {
    gsap.from(item as Element, {
      x: -20,
      opacity: 0,
      duration: 0.4,
      delay: Math.min(i * 0.05, 0.5),
      ease: 'power2.out',
      scrollTrigger: {
        trigger: item as Element,
        start: 'top 95%',
        once: true,
      },
    });
  });
</script>
