---
export const prerender = true;
import DesignLayout from "../../../layouts/DesignLayout.astro";
import { getAssetUrl } from "../../../utils/cdn";
import { productGuides } from "../../../data/designProductsData";

export function getStaticPaths() {
  return productGuides.map((p) => ({
    params: { product: p.slug },
    props: { guide: p },
  }));
}

const { guide: p } = Astro.props;
const current = `/design/products/${p.slug}`;

let sec = 0;
const num = () => String(++sec).padStart(2, "0");

const linkIcons: Record<string, string> = {
  website: "M2 9h14M9 2a11 11 0 0 1 0 14A11 11 0 0 1 9 2Zm0 0a7 7 0 1 0 0 14 7 7 0 0 0 0-14Z",
  play: "M4 2.5v13l11-6.5L4 2.5Z",
  appstore: "M9 2c1.8 0 2.2-2 4.4-1.3M9 5.5c-3.6-2.8-8 .8-5.8 6C4.5 14.7 6 17 7.5 17c1 0 1.3-.6 2.6-.6s1.6.6 2.6.6c1.5 0 3-2.3 4.3-5.5-3.6-1.5-3.4-5.8 0-6.7C15.6 3 13 3.5 11.6 4.8",
  read: "M2.5 3.5h6a2 2 0 0 1 2 2v9a1.5 1.5 0 0 0-1.5-1.5h-6.5v-9.5Zm13 0h-3a2 2 0 0 0-2 2v9a1.5 1.5 0 0 1 1.5-1.5h3.5v-9.5Z",
};
---

<DesignLayout
  title={`${p.name} Design Guide`}
  description={`How ${p.name} looks: logo, palette, typography, iconography, and identity rules for ACM-VIT's ${p.category.toLowerCase()} product.`}
  current={current}
>
  {p.googleFonts && <link rel="stylesheet" href={p.googleFonts} />}

  <section class="ds-hero">
    <div class="ds-kicker"><span class="ds-kicker-pill">Products · {p.name}</span></div>
    <h1 class="ds-h1">{p.tagline}</h1>
    <p class="ds-body-lg">{p.story[0]}</p>
  </section>

  <!-- Brand band -->
  <div
    class="pg-band ds-reveal"
    style={`background:${p.hero.bg}; color:${p.hero.fg};`}
  >
    <div class="pg-band-id">
      {p.logo && (
        <img
          src={getAssetUrl(p.logo.src)}
          alt={p.name}
          style={`width:${p.logo.width}px; max-width:60vw;`}
          loading="eager"
        />
      )}
      <div>
        <span class="pg-band-name">{p.wordmark ?? p.name}</span>
        <span class="pg-band-cat" style={`color:${p.hero.sub};`}>{p.category} · by ACM-VIT</span>
      </div>
    </div>
    <div class="pg-band-links">
      {
        p.links.map((l) => (
          <a
            href={l.href}
            target={l.href.startsWith("/") ? undefined : "_blank"}
            rel={l.href.startsWith("/") ? undefined : "noopener"}
            style={`color:${p.hero.fg}; border-color:color-mix(in srgb, ${p.hero.fg} 25%, transparent);`}
          >
            <svg width="15" height="15" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d={linkIcons[l.kind]}></path>
            </svg>
            {l.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Identity -->
  <section class="ds-section" id="identity">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Identity</h2></div>
    <p class="ds-body" style="max-width:72ch;">{p.story[1]}</p>
    <div class="ds-bento">
      {
        p.facts.map((f) => (
          <div class="ds-card ds-b3 ds-reveal">
            <span class="ds-small" style="text-transform:uppercase; letter-spacing:.08em; font-size:11.5px;">{f.label}</span>
            <span style="display:block; font-weight:640; margin-top:6px; font-size:15.5px;">{f.value}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Logo -->
  <section class="ds-section" id="logo">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Logo</h2></div>
    <div class="ds-bento">
      {
        p.logos.map((l) => (
          <div class="ds-card ds-b6 ds-reveal pg-logo-card" style={`background:${l.bg}; color:${l.fg}; border-color:color-mix(in srgb, ${l.fg} 14%, ${l.bg});`}>
            <div class="pg-logo-stage">
              {l.src && <img src={getAssetUrl(l.src)} alt={l.label} style={`width:${l.width ?? 120}px;`} loading="lazy" />}
              {l.text && (
                <span style={`font-family:${l.text.css}; font-size:${l.text.size}; font-weight:${l.text.weight ?? 700}; letter-spacing:-0.01em;`}>
                  {l.text.content}
                </span>
              )}
            </div>
            <span class="pg-logo-label">{l.label}</span>
          </div>
        ))
      }
    </div>
    <p class="ds-body pg-note">{p.logoNote}</p>
  </section>

  <!-- Color -->
  <section class="ds-section" id="color">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Color</h2></div>
    <div class="ds-bento">
      {
        p.palette.map((s) => (
          <div
            class="ds-card ds-b4 ds-reveal pg-swatch"
            style={`background:${s.hex}; color:${s.on}; border-color:color-mix(in srgb, ${s.on} 14%, ${s.hex});`}
          >
            <div class="pg-swatch-head">
              <span style="font-weight:660;">{s.name}</span>
              <code class="ds-mono">{s.hex.toUpperCase()}</code>
            </div>
            <p class="pg-swatch-use">{s.use}</p>
          </div>
        ))
      }
    </div>
    <p class="ds-body pg-note">{p.paletteNote}</p>
  </section>

  <!-- Typography -->
  <section class="ds-section" id="type">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Typography</h2></div>
    <div class="ds-bento">
      {
        p.type.map((t) => (
          <div class="ds-card ds-b6 ds-reveal">
            <div class="pg-type-head">
              <span class="ds-chip" style={`background:${p.accentTonal}; color:${p.accent};`}>{t.role}</span>
              <span class="ds-mono ds-small">{t.family} · {t.weights}</span>
            </div>
            <p
              class="pg-specimen"
              style={`font-family:${t.css}; font-size:${t.sampleSize ?? "24px"}; font-weight:${t.sampleWeight ?? 500};`}
            >
              {t.sample}
            </p>
            {(t.note || t.approximate) && (
              <p class="ds-small" style="margin-top:10px;">
                {t.note}{t.approximate && !t.note?.includes("approximate") ? " Specimen approximate." : ""}
              </p>
            )}
          </div>
        ))
      }
    </div>
    <p class="ds-body pg-note">{p.typeNote}</p>
  </section>

  <!-- Iconography -->
  <section class="ds-section" id="icons">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Iconography</h2></div>
    <div class="ds-bento">
      <div class="ds-card ds-b6 ds-reveal pg-icon-stage">
        {
          p.icons.images.map((im) => (
            <figure class="pg-icon-tile" style={im.bg ? `background:${im.bg};` : undefined}>
              <img src={getAssetUrl(im.src)} alt={im.alt} loading="lazy" />
              {im.label && <figcaption class="ds-mono">{im.label}</figcaption>}
            </figure>
          ))
        }
      </div>
      <div class="ds-card ds-b6 ds-reveal">
        <h3 class="ds-h4">How icons behave</h3>
        <ul class="pg-list" style="margin-top:10px">
          {p.icons.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Personality -->
  <section class="ds-section" id="personality">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Personality</h2></div>
    <div class="ds-bento">
      <div class="ds-card ds-b6 ds-reveal">
        <span class="ds-chip ds-chip-do" style="margin-bottom:12px">Do</span>
        <ul class="pg-list">
          {p.personality.do.map((d) => <li>{d}</li>)}
        </ul>
      </div>
      <div class="ds-card ds-b6 ds-reveal">
        <span class="ds-chip ds-chip-dont" style="margin-bottom:12px">Don't</span>
        <ul class="pg-list">
          {p.personality.dont.map((d) => <li>{d}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Motifs -->
  <section class="ds-section" id="motifs">
    <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">Motifs</h2></div>
    <div class="ds-bento">
      {
        p.motifs.map((m) => (
          <div class="ds-card ds-card-tonal ds-b4 ds-reveal">
            <h3 class="ds-h4">{m.title}</h3>
            <p class="ds-body" style="margin-top:6px">{m.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Product-specific extras -->
  {
    p.extras?.map((ex) => (
      <section class="ds-section">
        <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">{ex.title}</h2></div>
        {ex.intro && <p class="ds-body">{ex.intro}</p>}
        <div class="ds-bento">
          {ex.items.map((it) => (
            <div class="ds-card ds-b6 ds-reveal">
              <h3 class="ds-h4">{it.name}</h3>
              <p class="ds-body" style="margin-top:6px">{it.desc}</p>
            </div>
          ))}
        </div>
      </section>
    ))
  }

  <!-- In the wild -->
  {
    p.shots && (
      <section class="ds-section" id="screens">
        <div class="ds-sec-head"><span class="ds-sec-num">{num()}</span><h2 class="ds-h2">In the wild</h2></div>
        <div class="pg-shots">
          {p.shots.map((s) => (
            <img src={getAssetUrl(s.src)} alt={s.alt} loading="lazy" />
          ))}
        </div>
      </section>
    )
  }
</DesignLayout>

<style>
  @font-face {
    font-family: "PolySans DS";
    src: url("../../../assets/fonts/Standard/PolySans-Median.otf") format("opentype");
    font-weight: 400 500;
    font-display: swap;
  }
  @font-face {
    font-family: "PolySans Wide DS";
    src: url("../../../assets/fonts/Wide/PolySans-BulkyWide.otf") format("opentype");
    font-weight: 600 800;
    font-display: swap;
  }
  @font-face {
    font-family: "PolySans Mono DS";
    src: url("../../../assets/fonts/Mono/PolySans-MedianMono.otf") format("opentype");
    font-weight: 400 600;
    font-display: swap;
  }
  @font-face {
    font-family: "ChessType DS";
    src: url("/fonts/fonts-chesstype.ttf") format("truetype");
    font-display: swap;
  }

  .pg-band {
    border: 1px solid var(--ds-line);
    border-radius: var(--ds-r-lg);
    padding: clamp(26px, 4vw, 44px);
    margin-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .pg-band-id {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
  }
  .pg-band-name {
    display: block;
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 680;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .pg-band-cat {
    display: block;
    margin-top: 6px;
    font-size: 13.5px;
    font-weight: 560;
  }
  .pg-band-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .pg-band-links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid;
    border-radius: var(--ds-r-full);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.16s ease, transform 0.16s ease;
  }
  .pg-band-links a:hover {
    background: rgba(127, 127, 127, 0.18);
    transform: translateY(-1px);
  }

  .pg-logo-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pg-logo-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    padding: 10px 0;
  }
  .pg-logo-stage img {
    max-width: 80%;
    height: auto;
  }
  .pg-logo-label {
    font-size: 12px;
    font-weight: 620;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .pg-swatch {
    min-height: 150px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
  }
  .pg-swatch-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
  }
  .pg-swatch-head .ds-mono {
    font-size: 12px;
    opacity: 0.85;
  }
  .pg-swatch-use {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.55;
    opacity: 0.92;
  }

  .pg-type-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }
  .pg-specimen {
    margin: 18px 0 0;
    line-height: 1.25;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
  }

  .pg-icon-stage {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: stretch;
    align-content: flex-start;
  }
  .pg-icon-tile {
    margin: 0;
    flex: 1 1 96px;
    max-width: 150px;
    min-width: 86px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 8px 10px;
    border-radius: var(--ds-r-md);
    background: var(--ds-surface-tonal);
    border: 1px solid var(--ds-line);
  }
  .pg-icon-tile img {
    height: 48px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
  .pg-icon-tile figcaption {
    font-size: 10.5px;
    opacity: 0.7;
    text-align: center;
    color: inherit;
  }
  .pg-icon-tile[style] figcaption {
    color: #9a9a9a;
  }

  .pg-note {
    margin-top: 18px;
    max-width: 72ch;
  }

  .pg-list {
    margin: 0;
    padding-left: 18px;
    color: var(--ds-ink-2);
    font-size: 14.5px;
    line-height: 1.7;
  }
  .pg-list li + li {
    margin-top: 6px;
  }

  .pg-shots {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
    margin-top: 26px;
  }
  .pg-shots img {
    width: 100%;
    border-radius: var(--ds-r-md);
    border: 1px solid var(--ds-line);
    display: block;
  }
</style>
