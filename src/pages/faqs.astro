---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import Footer from "../layouts/Footer.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import FillButton from "../components/ui/FillButton.astro";

type Faq = { q: string; a: string };
type Category = { id: string; label: string; accent: string; faqs: Faq[] };

const categories: Category[] = [
  {
    id: "basics",
    label: "The Basics",
    accent: "#F95F4A",
    faqs: [
      {
        q: "What even is ACM-VIT?",
        a: "We're the VIT Vellore student chapter of ACM — the Association for Computing Machinery, the world's largest computing society. Founded in 2009, we're the campus's excuse to build things, break things, and occasionally fix them before a deadline.",
      },
      {
        q: "What's the difference between ACM and ACM-VIT?",
        a: "ACM is the global parent organisation — research journals, the Turing Award, very serious people in blazers. ACM-VIT is the local chapter that turns all that prestige into hackathons, workshops, and a group chat that never sleeps.",
      },
      {
        q: "Do I need to already know how to code?",
        a: "No. Bring curiosity, we'll supply the Stack Overflow tabs. Plenty of our best builders walked in not knowing what a for-loop was and walked out shipping projects.",
      },
      {
        q: "Is ACM-VIT only for Computer Science students?",
        a: "Not even close. We have Design, Management and Research folks who've never opened a terminal in their life. If you can bring a skill, we can find a use for it.",
      },
    ],
  },
  {
    id: "joining",
    label: "Joining & Membership",
    accent: "#FF007A",
    faqs: [
      {
        q: "How do I join ACM-VIT?",
        a: "We run a recruitment cycle at the start of each semester — a form, a couple of rounds, mild nerves. Keep an eye on our Instagram or drop a note through our contact form and we'll point you to the open cycle.",
      },
      {
        q: "Is there a membership fee?",
        a: "Nope. Your only real cost is time, sleep, and possibly a bit of your GPA during exam season.",
      },
      {
        q: "I'm a first-year — can I still apply?",
        a: "First years are exactly who we're looking for. Most of our current leads started as clueless freshers who happened to show up on time once.",
      },
      {
        q: "Recruitment is closed. Can I still get involved?",
        a: "Yes. Attend our open events and workshops, contribute to our projects on GitHub, or just show up to what's public. Doors reopen every semester — you won't miss the next one if you're already around.",
      },
    ],
  },
  {
    id: "domains",
    label: "Domains & Teams",
    accent: "#135DE2",
    faqs: [
      {
        q: "What are ACM-VIT's domains?",
        a: "Five of them: Technical, Competitive Coding, Design, Management, and Research. Each runs its own projects and events — you can browse what they're building right now.",
      },
      {
        q: "Can I be part of multiple domains?",
        a: "You pick one core domain at recruitment, but cross-domain collaboration happens constantly in practice — most of our better projects are the result of two domains arguing productively.",
      },
      {
        q: "What does the Design domain actually do?",
        a: "Everything you're looking at right now, including these cassette illustrations — plus posters, brand systems, and the occasional 3am Figma disagreement.",
      },
    ],
  },
  {
    id: "events",
    label: "Events",
    accent: "#42CD9D",
    faqs: [
      {
        q: "What kind of events does ACM-VIT run?",
        a: "Hackathons, technical workshops, speaker sessions, CTFs, and community programs like Hour of Code and Kickstart Learn. There's usually something on the calendar.",
      },
      {
        q: "Are events open to non-members?",
        a: "Most of them, yes. Some are exclusive to registered members, some are open campus-wide, and a few go beyond VIT entirely. Registration details go out on our socials closer to the date.",
      },
      {
        q: "How do I find out what's coming up?",
        a: "Our calendar page has the full schedule — or follow us on Instagram, which you're probably already refreshing anyway.",
      },
    ],
  },
  {
    id: "projects",
    label: "Projects & Open Source",
    accent: "#9B51E0",
    faqs: [
      {
        q: "Can I contribute to ACM-VIT projects without being a member?",
        a: "Absolutely. Most of what we build lives on GitHub and takes pull requests happily. Have a look at what we're currently shipping.",
      },
      {
        q: "What's z0d1ak?",
        a: "Our competitive Capture The Flag team, currently ranked among the best in the country. If \"capture the flag\" makes you think of a camping trip, this is not that.",
      },
      {
        q: "Does ACM-VIT actually ship real software, or is this all workshops?",
        a: "Both. We've contributed to SGLang's documentation, won hackathons on- and off-campus, and shipped more side projects than fit on one page. The receipts are all there.",
      },
    ],
  },
  {
    id: "everything-else",
    label: "Everything Else",
    accent: "#F2C94C",
    faqs: [
      {
        q: "What's GREP?",
        a: "Our bi-annual technical newsletter. Yes, named after the command — we thought it was clever too, and we stand by it.",
      },
      {
        q: "Is there merch?",
        a: "There is, and it sells out faster than we restock it. Worth checking before you assume you missed it.",
      },
      {
        q: "Who do I talk to about partnerships or sponsorships?",
        a: "Send a message through our contact form and we'll get back to you — usually faster than your professor replies to email.",
      },
      {
        q: "Why is everything on this site designed like a cassette tape?",
        a: "Because the web has enough stock photos of laptops. We'd rather it had more analog nostalgia and reels that actually spin.",
      },
    ],
  },
];

let counter = 0;
---

<Layout pageTitle="FAQs" backHref="/">
  <main class="faq-page relative w-full overflow-hidden">
    <div class="faq-glow" aria-hidden="true"></div>
    <div class="faq-grid-bg" aria-hidden="true">
      <span class="fg-v" style="left: 20%"></span>
      <span class="fg-v" style="left: 50%"></span>
      <span class="fg-v" style="left: 80%"></span>
    </div>

    <div class="faq-inner relative z-10 mx-auto w-full max-w-4xl px-5 pb-28 pt-32 sm:px-8">
      <SectionHeading
        eyebrow="ACM-VIT · Liner Notes"
        title="Frequently"
        accent="Asked"
        subtitle="Everything people ask us before, during, and occasionally after joining. Press play on a question."
        align="left"
        class="mb-12 !px-0"
      />

      <!-- Quick-jump chips -->
      <nav class="faq-jump" aria-label="Jump to category">
        {
          categories.map((cat) => (
            <a href={`#${cat.id}`} class="faq-jump-chip" style={`--accent: ${cat.accent}`}>
              {cat.label}
            </a>
          ))
        }
      </nav>

      <!-- Categories -->
      <div class="faq-stack">
        {
          categories.map((cat) => (
            <section id={cat.id} class="faq-category" style={`--accent: ${cat.accent}`} data-reveal>
              <header class="faq-cat-head">
                <span class="faq-cat-dot" aria-hidden="true"></span>
                <h2 class="faq-cat-title">{cat.label}</h2>
                <span class="faq-cat-count">{String(cat.faqs.length).padStart(2, "0")} tracks</span>
              </header>

              <div class="faq-list">
                {
                  cat.faqs.map((item) => {
                    counter += 1;
                    const track = String(counter).padStart(2, "0");
                    return (
                      <div class="faq-item" data-faq-item>
                        <button
                          class="faq-q"
                          type="button"
                          aria-expanded="false"
                          data-faq-trigger
                        >
                          <span class="faq-track">{track}</span>
                          <span class="faq-q-text">{item.q}</span>
                          <span class="faq-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 5v14l11-7z"/></svg>
                          </span>
                        </button>
                        <div class="faq-panel-wrap">
                          <div class="faq-panel-inner">
                            <p class="faq-a">{item.a}</p>
                          </div>
                        </div>
                      </div>
                    );
                  })
                }
              </div>
            </section>
          ))
        }
      </div>

      <!-- Still stuck -->
      <div class="faq-cta" data-reveal>
        <p class="faq-cta-eyebrow">Still stuck?</p>
        <h3 class="faq-cta-title">We didn't answer your question</h3>
        <p class="faq-cta-body">Fair. Not every track makes the album. Reach out and we'll get back to you.</p>
        <FillButton label="Get in touch" href="/#contact" class="faq-cta-btn" />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .faq-page {
    min-height: 100vh;
  }

  .faq-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(45% 30% at 20% 8%, rgba(0, 180, 216, 0.16), transparent 70%),
      radial-gradient(40% 35% at 85% 40%, rgba(249, 95, 74, 0.1), transparent 70%);
  }
  .faq-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .fg-v {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      rgba(254, 252, 217, 0.06) 0 3px,
      transparent 3px 18px
    );
  }
  :global(html[data-theme="light"]) .fg-v {
    background: repeating-linear-gradient(
      to bottom,
      rgba(38, 59, 51, 0.07) 0 3px,
      transparent 3px 18px
    );
  }

  /* ── Quick jump ── */
  .faq-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 3rem;
  }
  .faq-jump-chip {
    font-family: "PolySans Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(254, 252, 217, 0.75);
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(254, 252, 217, 0.14);
    background: rgba(254, 252, 217, 0.03);
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease, transform 0.3s ease;
  }
  .faq-jump-chip:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    transform: translateY(-2px);
  }
  :global(html[data-theme="light"]) .faq-jump-chip {
    color: rgba(26, 26, 26, 0.65);
    border-color: rgba(26, 26, 26, 0.14);
    background: rgba(0, 0, 0, 0.02);
  }

  /* ── Category ── */
  .faq-stack {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }
  .faq-category {
    scroll-margin-top: 6rem;
  }
  .faq-cat-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 1.1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(254, 252, 217, 0.12);
  }
  .faq-cat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }
  .faq-cat-title {
    margin: 0;
    font-family: "PolySans Trial", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #fefcd9;
  }
  .faq-cat-count {
    margin-left: auto;
    font-family: "PolySans Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(254, 252, 217, 0.4);
  }
  :global(html[data-theme="light"]) .faq-cat-head {
    border-bottom-color: rgba(26, 26, 26, 0.12);
  }
  :global(html[data-theme="light"]) .faq-cat-title {
    color: #1a1a1a;
  }
  :global(html[data-theme="light"]) .faq-cat-count {
    color: rgba(26, 26, 26, 0.4);
  }

  /* ── Items ── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .faq-item {
    border-radius: 14px;
    background: linear-gradient(160deg, #17171763 0%, #0f0f0f63 100%);
    border: 1px solid rgba(254, 252, 217, 0.09);
    transition: border-color 0.35s ease, background 0.35s ease, box-shadow 0.35s ease;
    overflow: hidden;
  }
  .faq-item.is-open {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: linear-gradient(160deg, #1b1b1b 0%, #0f0f0f 100%);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.35);
  }
  :global(html[data-theme="light"]) .faq-item {
    background: rgba(255, 255, 255, 0.35);
    border-color: rgba(26, 26, 26, 0.1);
  }
  :global(html[data-theme="light"]) .faq-item.is-open {
    background: rgba(255, 255, 255, 0.7);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1.05rem 1.15rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: "PolySans Trial", sans-serif;
  }
  .faq-track {
    flex: none;
    font-family: "PolySans Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(254, 252, 217, 0.35);
    transition: color 0.3s ease;
  }
  .faq-item.is-open .faq-track {
    color: var(--accent);
  }
  .faq-q-text {
    flex: 1;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.35;
    color: #fefcd9;
    letter-spacing: -0.005em;
  }
  :global(html[data-theme="light"]) .faq-q-text {
    color: #1a1a1a;
  }
  .faq-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    color: rgba(254, 252, 217, 0.5);
    border: 1px solid rgba(254, 252, 217, 0.15);
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), color 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .faq-icon svg {
    width: 11px;
    height: 11px;
    transform: translateX(1px);
  }
  .faq-item.is-open .faq-icon {
    transform: rotate(90deg);
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }
  :global(html[data-theme="light"]) .faq-icon {
    border-color: rgba(26, 26, 26, 0.15);
    color: rgba(26, 26, 26, 0.45);
  }

  .faq-panel-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  .faq-item.is-open .faq-panel-wrap {
    grid-template-rows: 1fr;
  }
  .faq-panel-inner {
    overflow: hidden;
  }
  .faq-a {
    margin: 0;
    padding: 0 1.15rem 1.2rem 2.75rem;
    font-family: "PolySans Mono", monospace;
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(254, 252, 217, 0.72);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.35s ease 0.08s, transform 0.35s ease 0.08s;
  }
  .faq-item.is-open .faq-a {
    opacity: 1;
    transform: translateY(0);
  }
  :global(html[data-theme="light"]) .faq-a {
    color: rgba(26, 26, 26, 0.68);
  }

  /* ── Bottom CTA ── */
  .faq-cta {
    margin-top: 5rem;
    padding: 2.5rem 2rem;
    border-radius: 20px;
    text-align: center;
    background: radial-gradient(80% 100% at 50% 0%, rgba(0, 180, 216, 0.12), transparent 70%);
    border: 1px solid rgba(254, 252, 217, 0.1);
  }
  .faq-cta-eyebrow {
    margin: 0;
    font-family: "PolySans Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #00b4d8;
  }
  .faq-cta-title {
    margin: 0.7rem 0 0;
    font-family: "PolySans Trial", sans-serif;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    color: #fefcd9;
  }
  .faq-cta-body {
    margin: 0.6rem auto 0;
    max-width: 40ch;
    font-family: "PolySans Mono", monospace;
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(254, 252, 217, 0.65);
  }
  .faq-cta :global(.faq-cta-btn) {
    --proj-color: #00b4d8;
    --proj-color-secondary: #0d0e0d;
    margin-top: 1.6rem;
  }
  :global(html[data-theme="light"]) .faq-cta-title {
    color: #1a1a1a;
  }
  :global(html[data-theme="light"]) .faq-cta-body {
    color: rgba(26, 26, 26, 0.65);
  }
  :global(html[data-theme="light"]) .faq-cta {
    border-color: rgba(26, 26, 26, 0.1);
    background: radial-gradient(80% 100% at 50% 0%, rgba(0, 180, 216, 0.1), transparent 70%);
  }

  [data-reveal] {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
    }
    .faq-panel-wrap,
    .faq-a,
    .faq-icon {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .faq-cat-count {
      display: none;
    }
    .faq-a {
      padding-left: 1.15rem;
    }
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    const trigger = target?.closest<HTMLElement>("[data-faq-trigger]");
    if (!trigger) return;

    const item = trigger.closest<HTMLElement>("[data-faq-item]");
    if (!item) return;

    const isOpen = item.classList.toggle("is-open");
    trigger.setAttribute("aria-expanded", String(isOpen));
  });

  function initFaqReveal() {
    const els = document.querySelectorAll<HTMLElement>("[data-reveal]");
    if (!els.length) return;

    import("gsap").then(({ gsap }) => {
      import("gsap/ScrollTrigger").then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        els.forEach((el) => {
          if (reduce) {
            gsap.set(el, { opacity: 1 });
            return;
          }
          gsap.fromTo(
            el,
            { opacity: 0, y: 24 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: { trigger: el, start: "top 88%" },
            },
          );
        });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFaqReveal);
  } else {
    initFaqReveal();
  }
</script>
