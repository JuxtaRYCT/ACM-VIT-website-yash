---
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LeetCode Progress Import</title>
  </head>
  <body>
    <main class="lc-shell">
      <header class="lc-topbar">
        <a href="/" class="lc-brand" aria-label="Back to ACM-VIT">ACM-VIT</a>
        <span class="lc-badge">LeetCode Import</span>
      </header>

      <section class="lc-grid">
        <div class="lc-copy">
          <p class="lc-kicker">Authenticated progress</p>
          <h1>
            <span>Import solved</span>
            <span>LeetCode</span>
            <span>questions</span>
          </h1>
          <p class="lc-subcopy">
            Use your own signed-in LeetCode session to retrieve the complete
            solved-question list and profile summary.
          </p>

          <div class="lc-security">
            <span class="lc-dot" aria-hidden="true"></span>
            <p>
              Session values are sent once to this server route, are not stored,
              and are cleared from this page after a successful import.
            </p>
          </div>
        </div>

        <form class="lc-form" data-leetcode-form autocomplete="off">
          <label class="lc-field">
            <span>LEETCODE_SESSION</span>
            <textarea
              name="leetcodeSession"
              rows="5"
              spellcheck="false"
              autocapitalize="off"
              autocomplete="off"
              required
            ></textarea>
          </label>

          <label class="lc-field">
            <span>csrftoken</span>
            <input
              name="csrfToken"
              type="password"
              spellcheck="false"
              autocapitalize="off"
              autocomplete="off"
              required
            />
          </label>

          <div class="lc-actions">
            <a
              href="https://leetcode.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="lc-link-btn"
            >
              Open LeetCode
            </a>
            <button type="submit" class="lc-primary" data-submit-btn>
              Import
            </button>
            <button type="button" class="lc-ghost" data-clear-btn>
              Clear
            </button>
          </div>
        </form>
      </section>

      <section class="lc-status" data-status>
        Waiting for an authenticated import.
      </section>

      <section class="lc-results" data-results hidden>
        <div class="lc-metrics" aria-label="Import metrics">
          <div>
            <span data-metric-user>--</span>
            <p>User</p>
          </div>
          <div>
            <span data-metric-solved>0</span>
            <p>Solved</p>
          </div>
          <div>
            <span data-metric-progress>0</span>
            <p>Progress rows</p>
          </div>
          <div>
            <span data-metric-time>--</span>
            <p>Imported</p>
          </div>
        </div>

        <div class="lc-table-toolbar">
          <label class="lc-search">
            <span class="sr-only">Search questions</span>
            <input
              type="search"
              placeholder="Search title, tag, or difficulty"
              data-search
            />
          </label>
          <button type="button" class="lc-download" data-download-btn disabled>
            Download JSON
          </button>
        </div>

        <div class="lc-table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Question</th>
                <th>Difficulty</th>
                <th>Submissions</th>
                <th>Last submitted</th>
                <th>Tags</th>
              </tr>
            </thead>
            <tbody data-question-rows></tbody>
          </table>
        </div>
      </section>
    </main>

    <script>
      const form = document.querySelector("[data-leetcode-form]");
      const submitBtn = document.querySelector("[data-submit-btn]");
      const clearBtn = document.querySelector("[data-clear-btn]");
      const statusEl = document.querySelector("[data-status]");
      const resultsEl = document.querySelector("[data-results]");
      const rowsEl = document.querySelector("[data-question-rows]");
      const searchEl = document.querySelector("[data-search]");
      const downloadBtn = document.querySelector("[data-download-btn]");
      const metricUser = document.querySelector("[data-metric-user]");
      const metricSolved = document.querySelector("[data-metric-solved]");
      const metricProgress = document.querySelector("[data-metric-progress]");
      const metricTime = document.querySelector("[data-metric-time]");
      const sessionInput = form.querySelector("[name='leetcodeSession']");
      const csrfInput = form.querySelector("[name='csrfToken']");

      let latestImport = null;
      const entities = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };

      const escapeHtml = (value) =>
        String(value ?? "").replace(/[&<>"']/g, (match) => entities[match]);

      const setStatus = (message, state = "idle") => {
        statusEl.textContent = message;
        statusEl.dataset.state = state;
      };

      const formatDate = (value) => {
        if (!value) return "--";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return value;
        return date.toLocaleString(undefined, {
          year: "numeric",
          month: "short",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        });
      };

      const getTagText = (question) =>
        (question.topicTags || []).map((tag) => tag.name).join(", ");

      const renderRows = (questions) => {
        const filter = searchEl.value.trim().toLowerCase();
        const visibleQuestions = filter
          ? questions.filter((question) => {
              const haystack = [
                question.frontendId,
                question.title,
                question.titleSlug,
                question.difficulty,
                getTagText(question),
              ]
                .join(" ")
                .toLowerCase();
              return haystack.includes(filter);
            })
          : questions;

        rowsEl.innerHTML = visibleQuestions
          .map((question) => {
            const tags = (question.topicTags || [])
              .slice(0, 4)
              .map((tag) => `<span>${escapeHtml(tag.name)}</span>`)
              .join("");
            const title = escapeHtml(question.title);
            const slug = encodeURIComponent(question.titleSlug || "");

            return `
              <tr>
                <td>${escapeHtml(question.frontendId || "--")}</td>
                <td>
                  <a href="https://leetcode.com/problems/${slug}/" target="_blank" rel="noopener noreferrer">
                    ${title}
                  </a>
                </td>
                <td><span class="lc-difficulty">${escapeHtml(question.difficulty)}</span></td>
                <td>${escapeHtml(question.numSubmitted ?? 0)}</td>
                <td>${escapeHtml(formatDate(question.lastSubmittedAt))}</td>
                <td><div class="lc-tags">${tags || "<span>None</span>"}</div></td>
              </tr>
            `;
          })
          .join("");
      };

      const renderImport = (payload) => {
        latestImport = payload;
        const questions = payload.questions || [];

        metricUser.textContent = payload.username || "Signed in";
        metricSolved.textContent = String(payload.progress?.solvedQuestions ?? questions.length);
        metricProgress.textContent = String(
          payload.progress?.fetchedProgressQuestions ?? questions.length
        );
        metricTime.textContent = formatDate(payload.importedAt);

        renderRows(questions);
        resultsEl.hidden = false;
        downloadBtn.disabled = false;
        setStatus(`Imported ${questions.length} solved questions.`, "success");
      };

      const clearSecrets = () => {
        sessionInput.value = "";
        csrfInput.value = "";
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const leetcodeSession = sessionInput.value.trim();
        const csrfToken = csrfInput.value.trim();

        if (!leetcodeSession || !csrfToken) {
          setStatus("Both LeetCode session values are required.", "error");
          return;
        }

        submitBtn.disabled = true;
        setStatus("Importing solved questions from LeetCode...", "loading");

        try {
          const response = await fetch("/api/leetcode-progress", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ leetcodeSession, csrfToken }),
          });

          const payload = await response.json();
          if (!response.ok) {
            throw new Error(payload.message || "Import failed.");
          }

          clearSecrets();
          renderImport(payload);
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "Import failed.",
            "error"
          );
        } finally {
          submitBtn.disabled = false;
        }
      });

      clearBtn.addEventListener("click", () => {
        clearSecrets();
        setStatus("Session fields cleared.", "idle");
      });

      searchEl.addEventListener("input", () => {
        if (latestImport) renderRows(latestImport.questions || []);
      });

      downloadBtn.addEventListener("click", () => {
        if (!latestImport) return;
        const blob = new Blob([JSON.stringify(latestImport, null, 2)], {
          type: "application/json",
        });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = `${latestImport.username || "leetcode"}-solved-questions.json`;
        link.click();
        URL.revokeObjectURL(link.href);
      });
    </script>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
    background: #0f1217;
    color: #f7f4ec;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .lc-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin: 0 auto;
    padding: 24px 0 48px;
  }

  .lc-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .lc-brand,
  .lc-badge {
    color: #f7f4ec;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .lc-badge {
    color: #8fc9ff;
    font-weight: 600;
  }

  .lc-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(360px, 1fr);
    gap: 40px;
    align-items: start;
    padding: 56px 0 28px;
    min-width: 0;
  }

  .lc-kicker {
    margin: 0 0 14px;
    color: #ff9b73;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    width: 100%;
    max-width: 620px;
    color: #fffaf0;
    font-size: clamp(42px, 7vw, 88px);
    line-height: 0.95;
    font-weight: 800;
    letter-spacing: 0;
    overflow-wrap: break-word;
  }

  h1 span {
    display: block;
  }

  .lc-copy {
    min-width: 0;
  }

  .lc-subcopy {
    max-width: 560px;
    margin: 22px 0 0;
    color: #c9d0d9;
    font-size: 18px;
    line-height: 1.55;
  }

  .lc-security {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    max-width: 560px;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: #aeb8c4;
    font-size: 14px;
    line-height: 1.5;
  }

  .lc-security p {
    margin: 0;
  }

  .lc-dot {
    width: 10px;
    height: 10px;
    flex: 0 0 auto;
    margin-top: 5px;
    border-radius: 50%;
    background: #58d68d;
    box-shadow: 0 0 0 5px rgba(88, 214, 141, 0.14);
  }

  .lc-form {
    display: grid;
    gap: 16px;
    min-width: 0;
    padding: 22px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: #171b22;
  }

  .lc-field {
    display: grid;
    gap: 8px;
    color: #d8dde5;
    font-size: 13px;
    font-weight: 700;
  }

  textarea,
  input {
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 6px;
    background: #0f1217;
    color: #fffaf0;
    font: inherit;
    font-size: 14px;
    line-height: 1.5;
    outline: none;
  }

  textarea {
    min-height: 132px;
    resize: vertical;
    padding: 12px;
  }

  input {
    height: 44px;
    padding: 0 12px;
  }

  textarea:focus,
  input:focus {
    border-color: #8fc9ff;
    box-shadow: 0 0 0 3px rgba(143, 201, 255, 0.16);
  }

  .lc-actions {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 10px;
    align-items: center;
  }

  .lc-link-btn,
  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-radius: 6px;
    padding: 0 16px;
    font: inherit;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  .lc-link-btn,
  .lc-ghost,
  .lc-download {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: transparent;
    color: #f7f4ec;
  }

  .lc-primary {
    border: 0;
    background: #ff744f;
    color: #111318;
  }

  .lc-primary:disabled,
  .lc-download:disabled {
    cursor: not-allowed;
    opacity: 0.56;
  }

  .lc-status {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    padding: 14px 0;
    color: #aeb8c4;
    font-size: 14px;
  }

  .lc-status[data-state="success"] {
    color: #58d68d;
  }

  .lc-status[data-state="error"] {
    color: #ff8d7f;
  }

  .lc-status[data-state="loading"] {
    color: #8fc9ff;
  }

  .lc-results {
    padding-top: 28px;
  }

  .lc-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.12);
  }

  .lc-metrics div {
    min-width: 0;
    background: #171b22;
    padding: 18px;
  }

  .lc-metrics span {
    display: block;
    overflow: hidden;
    color: #fffaf0;
    font-size: clamp(20px, 3vw, 32px);
    line-height: 1.1;
    font-weight: 800;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lc-metrics p {
    margin: 8px 0 0;
    color: #aeb8c4;
    font-size: 13px;
  }

  .lc-table-toolbar {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    margin: 20px 0 12px;
  }

  .lc-search input {
    height: 42px;
  }

  .lc-table-wrap {
    overflow: auto;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: #171b22;
  }

  table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    font-size: 14px;
  }

  th,
  td {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: left;
    vertical-align: top;
  }

  th {
    position: sticky;
    top: 0;
    background: #1f2530;
    color: #aeb8c4;
    font-size: 12px;
    text-transform: uppercase;
  }

  td {
    color: #e9edf2;
  }

  td a {
    color: #fffaf0;
    font-weight: 700;
    text-decoration: none;
  }

  .lc-difficulty {
    color: #8fc9ff;
    font-weight: 800;
  }

  .lc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    max-width: 360px;
  }

  .lc-tags span {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 3px 8px;
    color: #c9d0d9;
    font-size: 12px;
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .lc-shell {
      width: calc(100% - 20px);
      max-width: 720px;
      margin-left: 10px;
      margin-right: 10px;
      padding-top: 14px;
    }

    .lc-badge {
      display: none;
    }

    .lc-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-top: 34px;
    }

    .lc-copy,
    .lc-form,
    .lc-status,
    .lc-results {
      width: min(100%, 340px);
      max-width: 340px;
    }

    h1 {
      font-size: clamp(34px, 11vw, 46px);
      line-height: 1.04;
    }

    .lc-actions,
    .lc-table-toolbar,
    .lc-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
