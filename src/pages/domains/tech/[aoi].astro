---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../layouts/Footer.astro";
import "../../../styles/globals.css";
import "../../../styles/design-domain.css";
import { getAssetUrl } from "../../../utils/cdn";
import ToolCard from "../../../components/ToolCard.astro";
import ProjectCassetteCard from "../../../components/ui/ProjectCassetteCard.astro";
import {
  TECH_THEME_COLOR,
  techAOIs,
  techTools,
  techFooterMessage,
} from "../../../data/techDomainData";

export function getStaticPaths() {
  return techAOIs.map((aoi) => ({ params: { aoi: aoi.key } }));
}

const { aoi: aoiSlug } = Astro.params;
const aoiData = techAOIs.find((a) => a.key === aoiSlug);
if (!aoiData) return Astro.redirect("/domains/tech");

const aoiTools = aoiData.tools
  .map((slug) => techTools.find((t) => t.slug === slug))
  .filter((t): t is (typeof techTools)[number] => Boolean(t));

const otherAOIs = techAOIs.filter((a) => a.key !== aoiSlug);
---

<Layout pageTitle={aoiData.title} backHref="/domains/tech">
  <div
    style={`--domain-color: ${TECH_THEME_COLOR};`}
    data-egg-track={aoiData.key === "gamestudios" ? "GTA San Andreas Theme" : undefined}
  >

    <section class="dsg-hero" style="min-height: 70vh;">
      <div class="dsg-hero-inner">
        <div class="dsg-hero-text">
          <p class="dsg-hero-eyebrow" data-dsg-animate="fade-up">
            Tech - Area of Interest
          </p>
          <h1 class="dsg-hero-title" data-dsg-animate="fade-up" style="font-size: clamp(3rem, 8vw, 7rem);">
            {aoiData.title}
          </h1>
          <p class="dsg-hero-desc" data-dsg-animate="fade-up">
            {aoiData.shortDescription}
          </p>
        </div>
        <div class="dsg-cassette-fan" data-dsg-animate="fade-up" style="min-height: 300px;">
          <div class="dsg-fan-center" style="opacity: 1;">
            <img
              src={getAssetUrl(aoiData.cassetteSrc)}
              alt={aoiData.title}
              style="width: 380px;"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="dsg-about">
      <div class="dsg-about-inner">
        <h2 class="dsg-about-heading" data-dsg-animate="fade-up">
          What this <span>AOI</span> does
        </h2>
        <div class="dsg-about-body" data-dsg-animate="fade-up">
          {aoiData.longDescription.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <hr class="dsg-divider" />

    {aoiTools.length > 0 && (
      <section class="dsg-tools">
        <div class="dsg-tools-header">
          <p class="dsg-tools-label" data-dsg-animate="fade-up">Stack</p>
          <h2 class="dsg-tools-title" data-dsg-animate="fade-up">Tools We Use</h2>
        </div>
        <div class="dsg-aoi-tools-row">
          {aoiTools.map((tool, i) => (
            <ToolCard tool={tool} delaySeconds={i * 0.05} />
          ))}
        </div>
      </section>
    )}

    {aoiData.projects && aoiData.projects.length > 0 && (
      <>
        <hr class="dsg-divider" />
        <section class="dsg-events">
          <div class="dsg-events-header">
            <p class="dsg-events-label" data-dsg-animate="fade-up">Projects</p>
            <h2 class="dsg-events-title" data-dsg-animate="fade-up">What We've Built</h2>
          </div>
          <div class="dsg-events-row">
            {aoiData.projects.map((project) => (
              <ProjectCassetteCard
                title={project.title}
                desc={project.desc}
                domainColor={TECH_THEME_COLOR}
                fallbackImage={project.cassette}
              />
            ))}
          </div>
        </section>
      </>
    )}

    {aoiData.events && aoiData.events.length > 0 && (
      <>
        <hr class="dsg-divider" />
        <section class="dsg-events">
          <div class="dsg-events-header">
            <p class="dsg-events-label" data-dsg-animate="fade-up">Events</p>
            <h2 class="dsg-events-title" data-dsg-animate="fade-up">Where This Ships</h2>
          </div>
          <div class="dsg-events-row">
            {aoiData.events.map((event) => {
              const isExternal = event.external && event.href;
              const href = isExternal ? event.href : `/events/${event.slug}`;
              const extra = isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {};
              return (
                <a href={href} {...extra} class="dsg-event-card" data-dsg-animate="fade-up">
                  <img
                    src={getAssetUrl(event.cassette)}
                    alt={event.title}
                    loading="lazy"
                    decoding="async"
                  />
                  <h4>{event.title}</h4>
                  <p>{event.desc}</p>
                </a>
              );
            })}
          </div>
        </section>
      </>
    )}

    <hr class="dsg-divider" />

    {otherAOIs.length > 0 && (
      <section class="dsg-events">
        <div class="dsg-events-header">
          <p class="dsg-events-label" data-dsg-animate="fade-up">More from Tech</p>
          <h2 class="dsg-events-title" data-dsg-animate="fade-up">Other AOIs</h2>
        </div>
        <div class="dsg-events-row">
          {otherAOIs.map((aoi) => (
            <a href={`/domains/tech/${aoi.key}`} class="dsg-event-card" data-dsg-animate="fade-up">
              <img
                src={getAssetUrl(aoi.cassetteSrc)}
                alt={aoi.title}
                loading="lazy"
                decoding="async"
              />
              <h4>{aoi.title}</h4>
              <p>{aoi.shortDescription}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="dsg-footer-section">
      <div class="dsg-cassette-fan" data-dsg-fan>
        {otherAOIs.slice(0, 5).map((aoi, i) => (
          <div class="dsg-fan-card" style={`--fan-index: ${i}`} data-fan-card>
            <img
              src={getAssetUrl(aoi.cassetteSrc)}
              alt={aoi.title}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
      <p class="dsg-footer-msg">{techFooterMessage}</p>
      <a href="/domains/tech" class="dsg-back-link">
        <span aria-hidden="true">&larr;</span>
        Back to Tech
      </a>
    </section>
  </div>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  /* ── Easter egg: Game Studios AOI cues the GTA San Andreas theme in the
     site's cassette player, expanded, low in the mix. Autoplay-with-sound is
     blocked until a user gesture, so we arm on the first interaction. Only
     fires if the user hasn't already started their own track. ── */
  (() => {
    const track = document
      .querySelector("[data-egg-track]")
      ?.getAttribute("data-egg-track");
    if (!track) return;

    let done = false;
    const trigger = () => {
      if (done) return;
      const cp = (window as any).acmCassette;
      if (!cp) return; // player not initialised yet - wait for the next gesture
      const ok = cp.playByTitle(track, {
        volume: 0.18,
        expand: true,
        onlyIfPaused: true,
      });
      if (ok) {
        done = true;
        ["pointerdown", "keydown", "touchstart", "wheel"].forEach((ev) =>
          window.removeEventListener(ev, trigger)
        );
      }
    };

    ["pointerdown", "keydown", "touchstart", "wheel"].forEach((ev) =>
      window.addEventListener(ev, trigger, { passive: true })
    );
  })();

  const entry = gsap.timeline({ defaults: { ease: "power3.out" }, paused: true });

  const heroEls = document.querySelectorAll('.dsg-hero-text [data-dsg-animate="fade-up"]');
  entry.fromTo(heroEls,
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.12 }
  );

  const fan = document.querySelector('.dsg-cassette-fan[data-dsg-animate]');
  if (fan) {
    entry.fromTo(fan,
      { opacity: 0, scale: 0.9, rotate: -3 },
      { opacity: 1, scale: 1, rotate: 0, duration: 0.8 },
      "-=0.3"
    );
  }

  const centerImg = document.querySelector('.dsg-fan-center img');
  if (centerImg) {
    gsap.to(centerImg, {
      y: -12, duration: 2.5, ease: "sine.inOut", yoyo: true, repeat: -1,
    });
  }

  window.addEventListener("preloader:done", () => entry.play(), { once: true });

  const scrollEls = document.querySelectorAll(
    '.dsg-about [data-dsg-animate], .dsg-tools [data-dsg-animate], .dsg-events [data-dsg-animate]'
  );
  scrollEls.forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 24 },
      {
        opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
        delay: parseFloat((el as HTMLElement).style.getPropertyValue('--card-delay') || '0'),
        scrollTrigger: { trigger: el, start: "top 88%", once: true },
      }
    );
  });

  const fanCards = document.querySelectorAll("[data-fan-card]");
  const fanSection = document.querySelector(".dsg-cassette-fan");

  if (fanSection && fanCards.length > 0) {
    const fanAngles = [-25, -10, 10, 25, 35];
    const fanOffsetsX = [-220, -80, 80, 220, 320];
    const fanOffsetsY = [30, 5, 5, 30, 50];

    fanCards.forEach((card) => {
      gsap.set(card, { opacity: 0, rotation: 0, x: 0, y: 40, scale: 0.5 });
    });

    const fanTl = gsap.timeline({
      scrollTrigger: {
        trigger: fanSection,
        start: "top 80%",
        once: true,
      },
    });

    fanCards.forEach((card, i) => {
      fanTl.to(card, {
        opacity: 1,
        rotation: fanAngles[i] ?? 0,
        x: fanOffsetsX[i] ?? 0,
        y: fanOffsetsY[i] ?? 0,
        scale: 1,
        duration: 0.6,
        ease: "back.out(1.2)",
      }, i === 0 ? "+=0" : "-=0.45");
    });
  }
</script>
