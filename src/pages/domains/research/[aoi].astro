---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import Footer from "../../../layouts/Footer.astro";
import "../../../styles/globals.css";
import "../../../styles/design-domain.css";
import { getAssetUrl } from "../../../utils/cdn";
import ToolCard from "../../../components/ToolCard.astro";
import {
  RESEARCH_THEME_COLOR,
  researchAOIs,
  researchTools,
  researchFooterMessage,
} from "../../../data/researchDomainData";

export function getStaticPaths() {
  return researchAOIs.map((aoi) => ({ params: { aoi: aoi.key } }));
}

const { aoi: aoiSlug } = Astro.params;
const aoiData = researchAOIs.find((a) => a.key === aoiSlug);
if (!aoiData) return Astro.redirect("/domains/research");

const aoiTools = aoiData.tools
  .map((slug) => researchTools.find((t) => t.slug === slug))
  .filter((t): t is (typeof researchTools)[number] => Boolean(t));

const otherAOIs = researchAOIs.filter((a) => a.key !== aoiSlug);

interface SpotlightCard {
  href: string;
  title: string;
  cassette: string;
  desc: string;
  external: boolean;
}

const spotlightByAOI: Record<string, SpotlightCard[]> = {
  aiml: [
    {
      href: "https://nh.acmvit.in/",
      title: "Neural Hack",
      cassette: "/events/neural-hack-cassette.svg",
      desc: "ACM-VIT's flagship AI/ML hackathon. Teams build end-to-end ML systems under the clock, judged on technical depth and applied impact.",
      external: true,
    },
  ],
  cybersecurity: [
    {
      href: "/z0d1ak",
      title: "z0d1ak",
      cassette: "/aois/research/cassettes/cybersecurity.png",
      desc: "ACM-VIT's competitive CTF team. Currently India's number one ranked squad and seventh in the world, with members across web, pwn, crypto, and reversing.",
      external: false,
    },
  ],
};

const spotlight = spotlightByAOI[aoiData.key] ?? [];
---

<Layout pageTitle={aoiData.title} backHref="/domains/research">
  <div style={`--domain-color: ${RESEARCH_THEME_COLOR};`}>

    <section class="dsg-hero" style="min-height: 70vh;">
      <div class="dsg-hero-inner">
        <div class="dsg-hero-text">
          <p class="dsg-hero-eyebrow" data-dsg-animate="fade-up">
            Research - Area of Interest
          </p>
          <h1 class="dsg-hero-title" data-dsg-animate="fade-up" style="font-size: clamp(3rem, 8vw, 7rem);">
            {aoiData.title}
          </h1>
          <p class="dsg-hero-desc" data-dsg-animate="fade-up">
            {aoiData.shortDescription}
          </p>
        </div>
        <div class="dsg-cassette-fan" data-dsg-animate="fade-up" style="min-height: 300px;">
          <div class="dsg-fan-center" style="opacity: 1;">
            <img
              src={getAssetUrl(aoiData.cassetteSrc)}
              alt={aoiData.title}
              style="width: 380px;"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="dsg-about">
      <div class="dsg-about-inner">
        <h2 class="dsg-about-heading" data-dsg-animate="fade-up">
          What this <span>AOI</span> does
        </h2>
        <div class="dsg-about-body" data-dsg-animate="fade-up">
          {aoiData.longDescription.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <hr class="dsg-divider" />

    {aoiTools.length > 0 && (
      <section class="dsg-tools">
        <div class="dsg-tools-header">
          <p class="dsg-tools-label" data-dsg-animate="fade-up">Stack</p>
          <h2 class="dsg-tools-title" data-dsg-animate="fade-up">Tools We Use</h2>
        </div>
        <div class="dsg-aoi-tools-row">
          {aoiTools.map((tool, i) => (
            <ToolCard tool={tool} delaySeconds={i * 0.05} />
          ))}
        </div>
      </section>
    )}

    {spotlight.length > 0 && (
      <>
        <hr class="dsg-divider" />
        <section class="dsg-events">
          <div class="dsg-events-header">
            <p class="dsg-events-label" data-dsg-animate="fade-up">Spotlight</p>
            <h2 class="dsg-events-title" data-dsg-animate="fade-up">
              {aoiData.key === "cybersecurity" ? "Our CTF Team" : "Our Event"}
            </h2>
          </div>
          <div class="dsg-events-row">
            {spotlight.map((item) => (
              item.external ? (
                <a href={item.href} target="_blank" rel="noopener noreferrer" class="dsg-event-card" data-dsg-animate="fade-up">
                  <img src={getAssetUrl(item.cassette)} alt={item.title} loading="lazy" decoding="async" />
                  <h4>{item.title}</h4>
                  <p>{item.desc}</p>
                </a>
              ) : (
                <a href={item.href} class="dsg-event-card" data-dsg-animate="fade-up">
                  <img src={getAssetUrl(item.cassette)} alt={item.title} loading="lazy" decoding="async" />
                  <h4>{item.title}</h4>
                  <p>{item.desc}</p>
                </a>
              )
            ))}
          </div>
        </section>
      </>
    )}

    <hr class="dsg-divider" />

    {otherAOIs.length > 0 && (
      <section class="dsg-events">
        <div class="dsg-events-header">
          <p class="dsg-events-label" data-dsg-animate="fade-up">More from Research</p>
          <h2 class="dsg-events-title" data-dsg-animate="fade-up">Other AOIs</h2>
        </div>
        <div class="dsg-events-row">
          {otherAOIs.map((aoi) => (
            <a href={`/domains/research/${aoi.key}`} class="dsg-event-card" data-dsg-animate="fade-up">
              <img
                src={getAssetUrl(aoi.cassetteSrc)}
                alt={aoi.title}
                loading="lazy"
                decoding="async"
              />
              <h4>{aoi.title}</h4>
              <p>{aoi.shortDescription}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="dsg-footer-section">
      <div class="dsg-cassette-fan" data-dsg-fan>
        {otherAOIs.slice(0, 5).map((aoi, i) => (
          <div class="dsg-fan-card" style={`--fan-index: ${i}`} data-fan-card>
            <img
              src={getAssetUrl(aoi.cassetteSrc)}
              alt={aoi.title}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
      <p class="dsg-footer-msg">{researchFooterMessage}</p>
      <a href="/domains/research" class="dsg-back-link">
        <span aria-hidden="true">&larr;</span>
        Back to Research
      </a>
    </section>
  </div>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const entry = gsap.timeline({ defaults: { ease: "power3.out" }, paused: true });

  const heroEls = document.querySelectorAll('.dsg-hero-text [data-dsg-animate="fade-up"]');
  entry.fromTo(heroEls,
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.12 }
  );

  const fan = document.querySelector('.dsg-cassette-fan[data-dsg-animate]');
  if (fan) {
    entry.fromTo(fan,
      { opacity: 0, scale: 0.9, rotate: -3 },
      { opacity: 1, scale: 1, rotate: 0, duration: 0.8 },
      "-=0.3"
    );
  }

  const centerImg = document.querySelector('.dsg-fan-center img');
  if (centerImg) {
    gsap.to(centerImg, {
      y: -12, duration: 2.5, ease: "sine.inOut", yoyo: true, repeat: -1,
    });
  }

  window.addEventListener("preloader:done", () => entry.play(), { once: true });

  const scrollEls = document.querySelectorAll(
    '.dsg-about [data-dsg-animate], .dsg-tools [data-dsg-animate], .dsg-events [data-dsg-animate]'
  );
  scrollEls.forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 24 },
      {
        opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
        delay: parseFloat((el as HTMLElement).style.getPropertyValue('--card-delay') || '0'),
        scrollTrigger: { trigger: el, start: "top 88%", once: true },
      }
    );
  });

  const fanCards = document.querySelectorAll("[data-fan-card]");
  const fanSection = document.querySelector(".dsg-cassette-fan");

  if (fanSection && fanCards.length > 0) {
    const fanAngles = [-25, -10, 10, 25, 35];
    const fanOffsetsX = [-220, -80, 80, 220, 320];
    const fanOffsetsY = [30, 5, 5, 30, 50];

    fanCards.forEach((card) => {
      gsap.set(card, { opacity: 0, rotation: 0, x: 0, y: 40, scale: 0.5 });
    });

    const fanTl = gsap.timeline({
      scrollTrigger: {
        trigger: fanSection,
        start: "top 80%",
        once: true,
      },
    });

    fanCards.forEach((card, i) => {
      fanTl.to(card, {
        opacity: 1,
        rotation: fanAngles[i] ?? 0,
        x: fanOffsetsX[i] ?? 0,
        y: fanOffsetsY[i] ?? 0,
        scale: 1,
        duration: 0.6,
        ease: "back.out(1.2)",
      }, i === 0 ? "+=0" : "-=0.45");
    });
  }
</script>
