---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import "../../../styles/globals.css";
import Footer from "../../../layouts/Footer.astro";
import AnimatedButton from "../../../components/ui/AnimatedButton.astro";
---

<Layout pageTitle="2026 Edition" backHref="/merchandise">
  <section class="m26-hero" data-m26-hero>
    <div class="m26-line m26-line--1"></div>
    <div class="m26-line m26-line--2"></div>

    <div class="m26-center-col">
      <div class="m26-year-wrap">
        <h1 class="m26-year" data-m26-year>
          <span class="m26-yc" data-yc>2</span><span class="m26-yc" data-yc>0</span><span class="m26-yc" data-yc>2</span><span class="m26-yc" data-yc>6</span>
        </h1>
      </div>
      <div class="m26-cta" data-m26-cta>
        <AnimatedButton text="View Collection" href="/merchandise/2026/view" iconBg="#F95F4A" />
      </div>
    </div>

    <div class="m26-htee m26-htee--1" data-htee>
      <img src="/assets/merch/2026/board.png" alt="Board Tee" loading="eager" />
    </div>
    <div class="m26-htee m26-htee--2" data-htee>
      <img src="/assets/merch/2026/tech.png" alt="Tech Tee" loading="eager" />
    </div>
    <div class="m26-htee m26-htee--3" data-htee>
      <img src="/assets/merch/2026/design.png" alt="Design Tee" loading="lazy" />
    </div>

    <div class="m26-badge" data-badge>
      <span class="m26-badge__label">EDITION</span>
      <span class="m26-badge__year">'26</span>
    </div>

    <div class="m26-hero-info" data-hero-info>
      <p class="m26-hero-info__tag">THE 2026 COLLECTION</p>
      <h2 class="m26-hero-info__title">Atlas. Mapped per domain.</h2>
      <p class="m26-hero-info__body">
        Six domain tees built around the Atlas theme. Tech, Board, Competitive
        Coding, Design, Management and Research &mdash; each with its own
        layout over a shared visual system.
      </p>
    </div>
  </section>

  <section class="m26-end" data-m26-end>
    <div class="m26-end__inner">
      <p class="m26-end__text" data-end-anim>you have reached the end of the rack</p>
      <p class="m26-end__sub" data-end-anim>no more hangers, just vibes from here</p>
      <img
        src="/assets/merch/lineup.png"
        alt="ACM-VIT merchandise lineup"
        class="m26-end__img"
        loading="lazy"
        data-end-anim
      />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .m26-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .m26-line {
    position: absolute;
    z-index: 1;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(249, 95, 74, 0.14) 30%, rgba(249, 95, 74, 0.14) 70%, transparent 100%);
  }
  .m26-line--1 { top: 18%; }
  .m26-line--2 { bottom: 22%; }

  .m26-center-col {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    pointer-events: none;
  }

  .m26-year-wrap { pointer-events: none; user-select: none; }

  .m26-cta {
    opacity: 0;
    transform: translateY(12px);
    pointer-events: auto;
    z-index: 5;
    position: relative;
  }

  .m26-year {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(20vw, 28vw, 38vw);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: rgba(249, 95, 74, 0.18);
    margin: 0;
    display: flex;
    white-space: nowrap;
  }

  .m26-yc { display: inline-block; opacity: 0; transform: translateY(80px); }

  .m26-htee { position: absolute; z-index: 2; opacity: 0; transform: translateY(40px); }
  .m26-htee img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.5)); }

  .m26-htee--1 {
    left: 6%;
    top: 50%;
    width: clamp(220px, 30vw, 420px);
    aspect-ratio: 2.16;
    transform: translateY(-55%) rotate(-6deg);
  }
  .m26-htee--2 {
    right: 5%;
    top: 38%;
    width: clamp(180px, 24vw, 340px);
    aspect-ratio: 2.16;
    transform: translateY(-50%) rotate(5deg);
  }
  .m26-htee--3 {
    right: 16%;
    bottom: 8%;
    width: clamp(140px, 18vw, 240px);
    aspect-ratio: 2.16;
    transform: rotate(-3deg);
  }

  .m26-badge {
    position: absolute;
    top: 50%;
    right: 28px;
    transform: translateY(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    opacity: 0;
  }

  .m26-badge__label {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(249, 95, 74, 0.5);
  }

  .m26-badge__year {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(249, 95, 74, 0.25);
  }

  .m26-hero-info {
    position: absolute;
    left: clamp(1.5rem, 4vw, 3.5rem);
    bottom: clamp(3rem, 8vh, 6rem);
    z-index: 5;
    max-width: 440px;
    opacity: 0;
    transform: translateY(20px);
  }

  .m26-hero-info__tag {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #F95F4A;
    margin: 0 0 0.6rem;
  }

  .m26-hero-info__title {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: #FEFCD9;
    margin: 0 0 0.6rem;
  }

  .m26-hero-info__body {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(254, 252, 217, 0.4);
    margin: 0 0 1.2rem;
    max-width: 380px;
  }

  .m26-end { position: relative; padding: 5rem 1.5rem 2rem; overflow: hidden; }
  .m26-end__inner { max-width: 56rem; margin: 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .m26-end__text {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    color: rgba(254, 252, 217, 0.12);
    text-transform: lowercase;
    margin: 0;
  }
  .m26-end__sub {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(254, 252, 217, 0.07);
    margin: 0.25rem 0 0;
  }
  .m26-end__img {
    width: 100%;
    max-width: 48rem;
    height: auto;
    object-fit: contain;
    margin-top: 2rem;
    mix-blend-mode: lighten;
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.3));
  }

  @media (max-width: 1024px) {
    .m26-htee--1 { width: clamp(200px, 28vw, 340px); }
    .m26-htee--2 { width: clamp(170px, 22vw, 280px); }
    .m26-htee--3 { width: clamp(120px, 16vw, 200px); }
  }

  @media (max-width: 768px) {
    .m26-year { font-size: clamp(22vw, 28vw, 32vw); }
    .m26-htee--1 { left: 3%; width: clamp(170px, 40vw, 260px); }
    .m26-htee--2 { right: 1%; width: clamp(150px, 32vw, 220px); }
    .m26-htee--3 { display: none; }
    .m26-badge { display: none; }
    .m26-hero-info { max-width: 60%; bottom: calc(80px + env(safe-area-inset-bottom, 0px)); }
    .m26-hero-info__body { font-size: 0.72rem; max-width: 100%; }
  }

  /* Phones: stack the hero vertically so nothing overlaps the CTA or navbar */
  @media (max-width: 480px) {
    .m26-hero {
      flex-direction: column;
      justify-content: flex-start;
      gap: 0;
      padding: 5.5rem 1.25rem calc(104px + env(safe-area-inset-bottom, 0px));
    }
    .m26-line--2 { display: none; }
    .m26-year { font-size: 24vw; }
    .m26-center-col { order: 2; margin-top: 0.5rem; gap: 1rem; }
    .m26-htee--2,
    .m26-htee--3 { display: none; }
    .m26-htee--1 {
      order: 1;
      position: relative;
      left: auto;
      top: auto;
      width: 58vw;
      max-width: 240px;
      margin: 0 auto;
      transform: rotate(-4deg);
    }
    .m26-hero-info {
      order: 3;
      position: relative;
      left: auto;
      bottom: auto;
      max-width: 100%;
      margin-top: 1.75rem;
    }
  }

  :global(html[data-theme="light"]) .m26-year { color: rgba(249, 95, 74, 0.14); }
  :global(html[data-theme="light"]) .m26-badge__label { color: rgba(217, 68, 48, 0.5); }
  :global(html[data-theme="light"]) .m26-badge__year { -webkit-text-stroke-color: rgba(217, 68, 48, 0.2); }
  :global(html[data-theme="light"]) .m26-hero-info__title { color: #1a1a1a; }
  :global(html[data-theme="light"]) .m26-hero-info__body { color: rgba(30, 20, 10, 0.45); }
  :global(html[data-theme="light"]) .m26-htee img { filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.15)); }
  :global(html[data-theme="light"]) .m26-end__text { color: rgba(30, 20, 10, 0.1); }
  :global(html[data-theme="light"]) .m26-end__sub { color: rgba(30, 20, 10, 0.06); }
  :global(html[data-theme="light"]) .m26-end__img { mix-blend-mode: multiply; filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.08)); }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const chars = document.querySelectorAll("[data-yc]");
  const htees = document.querySelectorAll("[data-htee]");
  const badge = document.querySelector("[data-badge]");
  const heroInfo = document.querySelector("[data-hero-info]");
  const cta = document.querySelector("[data-m26-cta]");

  const tl = gsap.timeline({ defaults: { ease: "power3.out" }, delay: 0.35 });

  tl.to(chars, { opacity: 1, y: 0, duration: 0.85, stagger: 0.1 });
  if (cta) tl.to(cta, { opacity: 1, y: 0, duration: 0.5 }, "-=0.3");

  htees.forEach((tee, i) => {
    tl.to(tee, { opacity: 1, y: 0, duration: 0.75, ease: "power3.out" }, `-=${0.55 - i * 0.08}`);
  });

  if (badge) tl.to(badge, { opacity: 1, duration: 0.45 }, "-=0.3");
  if (heroInfo) tl.to(heroInfo, { opacity: 1, y: 0, duration: 0.6 }, "-=0.3");

  htees.forEach((tee, i) => {
    gsap.to(tee, {
      y: `+=${7 + i * 3}`,
      duration: 3 + i * 0.6,
      ease: "sine.inOut",
      repeat: -1,
      yoyo: true,
      delay: i * 0.4,
    });
  });

  const endAnims = document.querySelectorAll("[data-end-anim]");
  gsap.fromTo(endAnims,
    { opacity: 0, y: 30 },
    {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: "power3.out",
      scrollTrigger: { trigger: ".m26-end", start: "top 85%", once: true },
    }
  );
</script>
