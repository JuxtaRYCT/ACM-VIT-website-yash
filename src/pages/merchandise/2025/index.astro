---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import "../../../styles/globals.css";
import Footer from "../../../layouts/Footer.astro";
import AnimatedButton from "../../../components/ui/AnimatedButton.astro";
---

<Layout pageTitle="2025 Edition" backHref="/merchandise">
  <!-- ═══ HERO ═══ -->
  <section class="m25-hero" data-m25-hero>
    <div class="m25-line m25-line--1"></div>
    <div class="m25-line m25-line--2"></div>

    <div class="m25-center-col">
      <div class="m25-year-wrap">
        <h1 class="m25-year" data-m25-year>
          <span class="m25-yc" data-yc>2</span><span class="m25-yc" data-yc>0</span><span class="m25-yc" data-yc>2</span><span class="m25-yc" data-yc>5</span>
        </h1>
      </div>
      <div class="m25-cta" data-m25-cta>
        <AnimatedButton text="View Collection" href="/merchandise/2025/view" iconBg="#F95F4A" />
      </div>
    </div>

    <!-- Floating tees -->
    <div class="m25-htee m25-htee--1" data-htee>
      <img src="/merch/2025/black-front/merch-2025-black-front-board.png" alt="Board T-shirt" loading="eager" />
    </div>
    <div class="m25-htee m25-htee--2" data-htee>
      <img src="/merch/2025/hoodie/merch-2025-hoodie-back.png" alt="Hoodie" loading="eager" />
    </div>
    <div class="m25-htee m25-htee--3" data-htee>
      <img src="/merch/2025/black-back/merch-2025-black-back-design.png" alt="Design T-shirt Back" loading="lazy" />
    </div>

    <!-- Badge -->
    <div class="m25-badge" data-badge>
      <span class="m25-badge__label">EDITION</span>
      <span class="m25-badge__year">'25</span>
    </div>

    <!-- Info overlay (inside hero, no scroll needed) -->
    <div class="m25-hero-info" data-hero-info>
      <p class="m25-hero-info__tag">THE 2025 COLLECTION</p>
      <h2 class="m25-hero-info__title">Built for the community.</h2>
      <p class="m25-hero-info__body">
        7 domains, each with a unique accent and the Wayfarer back illustration.
        Junior Core got an exclusive black-only variant.
        The Hoodie &mdash; Senior Core and Board only &mdash; lime-green on pitch black.
      </p>
    </div>
  </section>

  <!-- ═══ END OF RACK ═══ -->
  <section class="m25-end" data-m25-end>
    <div class="m25-end__inner">
      <p class="m25-end__text" data-end-anim>you have reached the end of the rack</p>
      <p class="m25-end__sub" data-end-anim>no more hangers, just vibes from here</p>
      <img
        src="/merch/merch-lineup.png"
        alt="ACM-VIT merchandise lineup"
        class="m25-end__img"
        loading="lazy"
        data-end-anim
      />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ══════ HERO ══════ */
  .m25-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .m25-line {
    position: absolute;
    z-index: 1;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(249, 95, 74, 0.12) 30%, rgba(249, 95, 74, 0.12) 70%, transparent 100%);
  }
  .m25-line--1 { top: 18%; }
  .m25-line--2 { bottom: 22%; }

  .m25-center-col {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    pointer-events: none;
  }

  .m25-year-wrap {
    pointer-events: none;
    user-select: none;
  }

  .m25-cta {
    opacity: 0;
    transform: translateY(12px);
    pointer-events: auto;
    z-index: 5;
    position: relative;
  }

  .m25-year {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(20vw, 28vw, 38vw);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: rgba(249, 95, 74, 0.18);
    margin: 0;
    display: flex;
    white-space: nowrap;
  }

  .m25-yc {
    display: inline-block;
    opacity: 0;
    transform: translateY(80px);
  }

  /* Floating tees */
  .m25-htee {
    position: absolute;
    z-index: 2;
    opacity: 0;
    transform: translateY(40px);
  }

  .m25-htee img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.5));
  }

  .m25-htee--1 {
    left: 8%;
    top: 50%;
    width: clamp(200px, 28vw, 380px);
    aspect-ratio: 1;
    transform: translateY(-55%) rotate(-7deg);
  }

  .m25-htee--2 {
    right: 6%;
    top: 38%;
    width: clamp(160px, 20vw, 280px);
    aspect-ratio: 0.8;
    transform: translateY(-50%) rotate(5deg);
  }

  .m25-htee--3 {
    right: 14%;
    bottom: 8%;
    width: clamp(120px, 14vw, 200px);
    aspect-ratio: 0.85;
    transform: rotate(-3deg);
  }

  /* Badge */
  .m25-badge {
    position: absolute;
    top: 50%;
    right: 28px;
    transform: translateY(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    opacity: 0;
  }

  .m25-badge__label {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(249, 95, 74, 0.45);
  }

  .m25-badge__year {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(249, 95, 74, 0.22);
  }

  /* ── Hero Info (inside hero, bottom-left) ── */
  .m25-hero-info {
    position: absolute;
    left: clamp(1.5rem, 4vw, 3.5rem);
    bottom: clamp(3rem, 8vh, 6rem);
    z-index: 5;
    max-width: 440px;
    opacity: 0;
    transform: translateY(20px);
  }

  .m25-hero-info__tag {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #F95F4A;
    margin: 0 0 0.6rem;
  }

  .m25-hero-info__title {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: #FEFCD9;
    margin: 0 0 0.6rem;
  }

  .m25-hero-info__body {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(254, 252, 217, 0.4);
    margin: 0 0 1.2rem;
    max-width: 380px;
  }

  /* ══════ END OF RACK ══════ */
  .m25-end {
    position: relative;
    padding: 5rem 1.5rem 2rem;
    overflow: hidden;
  }

  .m25-end__inner {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .m25-end__text {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    color: rgba(254, 252, 217, 0.12);
    text-transform: lowercase;
    margin: 0;
  }

  .m25-end__sub {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(254, 252, 217, 0.07);
    margin: 0.25rem 0 0;
  }

  .m25-end__img {
    width: 100%;
    max-width: 48rem;
    height: auto;
    object-fit: contain;
    margin-top: 2rem;
    mix-blend-mode: lighten;
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.3));
  }

  /* ══════ RESPONSIVE ══════ */
  @media (max-width: 1024px) {
    .m25-htee--1 { width: clamp(180px, 26vw, 300px); }
    .m25-htee--2 { width: clamp(150px, 20vw, 240px); }
    .m25-htee--3 { width: clamp(100px, 12vw, 160px); }
  }

  @media (max-width: 768px) {
    .m25-year { font-size: clamp(22vw, 28vw, 32vw); }
    .m25-htee--1 { left: 4%; width: clamp(150px, 36vw, 220px); }
    .m25-htee--2 { right: 2%; width: clamp(130px, 28vw, 180px); }
    .m25-htee--3 { display: none; }
    .m25-badge { display: none; }
    .m25-hero-info { max-width: 55%; bottom: calc(80px + env(safe-area-inset-bottom, 0px)); }
    .m25-hero-info__body { font-size: 0.72rem; max-width: 100%; }
  }

  /* Phones: stack the hero vertically so nothing overlaps the CTA or navbar */
  @media (max-width: 480px) {
    .m25-hero {
      flex-direction: column;
      justify-content: flex-start;
      gap: 0;
      padding: 5.5rem 1.25rem calc(104px + env(safe-area-inset-bottom, 0px));
    }
    .m25-line--2 { display: none; }
    .m25-year { font-size: 24vw; }
    .m25-center-col { order: 2; margin-top: 0.5rem; gap: 1rem; }
    .m25-htee--2,
    .m25-htee--3 { display: none; }
    .m25-htee--1 {
      order: 1;
      position: relative;
      left: auto;
      top: auto;
      width: 58vw;
      max-width: 240px;
      margin: 0 auto;
      transform: rotate(-4deg);
    }
    .m25-hero-info {
      order: 3;
      position: relative;
      left: auto;
      bottom: auto;
      max-width: 100%;
      margin-top: 1.75rem;
    }
  }

  /* ══════ LIGHT THEME ══════ */
  :global(html[data-theme="light"]) .m25-year { color: rgba(249, 95, 74, 0.14); }
  :global(html[data-theme="light"]) .m25-badge__label { color: rgba(249, 95, 74, 0.3); }
  :global(html[data-theme="light"]) .m25-badge__year { -webkit-text-stroke-color: rgba(249, 95, 74, 0.12); }
  :global(html[data-theme="light"]) .m25-hero-info__title { color: #1a1a1a; }
  :global(html[data-theme="light"]) .m25-hero-info__body { color: rgba(30, 20, 10, 0.45); }
  :global(html[data-theme="light"]) .m25-htee img { filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.15)); }
  :global(html[data-theme="light"]) .m25-end__text { color: rgba(30, 20, 10, 0.1); }
  :global(html[data-theme="light"]) .m25-end__sub { color: rgba(30, 20, 10, 0.06); }
  :global(html[data-theme="light"]) .m25-end__img { mix-blend-mode: multiply; filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.08)); }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const chars = document.querySelectorAll("[data-yc]");
  const htees = document.querySelectorAll("[data-htee]");
  const badge = document.querySelector("[data-badge]");
  const heroInfo = document.querySelector("[data-hero-info]");
  const cta = document.querySelector("[data-m25-cta]");

  const tl = gsap.timeline({ defaults: { ease: "power3.out" }, delay: 0.35 });

  tl.to(chars, { opacity: 1, y: 0, duration: 0.85, stagger: 0.1 });
  if (cta) tl.to(cta, { opacity: 1, y: 0, duration: 0.5 }, "-=0.3");

  htees.forEach((tee, i) => {
    tl.to(tee, { opacity: 1, y: 0, duration: 0.75, ease: "power3.out" }, `-=${0.55 - i * 0.08}`);
  });

  if (badge) tl.to(badge, { opacity: 1, duration: 0.45 }, "-=0.3");
  if (heroInfo) tl.to(heroInfo, { opacity: 1, y: 0, duration: 0.6 }, "-=0.3");

  htees.forEach((tee, i) => {
    gsap.to(tee, {
      y: `+=${7 + i * 3}`,
      duration: 3 + i * 0.6,
      ease: "sine.inOut",
      repeat: -1,
      yoyo: true,
      delay: i * 0.4,
    });
  });

  // End section
  const endAnims = document.querySelectorAll("[data-end-anim]");
  gsap.fromTo(endAnims,
    { opacity: 0, y: 30 },
    {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: "power3.out",
      scrollTrigger: { trigger: ".m25-end", start: "top 85%", once: true },
    }
  );
</script>
