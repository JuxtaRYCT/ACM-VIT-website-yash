---
export const prerender = true;
import Layout from "../../../layouts/Layout.astro";
import "../../../styles/globals.css";
import Footer from "../../../layouts/Footer.astro";

const items = [
  { name: "Board", slug: "board", accent: "#FF0054", hasWhite: true },
  { name: "App", slug: "app", accent: "#9B51E0", hasWhite: true },
  { name: "Competitive Coding", slug: "cc", accent: "#42CD9D", hasWhite: true },
  { name: "Design", slug: "design", accent: "#FF0054", hasWhite: true },
  { name: "Management", slug: "management", accent: "#008080", hasWhite: true },
  { name: "Research", slug: "research", accent: "#135DE2", hasWhite: true },
  { name: "Web", slug: "web", accent: "#B4E35B", hasWhite: true },
  { name: "Junior Core", slug: "JC", accent: "#00BFFF", hasWhite: false },
  { name: "Hoodie", slug: "hoodie", accent: "#B4E35B", hasWhite: false, isHoodie: true },
];
---

<Layout pageTitle="2025 - View Collection" backHref="/merchandise/2025">
  <section class="vw" data-vw>
    <div class="vw-tint" data-vw-tint></div>

    <!-- Left content -->
    <div class="vw-left">
      <h1 class="vw-title" data-vw-title>Wayfarer T-shirt</h1>
      <p class="vw-domain" data-vw-domain>Board</p>
      <p class="vw-sub" data-vw-sub>
        Each domain got its own accent and Wayfarer illustration.<br />
        Swipe through all 9.
      </p>
    </div>

    <!-- Stage: front + back together -->
    <div class="vw-stage" data-vw-stage>
      {items.map((item, i) => (
        <div
          class={`vw-product ${i === 0 ? "vw-product--active" : ""}`}
          data-vw-product={item.slug}
          data-idx={i}
          data-has-white={item.hasWhite ? "true" : "false"}
          data-is-hoodie={item.isHoodie ? "true" : "false"}
        >
          <div class="vw-duo">
            <div class="vw-duo__side">
              {item.isHoodie ? (
                <img class="vw-pimg" data-pv="black-front" src="/assets/merch/2025/hoodie/hoodie_front.png" alt="Hoodie Front" loading="lazy" />
              ) : (
                <>
                  <img class="vw-pimg" data-pv="black-front" src={`/assets/merch/2025/black-front/${item.slug}.png`} alt={`${item.name} Black Front`} loading={i === 0 ? "eager" : "lazy"} />
                  {item.hasWhite && (
                    <img class="vw-pimg" data-pv="white-front" src={`/assets/merch/2025/white-front/${item.slug}.png`} alt={`${item.name} White Front`} loading="lazy" />
                  )}
                </>
              )}
            </div>
            <div class="vw-duo__side">
              {item.isHoodie ? (
                <img class="vw-pimg" data-pv="black-back" src="/assets/merch/2025/hoodie/hoodie_back.png" alt="Hoodie Back" loading="lazy" />
              ) : (
                <>
                  <img class="vw-pimg" data-pv="black-back" src={`/assets/merch/2025/black-back/${item.slug}.png`} alt={`${item.name} Black Back`} loading="lazy" />
                  {item.hasWhite && (
                    <img class="vw-pimg" data-pv="white-back" src={`/assets/merch/2025/white-back/${item.slug}.png`} alt={`${item.name} White Back`} loading="lazy" />
                  )}
                </>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

  </section>

  <!-- Fixed dock overlay (blog-style, pops from bottom) -->
  <div class="vw-dock-wrap">
    <div class="vw-dock" data-vw-dock>
      <button class="vw-dock-btn dock-ctrl" data-arrow="prev" aria-label="Previous">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="vw-dock-sep dock-div"></div>

      <div class="vw-dots dock-ctrl">
        {items.map((item, i) => (
          <button
            class={`vw-navdot ${i === 0 ? "active" : ""}`}
            data-nav={i}
            style={`--dot-c: ${item.accent}`}
            aria-label={item.name}
          ><span></span></button>
        ))}
      </div>

      <div class="vw-dock-sep dock-div"></div>

      <button class="vw-dock-btn dock-ctrl" data-arrow="next" aria-label="Next">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>

      <div class="vw-dock-sep dock-div"></div>

      <!-- Color toggle -->
      <button class="vw-cdot vw-cdot--black active dock-ctrl" data-cdot="black" aria-label="Black">
        <span class="vw-cdot__fill"></span>
      </button>
      <button class="vw-cdot vw-cdot--white dock-ctrl" data-cdot="white" aria-label="White">
        <span class="vw-cdot__fill"></span>
      </button>
    </div>
  </div>

  <!-- ═══ END OF RACK ═══ -->
  <section class="m25-end" data-m25-end>
    <div class="m25-end__inner">
      <p class="m25-end__text" data-end-anim>you have reached the end of the rack</p>
      <p class="m25-end__sub" data-end-anim>no more hangers, just vibes from here</p>
      <img
        src="/assets/merch/lineup.png"
        alt="ACM-VIT merchandise lineup"
        class="m25-end__img"
        loading="lazy"
        data-end-anim
      />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Rock+Salt&display=swap');

  .vw {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }

  .vw-tint {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(ellipse at 55% 45%, rgba(255, 0, 84, 0.035) 0%, transparent 65%);
    pointer-events: none;
  }

  /* ── Left ── */
  .vw-left {
    position: absolute;
    left: clamp(1.5rem, 5vw, 5rem);
    top: clamp(90px, 12vh, 130px);
    z-index: 5;
    max-width: 38%;
  }

  .vw-title {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3.2vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FEFCD9;
    margin: 0 0 1rem;
  }

  .vw-domain {
    font-family: "Rock Salt", cursive;
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #F95F4A;
    margin: 0 0 0.8rem;
  }

  .vw-sub {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: clamp(0.82rem, 1.1vw, 1rem);
    font-weight: 400;
    line-height: 1.65;
    color: rgba(254, 252, 217, 0.35);
    margin: 0;
  }

  /* ══════ STAGE ══════ */
  .vw-stage {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Products: front + back side by side */
  .vw-product {
    position: absolute;
    width: clamp(480px, 62vw, 900px);
    height: clamp(280px, 42vh, 520px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    margin-top: 1%;
  }

  .vw-product--active {
    opacity: 1;
    pointer-events: auto;
  }

  .vw-duo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 2vw, 2rem);
    width: 100%;
    height: 100%;
  }

  .vw-duo__side {
    position: relative;
    flex: 0 0 auto;
    width: clamp(200px, 28vw, 400px);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vw-pimg {
    position: absolute;
    width: 92%;
    height: 92%;
    object-fit: contain;
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.45));
    opacity: 0;
    transition: filter 0.5s ease;
  }

  .vw-product--active .vw-duo__side:first-child .vw-pimg[data-pv="black-front"],
  .vw-product--active .vw-duo__side:last-child .vw-pimg[data-pv="black-back"] {
    opacity: 1;
  }

  /* ══════ DOCK ══════ */
  .vw-dock-wrap {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9000;
    pointer-events: none;
  }

  .vw-dock {
    display: flex;
    min-height: 52px;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(30, 30, 30, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    pointer-events: auto;
  }

  .vw-dock-sep {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  .vw-dock-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(254, 252, 217, 0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vw-dock-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    color: rgba(254, 252, 217, 0.95);
  }

  .vw-dock-btn:active {
    transform: scale(0.92);
  }

  .vw-dots {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .vw-navdot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: transform 0.3s ease;
  }

  .vw-navdot:hover { transform: scale(1.3); }

  .vw-navdot span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dot-c);
    opacity: 0.3;
    transition: opacity 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .vw-navdot.active span {
    opacity: 1;
    transform: scale(1.5);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.06);
  }

  /* Color dots in dock */
  .vw-cdot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    padding: 0;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vw-cdot:hover { transform: scale(1.15); }
  .vw-cdot:active { transform: scale(0.92); }

  .vw-cdot__fill {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  .vw-cdot--black .vw-cdot__fill {
    background: #1a1a1a;
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .vw-cdot--white .vw-cdot__fill {
    background: #eee;
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .vw-cdot.active .vw-cdot__fill {
    box-shadow: 0 0 0 3px rgba(249, 95, 74, 0.5);
    transform: scale(1.1);
  }

  .vw-cdot.disabled {
    opacity: 0.15;
    pointer-events: none;
  }

  /* ══════ END OF RACK ══════ */
  .m25-end {
    position: relative;
    padding: 5rem 1.5rem 2rem;
    overflow: hidden;
  }

  .m25-end__inner {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .m25-end__text {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.8rem);
    letter-spacing: -0.02em;
    color: rgba(254, 252, 217, 0.12);
    text-transform: lowercase;
    margin: 0;
  }

  .m25-end__sub {
    font-family: "PolySans Trial", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(254, 252, 217, 0.07);
    margin: 0.25rem 0 0;
  }

  .m25-end__img {
    width: 100%;
    max-width: 48rem;
    height: auto;
    object-fit: contain;
    margin-top: 2rem;
    mix-blend-mode: lighten;
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.3));
  }

  /* ══════ RESPONSIVE ══════ */
  @media (max-width: 1024px) {
    .vw-product { width: clamp(400px, 58vw, 700px); height: clamp(240px, 38vh, 440px); }
    .vw-duo__side { width: clamp(180px, 26vw, 320px); }
  }

  @media (max-width: 768px) {
    .vw-left {
      top: 80px;
      max-width: 55%;
    }

    .vw-title { font-size: clamp(1.3rem, 4.5vw, 2rem); }
    .vw-domain { font-size: clamp(1rem, 3.5vw, 1.5rem); }

    .vw-product {
      width: 88vw;
      height: clamp(200px, 34vh, 320px);
      margin-top: 3%;
    }

    .vw-duo { gap: 0.5rem; }
    .vw-duo__side { width: 40vw; }

    .vw-sub { display: none; }
  }

  @media (max-width: 480px) {
    .vw-left { top: 72px; max-width: 65%; }
    .vw-product { width: 94vw; height: 38vh; }
    .vw-duo__side { width: 44vw; }
    .vw-dots { gap: 2px; }
    .vw-navdot { width: 14px; height: 14px; }
    .vw-navdot span { width: 5px; height: 5px; }
    .vw-dock { padding: 6px 10px; gap: 4px; }
    .vw-dock-btn { width: 28px; height: 28px; }
    .vw-cdot { width: 26px; height: 26px; }
    .vw-cdot__fill { width: 16px; height: 16px; }
  }

  /* ══════ LIGHT THEME ══════ */
  :global(html[data-theme="light"]) .vw-title { color: #1a1a1a; }
  :global(html[data-theme="light"]) .vw-domain { color: #d94430; }
  :global(html[data-theme="light"]) .vw-sub { color: rgba(30, 20, 10, 0.4); }
  :global(html[data-theme="light"]) .vw-dock {
    background: rgba(22, 22, 22, 0.94);
    border-color: rgba(249, 95, 74, 0.25);
    box-shadow: 0 12px 36px rgba(45, 20, 12, 0.25);
  }
  :global(html[data-theme="light"]) .vw-pimg { filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.12)); }
  :global(html[data-theme="light"]) .m25-end__text { color: rgba(30, 20, 10, 0.1); }
  :global(html[data-theme="light"]) .m25-end__sub { color: rgba(30, 20, 10, 0.06); }
  :global(html[data-theme="light"]) .m25-end__img { mix-blend-mode: multiply; filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.08)); }
</style>

<script>
  import { gsap } from "gsap";
  import { Flip } from "gsap/Flip";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(Flip, ScrollTrigger);

  const ITEMS = [
    { name: "Board", slug: "board", accent: "#FF0054", hasWhite: true, isHoodie: false },
    { name: "App", slug: "app", accent: "#9B51E0", hasWhite: true, isHoodie: false },
    { name: "Competitive Coding", slug: "cc", accent: "#42CD9D", hasWhite: true, isHoodie: false },
    { name: "Design", slug: "design", accent: "#FF0054", hasWhite: true, isHoodie: false },
    { name: "Management", slug: "management", accent: "#008080", hasWhite: true, isHoodie: false },
    { name: "Research", slug: "research", accent: "#135DE2", hasWhite: true, isHoodie: false },
    { name: "Web", slug: "web", accent: "#B4E35B", hasWhite: true, isHoodie: false },
    { name: "Junior Core", slug: "JC", accent: "#00BFFF", hasWhite: false, isHoodie: false },
    { name: "Hoodie", slug: "hoodie", accent: "#B4E35B", hasWhite: false, isHoodie: true },
  ];

  let idx = 0;
  let color: "black" | "white" = "black";
  let busy = false;

  const products = document.querySelectorAll<HTMLElement>(".vw-product");
  const navDots = document.querySelectorAll<HTMLButtonElement>(".vw-navdot");
  const cDots = document.querySelectorAll<HTMLButtonElement>("[data-cdot]");
  const arrows = document.querySelectorAll<HTMLButtonElement>("[data-arrow]");
  const titleEl = document.querySelector<HTMLElement>("[data-vw-title]");
  const domainEl = document.querySelector<HTMLElement>("[data-vw-domain]");
  const subEl = document.querySelector<HTMLElement>("[data-vw-sub]");
  const tint = document.querySelector<HTMLElement>("[data-vw-tint]");
  const whiteDot = document.querySelector<HTMLButtonElement>('[data-cdot="white"]');
  const dock = document.querySelector<HTMLElement>("[data-vw-dock]");

  function showDuo(product: HTMLElement, c: "black" | "white") {
    product.querySelectorAll<HTMLImageElement>(".vw-pimg").forEach((img) => {
      const pv = img.dataset.pv || "";
      const show = pv === `${c}-front` || pv === `${c}-back`;
      gsap.to(img, { opacity: show ? 1 : 0, duration: 0.45, ease: "power2.inOut" });
    });
  }

  function hexToRgb(hex: string) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r},${g},${b}`;
  }

  function updateMeta(item: typeof ITEMS[0]) {
    if (titleEl) {
      titleEl.textContent = item.isHoodie ? "State Transition Gear" : "Wayfarer T-shirt";
    }
    if (domainEl) {
      domainEl.textContent = item.name;
      domainEl.style.color = item.accent;
    }
    if (subEl) {
      subEl.innerHTML = item.isHoodie
        ? "Named after the state-machine woven into its back panel -<br/>every transition mapped, every state accounted for."
        : "Each domain got its own accent and Wayfarer illustration.<br/>Swipe through all 9.";
    }
  }

  // ── Entry Animation ──
  const entry = gsap.timeline({ defaults: { ease: "power3.out" }, paused: true });
  window.addEventListener("preloader:done", () => entry.play(), { once: true });

  entry.fromTo("[data-vw-title]", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 });
  entry.fromTo("[data-vw-domain]", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.45 }, "-=0.25");
  entry.fromTo("[data-vw-sub]", { opacity: 0 }, { opacity: 1, duration: 0.4 }, "-=0.2");

  const firstP = products[0];
  if (firstP) {
    entry.fromTo(firstP,
      { opacity: 0, y: 50, scale: 0.88 },
      { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: "power3.out" },
      "-=0.4"
    );
  }

  // Dock entrance - exact blog-dock animation with Flip
  if (dock) {
    const controls = dock.querySelectorAll<HTMLElement>(".dock-ctrl");
    const dividers = dock.querySelectorAll<HTMLElement>(".dock-div");

    const naturalW = dock.getBoundingClientRect().width;
    const naturalH = dock.getBoundingClientRect().height;

    gsap.set(dock, {
      opacity: 0,
      y: 24,
      scale: 0.7,
      width: naturalH,
      height: naturalH,
      overflow: "hidden",
    });
    gsap.set([controls, dividers], { opacity: 0 });

    const dockTl = gsap.timeline();

    // Phase 1: pop up as small circle
    dockTl.to(dock, {
      opacity: 1,
      y: -6,
      scale: 1.05,
      duration: 0.35,
      ease: "power2.out",
    });

    // Phase 2: settle
    dockTl.to(dock, {
      y: 0,
      scale: 1,
      duration: 0.25,
      ease: "power3.out",
    });

    // Phase 3: Flip expand to full width
    dockTl.add(() => {
      const state = Flip.getState(dock);
      dock.style.width = `${naturalW}px`;

      Flip.from(state, {
        duration: 0.5,
        ease: "power3.out",
        onComplete: () => {
          dock.style.width = "";
          dock.style.height = "";
          dock.style.overflow = "";

          // Phase 4: fade in controls with stagger
          gsap.to([controls, dividers], {
            opacity: 1,
            duration: 0.3,
            stagger: 0.025,
            ease: "power2.out",
          });
        },
      });
    }, "-=0.08");

    entry.add(dockTl, "-=0.3");
  }

  // ── Navigate ──
  function go(newIdx: number) {
    if (newIdx === idx || busy) return;
    busy = true;

    const oldP = products[idx];
    const newP = products[newIdx];
    const item = ITEMS[newIdx];
    if (!oldP || !newP || !item) { busy = false; return; }

    // Reset color if needed
    if (!item.hasWhite && color === "white") {
      color = "black";
      cDots.forEach((d) => d.classList.toggle("active", d.dataset.cdot === "black"));
    }

    const tl = gsap.timeline({ onComplete: () => { idx = newIdx; busy = false; } });

    // Out
    tl.to(oldP, { opacity: 0, scale: 0.88, duration: 0.3, ease: "power2.in",
      onComplete: () => {
        oldP.classList.remove("vw-product--active");
        oldP.querySelectorAll<HTMLImageElement>(".vw-pimg").forEach(i => gsap.set(i, { opacity: 0 }));
      }
    });

    // Prep new
    newP.querySelectorAll<HTMLImageElement>(".vw-pimg").forEach(img => {
      const pv = img.dataset.pv || "";
      const show = pv === `${color}-front` || pv === `${color}-back`;
      gsap.set(img, { opacity: show ? 1 : 0 });
    });

    // In
    tl.fromTo(newP,
      { opacity: 0, scale: 1.08 },
      { opacity: 1, scale: 1, duration: 0.5, ease: "power3.out",
        onStart: () => newP.classList.add("vw-product--active")
      },
      "-=0.05"
    );

    // Update title, domain, sub
    tl.add(() => updateMeta(item), 0.15);

    // Tint
    const rgb = hexToRgb(item.accent);
    tl.to(tint, {
      background: `radial-gradient(ellipse at 55% 45%, rgba(${rgb},0.035) 0%, transparent 65%)`,
      duration: 0.5,
    }, 0);

    // Dots
    navDots.forEach((d, i) => d.classList.toggle("active", i === newIdx));

    // White dot
    if (whiteDot) whiteDot.classList.toggle("disabled", !item.hasWhite);
  }

  // ── Color Toggle ──
  function setColor(c: "black" | "white") {
    if (c === color || busy) return;
    const item = ITEMS[idx];
    if (!item || (c === "white" && !item.hasWhite)) return;

    busy = true;
    color = c;
    cDots.forEach((d) => d.classList.toggle("active", d.dataset.cdot === c));

    const product = products[idx];
    if (!product) { busy = false; return; }

    const tl = gsap.timeline({
      defaults: { duration: 0.5, ease: "power3.inOut" },
      onComplete: () => { busy = false; }
    });

    // Crossfade both front + back
    showDuo(product, c);

    tl.to({}, { duration: 0.5, onComplete: () => { busy = false; } });
    busy = false;
  }

  // ── Listeners ──
  navDots.forEach((d) => d.addEventListener("click", () => go(parseInt(d.dataset.nav || "0"))));
  cDots.forEach((d) => d.addEventListener("click", () => setColor(d.dataset.cdot as "black" | "white")));
  arrows.forEach((a) => a.addEventListener("click", () => {
    const n = ITEMS.length;
    go(a.dataset.arrow === "next" ? (idx + 1) % n : (idx - 1 + n) % n);
  }));

  // Keyboard
  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight") go((idx + 1) % ITEMS.length);
    if (e.key === "ArrowLeft") go((idx - 1 + ITEMS.length) % ITEMS.length);
  });

  // End section scroll animation
  const endAnims = document.querySelectorAll("[data-end-anim]");
  gsap.fromTo(endAnims,
    { opacity: 0, y: 30 },
    {
      opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: "power3.out",
      scrollTrigger: { trigger: ".m25-end", start: "top 85%", once: true },
    }
  );
</script>
