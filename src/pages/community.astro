---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import { getAssetUrl } from "../utils/cdn";

import IgnitingMinds from "../sections/IgnitingMinds.astro";
import CodeOfConduct from "../sections/CodeOfConduct.astro";
import DistinguishedSpeaker from "../sections/DistinguishedSpeaker.astro";

import Footer from "../layouts/Footer.astro";
---

<Layout pageTitle="Community" backHref="/#community">
  <!-- Hero -->
  <section class="community-hero relative overflow-hidden pb-16 md:pb-24 pt-8 md:pt-16">
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.06]"
      style={`background-image: url(${getAssetUrl("/backgrounds/background_pattern.webp")}); background-size: cover;`}
    ></div>

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 relative z-10">
      <p
        class="text-[#FF5F4A] text-xs sm:text-sm font-mono tracking-[0.3em] uppercase mb-8 md:mb-12"
      >
        ACM-VIT &mdash; Community Initiatives
      </p>

      <h1
        class="text-[clamp(3.5rem,10vw,12rem)] font-bold text-[#FFFDD0] uppercase tracking-tighter leading-[0.82]"
      >
        COMM<span class="text-[#FF5F4A]">UNITY</span>
      </h1>

      <div class="w-20 h-[3px] bg-[#FF5F4A] my-8 md:my-10"></div>

      <div class="md:grid md:grid-cols-2 gap-12 items-end">
        <p
          class="text-gray-300 font-mono text-xs sm:text-sm leading-relaxed uppercase max-w-xl"
        >
          From school outreach programs to distinguished speaker sessions,
          ACM-VIT's community initiatives drive inclusive growth and real-world
          impact across technology and education.
        </p>
        <div class="mt-8 md:mt-0 flex md:justify-end">
          <div class="flex gap-10 text-[#FFFDD0]">
            <div>
              <span class="text-3xl md:text-4xl font-bold tracking-tight"
                >5+</span
              >
              <p class="text-gray-500 font-mono text-[0.65rem] mt-1 uppercase">
                Initiatives
              </p>
            </div>
            <div>
              <span class="text-3xl md:text-4xl font-bold tracking-tight"
                >500+</span
              >
              <p class="text-gray-500 font-mono text-[0.65rem] mt-1 uppercase">
                Students Reached
              </p>
            </div>
            <div>
              <span class="text-3xl md:text-4xl font-bold tracking-tight"
                >1</span
              >
              <p class="text-gray-500 font-mono text-[0.65rem] mt-1 uppercase">
                Int'l Award
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section Navigator — Bento Grid -->
  <section class="py-12 md:py-20 border-t border-white/10">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10">
      <div class="community-grid">
        <!-- 01 Outreach -->
        <a
          href="#community-outreach"
          class="community-card card-has-img group"
          style="--card-i:0"
        >
          <img
            src={getAssetUrl("/outreach/outreach-event.webp")}
            alt="Outreach Event"
            class="card-bg-img"
            loading="lazy"
            decoding="async"
          />
          <div class="card-overlay"></div>
          <div class="card-content">
            <span class="card-num">01</span>
            <h3 class="card-title">Outreach</h3>
            <p class="card-subtitle">Beyond The Norm</p>
            <p class="card-desc">
              Interactive workshops bringing computing to school students
              through flowcharts & digital logic.
            </p>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>

        <!-- 02 SDG -->
        <a
          href="#community-sdg"
          class="community-card card-gradient group"
          style="--card-i:1"
        >
          <div class="card-content">
            <span class="card-num">02</span>
            <h3 class="card-title">SDG</h3>
            <p class="card-subtitle">Quality Education</p>
            <p class="card-desc">
              Aligned with UN SDG 4, reducing the digital learning gap in rural
              communities through technology.
            </p>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>

        <!-- 03 Award -->
        <a
          href="#community-award"
          class="community-card card-has-img group"
          style="--card-i:2"
        >
          <img
            src={getAssetUrl("/ui/acm-celeb.png")}
            alt="ACM International Award"
            class="card-bg-img"
            loading="lazy"
            decoding="async"
          />
          <div class="card-overlay"></div>
          <div class="card-content">
            <span class="card-num">03</span>
            <h3 class="card-title">Int'l Award</h3>
            <p class="card-subtitle">Outstanding Service</p>
            <p class="card-desc">
              ACM International Chapter Award recognizing community-first work
              across student initiatives.
            </p>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>

        <!-- 04 Code of Conduct -->
        <a
          href="#community-conduct"
          class="community-card card-gradient group"
          style="--card-i:3"
        >
          <div class="card-content">
            <span class="card-num">04</span>
            <h3 class="card-title">Code of Conduct</h3>
            <p class="card-subtitle">Ethics & Values</p>
            <p class="card-desc">
              Our commitment to ACM ethical principles, professional conduct,
              and computing for the public good.
            </p>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>

        <!-- 05 Distinguished Speakers -->
        <a
          href="#community-speaker"
          class="community-card card-has-img card-wide group"
          style="--card-i:4"
        >
          <img
            src={getAssetUrl("/community/peter-robinson.webp")}
            alt="Distinguished Speakers"
            class="card-bg-img"
            loading="lazy"
            decoding="async"
          />
          <div class="card-overlay"></div>
          <div class="card-content">
            <span class="card-num">05</span>
            <h3 class="card-title">Distinguished Speakers</h3>
            <p class="card-subtitle">Industry Leader Keynotes</p>
            <p class="card-desc">
              Sessions from world-renowned researchers and industry leaders in
              computing and technology.
            </p>
            <span class="card-arrow" aria-hidden="true">&#8599;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="border-t border-dashed border-[#999999]/30 max-w-[1400px] mx-auto">
    <p
      class="text-center text-gray-500 font-mono text-[0.65rem] tracking-[0.4em] uppercase py-8"
    >
      Explore in detail
    </p>
  </div>

  <!-- Full Sections -->
  <IgnitingMinds />
  <CodeOfConduct />
  <DistinguishedSpeaker />

  <!-- Back to Home -->
  <section class="py-16 md:py-24 border-t border-white/10">
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 text-center">
      <a
        href="/"
        class="inline-flex items-center gap-3 text-[#FFFDD0] text-sm font-mono uppercase tracking-[0.18em] border border-white/12 px-6 py-4 transition-all duration-300 hover:border-[#FF5F4A] hover:text-[#FF5F4A] rounded-full"
      >
        <span aria-hidden="true" class="text-[#FF5F4A]">&larr;</span>
        Back to Home
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── Bento Grid ── */
  .community-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .community-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .community-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .community-card:nth-child(1) {
      grid-column: span 2;
    }
    .community-card:nth-child(2) {
      grid-column: span 2;
    }
    .community-card:nth-child(3) {
      grid-column: span 2;
    }
    .community-card:nth-child(4) {
      grid-column: span 2;
    }
    .community-card:nth-child(5) {
      grid-column: span 4;
    }
  }

  /* ── Base card ── */
  .community-card {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    min-height: 300px;
    display: flex;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    animation: cardReveal 0.6s ease both;
    animation-delay: calc(var(--card-i, 0) * 0.08s);
  }

  @keyframes cardReveal {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .community-card:hover {
    border-color: rgba(255, 95, 74, 0.4);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(255, 95, 74, 0.06);
    transform: translateY(-4px);
  }

  /* ── Image card ── */
  .card-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .community-card:hover .card-bg-img {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.55) 40%,
      rgba(0, 0, 0, 0.25) 100%
    );
    transition: background 0.5s ease;
  }

  .community-card:hover .card-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.4) 40%,
      rgba(0, 0, 0, 0.15) 100%
    );
  }

  /* ── Gradient card (no image) ── */
  .card-gradient {
    background: linear-gradient(
      145deg,
      rgba(255, 95, 74, 0.08) 0%,
      rgba(13, 14, 13, 0.6) 50%,
      rgba(255, 95, 74, 0.04) 100%
    );
    border-color: rgba(255, 255, 255, 0.06);
  }

  .card-gradient::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 30% 80%,
      rgba(255, 95, 74, 0.06) 0%,
      transparent 60%
    );
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .card-gradient:hover {
    background: linear-gradient(
      145deg,
      rgba(255, 95, 74, 0.12) 0%,
      rgba(13, 14, 13, 0.5) 50%,
      rgba(255, 95, 74, 0.06) 100%
    );
  }

  /* ── Card content ── */
  .card-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .card-content {
      padding: 2rem;
    }
  }

  .card-num {
    color: #ff5f4a;
    font-family: "PolySans Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .card-title {
    font-family: "PolySans Trial", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fffdd0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  @media (min-width: 768px) {
    .card-title {
      font-size: 1.75rem;
    }
  }

  .card-subtitle {
    color: #ff5f4a;
    font-size: 0.8rem;
    font-family: "Inter", sans-serif;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .card-desc {
    color: #9ca3af;
    font-family: "PolySans Mono", monospace;
    font-size: 0.7rem;
    line-height: 1.7;
    max-width: 340px;
  }

  .card-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: #ff5f4a;
    font-size: 1.25rem;
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: all 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .community-card:hover .card-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* ── Wide card (speakers) on tablet ── */
  @media (min-width: 640px) and (max-width: 1023px) {
    .card-wide {
      grid-column: span 2;
    }
  }
</style>
